<UserControl x:Class="LearningTrainer.Views.BulkAddWordView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:converters="clr-namespace:LearningTrainer.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="700"
             Background="{DynamicResource MainBackgroundBrush}">

    <UserControl.Resources>
        <converters:StringNullOrEmptyToVisibilityConverter x:Key="StringNullOrEmptyToVisibilityConverter"/>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <converters:InvertedBooleanToVisibilityConverter x:Key="InvertedBooleanToVisibilityConverter"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
        <Border Background="{DynamicResource SecondaryMainBackgroundBrush}" 
                CornerRadius="12" 
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                Margin="20"
                Padding="30"
                MaxWidth="700"
                VerticalAlignment="Top">

            <Border.Effect>
                <DropShadowEffect Color="Black" Opacity="0.15" BlurRadius="15" ShadowDepth="4"/>
            </Border.Effect>

            <StackPanel>
                <TextBlock Text="📋 Массовое добавление слов" 
                           FontSize="{DynamicResource HeaderFontSize}"
                           FontWeight="Bold" 
                           Foreground="{DynamicResource PrimaryTextBrush}"
                           Margin="0,0,0,10"/>

                <!-- Фаза 1: Ввод текста -->
                <StackPanel Visibility="{Binding IsParsed, Converter={StaticResource InvertedBooleanToVisibilityConverter}}">
                    <TextBlock Text="Вставьте список слов (каждое слово на новой строке):" 
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               FontWeight="Medium" Margin="0,0,0,5"/>
                    <TextBlock Text="Формат: слово - перевод (разделители: -, —, =, Tab)" 
                               Foreground="{DynamicResource TertiaryTextBrush}"
                               FontSize="12" Margin="0,0,0,10"/>

                    <Border Style="{StaticResource InputContainerStyle}">
                        <TextBox Text="{Binding RawText, UpdateSourceTrigger=PropertyChanged}" 
                                 Foreground="{DynamicResource PrimaryTextBrush}"
                                 CaretBrush="{DynamicResource PrimaryTextBrush}"
                                 FontSize="{DynamicResource BaseFontSize}"
                                 FontFamily="Consolas"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Padding="4"
                                 Height="250" 
                                 VerticalContentAlignment="Top"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"/>
                    </Border>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                        <Button Content="Готово" 
                                Command="{Binding DoneCommand}"
                                Style="{StaticResource BaseButton}" 
                                Width="100" Margin="0,0,10,0"/>
                        <Button Content="Разобрать →" 
                                Command="{Binding ParseCommand}"
                                Style="{StaticResource SuccessButton}" 
                                Width="130"/>
                    </StackPanel>
                </StackPanel>

                <!-- Фаза 2: Предпросмотр -->
                <StackPanel Visibility="{Binding IsParsed, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <DockPanel Margin="0,0,0,10">
                        <TextBlock DockPanel.Dock="Left" VerticalAlignment="Center"
                                   Foreground="{DynamicResource SecondaryTextBrush}" FontWeight="Medium">
                            <Run Text="Найдено слов:"/>
                            <Run Text="{Binding ParsedWords.Count, Mode=OneWay}" FontWeight="Bold"/>
                            <Run Text="  |  К добавлению:"/>
                            <Run Text="{Binding ValidCount, Mode=OneWay}" FontWeight="Bold" Foreground="{DynamicResource SuccessBrush}"/>
                        </TextBlock>
                    </DockPanel>

                    <!-- Результат сохранения -->
                    <Border Background="{DynamicResource InputBackgroundBrush}"
                            CornerRadius="6" Padding="12,8" Margin="0,0,0,10"
                            Visibility="{Binding ResultMessage, Converter={StaticResource StringNullOrEmptyToVisibilityConverter}}">
                        <TextBlock Text="{Binding ResultMessage}" 
                                   Foreground="{DynamicResource SuccessBrush}" 
                                   FontWeight="SemiBold" FontSize="14"/>
                    </Border>

                    <DataGrid ItemsSource="{Binding ParsedWords}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              HeadersVisibility="Column"
                              MaxHeight="350"
                              Background="{DynamicResource SecondaryMainBackgroundBrush}"
                              BorderThickness="1"
                              BorderBrush="{DynamicResource BorderBrush}"
                              GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="{DynamicResource SeparatorBrush}"
                              RowHeight="36" FontSize="13">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Слово" Binding="{Binding OriginalWord}" Width="*"
                                                Foreground="{DynamicResource PrimaryTextBrush}"/>
                            <DataGridTextColumn Header="Перевод" Binding="{Binding Translation}" Width="*"
                                                Foreground="{DynamicResource PrimaryTextBrush}"/>
                            <DataGridTemplateColumn Header="" Width="36">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="⚠️" FontSize="14" VerticalAlignment="Center" HorizontalAlignment="Center"
                                                   ToolTip="Дубликат — уже есть в словаре"
                                                   Visibility="{Binding IsDuplicate, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="" Width="36">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="✕" FontSize="12" Cursor="Hand"
                                                Background="Transparent" BorderThickness="0"
                                                Foreground="#DC2626"
                                                Command="{Binding DataContext.RemoveEntryCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                        <Button Content="← Назад" 
                                Command="{Binding BackToInputCommand}"
                                Style="{StaticResource BaseButton}" 
                                Width="100" Margin="0,0,10,0"/>
                        <Button Content="Готово" 
                                Command="{Binding DoneCommand}"
                                Style="{StaticResource BaseButton}" 
                                Width="100" Margin="0,0,10,0"/>
                        <Button Content="💾 Сохранить все" 
                                Command="{Binding SaveAllCommand}"
                                Style="{StaticResource SuccessButton}" 
                                Width="150"/>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </Border>
    </ScrollViewer>
</UserControl>
