<UserControl x:Class="LearningTrainer.Views.LearningView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:LearningTrainer.Views"
             xmlns:system="clr-namespace:System;assembly=mscorlib" 
             xmlns:models="clr-namespace:LearningTrainerShared.Models;assembly=LearningTrainerShared"
             xmlns:converters="clr-namespace:LearningTrainer.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800"
             Background="{DynamicResource MainBackgroundBrush}"
             Focusable="True" PreviewKeyDown="UserControl_PreviewKeyDown">

    <UserControl.Resources>
        <system:Boolean x:Key="True">True</system:Boolean>
        <system:Boolean x:Key="False">False</system:Boolean>
        <converters:BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <converters:InvertedBooleanToVisibilityConverter x:Key="InverseBoolToVis"/>
        <converters:InvertedBooleanConverter x:Key="InverseBoolConverter"/>

        <Style x:Key="McqOptionButton" TargetType="Button">
            <Setter Property="FontSize" Value="{DynamicResource FontSizeMedium}"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="Margin" Value="0,4"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="{DynamicResource SecondaryMainBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource PrimaryAccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ExerciseTypeRadio" TargetType="RadioButton">
            <Setter Property="FontSize" Value="{DynamicResource FontSizeBase}"/>
            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="4,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd" Background="{DynamicResource SecondaryMainBackgroundBrush}" 
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="2"
                                CornerRadius="16" Padding="14,8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource PrimaryAccentBrush}"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource PrimaryAccentBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsChecked" Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource PrimaryAccentBrush}"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <!-- ====== EMPTY SESSION SCREEN ====== -->
        <Grid Background="{DynamicResource MainBackgroundBrush}"
              VerticalAlignment="Center" HorizontalAlignment="Center"
              Visibility="{Binding IsEmptySession, Converter={StaticResource BoolToVis}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="420">
                <TextBlock Text="✓" FontSize="{DynamicResource FontSizeHuge}" HorizontalAlignment="Center"
                           Foreground="{DynamicResource SuccessBrush}" FontWeight="Bold"/>
                <TextBlock Text="Все слова повторены!" FontSize="{DynamicResource FontSizeTitle}" FontWeight="Bold"
                           Foreground="{DynamicResource PrimaryTextBrush}" 
                           HorizontalAlignment="Center" Margin="0,12,0,0"/>
                <TextBlock Text="На данный момент нет слов, требующих повторения. Вы можете вернуться позже или начать тренировку со всеми словами досрочно."
                           FontSize="{DynamicResource FontSizeBase}" TextWrapping="Wrap" TextAlignment="Center"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           HorizontalAlignment="Center" Margin="0,12,0,24"/>

                <Button Content="Начать досрочно" 
                        Command="{Binding StartEarlyCommand}"
                        HorizontalAlignment="Center"
                        Width="220" Height="44" FontSize="{DynamicResource FontSizeBody}"
                        Margin="0,0,0,10">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasDictionaryWords}" Value="False">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <Button Content="Вернуться на дашборд" 
                        Command="{Binding CloseTabCommand}" 
                        Style="{StaticResource BaseButton}" 
                        HorizontalAlignment="Center"
                        Width="220" Height="40" FontSize="{DynamicResource FontSizeBase}"/>
            </StackPanel>
        </Grid>

        <!-- ====== SESSION RESULTS SCREEN ====== -->
        <Grid Background="{DynamicResource MainBackgroundBrush}" 
              VerticalAlignment="Center" HorizontalAlignment="Center"
              Visibility="{Binding IsSessionComplete, Converter={StaticResource BooleanToVisibilityConverter}}">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" MaxHeight="600"
                          Padding="0,0,4,0">
                <ScrollViewer.Resources>
                    <Style TargetType="ScrollBar">
                        <Setter Property="Width" Value="6"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ScrollBar">
                                    <Track x:Name="PART_Track" IsDirectionReversed="True">
                                        <Track.Thumb>
                                            <Thumb>
                                                <Thumb.Style>
                                                    <Style TargetType="Thumb">
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="Thumb">
                                                                    <Border Background="{DynamicResource BorderBrush}" 
                                                                            CornerRadius="3" Opacity="0.6"/>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Style>
                                                </Thumb.Style>
                                            </Thumb>
                                        </Track.Thumb>
                                    </Track>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ScrollViewer.Resources>
                <StackPanel HorizontalAlignment="Center" Margin="20">
                    <!-- Result Icon -->
                    <TextBlock Text="{Binding ResultEmoji}" FontSize="{DynamicResource FontSizeMega}" HorizontalAlignment="Center"
                               Foreground="{DynamicResource PrimaryAccentBrush}"/>
                    <TextBlock Text="{Binding ResultMessage}"
                               FontSize="{DynamicResource FontSizeDisplay3}" FontWeight="Bold" 
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,8,0,0"/>

                    <!-- Stats cards -->
                    <UniformGrid Columns="4" Margin="0,24,0,0" HorizontalAlignment="Center" MaxWidth="700">
                        <!-- Total -->
                        <Border Background="{DynamicResource SecondaryMainBackgroundBrush}" 
                                CornerRadius="10" Margin="4" Padding="16,12"
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="{Binding TotalWordsCount}" FontSize="{DynamicResource FontSizeDisplay3}" FontWeight="Bold"
                                           Foreground="{DynamicResource PrimaryAccentBrush}" HorizontalAlignment="Center"/>
                                <TextBlock Text="Всего" FontSize="{DynamicResource FontSizeSmall}"
                                           Foreground="{DynamicResource SecondaryTextBrush}" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <!-- Correct -->
                        <Border Background="{DynamicResource SecondaryMainBackgroundBrush}" 
                                CornerRadius="10" Margin="4" Padding="16,12"
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="{Binding CorrectCount}" FontSize="{DynamicResource FontSizeDisplay3}" FontWeight="Bold"
                                           Foreground="{DynamicResource SuccessBrush}" HorizontalAlignment="Center"/>
                                <TextBlock Text="Верно" FontSize="{DynamicResource FontSizeSmall}"
                                           Foreground="{DynamicResource SecondaryTextBrush}" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <!-- Wrong -->
                        <Border Background="{DynamicResource SecondaryMainBackgroundBrush}" 
                                CornerRadius="10" Margin="4" Padding="16,12"
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="{Binding WrongCount}" FontSize="{DynamicResource FontSizeDisplay3}" FontWeight="Bold"
                                           Foreground="{DynamicResource DangerBrush}" HorizontalAlignment="Center"/>
                                <TextBlock Text="Ошибки" FontSize="{DynamicResource FontSizeSmall}"
                                           Foreground="{DynamicResource SecondaryTextBrush}" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <!-- Duration -->
                        <Border Background="{DynamicResource SecondaryMainBackgroundBrush}" 
                                CornerRadius="10" Margin="4" Padding="12,12"
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="{Binding SessionDuration}" FontSize="{DynamicResource FontSizeMedium}" FontWeight="Bold"
                                           Foreground="{DynamicResource PrimaryTextBrush}" HorizontalAlignment="Center"
                                           TextWrapping="Wrap" TextAlignment="Center"/>
                                <TextBlock Text="Время" FontSize="{DynamicResource FontSizeSmall}"
                                           Foreground="{DynamicResource SecondaryTextBrush}" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <!-- Accuracy bar -->
                    <StackPanel Margin="0,20,0,0" HorizontalAlignment="Center" Width="400">
                        <Grid>
                            <TextBlock Text="Точность" FontSize="{DynamicResource FontSizeBase}" 
                                       Foreground="{DynamicResource SecondaryTextBrush}"/>
                            <TextBlock HorizontalAlignment="Right" FontSize="{DynamicResource FontSizeBase}" FontWeight="SemiBold"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       Text="{Binding AccuracyPercent, StringFormat={}{0:0}%}"/>
                        </Grid>
                        <Border CornerRadius="5" Height="10" Margin="0,6,0,0"
                                Background="{DynamicResource BorderBrush}">
                            <Border CornerRadius="5" HorizontalAlignment="Left"
                                    Background="{DynamicResource SuccessBrush}"
                                    Width="{Binding AccuracyPercent, Converter={StaticResource PercentToFixedWidthConverter}}"/>
                        </Border>
                    </StackPanel>

                    <!-- Difficult words list -->
                    <StackPanel Margin="0,20,0,0" HorizontalAlignment="Center" Width="400">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding DifficultWords.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <TextBlock Text="Слова с ошибками:" FontSize="{DynamicResource FontSizeBase}" FontWeight="SemiBold"
                                   Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,8"/>
                        <ItemsControl ItemsSource="{Binding DifficultWords}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource SecondaryMainBackgroundBrush}"
                                            CornerRadius="6" Margin="0,2" Padding="12,6"
                                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                        <TextBlock Text="{Binding OriginalWord}" FontSize="{DynamicResource FontSizeBase}"
                                                   Foreground="{DynamicResource DangerBrush}"/>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- Action buttons -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,24,0,0">
                        <!-- Review Errors button (#8) -->
                        <Button Content="  🔁 Повторить ошибки  "
                                Command="{Binding ReviewErrorsCommand}"
                                Style="{StaticResource BaseButton}"
                                Padding="16,10"
                                MinHeight="40"
                                Margin="0,0,8,0">
                            <Button.Visibility>
                                <Binding Path="HasDifficultWords" Converter="{StaticResource BooleanToVisibilityConverter}"/>
                            </Button.Visibility>
                        </Button>
                        <Button Content="  📋 Скопировать отчёт  " 
                                Command="{Binding CopyReportCommand}" 
                                Style="{StaticResource BaseButton}" 
                                Padding="16,10"
                                MinHeight="40"
                                Margin="0,0,8,0"/>
                        <Button Content="   Вернуться на дашборд   " 
                                Command="{Binding CloseTabCommand}" 
                                Style="{StaticResource BaseButton}" 
                                Padding="20,10"
                                MinHeight="40"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <Grid>
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Visible"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsSessionComplete}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsEmptySession}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Error Review Round banner (#8) -->
            <Border Grid.Row="0" Background="#200066FF" CornerRadius="8" 
                    Padding="12,6" Margin="20,8,20,0"
                    Visibility="{Binding IsErrorReviewRound, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="🔁 Бонусный раунд — повторение ошибок" FontSize="{DynamicResource FontSizeBase}" FontWeight="SemiBold"
                           Foreground="{DynamicResource PrimaryAccentBrush}" HorizontalAlignment="Center"/>
            </Border>

            <!-- Session progress bar -->
            <StackPanel Grid.Row="0" Margin="20,12,20,4"
                        Visibility="{Binding IsExerciseTypeChosen, Converter={StaticResource BoolToVis}}">
                <Grid Margin="0,0,0,4">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock FontSize="{DynamicResource FontSizeCaption}" Foreground="{DynamicResource SecondaryTextBrush}">
                            <Run Text="{Binding CompletedWordsCount, Mode=OneWay}"/>
                            <Run Text=" / "/>
                            <Run Text="{Binding TotalWordsCount, Mode=OneWay}"/>
                        </TextBlock>
                        <!-- Streak indicator -->
                        <Border Margin="12,0,0,0" CornerRadius="8" Padding="8,2"
                                Background="#20FF6B00"
                                Visibility="{Binding ShowStreak, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                            <TextBlock FontSize="{DynamicResource FontSizeSmall}" Foreground="#FF6B00" FontWeight="SemiBold">
                                <Run Text="🔥"/>
                                <Run Text="{Binding CurrentStreak, Mode=OneWay}"/>
                            </TextBlock>
                        </Border>
                    </StackPanel>
                    <TextBlock HorizontalAlignment="Right" FontSize="{DynamicResource FontSizeCaption}"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               Text="{Binding SessionProgress, Mode=OneWay, StringFormat={}{0:0}%}"/>
                </Grid>
                <ProgressBar Value="{Binding SessionProgress, Mode=OneWay}" Minimum="0" Maximum="100" Height="6">
                    <ProgressBar.Template>
                        <ControlTemplate TargetType="ProgressBar">
                            <Border CornerRadius="3" Background="{DynamicResource BorderBrush}" x:Name="PART_Track">
                                <Border CornerRadius="3" HorizontalAlignment="Left"
                                        Background="{DynamicResource PrimaryAccentBrush}"
                                        x:Name="PART_Indicator"/>
                            </Border>
                        </ControlTemplate>
                    </ProgressBar.Template>
                </ProgressBar>

                <!-- Mastery Indicator (§18.1) -->
                <StackPanel Orientation="Horizontal" Margin="0,4,0,0"
                            Visibility="{Binding IsMatchingMode, Converter={StaticResource InverseBoolToVis}}">
                    <TextBlock Text="{Binding MasteryStars, Mode=OneWay}" FontSize="11" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding MasteryLevelText, Mode=OneWay}" FontSize="{DynamicResource FontSizeSmall}" 
                               Foreground="{DynamicResource SecondaryTextBrush}" Margin="6,0,0,0"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </StackPanel>

            <!-- Exercise type selector (shown before training starts) -->
            <Grid Grid.Row="0" Grid.RowSpan="3" 
                  Visibility="{Binding IsExerciseTypeChosen, Converter={StaticResource InverseBoolToVis}}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                              Padding="0,0,4,0">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="500" Margin="20,20">
                    <TextBlock Text="Выберите режим тренировки" FontSize="{DynamicResource FontSizeXLarge}" FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTextBrush}" HorizontalAlignment="Center"
                               TextWrapping="Wrap" TextAlignment="Center"
                               Margin="0,0,0,16"/>

                    <!-- Word limit selector (4.3) -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,12">
                        <TextBlock Text="Слов:" FontSize="{DynamicResource FontSizeCaption}" VerticalAlignment="Center" Margin="0,0,8,0"
                                   Foreground="{DynamicResource SecondaryTextBrush}"/>
                        <RadioButton Content="10" GroupName="WordLimit" Style="{StaticResource ExerciseTypeRadio}"
                                     Command="{Binding SetWordLimitCommand}" CommandParameter="10"/>
                        <RadioButton Content="20" GroupName="WordLimit" Style="{StaticResource ExerciseTypeRadio}"
                                     Command="{Binding SetWordLimitCommand}" CommandParameter="20"/>
                        <RadioButton Content="50" GroupName="WordLimit" Style="{StaticResource ExerciseTypeRadio}"
                                     Command="{Binding SetWordLimitCommand}" CommandParameter="50"/>
                        <RadioButton Content="Все" GroupName="WordLimit" Style="{StaticResource ExerciseTypeRadio}"
                                     IsChecked="True"
                                     Command="{Binding SetWordLimitCommand}" CommandParameter="0"/>
                    </StackPanel>

                    <!-- Translation direction selector -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,20">
                        <TextBlock Text="Направление:" FontSize="{DynamicResource FontSizeCaption}" VerticalAlignment="Center" Margin="0,0,8,0"
                                   Foreground="{DynamicResource SecondaryTextBrush}"/>
                        <RadioButton Content="Прямой" GroupName="TransDir" Style="{StaticResource ExerciseTypeRadio}"
                                     IsChecked="True"
                                     Command="{Binding SetTranslationDirectionCommand}" CommandParameter="direct"/>
                        <RadioButton Content="Обратный" GroupName="TransDir" Style="{StaticResource ExerciseTypeRadio}"
                                     Command="{Binding SetTranslationDirectionCommand}" CommandParameter="reverse"/>
                        <RadioButton Content="Случайный" GroupName="TransDir" Style="{StaticResource ExerciseTypeRadio}"
                                     Command="{Binding SetTranslationDirectionCommand}" CommandParameter="random"/>
                    </StackPanel>

                    <Button Command="{Binding SetExerciseTypeCommand}" CommandParameter="flashcard"
                            Margin="0,4" Height="60" Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource McqOptionButton}">
                                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🃏" FontSize="{DynamicResource FontSizeXLarge}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Карточки" FontSize="{DynamicResource FontSizeMedium}" FontWeight="SemiBold"/>
                                <TextBlock Text="Переверните карточку и оцените себя" FontSize="{DynamicResource FontSizeSmall}" Opacity="0.6"/>
                            </StackPanel>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding SetExerciseTypeCommand}" CommandParameter="mcq"
                            Margin="0,4" Height="60" Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource McqOptionButton}">
                                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📝" FontSize="{DynamicResource FontSizeXLarge}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Тест" FontSize="{DynamicResource FontSizeMedium}" FontWeight="SemiBold"/>
                                <TextBlock Text="Выберите правильный перевод из 4 вариантов" FontSize="{DynamicResource FontSizeSmall}" Opacity="0.6"/>
                            </StackPanel>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding SetExerciseTypeCommand}" CommandParameter="typing"
                            Margin="0,4" Height="60" Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource McqOptionButton}">
                                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⌨️" FontSize="{DynamicResource FontSizeXLarge}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Ввод" FontSize="{DynamicResource FontSizeMedium}" FontWeight="SemiBold"/>
                                <TextBlock Text="Напишите перевод самостоятельно" FontSize="{DynamicResource FontSizeSmall}" Opacity="0.6"/>
                            </StackPanel>
                        </StackPanel>
                    </Button>

                    <!-- Mixed mode (2.3) -->
                    <Button Command="{Binding SetExerciseTypeCommand}" CommandParameter="mixed"
                            Margin="0,4" Height="60" Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource McqOptionButton}">
                                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🎲" FontSize="{DynamicResource FontSizeXLarge}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Смешанный" FontSize="{DynamicResource FontSizeMedium}" FontWeight="SemiBold"/>
                                <TextBlock Text="Тип упражнения меняется для каждого слова" FontSize="{DynamicResource FontSizeSmall}" Opacity="0.6"/>
                            </StackPanel>
                        </StackPanel>
                    </Button>

                    <!-- Listening mode -->
                    <Button Command="{Binding SetExerciseTypeCommand}" CommandParameter="listening"
                            Margin="0,4" Height="60" Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource McqOptionButton}">
                                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🎧" FontSize="{DynamicResource FontSizeXLarge}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Аудирование" FontSize="{DynamicResource FontSizeMedium}" FontWeight="SemiBold"/>
                                <TextBlock Text="Услышьте слово и напишите его" FontSize="{DynamicResource FontSizeSmall}" Opacity="0.6"/>
                            </StackPanel>
                        </StackPanel>
                    </Button>

                    <!-- Matching mode (§18.1a) -->
                    <Button Command="{Binding SetExerciseTypeCommand}" CommandParameter="matching"
                            Margin="0,4" Height="60" Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource McqOptionButton}">
                                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔗" FontSize="{DynamicResource FontSizeXLarge}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Сопоставление" FontSize="{DynamicResource FontSizeMedium}" FontWeight="SemiBold"/>
                                <TextBlock Text="Соедините слова с переводами" FontSize="{DynamicResource FontSizeSmall}" Opacity="0.6"/>
                            </StackPanel>
                        </StackPanel>
                    </Button>

                    <!-- Cloze mode (§18.1b) -->
                    <Button Command="{Binding SetExerciseTypeCommand}" CommandParameter="cloze"
                            Margin="0,4" Height="60" Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource McqOptionButton}">
                                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📝" FontSize="{DynamicResource FontSizeXLarge}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Заполни пропуск" FontSize="{DynamicResource FontSizeMedium}" FontWeight="SemiBold"/>
                                <TextBlock Text="Вставьте слово в контекстное предложение" FontSize="{DynamicResource FontSizeSmall}" Opacity="0.6"/>
                            </StackPanel>
                        </StackPanel>
                    </Button>

                    <!-- Spelling Bee (§18.1c) -->
                    <Button Command="{Binding SetExerciseTypeCommand}" CommandParameter="spellingbee"
                            Margin="0,4" Height="60" Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource McqOptionButton}">
                                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🐝" FontSize="{DynamicResource FontSizeXLarge}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Spelling Bee" FontSize="{DynamicResource FontSizeMedium}" FontWeight="SemiBold"/>
                                <TextBlock Text="Прослушайте и напишите слово по буквам" FontSize="{DynamicResource FontSizeSmall}" Opacity="0.6"/>
                            </StackPanel>
                        </StackPanel>
                    </Button>

                    <!-- Speed Round (§18.1d) -->
                    <Button Command="{Binding StartSpeedRoundCommand}"
                            Margin="0,12,0,4" Height="60" Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource McqOptionButton}">
                                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                <Setter Property="BorderBrush" Value="{DynamicResource WarningBrush}"/>
                                <Setter Property="BorderThickness" Value="2"/>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⚡" FontSize="{DynamicResource FontSizeXLarge}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Скоростной раунд" FontSize="{DynamicResource FontSizeMedium}" FontWeight="SemiBold"/>
                                <TextBlock Text="60 секунд — отвечай как можно быстрее!" FontSize="{DynamicResource FontSizeSmall}" Opacity="0.6"/>
                            </StackPanel>
                        </StackPanel>
                    </Button>
                </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- ====== FLASHCARD MODE ====== -->
            <Grid Grid.Row="1">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsExerciseTypeChosen}" Value="True"/>
                                    <Condition Binding="{Binding IsFlashcardMode}" Value="True"/>
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Visibility" Value="Visible"/>
                            </MultiDataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
                <Grid HorizontalAlignment="Center" VerticalAlignment="Center" Width="400" Height="250">
                    <Grid.Resources>
                        <Style TargetType="TextBlock" x:Key="CardTextStyle">
                            <Setter Property="FontSize" Value="{DynamicResource FontSizeDisplay2}"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="TextWrapping" Value="Wrap"/>
                            <Setter Property="TextAlignment" Value="Center"/>
                        </Style>
                    </Grid.Resources>

                    <!-- Back (Translation) -->
                    <Border>
                        <Border.RenderTransform>
                            <ScaleTransform ScaleX="0" />
                        </Border.RenderTransform>
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="{DynamicResource SuccessBrush}"/>
                                <Setter Property="CornerRadius" Value="16"/>
                                <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
                                <Setter Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect ShadowDepth="4" Color="Black" Opacity="0.3" BlurRadius="20"/>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsFlipped}" Value="True">
                                        <DataTrigger.EnterActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX" To="1" BeginTime="0:0:0.2" Duration="0:0:0.2"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.EnterActions>
                                        <DataTrigger.ExitActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX" To="0" Duration="0:0:0.2"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.ExitActions>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>

                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="{Binding ExpectedAnswer}" Style="{StaticResource CardTextStyle}" Foreground="White"/>
                            <TextBlock Text="{Binding CurrentWord.Example}"
                                       FontSize="{DynamicResource FontSizeBase}" FontStyle="Italic" Foreground="White" Opacity="0.85"
                                       HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"
                                       Margin="10,10,10,0" MaxWidth="360">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CurrentWord.Example}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding CurrentWord.Example}" Value="">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <!-- Front (Original) -->
                    <Border>
                        <Border.RenderTransform>
                            <ScaleTransform ScaleX="1" />
                        </Border.RenderTransform>
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="{DynamicResource SecondaryMainBackgroundBrush}"/>
                                <Setter Property="CornerRadius" Value="16"/>
                                <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
                                <Setter Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect ShadowDepth="4" Color="Black" Opacity="0.2" BlurRadius="20"/>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsFlipped}" Value="True">
                                        <DataTrigger.EnterActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX" To="0" Duration="0:0:0.2"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.EnterActions>
                                        <DataTrigger.ExitActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX" To="1" BeginTime="0:0:0.2" Duration="0:0:0.2"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.ExitActions>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>

                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="{Binding DisplayedText}" 
                                       Style="{StaticResource CardTextStyle}"
                                       Foreground="{DynamicResource PrimaryTextBrush}"/>
                            <TextBlock Text="{Binding DisplayedTranscription}"
                                       FontSize="{DynamicResource FontSizeLarge}" Foreground="{DynamicResource PrimaryAccentBrush}"
                                       FontFamily="Arial" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                            <Button Command="{Binding SpeakWordCommand}" 
                                    ToolTip="Озвучить слово"
                                    Background="Transparent" BorderThickness="0" 
                                    Cursor="Hand" Margin="0,8,0,0"
                                    HorizontalAlignment="Center">
                                <TextBlock Text="🔊" FontSize="{DynamicResource FontSizeXLarge}"/>
                            </Button>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>

            <!-- ====== MCQ MODE ====== -->
            <Grid Grid.Row="1">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsExerciseTypeChosen}" Value="True"/>
                                    <Condition Binding="{Binding IsMcqMode}" Value="True"/>
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Visibility" Value="Visible"/>
                            </MultiDataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="450">
                    <!-- Question -->
                    <Border Background="{DynamicResource SecondaryMainBackgroundBrush}" CornerRadius="16" Padding="24"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="0,0,0,20">
                        <Border.Effect>
                            <DropShadowEffect ShadowDepth="4" Color="Black" Opacity="0.2" BlurRadius="20"/>
                        </Border.Effect>
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="{Binding DisplayedText}" 
                                       FontSize="{DynamicResource FontSizeDisplay2}" FontWeight="Bold" HorizontalAlignment="Center"
                                       Foreground="{DynamicResource PrimaryTextBrush}"/>
                            <TextBlock Text="{Binding DisplayedTranscription}"
                                       FontSize="{DynamicResource FontSizeSubtitle}" Foreground="{DynamicResource PrimaryAccentBrush}"
                                       HorizontalAlignment="Center" Margin="0,6,0,0"/>
                            <Button Command="{Binding SpeakWordCommand}" 
                                    ToolTip="Озвучить слово"
                                    Background="Transparent" BorderThickness="0" 
                                    Cursor="Hand" Margin="0,6,0,0"
                                    HorizontalAlignment="Center">
                                <TextBlock Text="🔊" FontSize="{DynamicResource FontSizeLarge}"/>
                            </Button>
                        </StackPanel>
                    </Border>

                    <!-- Options with highlighting -->
                    <ItemsControl ItemsSource="{Binding McqOptions}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Command="{Binding DataContext.SelectMcqOptionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        IsEnabled="{Binding DataContext.McqAnswered, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource InverseBoolConverter}}"
                                        Cursor="Hand" FontSize="{DynamicResource FontSizeMedium}" Padding="16,12" Margin="0,4"
                                        HorizontalContentAlignment="Left"
                                        Foreground="{DynamicResource PrimaryTextBrush}">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="Bd" 
                                                                Background="{DynamicResource SecondaryMainBackgroundBrush}" 
                                                                BorderBrush="{DynamicResource BorderBrush}" 
                                                                BorderThickness="2" CornerRadius="10" 
                                                                Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                                              VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource PrimaryAccentBrush}"/>
                                                            </Trigger>
                                                            <DataTrigger Binding="{Binding IsRevealed}" Value="True">
                                                                <Setter TargetName="Bd" Property="Opacity" Value="0.5"/>
                                                            </DataTrigger>
                                                            <MultiDataTrigger>
                                                                <MultiDataTrigger.Conditions>
                                                                    <Condition Binding="{Binding IsRevealed}" Value="True"/>
                                                                    <Condition Binding="{Binding IsCorrect}" Value="True"/>
                                                                </MultiDataTrigger.Conditions>
                                                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource SuccessBrush}"/>
                                                                <Setter TargetName="Bd" Property="Background" Value="#20198754"/>
                                                                <Setter TargetName="Bd" Property="Opacity" Value="1"/>
                                                            </MultiDataTrigger>
                                                            <MultiDataTrigger>
                                                                <MultiDataTrigger.Conditions>
                                                                    <Condition Binding="{Binding IsRevealed}" Value="True"/>
                                                                    <Condition Binding="{Binding IsSelected}" Value="True"/>
                                                                    <Condition Binding="{Binding IsCorrect}" Value="False"/>
                                                                </MultiDataTrigger.Conditions>
                                                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource DangerBrush}"/>
                                                                <Setter TargetName="Bd" Property="Background" Value="#20dc3545"/>
                                                                <Setter TargetName="Bd" Property="Opacity" Value="1"/>
                                                            </MultiDataTrigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </Button.Style>
                                    <TextBlock Text="{Binding Text}" TextWrapping="Wrap"/>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- MCQ Feedback -->
                    <StackPanel Margin="0,16,0,0" Visibility="{Binding McqAnswered, Converter={StaticResource BoolToVis}}">
                        <Border CornerRadius="10" Padding="12,8" HorizontalAlignment="Center">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="#20dc3545"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding McqWasCorrect}" Value="True">
                                            <Setter Property="Background" Value="#20198754"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock FontSize="{DynamicResource FontSizeMedium}" FontWeight="SemiBold" HorizontalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="❌ Неверно"/>
                                        <Setter Property="Foreground" Value="{DynamicResource DangerBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding McqWasCorrect}" Value="True">
                                                <Setter Property="Text" Value="✅ Правильно!"/>
                                                <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Border>

                        <!-- Example after answer (3.6) -->
                        <TextBlock Margin="0,8,0,0" FontSize="{DynamicResource FontSizeCaption}" FontStyle="Italic"
                                   HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   Text="{Binding CurrentWord.Example}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentWord.Example}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding CurrentWord.Example}" Value="">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <!-- Error context block (#3) -->
                        <Border CornerRadius="8" Padding="10,8" Margin="0,8,0,0"
                                Background="{DynamicResource MainBackgroundBrush}"
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                Visibility="{Binding ShowErrorContext, Converter={StaticResource BoolToVis}}">
                            <StackPanel>
                                <TextBlock Text="{Binding ErrorContextTranscription}"
                                           FontSize="{DynamicResource FontSizeMedium}" FontFamily="Arial"
                                           Foreground="{DynamicResource PrimaryAccentBrush}"
                                           HorizontalAlignment="Center" Margin="0,0,0,4">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ErrorContextTranscription}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding ErrorContextTranscription}" Value="">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock Text="{Binding ErrorContextExample}"
                                           FontSize="{DynamicResource FontSizeCaption}" FontStyle="Italic" TextWrapping="Wrap"
                                           TextAlignment="Center"
                                           Foreground="{DynamicResource SecondaryTextBrush}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ErrorContextExample}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding ErrorContextExample}" Value="">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <Button Command="{Binding SpeakWordCommand}" 
                                        ToolTip="Озвучить слово"
                                        Background="Transparent" BorderThickness="0" 
                                        Cursor="Hand" Margin="0,4,0,0"
                                        HorizontalAlignment="Center">
                                    <TextBlock Text="🔊 Послушать" FontSize="{DynamicResource FontSizeCaption}" Foreground="{DynamicResource PrimaryAccentBrush}"/>
                                </Button>
                            </StackPanel>
                        </Border>

                        <Button Content="Далее →" Command="{Binding NextMcqWordCommand}"
                                Style="{StaticResource PrimaryButton}" 
                                HorizontalAlignment="Center" Margin="0,12,0,0"
                                Width="160" Height="40" FontSize="{DynamicResource FontSizeBody}"/>
                    </StackPanel>

                    <!-- Skip button (3.5) -->
                    <Button Content="Пропустить (Esc)" Command="{Binding SkipWordCommand}"
                            Background="Transparent" BorderThickness="0" Cursor="Hand"
                            Foreground="{DynamicResource SecondaryTextBrush}" FontSize="{DynamicResource FontSizeSmall}"
                            HorizontalAlignment="Center" Margin="0,8,0,0"
                            Visibility="{Binding McqAnswered, Converter={StaticResource InverseBoolToVis}}"/>
                </StackPanel>
            </Grid>

            <!-- ====== TYPING MODE ====== -->
            <Grid Grid.Row="1">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsExerciseTypeChosen}" Value="True"/>
                                    <Condition Binding="{Binding IsTypingMode}" Value="True"/>
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Visibility" Value="Visible"/>
                            </MultiDataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="450">
                    <!-- Question -->
                    <Border Background="{DynamicResource SecondaryMainBackgroundBrush}" CornerRadius="16" Padding="24"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="0,0,0,20">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="{Binding DisplayedText}" 
                                       FontSize="{DynamicResource FontSizeDisplay2}" FontWeight="Bold" HorizontalAlignment="Center"
                                       Foreground="{DynamicResource PrimaryTextBrush}"/>
                            <TextBlock Text="{Binding DisplayedTranscription}"
                                       FontSize="{DynamicResource FontSizeSubtitle}" Foreground="{DynamicResource PrimaryAccentBrush}"
                                       HorizontalAlignment="Center" Margin="0,6,0,0"/>
                            <Button Command="{Binding SpeakWordCommand}" 
                                    ToolTip="Озвучить слово"
                                    Background="Transparent" BorderThickness="0" 
                                    Cursor="Hand" Margin="0,6,0,0"
                                    HorizontalAlignment="Center">
                                <TextBlock Text="🔊" FontSize="{DynamicResource FontSizeLarge}"/>
                            </Button>
                        </StackPanel>
                    </Border>

                    <!-- Input -->
                    <TextBox Text="{Binding TypedAnswer, UpdateSourceTrigger=PropertyChanged}"
                             FontSize="{DynamicResource FontSizeLarge}" Padding="12" HorizontalContentAlignment="Center"
                             Background="{DynamicResource SecondaryMainBackgroundBrush}"
                             Foreground="{DynamicResource PrimaryTextBrush}"
                             BorderBrush="{DynamicResource BorderBrush}" BorderThickness="2"
                             IsEnabled="{Binding TypingAnswered, Converter={StaticResource InverseBoolConverter}}">
                        <TextBox.Style>
                            <Style TargetType="TextBox">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding TypingWasCorrect}" Value="True">
                                        <Setter Property="BorderBrush" Value="{DynamicResource SuccessBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>

                    <!-- Hint (#5) -->
                    <StackPanel Visibility="{Binding TypingAnswered, Converter={StaticResource InverseBoolToVis}}">
                        <Button Content="💡 Подсказка" Command="{Binding UseHintCommand}"
                                Style="{StaticResource BaseButton}"
                                HorizontalAlignment="Center" Margin="0,8,0,0"
                                Padding="14,6" FontSize="{DynamicResource FontSizeCaption}" Opacity="0.8"/>
                        <TextBlock Text="{Binding HintText}" FontSize="{DynamicResource FontSizeBase}" FontStyle="Italic"
                                   HorizontalAlignment="Center" Margin="0,6,0,0"
                                   Foreground="{DynamicResource PrimaryAccentBrush}"
                                   Visibility="{Binding HintUsed, Converter={StaticResource BoolToVis}}"/>
                    </StackPanel>

                    <!-- Check button -->
                    <Button Content="Проверить" Command="{Binding CheckTypingCommand}"
                            Style="{StaticResource PrimaryButton}"
                            HorizontalAlignment="Center" Margin="0,12,0,0"
                            Width="180" Height="44" FontSize="{DynamicResource FontSizeMedium}"
                            Visibility="{Binding TypingAnswered, Converter={StaticResource InverseBoolToVis}}"/>

                    <!-- Typing Feedback -->
                    <StackPanel Margin="0,16,0,0" Visibility="{Binding TypingAnswered, Converter={StaticResource BoolToVis}}">
                        <Border CornerRadius="10" Padding="12,8" HorizontalAlignment="Center">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="#20dc3545"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding TypingWasCorrect}" Value="True">
                                            <Setter Property="Background" Value="#20198754"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding TypingWasAlmostCorrect}" Value="True">
                                            <Setter Property="Background" Value="#200066FF"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock FontSize="{DynamicResource FontSizeMedium}" FontWeight="SemiBold" HorizontalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="❌ Неверно"/>
                                        <Setter Property="Foreground" Value="{DynamicResource DangerBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding TypingWasCorrect}" Value="True">
                                                <Setter Property="Text" Value="✅ Правильно!"/>
                                                <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding TypingWasAlmostCorrect}" Value="True">
                                                <Setter Property="Text" Value="⚡ Почти правильно!"/>
                                                <Setter Property="Foreground" Value="{DynamicResource PrimaryAccentBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Border>

                        <!-- Show correct answer if wrong -->
                        <TextBlock Margin="0,8,0,0" FontSize="{DynamicResource FontSizeBase}" HorizontalAlignment="Center"
                                   Foreground="{DynamicResource SecondaryTextBrush}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding TypingWasCorrect}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                            <Run Text="Правильный ответ: "/>
                            <Run Text="{Binding CorrectAnswerDisplay, Mode=OneWay}" FontWeight="Bold"
                                 Foreground="{DynamicResource SuccessBrush}"/>
                        </TextBlock>

                        <!-- Typing Diff (#16) -->
                        <StackPanel HorizontalAlignment="Center" Margin="0,6,0,0">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding TypingWasCorrect}" Value="False"/>
                                                <Condition Binding="{Binding TypingAnswered}" Value="True"/>
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </MultiDataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <TextBlock FontSize="{DynamicResource FontSizeSmall}" Foreground="{DynamicResource SecondaryTextBrush}"
                                       HorizontalAlignment="Center" Margin="0,0,0,2">
                                <Run Text="Ваш ввод: "/>
                                <Run Text="{Binding TypingDiffUser, Mode=OneWay}" Foreground="{DynamicResource DangerBrush}"/>
                            </TextBlock>
                            <TextBlock FontSize="{DynamicResource FontSizeSmall}" Foreground="{DynamicResource SecondaryTextBrush}"
                                       HorizontalAlignment="Center">
                                <Run Text="Верно:       "/>
                                <Run Text="{Binding TypingDiffCorrect, Mode=OneWay}" Foreground="{DynamicResource SuccessBrush}"/>
                            </TextBlock>
                        </StackPanel>

                       

                        <!-- Error context block (#3) -->
                        <Border CornerRadius="8" Padding="10,8" Margin="0,8,0,0"
                                Background="{DynamicResource MainBackgroundBrush}"
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                Visibility="{Binding ShowErrorContext, Converter={StaticResource BoolToVis}}">
                            <StackPanel>
                                <TextBlock Text="{Binding ErrorContextTranscription}"
                                           FontSize="{DynamicResource FontSizeMedium}" FontFamily="Arial"
                                           Foreground="{DynamicResource PrimaryAccentBrush}"
                                           HorizontalAlignment="Center" Margin="0,0,0,4">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ErrorContextTranscription}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding ErrorContextTranscription}" Value="">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock Text="{Binding ErrorContextExample}"
                                           FontSize="{DynamicResource FontSizeCaption}" FontStyle="Italic" TextWrapping="Wrap"
                                           TextAlignment="Center"
                                           Foreground="{DynamicResource SecondaryTextBrush}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ErrorContextExample}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding ErrorContextExample}" Value="">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <Button Command="{Binding SpeakWordCommand}" 
                                        ToolTip="Озвучить слово"
                                        Background="Transparent" BorderThickness="0" 
                                        Cursor="Hand" Margin="0,4,0,0"
                                        HorizontalAlignment="Center">
                                    <TextBlock Text="🔊 Послушать" FontSize="{DynamicResource FontSizeCaption}" Foreground="{DynamicResource PrimaryAccentBrush}"/>
                                </Button>
                            </StackPanel>
                        </Border>

                        <Button Content="Далее →" Command="{Binding NextTypingWordCommand}"
                                Style="{StaticResource PrimaryButton}" 
                                HorizontalAlignment="Center" Margin="0,12,0,0"
                                Width="160" Height="40" FontSize="{DynamicResource FontSizeBody}"/>
                    </StackPanel>

                    <!-- Skip button (3.5) -->
                    <Button Content="Пропустить (Esc)" Command="{Binding SkipWordCommand}"
                            Background="Transparent" BorderThickness="0" Cursor="Hand"
                            Foreground="{DynamicResource SecondaryTextBrush}" FontSize="{DynamicResource FontSizeSmall}"
                            HorizontalAlignment="Center" Margin="0,8,0,0"
                            Visibility="{Binding TypingAnswered, Converter={StaticResource InverseBoolToVis}}"/>
                </StackPanel>
            </Grid>

            <!-- ====== LISTENING MODE ====== -->
            <Grid Grid.Row="1">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsExerciseTypeChosen}" Value="True"/>
                                    <Condition Binding="{Binding IsListeningMode}" Value="True"/>
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Visibility" Value="Visible"/>
                            </MultiDataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="450">
                    <!-- Audio prompt -->
                    <Border Background="{DynamicResource SecondaryMainBackgroundBrush}" CornerRadius="16" Padding="24"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="0,0,0,20">
                        <Border.Effect>
                            <DropShadowEffect ShadowDepth="4" Color="Black" Opacity="0.2" BlurRadius="20"/>
                        </Border.Effect>
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="🎧" FontSize="{DynamicResource FontSizeDisplay1}" HorizontalAlignment="Center"/>
                            <TextBlock Text="Прослушайте и напишите слово" FontSize="{DynamicResource FontSizeMedium}"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       HorizontalAlignment="Center" Margin="0,8,0,0"/>
                            <Button Command="{Binding ReplayListeningCommand}" 
                                    ToolTip="Повторить озвучку"
                                    Background="Transparent" BorderThickness="0" 
                                    Cursor="Hand" Margin="0,10,0,0"
                                    HorizontalAlignment="Center">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🔊" FontSize="{DynamicResource FontSizeXLarge}" Margin="0,0,6,0"/>
                                    <TextBlock Text="Повторить" FontSize="{DynamicResource FontSizeMedium}" VerticalAlignment="Center"
                                               Foreground="{DynamicResource PrimaryAccentBrush}"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>

                    <!-- Input -->
                    <TextBox Text="{Binding ListeningTypedAnswer, UpdateSourceTrigger=PropertyChanged}"
                             FontSize="{DynamicResource FontSizeLarge}" Padding="12" HorizontalContentAlignment="Center"
                             Background="{DynamicResource SecondaryMainBackgroundBrush}"
                             Foreground="{DynamicResource PrimaryTextBrush}"
                             BorderBrush="{DynamicResource BorderBrush}" BorderThickness="2"
                             IsEnabled="{Binding ListeningAnswered, Converter={StaticResource InverseBoolConverter}}">
                        <TextBox.Style>
                            <Style TargetType="TextBox">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ListeningWasCorrect}" Value="True">
                                        <Setter Property="BorderBrush" Value="{DynamicResource SuccessBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>

                    <!-- Check button -->
                    <Button Content="Проверить" Command="{Binding CheckListeningCommand}"
                            Style="{StaticResource PrimaryButton}"
                            HorizontalAlignment="Center" Margin="0,12,0,0"
                            Width="180" Height="44" FontSize="{DynamicResource FontSizeMedium}"
                            Visibility="{Binding ListeningAnswered, Converter={StaticResource InverseBoolToVis}}"/>

                    <!-- Listening Feedback -->
                    <StackPanel Margin="0,16,0,0" Visibility="{Binding ListeningAnswered, Converter={StaticResource BoolToVis}}">
                        <Border CornerRadius="10" Padding="12,8" HorizontalAlignment="Center">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="#20dc3545"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ListeningWasCorrect}" Value="True">
                                            <Setter Property="Background" Value="#20198754"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding ListeningWasAlmostCorrect}" Value="True">
                                            <Setter Property="Background" Value="#200066FF"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock FontSize="{DynamicResource FontSizeMedium}" FontWeight="SemiBold" HorizontalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="❌ Неверно"/>
                                        <Setter Property="Foreground" Value="{DynamicResource DangerBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ListeningWasCorrect}" Value="True">
                                                <Setter Property="Text" Value="✅ Правильно!"/>
                                                <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding ListeningWasAlmostCorrect}" Value="True">
                                                <Setter Property="Text" Value="⚡ Почти правильно!"/>
                                                <Setter Property="Foreground" Value="{DynamicResource PrimaryAccentBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Border>

                        <!-- Show correct answer if wrong -->
                        <TextBlock Margin="0,8,0,0" FontSize="{DynamicResource FontSizeBase}" HorizontalAlignment="Center"
                                   Foreground="{DynamicResource SecondaryTextBrush}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ListeningWasCorrect}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                            <Run Text="Правильный ответ: "/>
                            <Run Text="{Binding CurrentWord.OriginalWord, Mode=OneWay}" FontWeight="Bold"
                                 Foreground="{DynamicResource SuccessBrush}"/>
                        </TextBlock>

                        <!-- Transcription after answer -->
                        <TextBlock Text="{Binding CurrentWord.Transcription}"
                                   FontSize="{DynamicResource FontSizeMedium}" FontFamily="Arial"
                                   Foreground="{DynamicResource PrimaryAccentBrush}"
                                   HorizontalAlignment="Center" Margin="0,4,0,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentWord.Transcription}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding CurrentWord.Transcription}" Value="">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <!-- Translation hint -->
                        <TextBlock Margin="0,4,0,0" FontSize="{DynamicResource FontSizeCaption}" HorizontalAlignment="Center"
                                   Foreground="{DynamicResource SecondaryTextBrush}">
                            <Run Text="Перевод: "/>
                            <Run Text="{Binding CurrentWord.Translation, Mode=OneWay}" FontStyle="Italic"/>
                        </TextBlock>

                        <!-- Error context block (#3) -->
                        <Border CornerRadius="8" Padding="10,8" Margin="0,8,0,0"
                                Background="{DynamicResource MainBackgroundBrush}"
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                Visibility="{Binding ShowErrorContext, Converter={StaticResource BoolToVis}}">
                            <StackPanel>
                                <TextBlock Text="{Binding ErrorContextExample}"
                                           FontSize="{DynamicResource FontSizeCaption}" FontStyle="Italic" TextWrapping="Wrap"
                                           TextAlignment="Center"
                                           Foreground="{DynamicResource SecondaryTextBrush}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ErrorContextExample}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding ErrorContextExample}" Value="">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <Button Content="Далее →" Command="{Binding NextListeningWordCommand}"
                                Style="{StaticResource PrimaryButton}" 
                                HorizontalAlignment="Center" Margin="0,12,0,0"
                                Width="160" Height="40" FontSize="{DynamicResource FontSizeBody}"/>
                    </StackPanel>

                    <!-- Skip button -->
                    <Button Content="Пропустить (Esc)" Command="{Binding SkipWordCommand}"
                            Background="Transparent" BorderThickness="0" Cursor="Hand"
                            Foreground="{DynamicResource SecondaryTextBrush}" FontSize="{DynamicResource FontSizeSmall}"
                            HorizontalAlignment="Center" Margin="0,8,0,0"
                            Visibility="{Binding ListeningAnswered, Converter={StaticResource InverseBoolToVis}}"/>
                </StackPanel>
            </Grid>

            <!-- ====== CLOZE MODE (§18.1b) ====== -->
            <Grid Grid.Row="1">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsExerciseTypeChosen}" Value="True"/>
                                    <Condition Binding="{Binding IsClozeMode}" Value="True"/>
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Visibility" Value="Visible"/>
                            </MultiDataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>

                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="500">
                    <TextBlock Text="📝 Заполните пропуск" FontSize="{DynamicResource FontSizeLarge}" FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTextBrush}" HorizontalAlignment="Center" Margin="0,0,0,16"/>

                    <!-- Cloze sentence -->
                    <Border Background="{DynamicResource SecondaryMainBackgroundBrush}" CornerRadius="12" Padding="24,20" Margin="0,0,0,16"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                        <TextBlock Text="{Binding ClozeSentence}" FontSize="{DynamicResource FontSizeMedium}" TextWrapping="Wrap"
                                   Foreground="{DynamicResource PrimaryTextBrush}" TextAlignment="Center" LineHeight="28"/>
                    </Border>

                    <!-- Input -->
                    <TextBox Text="{Binding ClozeAnswer, UpdateSourceTrigger=PropertyChanged}"
                             FontSize="{DynamicResource FontSizeMedium}" Padding="12,8" Margin="0,0,0,8"
                             HorizontalContentAlignment="Center" MaxWidth="300"
                             IsEnabled="{Binding ClozeAnswered, Converter={StaticResource InverseBoolConverter}}">
                        <TextBox.Style>
                            <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ClozeWasCorrect}" Value="True">
                                        <Setter Property="BorderBrush" Value="{DynamicResource SuccessBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>

                    <!-- Hint (§1.1 Context-Aware Hints) -->
                    <StackPanel Visibility="{Binding ClozeAnswered, Converter={StaticResource InverseBoolToVis}}">
                        <Button Content="💡 Подсказка" Command="{Binding UseHintCommand}"
                                Style="{StaticResource BaseButton}"
                                HorizontalAlignment="Center" Margin="0,8,0,0"
                                Padding="14,6" FontSize="{DynamicResource FontSizeCaption}" Opacity="0.8"/>
                        <TextBlock Text="{Binding HintText}" FontSize="{DynamicResource FontSizeBase}" FontStyle="Italic"
                                   HorizontalAlignment="Center" Margin="0,6,0,0" TextWrapping="Wrap" MaxWidth="400"
                                   TextAlignment="Center" Foreground="{DynamicResource PrimaryAccentBrush}"
                                   Visibility="{Binding HintUsed, Converter={StaticResource BoolToVis}}"/>
                    </StackPanel>

                    <!-- Check button -->
                    <Button Content="Проверить" Command="{Binding CheckClozeCommand}"
                            Style="{StaticResource McqOptionButton}" HorizontalAlignment="Center"
                            Width="160" Height="40" FontSize="{DynamicResource FontSizeBody}"
                            Visibility="{Binding ClozeAnswered, Converter={StaticResource InverseBoolToVis}}"/>

                    <!-- Cloze feedback -->
                    <StackPanel Margin="0,16,0,0" Visibility="{Binding ClozeAnswered, Converter={StaticResource BoolToVis}}">
                        <TextBlock HorizontalAlignment="Center" FontSize="{DynamicResource FontSizeLarge}" FontWeight="Bold">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="✗ Неправильно"/>
                                    <Setter Property="Foreground" Value="{DynamicResource DangerBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ClozeWasCorrect}" Value="True">
                                            <Setter Property="Text" Value="✓ Правильно!"/>
                                            <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <!-- Show correct answer if wrong -->
                        <TextBlock HorizontalAlignment="Center" FontSize="{DynamicResource FontSizeMedium}" Margin="0,8,0,0"
                                   Foreground="{DynamicResource SecondaryTextBrush}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ClozeWasCorrect}" Value="False">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                            <Run Text="Правильный ответ: "/>
                            <Run Text="{Binding ClozeCorrectWord, Mode=OneWay}" FontWeight="Bold" Foreground="{DynamicResource SuccessBrush}"/>
                        </TextBlock>

                        <!-- Translation hint -->
                        <TextBlock HorizontalAlignment="Center" FontSize="{DynamicResource FontSizeBody}" Margin="0,4,0,0"
                                   Foreground="{DynamicResource SecondaryTextBrush}">
                            <Run Text="Перевод: "/>
                            <Run Text="{Binding CurrentWord.Translation, Mode=OneWay}" FontWeight="SemiBold"/>
                        </TextBlock>

                        <Button Content="Далее →" Command="{Binding NextClozeWordCommand}"
                                Style="{StaticResource McqOptionButton}" HorizontalAlignment="Center"
                                Margin="0,12,0,0" Width="160" Height="40" FontSize="{DynamicResource FontSizeBody}"/>
                    </StackPanel>

                    <!-- Skip button -->
                    <Button Content="Пропустить (Esc)" Command="{Binding SkipWordCommand}"
                            Background="Transparent" BorderThickness="0" Cursor="Hand"
                            Foreground="{DynamicResource SecondaryTextBrush}" FontSize="{DynamicResource FontSizeSmall}"
                            HorizontalAlignment="Center" Margin="0,8,0,0"
                            Visibility="{Binding ClozeAnswered, Converter={StaticResource InverseBoolToVis}}"/>
                </StackPanel>
            </Grid>

            <!-- ====== SPELLING BEE MODE (§18.1c) ====== -->
            <Grid Grid.Row="1">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsExerciseTypeChosen}" Value="True"/>
                                    <Condition Binding="{Binding IsSpellingBeeMode}" Value="True"/>
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Visibility" Value="Visible"/>
                            </MultiDataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>

                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="500">
                    <!-- Audio prompt -->
                    <Border Background="{DynamicResource SecondaryMainBackgroundBrush}" CornerRadius="16" Padding="24"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="0,0,0,16">
                        <Border.Effect>
                            <DropShadowEffect ShadowDepth="4" Color="Black" Opacity="0.2" BlurRadius="20"/>
                        </Border.Effect>
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="🐝" FontSize="{DynamicResource FontSizeDisplay1}" HorizontalAlignment="Center"/>
                            <TextBlock Text="Прослушайте и напишите слово" FontSize="{DynamicResource FontSizeMedium}"
                                       Foreground="{DynamicResource SecondaryTextBrush}" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                            <TextBlock Text="{Binding SpellingHint}" FontSize="{DynamicResource FontSizeBase}" FontStyle="Italic"
                                       Foreground="{DynamicResource PrimaryAccentBrush}" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                            <Button Command="{Binding ReplayListeningCommand}" 
                                    ToolTip="Повторить озвучку" Background="Transparent" BorderThickness="0" 
                                    Cursor="Hand" Margin="0,10,0,0" HorizontalAlignment="Center">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🔊" FontSize="{DynamicResource FontSizeXLarge}" Margin="0,0,6,0"/>
                                    <TextBlock Text="Повторить" FontSize="{DynamicResource FontSizeMedium}" VerticalAlignment="Center"
                                               Foreground="{DynamicResource PrimaryAccentBrush}"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>

                    <!-- Translation hint -->
                    <TextBlock HorizontalAlignment="Center" FontSize="{DynamicResource FontSizeBase}" Margin="0,0,0,12"
                               Foreground="{DynamicResource SecondaryTextBrush}">
                        <Run Text="Перевод: "/>
                        <Run Text="{Binding CurrentWord.Translation, Mode=OneWay}" FontWeight="SemiBold"/>
                    </TextBlock>

                    <!-- Input -->
                    <TextBox Text="{Binding SpellingAnswer, UpdateSourceTrigger=PropertyChanged}"
                             FontSize="{DynamicResource FontSizeLarge}" Padding="12" HorizontalContentAlignment="Center"
                             Background="{DynamicResource SecondaryMainBackgroundBrush}"
                             Foreground="{DynamicResource PrimaryTextBrush}"
                             BorderBrush="{DynamicResource BorderBrush}" BorderThickness="2"
                             CharacterCasing="Normal"
                             IsEnabled="{Binding SpellingAnswered, Converter={StaticResource InverseBoolConverter}}">
                        <TextBox.Style>
                            <Style TargetType="TextBox">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SpellingWasCorrect}" Value="True">
                                        <Setter Property="BorderBrush" Value="{DynamicResource SuccessBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>

                    <!-- Hint (§1.1 Context-Aware Hints) -->
                    <StackPanel Visibility="{Binding SpellingAnswered, Converter={StaticResource InverseBoolToVis}}">
                        <Button Content="💡 Подсказка" Command="{Binding UseHintCommand}"
                                Style="{StaticResource BaseButton}"
                                HorizontalAlignment="Center" Margin="0,8,0,0"
                                Padding="14,6" FontSize="{DynamicResource FontSizeCaption}" Opacity="0.8"/>
                        <TextBlock Text="{Binding HintText}" FontSize="{DynamicResource FontSizeBase}" FontStyle="Italic"
                                   HorizontalAlignment="Center" Margin="0,6,0,0" TextWrapping="Wrap" MaxWidth="400"
                                   TextAlignment="Center" Foreground="{DynamicResource PrimaryAccentBrush}"
                                   Visibility="{Binding HintUsed, Converter={StaticResource BoolToVis}}"/>
                    </StackPanel>

                    <!-- Check button -->
                    <Button Content="Проверить" Command="{Binding CheckSpellingCommand}"
                            Style="{StaticResource McqOptionButton}" HorizontalAlignment="Center"
                            Width="160" Height="40" FontSize="{DynamicResource FontSizeBody}" Margin="0,12,0,0"
                            Visibility="{Binding SpellingAnswered, Converter={StaticResource InverseBoolToVis}}"/>

                    <!-- Feedback -->
                    <StackPanel Margin="0,16,0,0" Visibility="{Binding SpellingAnswered, Converter={StaticResource BoolToVis}}">
                        <TextBlock HorizontalAlignment="Center" FontSize="{DynamicResource FontSizeLarge}" FontWeight="Bold">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="✗ Неправильно"/>
                                    <Setter Property="Foreground" Value="{DynamicResource DangerBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SpellingWasCorrect}" Value="True">
                                            <Setter Property="Text" Value="✓ Правильно!"/>
                                            <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <TextBlock HorizontalAlignment="Center" FontSize="{DynamicResource FontSizeMedium}" Margin="0,8,0,0"
                                   Foreground="{DynamicResource SecondaryTextBrush}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SpellingWasCorrect}" Value="False">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                            <Run Text="Правильный ответ: "/>
                            <Run Text="{Binding CurrentWord.OriginalWord, Mode=OneWay}" FontWeight="Bold" Foreground="{DynamicResource SuccessBrush}"/>
                        </TextBlock>

                        <Button Content="Далее →" Command="{Binding NextSpellingWordCommand}"
                                Style="{StaticResource McqOptionButton}" HorizontalAlignment="Center"
                                Margin="0,12,0,0" Width="160" Height="40" FontSize="{DynamicResource FontSizeBody}"/>
                    </StackPanel>

                    <!-- Skip -->
                    <Button Content="Пропустить (Esc)" Command="{Binding SkipWordCommand}"
                            Background="Transparent" BorderThickness="0" Cursor="Hand"
                            Foreground="{DynamicResource SecondaryTextBrush}" FontSize="{DynamicResource FontSizeSmall}"
                            HorizontalAlignment="Center" Margin="0,8,0,0"
                            Visibility="{Binding SpellingAnswered, Converter={StaticResource InverseBoolToVis}}"/>
                </StackPanel>
            </Grid>

            <!-- ====== MATCHING MODE (§18.1a) ====== -->
            <Grid Grid.Row="1">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsExerciseTypeChosen}" Value="True"/>
                                    <Condition Binding="{Binding IsMatchingMode}" Value="True"/>
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Visibility" Value="Visible"/>
                            </MultiDataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>

                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="700">
                    <TextBlock Text="🔗 Соедините слова с переводами" FontSize="{DynamicResource FontSizeLarge}" FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTextBrush}" HorizontalAlignment="Center" Margin="0,0,0,16"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,8">
                        <TextBlock Foreground="{DynamicResource SecondaryTextBrush}" FontSize="{DynamicResource FontSizeBody}">
                            <Run Text="{Binding MatchedPairsCount, Mode=OneWay}"/>
                            <Run Text="/"/>
                            <Run Text="{Binding MatchTotalPairs, Mode=OneWay}"/>
                            <Run Text="пар найдено"/>
                        </TextBlock>
                    </StackPanel>

                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Left column: originals -->
                        <ItemsControl Grid.Column="0" ItemsSource="{Binding MatchItems}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Command="{Binding DataContext.SelectMatchItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Margin="0,4" Height="48" Cursor="Hand" HorizontalContentAlignment="Center">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource McqOptionButton}">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsOriginal}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsMatched}" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource SuccessBrush}"/>
                                                        <Setter Property="Foreground" Value="White"/>
                                                        <Setter Property="IsEnabled" Value="False"/>
                                                        <Setter Property="Opacity" Value="0.6"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                        <Setter Property="BorderBrush" Value="{DynamicResource PrimaryAccentBrush}"/>
                                                        <Setter Property="BorderThickness" Value="3"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsWrong}" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource DangerBrush}"/>
                                                        <Setter Property="Foreground" Value="White"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                        <TextBlock Text="{Binding Text}" FontSize="{DynamicResource FontSizeMedium}" TextWrapping="Wrap" TextAlignment="Center"/>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Right column: translations -->
                        <ItemsControl Grid.Column="2" ItemsSource="{Binding MatchItems}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Command="{Binding DataContext.SelectMatchItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Margin="0,4" Height="48" Cursor="Hand" HorizontalContentAlignment="Center">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource McqOptionButton}">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsOriginal}" Value="False">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsMatched}" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource SuccessBrush}"/>
                                                        <Setter Property="Foreground" Value="White"/>
                                                        <Setter Property="IsEnabled" Value="False"/>
                                                        <Setter Property="Opacity" Value="0.6"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                        <Setter Property="BorderBrush" Value="{DynamicResource PrimaryAccentBrush}"/>
                                                        <Setter Property="BorderThickness" Value="3"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsWrong}" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource DangerBrush}"/>
                                                        <Setter Property="Foreground" Value="White"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                        <TextBlock Text="{Binding Text}" FontSize="{DynamicResource FontSizeMedium}" TextWrapping="Wrap" TextAlignment="Center"/>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>

                    <!-- Matching completed -->
                    <StackPanel Visibility="{Binding MatchingCompleted, Converter={StaticResource BoolToVis}}" Margin="0,16,0,0" HorizontalAlignment="Center">
                        <TextBlock Text="✅ Все пары найдены!" FontSize="{DynamicResource FontSizeLarge}" FontWeight="Bold"
                                   Foreground="{DynamicResource SuccessBrush}" HorizontalAlignment="Center"/>
                        <Button Content="Далее →" Command="{Binding NextMatchingRoundCommand}"
                                Style="{StaticResource McqOptionButton}" HorizontalAlignment="Center"
                                Margin="0,12,0,0" Width="160" Height="40" FontSize="{DynamicResource FontSizeBody}"/>
                    </StackPanel>
                </StackPanel>
            </Grid>

            <!-- ====== POMODORO BREAK OVERLAY (§18.1) ====== -->
            <Border Grid.Row="0" Grid.RowSpan="3" Panel.ZIndex="50"
                    Visibility="{Binding ShowPomodoroBreak, Converter={StaticResource BoolToVis}}"
                    Background="#CC000000">
                <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                        Background="{DynamicResource CardBackgroundBrush}" CornerRadius="20" Padding="40,32"
                        MaxWidth="420">
                    <Border.Effect>
                        <DropShadowEffect ShadowDepth="4" BlurRadius="20" Opacity="0.3"/>
                    </Border.Effect>
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="🍅" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                        <TextBlock Text="Время для перерыва!" FontSize="22" FontWeight="Bold"
                                   Foreground="{DynamicResource PrimaryTextBrush}" HorizontalAlignment="Center"
                                   Margin="0,0,0,8"/>
                        <TextBlock Text="{Binding PomodoroMessage}" FontSize="14" TextWrapping="Wrap"
                                   Foreground="{DynamicResource SecondaryTextBrush}" HorizontalAlignment="Center"
                                   TextAlignment="Center" Margin="0,0,0,4"/>
                        <TextBlock Text="Встаньте, разомнитесь, отдохните глаза 👀" FontSize="13"
                                   Foreground="{DynamicResource SecondaryTextBrush}" HorizontalAlignment="Center"
                                   Margin="0,0,0,24"/>
                        <Button Command="{Binding DismissBreakCommand}" Content="Продолжить тренировку →"
                                Padding="20,10" FontSize="15" FontWeight="SemiBold" Cursor="Hand"
                                HorizontalAlignment="Center" Background="{DynamicResource AccentBrush}"
                                Foreground="White" BorderThickness="0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="10"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Border>
            </Border>

            <!-- ====== SPEED ROUND OVERLAY (§18.1d) ====== -->
            <Border Grid.Row="0" VerticalAlignment="Top" HorizontalAlignment="Right" Margin="20,8,20,0"
                    CornerRadius="12" Padding="16,8"
                    Visibility="{Binding ShowSpeedOverlay, Converter={StaticResource BoolToVis}}">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
                        <Setter Property="BorderBrush" Value="{DynamicResource WarningBrush}"/>
                        <Setter Property="BorderThickness" Value="2"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SpeedRoundTimeLeft, Converter={StaticResource BoolToVis}, ConverterParameter=10}" Value="True">
                                <Setter Property="Background" Value="#FFEBEE"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="⏱️" FontSize="18" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock FontSize="20" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,16,0">
                        <TextBlock.Text>
                            <Binding Path="SpeedRoundTimeLeft" StringFormat="{}{0}с"/>
                        </TextBlock.Text>
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBlock Text="⚡" FontSize="18" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <TextBlock FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryAccentBrush}" VerticalAlignment="Center">
                        <TextBlock.Text>
                            <Binding Path="SpeedRoundScore" StringFormat="{}{0} очков"/>
                        </TextBlock.Text>
                    </TextBlock>
                </StackPanel>
            </Border>

            <!-- Flashcard bottom buttons -->
            <StackPanel Grid.Row="2" Orientation="Vertical" 
                        HorizontalAlignment="Center" 
                        Margin="0,0,0,40">
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsExerciseTypeChosen}" Value="True"/>
                                    <Condition Binding="{Binding IsFlashcardMode}" Value="True"/>
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Visibility" Value="Visible"/>
                            </MultiDataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>

                <Button Content="{DynamicResource Loc.Learning.ShowAnswerButton}" 
                        Command="{Binding FlipCardCommand}"
                        Width="220" Height="48" FontSize="{DynamicResource FontSizeMedium}" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Setter Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect Color="Black" Opacity="0.2" BlurRadius="10" ShadowDepth="2"/>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsFlipped}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <StackPanel Orientation="Horizontal">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsFlipped}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <Button Content="{DynamicResource Loc.Learning.AgainLabel}" 
                            Command="{Binding AnswerCommand}" 
                            CommandParameter="{x:Static models:ResponseQuality.Again}"
                            Style="{StaticResource DangerButton}" 
                            Width="100" Height="45" Margin="5"/>

                    <Button Content="{DynamicResource Loc.Learning.HardLabel}" 
                            Command="{Binding AnswerCommand}" 
                            CommandParameter="{x:Static models:ResponseQuality.Hard}"
                            Style="{StaticResource BaseButton}" 
                            Width="100" Height="45" Margin="5"/>

                    <Button Content="{DynamicResource Loc.Learning.FineLabel}" 
                            Command="{Binding AnswerCommand}" 
                            CommandParameter="{x:Static models:ResponseQuality.Good}"
                            Style="{StaticResource BaseButton}" 
                            Width="100" Height="45" Margin="5"/>

                    <Button Content="{DynamicResource Loc.Learning.EasyLabel}" 
                            Command="{Binding AnswerCommand}" 
                            CommandParameter="{x:Static models:ResponseQuality.Easy}"
                            Style="{StaticResource SuccessButton}" 
                            Width="100" Height="45" Margin="5"/>

                </StackPanel>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>