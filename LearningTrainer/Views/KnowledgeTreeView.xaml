<UserControl x:Class="LearningTrainer.Views.KnowledgeTreeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:viewmodels="clr-namespace:LearningTrainer.ViewModels"
             xmlns:converters="clr-namespace:LearningTrainer.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1000"
             Background="{DynamicResource BackgroundBrush}">

    <UserControl.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <converters:InvertedBooleanToVisibilityConverter x:Key="InvBoolToVis"/>
        <converters:InvertedBooleanConverter x:Key="InvBool"/>
    </UserControl.Resources>

    <Grid>
        <!-- Loading overlay -->
        <Border Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"
                Background="{DynamicResource BackgroundBrush}" Panel.ZIndex="10">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="⏳ Загрузка Дерева Знаний..." FontSize="18" HorizontalAlignment="Center"
                           Foreground="{DynamicResource TextBrush}"/>
            </StackPanel>
        </Border>

        <!-- Main content -->
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      Visibility="{Binding IsLoading, Converter={StaticResource InvBoolToVis}}">
            <Grid Margin="24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Wilting warning -->
                <Border Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="0"
                        Visibility="{Binding IsWilting, Converter={StaticResource BoolToVis}}"
                        Background="#FFF3CD" CornerRadius="8" Padding="12" Margin="0,0,0,16">
                    <TextBlock Text="{Binding WiltingMessage}" FontSize="14" Foreground="#856404"
                               TextWrapping="Wrap"/>
                </Border>

                <!-- Tree display -->
                <Border Grid.Column="0" Grid.Row="1" CornerRadius="12" Padding="24"
                        Background="{DynamicResource CardBackgroundBrush}" Margin="0,0,16,16">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="{Binding StageEmoji}" FontSize="96" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding StageName}" FontSize="28" FontWeight="Bold"
                                   HorizontalAlignment="Center" Margin="0,8,0,0"
                                   Foreground="{DynamicResource TextBrush}"/>
                        <TextBlock Text="{Binding StatsText}" FontSize="16" Opacity="0.7"
                                   HorizontalAlignment="Center" Margin="0,4,0,16"
                                   Foreground="{DynamicResource TextBrush}"/>

                        <!-- Progress bar -->
                        <TextBlock Text="{Binding ProgressText}" FontSize="13" HorizontalAlignment="Center"
                                   Margin="0,0,0,6" Foreground="{DynamicResource TextBrush}" Opacity="0.8"/>
                        <Grid Height="14" Width="400" MaxWidth="400">
                            <Border Background="#E0E0E0" CornerRadius="7"/>
                            <Border Background="#4CAF50" CornerRadius="7" HorizontalAlignment="Left">
                                <Border.Width>
                                    <MultiBinding>
                                        <MultiBinding.Converter>
                                            <converters:PercentToWidthConverter/>
                                        </MultiBinding.Converter>
                                        <Binding Path="ProgressPercent"/>
                                        <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=Grid}"/>
                                    </MultiBinding>
                                </Border.Width>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Skins panel -->
                <Border Grid.Column="1" Grid.Row="1" CornerRadius="12" Padding="16"
                        Background="{DynamicResource CardBackgroundBrush}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="🎨 Скины дерева" FontSize="18" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextBrush}" Margin="0,0,0,12"/>
                        <ItemsControl ItemsSource="{Binding Skins}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Margin="0,0,0,6" Padding="10,8"
                                            HorizontalContentAlignment="Left"
                                            Command="{Binding DataContext.ChangeSkinCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding Id}"
                                            IsEnabled="{Binding IsActive, Converter={StaticResource InvBool}}">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Name}" FontSize="14" VerticalAlignment="Center"/>
                                            <TextBlock Text=" ✓" FontSize="14" Foreground="Green"
                                                       Visibility="{Binding IsActive, Converter={StaticResource BoolToVis}}"/>
                                        </StackPanel>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Branches: Dictionaries -->
                <Border Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="2" CornerRadius="12" Padding="16"
                        Background="{DynamicResource CardBackgroundBrush}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="🌿 Ветки — Словари" FontSize="18" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextBrush}" Margin="0,0,0,12"/>
                        <ItemsControl ItemsSource="{Binding TreeState.Branches}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="8" Padding="12" Margin="0,0,8,8"
                                            BorderThickness="1" BorderBrush="#E0E0E0" Width="220">
                                        <StackPanel>
                                            <TextBlock FontSize="14" FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis"
                                                       Foreground="{DynamicResource TextBrush}">
                                                <Run Text="🌿 "/><Run Text="{Binding DictionaryName, Mode=OneWay}"/>
                                            </TextBlock>
                                            <TextBlock FontSize="12" Opacity="0.7" Margin="0,4,0,6"
                                                       Foreground="{DynamicResource TextBrush}">
                                                <Run Text="{Binding LearnedWords, Mode=OneWay}"/><Run Text="/"/><Run Text="{Binding TotalWords, Mode=OneWay}"/><Run Text=" слов"/>
                                            </TextBlock>
                                            <Grid Height="6">
                                                <Border Background="#E0E0E0" CornerRadius="3"/>
                                                <Border Background="#4CAF50" CornerRadius="3" HorizontalAlignment="Left">
                                                    <Border.Width>
                                                        <MultiBinding>
                                                            <MultiBinding.Converter>
                                                                <converters:PercentToWidthConverter/>
                                                            </MultiBinding.Converter>
                                                            <Binding Path="CompletionPercent"/>
                                                            <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=Grid}"/>
                                                        </MultiBinding>
                                                    </Border.Width>
                                                </Border>
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Fruits: Grammar -->
                <Border Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="3" CornerRadius="12" Padding="16"
                        Background="{DynamicResource CardBackgroundBrush}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="🍎 Плоды — Грамматика" FontSize="18" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextBrush}" Margin="0,0,0,12"/>
                        <ItemsControl ItemsSource="{Binding TreeState.Fruits}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="16" Padding="8,4" Margin="0,0,6,6"
                                            Background="{DynamicResource CardBackgroundBrush}"
                                            BorderThickness="1" BorderBrush="#E0E0E0">
                                        <TextBlock FontSize="13" Foreground="{DynamicResource TextBrush}">
                                            <Run Text="{Binding IsMastered, Mode=OneWay, StringFormat={}{0:🍎;🍏;🍏}}"/>
                                            <Run Text="{Binding RuleName, Mode=OneWay}"/>
                                        </TextBlock>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
