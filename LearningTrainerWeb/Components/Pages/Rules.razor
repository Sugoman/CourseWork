@page "/rules"
@using LearningTrainerWeb.Services
@inject IContentApiService ContentApi
@inject ILogger<LearningTrainerWeb.Components.Pages.Rules> Logger

<PageTitle>Правила - Ingat</PageTitle>

<div class="container">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div class="section-heading" style="margin-bottom: 0;">
            <i class="bi bi-journal-text"></i>
            <h1 style="margin-bottom: 0;">Правила</h1>
        </div>
    </div>

    <!-- Search & Filters -->
    <div class="dict-search-wrap">
        <div class="dict-search-bar">
            <i class="bi bi-search dict-search-icon"></i>
            <input type="text"
                   class="dict-search-input"
                   placeholder="Найти правило по названию..."
                   @bind="SearchQuery"
                   @bind:event="oninput"
                   @onkeyup="OnSearchKeyUp" />
            @if (!string.IsNullOrEmpty(SearchQuery))
            {
                <button class="dict-search-clear" @onclick="() => { SearchQuery = string.Empty; ApplyFilters(); }">
                    <i class="bi bi-x-lg"></i>
                </button>
            }
        </div>

        <div class="dict-filters-row">
            <div class="dict-filter-group">
                <label class="dict-filter-label">
                    <i class="bi bi-tag"></i> Категория
                </label>
                <select class="dict-filter-select" @bind="SelectedCategory" @bind:after="ApplyFilters">
                    <option value="">Все категории</option>
                    <option value="Grammar">Грамматика</option>
                    <option value="Vocabulary">Лексика</option>
                    <option value="Pronunciation">Произношение</option>
                </select>
            </div>

            <div class="dict-filter-group">
                <label class="dict-filter-label">
                    <i class="bi bi-bar-chart"></i> Уровень
                </label>
                <select class="dict-filter-select" @bind="SelectedDifficulty" @bind:after="ApplyFilters">
                    <option value="0">Любой</option>
                    <option value="1">Начальный</option>
                    <option value="2">Средний</option>
                    <option value="3">Продвинутый</option>
                </select>
            </div>
        </div>

        @if (HasActiveFilters)
        {
            <div class="dict-active-filters">
                <span class="dict-af-label">Фильтры:</span>
                @if (!string.IsNullOrEmpty(SearchQuery))
                {
                    <span class="dict-af-tag">
                        <i class="bi bi-search"></i> «@SearchQuery»
                        <button class="dict-af-remove" @onclick="() => { SearchQuery = string.Empty; ApplyFilters(); }">
                            <i class="bi bi-x"></i>
                        </button>
                    </span>
                }
                @if (!string.IsNullOrEmpty(SelectedCategory))
                {
                    <span class="dict-af-tag">
                        <i class="bi bi-tag"></i> @SelectedCategory
                        <button class="dict-af-remove" @onclick="() => { SelectedCategory = string.Empty; ApplyFilters(); }">
                            <i class="bi bi-x"></i>
                        </button>
                    </span>
                }
                @if (SelectedDifficulty > 0)
                {
                    <span class="dict-af-tag">
                        <i class="bi bi-bar-chart"></i> @GetDifficultyText(SelectedDifficulty)
                        <button class="dict-af-remove" @onclick="() => { SelectedDifficulty = 0; ApplyFilters(); }">
                            <i class="bi bi-x"></i>
                        </button>
                    </span>
                }
                <button class="dict-af-clear" @onclick="ClearFilters">
                    <i class="bi bi-x-circle me-1"></i>Сбросить все
                </button>
            </div>
        }
    </div>

    <!-- Content -->
    @if (IsLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border" style="width: 3rem; height: 3rem;" role="status">
                <span class="visually-hidden">Загрузка...</span>
            </div>
            <p class="text-muted mt-3">Загрузка правил...</p>
        </div>
    }
    else if (RuleItems == null || !RuleItems.Any())
    {
        <!-- Улучшенное пустое состояние -->
        <div class="empty-state-card">
            <div class="empty-state-icon">
                <i class="bi bi-journal-text"></i>
            </div>
            <h3>Правила не найдены</h3>
            <p class="text-muted mb-4">
                @if (HasActiveFilters)
                {
                    <span>По вашему запросу ничего не найдено. Попробуйте изменить параметры поиска.</span>
                }
                else
                {
                    <span>В маркетплейсе пока нет опубликованных правил грамматики.</span>
                }
            </p>
            
            <div class="empty-state-actions">
                @if (HasActiveFilters)
                {
                    <button class="btn btn-outline-primary" @onclick="ClearFilters">
                        <i class="bi bi-x-circle me-2"></i>Сбросить фильтры
                    </button>
                }
                
                <a href="dictionaries" class="btn btn-primary">
                    <i class="bi bi-book me-2"></i>Перейти к словарям
                </a>
            </div>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var rule in RuleItems)
            {
                <div class="col-sm-6 col-md-4">
                    <div class="card h-100">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <h5 class="fw-bold mb-0" style="color: var(--gray-900);">@rule.Title</h5>
                                <span class="badge rounded-pill px-3 py-2 @GetDifficultyBadgeClass(rule.DifficultyLevel)">
                                    @GetDifficultyText(rule.DifficultyLevel)
                                </span>
                            </div>

                            <p class="text-muted small mb-3" style="min-height: 45px; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                                @rule.Description
                            </p>

                            <div class="d-flex gap-2 mb-3">
                                <span class="badge bg-secondary">@rule.Category</span>
                            </div>

                            <div class="d-flex justify-content-between align-items-center">
                                <div class="d-flex align-items-center gap-2">
                                    <i class="bi bi-star-fill text-warning"></i>
                                    <span class="fw-bold">@rule.Rating.ToString("F1")</span>
                                </div>
                                <div class="d-flex gap-2">
                                    <a href="rule/@rule.Id" class="btn btn-link btn-sm text-decoration-none text-primary fw-medium">
                                        Читать
                                    </a>
                                    <button class="btn btn-primary btn-sm px-3 rounded-pill gap-2" @onclick="() => DownloadRule(rule.Id)" disabled="@IsDownloading">
                                        <i class="bi bi-download me-1"></i> Скачать
                                    </button>
                                </div>
                            </div>
                        </div>
                        <div class="card-footer">
                            <div class="d-flex align-items-center justify-content-between text-muted small">
                                <div class="d-flex align-items-center gap-2">
                                    <i class="bi bi-person-circle" style="font-size: 1.2rem;"></i>
                                    <span>@rule.AuthorName</span>
                                </div>
                                <div class="d-flex align-items-center gap-3">
                                    <span><i class="bi bi-calendar3 me-1"></i>@rule.CreatedAt.ToString("dd.MM")</span>
                                    <span><i class="bi bi-download me-1"></i>@rule.Downloads</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- Pagination -->
        @if (TotalPages > 1)
        {
            <nav class="mt-5">
                <ul class="pagination justify-content-center">
                    <li class="page-item @(CurrentPage == 1 ? "disabled" : "")">
                        <button class="page-link" @onclick="() => LoadPage(CurrentPage - 1)">
                            <i class="bi bi-chevron-left"></i>
                        </button>
                    </li>
                    @for (int i = 1; i <= TotalPages; i++)
                    {
                        var pageNum = i;
                        <li class="page-item @(pageNum == CurrentPage ? "active" : "")">
                            <button class="page-link" @onclick="() => LoadPage(pageNum)">@pageNum</button>
                        </li>
                    }
                    <li class="page-item @(CurrentPage == TotalPages ? "disabled" : "")">
                        <button class="page-link" @onclick="() => LoadPage(CurrentPage + 1)">
                            <i class="bi bi-chevron-right"></i>
                        </button>
                    </li>
                </ul>
            </nav>
        }
    }
</div>

<LearningTrainerWeb.Components.Shared.AppToast
    Message="@DownloadMessage"
    IsSuccess="@DownloadSuccess"
    OnDismiss="() => DownloadMessage = null" />

@code {
    private List<RuleListItem>? RuleItems;
    private bool IsLoading = true;
    private string SearchQuery = "";
    private string SelectedCategory = "";
    private int SelectedDifficulty = 0;
    private bool HasActiveFilters => !string.IsNullOrEmpty(SearchQuery) || !string.IsNullOrEmpty(SelectedCategory) || SelectedDifficulty > 0;
    private int CurrentPage = 1;
    private int TotalPages = 1;
    private const int PageSize = 9;
    private string? DownloadMessage;
    private bool DownloadSuccess;
    private bool IsDownloading;

    protected override async Task OnInitializedAsync()
    {
        await LoadRules();
    }

    private async Task LoadRules()
    {
        IsLoading = true;
        try
        {
            var result = await ContentApi.GetPublicRulesAsync(
                SearchQuery, SelectedCategory, SelectedDifficulty, CurrentPage, PageSize);
            RuleItems = result.Items;
            TotalPages = result.TotalPages;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading rules");
            RuleItems = new List<RuleListItem>();
        }
        finally
        {
            IsLoading = false;
        }
    }

    private async Task OnSearchKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await ApplyFilters();
        }
    }

    private async Task ApplyFilters()
    {
        CurrentPage = 1;
        await LoadRules();
    }

    private async Task ClearFilters()
    {
        SearchQuery = "";
        SelectedCategory = "";
        SelectedDifficulty = 0;
        CurrentPage = 1;
        await LoadRules();
    }

    private async Task LoadPage(int page)
    {
        if (page < 1 || page > TotalPages) return;
        CurrentPage = page;
        await LoadRules();
    }

    private async Task DownloadRule(int ruleId)
    {
        if (IsDownloading) return;

        IsDownloading = true;
        StateHasChanged();
        try
        {
            await ContentApi.DownloadRuleAsync(ruleId);
            DownloadMessage = "Правило успешно скачано!";
            DownloadSuccess = true;
        }
        catch (Exception ex)
        {
            DownloadMessage = $"Ошибка: {ex.Message}";
            DownloadSuccess = false;
            Logger.LogError(ex, "Error downloading rule {RuleId}", ruleId);
        }
        finally
        {
            IsDownloading = false;
        }
        StateHasChanged();
        await Task.Delay(3000);
        DownloadMessage = null;
        StateHasChanged();
    }

    private string GetDifficultyBadgeClass(int level) => level switch
    {
        1 => "bg-success",
        2 => "bg-warning text-dark",
        3 => "bg-danger",
        _ => "bg-secondary"
    };

    private string GetDifficultyText(int level) => level switch
    {
        1 => "Начальный",
        2 => "Средний",
        3 => "Продвинутый",
        _ => "Неизвестно"
    };
}
