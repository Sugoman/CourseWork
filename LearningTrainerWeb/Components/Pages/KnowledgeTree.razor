@page "/knowledge-tree"
@using LearningTrainerShared.Models
@using LearningTrainerShared.Models.KnowledgeTreeDto
@inject IKnowledgeTreeApiService TreeService
@inject IAuthService AuthService
@inject IJSRuntime JS
@inject NavigationManager Navigation
@implements IDisposable
@rendermode InteractiveServer

<PageTitle>Дерево знаний — Ingat</PageTitle>

@if (IsLoading)
{
    <div class="d-flex justify-content-center align-items-center" style="min-height: 60vh;">
        <div class="spinner-border text-success" role="status">
            <span class="visually-hidden">Загрузка...</span>
        </div>
    </div>
}
else if (!IsAuthenticated)
{
    <div class="container text-center py-5">
        <h3>Войдите, чтобы увидеть своё Дерево Знаний</h3>
        <a href="/login" class="btn btn-primary mt-3">Войти</a>
    </div>
}
else if (Tree != null)
{
    <div class="tree-layout">
        @* ── Side panel ── *@
        <aside class="tree-sidebar">
            <div class="st-panel">
                <div class="st-panel-header">@Tree.StageEmoji @Tree.StageName · Ур. @Tree.TreeLevel</div>
                <div class="st-stat-row">
                    <span class="text-muted">XP дерева</span>
                    <strong>@Tree.TreeXp.ToString("N0")</strong>
                </div>
                <div class="st-stat-row">
                    <span class="text-muted">Слов выучено</span>
                    <strong>@Tree.TotalWordsContributed</strong>
                </div>
                <div class="st-progress-label">
                    @Tree.StageName → след. стадия
                    <span>@Tree.ProgressToNextStage.ToString("F0")%</span>
                </div>
                <div class="progress" style="height: 6px;">
                    <div class="progress-bar bg-success" style="width: @Inv(Tree.ProgressToNextStage)%"></div>
                </div>
            </div>

            @* Pour XP *@
            <div class="st-panel">
                <div class="st-panel-header"><i class="bi bi-droplet-fill text-primary"></i> Влить XP</div>
                <p class="small text-muted mb-2">Доступно: <strong>@Tree.AvailableUserXp</strong></p>
                <div class="input-group input-group-sm mb-2">
                    <input type="number" class="form-control" @bind="PourAmount" min="1" max="@Tree.AvailableUserXp" placeholder="XP"/>
                    <button class="btn btn-success btn-sm" @onclick="PourXpAsync" disabled="@(IsPouringXp || PourAmount <= 0)">
                        @if (IsPouringXp) { <span class="spinner-border spinner-border-sm"></span> }
                        else { <span>💧</span> }
                    </button>
                </div>
                @if (!string.IsNullOrEmpty(PourMessage))
                {
                    <div class="alert py-1 px-2 small mb-0 @(PourSuccess ? "alert-success" : "alert-danger")">@PourMessage</div>
                }
            </div>

            @* Selected branch/twig info *@
            @if (SelectedBranch != null)
            {
                <div class="st-panel">
                    <div class="st-panel-header">🌿 @SelectedBranch.TagName</div>
                    <div class="st-stat-row">
                        <span class="text-muted">Словарей</span>
                        <span>@SelectedBranch.Twigs.Count</span>
                    </div>
                    <div class="st-stat-row">
                        <span class="text-muted">Прогресс</span>
                        <span>@SelectedBranch.LearnedWords / @SelectedBranch.TotalWords</span>
                    </div>
                    <div class="progress mb-2" style="height: 5px;">
                        <div class="progress-bar bg-info" style="width: @Inv(SelectedBranch.Progress * 100)%"></div>
                    </div>
                </div>
            }
            @if (SelectedTwig != null)
            {
                <div class="st-panel">
                    <div class="st-panel-header">🍃 @SelectedTwig.DictionaryName</div>
                    <div class="st-stat-row">
                        <span class="text-muted">Прогресс</span>
                        <span>@SelectedTwig.LearnedWords / @SelectedTwig.TotalWords</span>
                    </div>
                    <div class="progress mb-2" style="height: 5px;">
                        <div class="progress-bar bg-success" style="width: @Inv(SelectedTwig.Progress * 100)%"></div>
                    </div>
                    <button class="btn btn-outline-primary btn-sm w-100" @onclick="() => DrillIntoTwig(SelectedTwig)">
                        <i class="bi bi-eye"></i> Показать слова
                    </button>
                </div>
            }

            <div class="st-panel">
                <button class="btn btn-sm btn-outline-secondary w-100 mb-2" @onclick="ResetView">
                    <i class="bi bi-arrows-fullscreen"></i> Всё дерево
                </button>
                <button class="btn btn-sm btn-success w-100" @onclick="GoToTraining">
                    <i class="bi bi-mortarboard-fill"></i> Тренировка
                </button>
            </div>
        </aside>

        @* ── Main SVG Canvas ── *@
        <div class="tree-canvas-wrap"
             @onmousedown="OnPointerDown" @onmousemove="OnPointerMove"
             @onmouseup="OnPointerUp" @onmouseleave="OnPointerUp">

            <div id="cloud-overlay" class="cloud-overlay hidden">
                <div class="cloud-panel cloud-left"></div>
                <div class="cloud-panel cloud-right"></div>
            </div>

            @if (Tree.IsWilting)
            {
                <div class="wilt-banner">
                    <i class="bi bi-exclamation-triangle"></i> Дерево увядает! @Tree.DaysSinceActivity дней без занятий.
                </div>
            }

            <svg id="tree-svg"
                 viewBox="@($"{F(VX)} {F(VY)} {F(VW)} {F(VH)}")"
                 preserveAspectRatio="xMidYMid meet"
                 style="width:100%;height:100%;cursor:@(IsDragging?"grabbing":"grab");"
                 xmlns="http://www.w3.org/2000/svg">

                <defs>
                    @* Sky gradient background *@
                    <linearGradient id="sky-grad" x1="0" y1="0" x2="0" y2="1">
                        <stop offset="0%" stop-color="#b3e5fc"/>
                        <stop offset="60%" stop-color="#e8f5e9"/>
                        <stop offset="100%" stop-color="#8d6e63" stop-opacity="0.3"/>
                    </linearGradient>
                    @* Bark texture gradient *@
                    <linearGradient id="bark-grad" x1="0" y1="0" x2="1" y2="0">
                        <stop offset="0%" stop-color="#5D4037"/>
                        <stop offset="30%" stop-color="#6D4C41"/>
                        <stop offset="50%" stop-color="#795548"/>
                        <stop offset="70%" stop-color="#6D4C41"/>
                        <stop offset="100%" stop-color="#4E342E"/>
                    </linearGradient>
                    <linearGradient id="branch-grad" x1="0" y1="0" x2="1" y2="0">
                        <stop offset="0%" stop-color="#6D4C41"/>
                        <stop offset="50%" stop-color="#8D6E63"/>
                        <stop offset="100%" stop-color="#5D4037"/>
                    </linearGradient>
                    <linearGradient id="twig-grad" x1="0" y1="0" x2="1" y2="0">
                        <stop offset="0%" stop-color="#795548"/>
                        <stop offset="100%" stop-color="#A1887F"/>
                    </linearGradient>
                    <filter id="wood-shadow">
                        <feDropShadow dx="2" dy="3" stdDeviation="2" flood-color="#3E2723" flood-opacity="0.3"/>
                    </filter>
                    <filter id="leaf-glow">
                        <feGaussianBlur stdDeviation="2" result="blur"/>
                        <feMerge>
                            <feMergeNode in="blur"/>
                            <feMergeNode in="SourceGraphic"/>
                        </feMerge>
                    </filter>
                </defs>

                @* Sky background *@
                <rect x="0" y="0" width="@F(Tree.CanvasWidth)" height="@F(Tree.CanvasHeight)" fill="url(#sky-grad)"/>

                @* Ground *@
                <ellipse cx="@F(Tree.CanvasWidth / 2)" cy="@F(Tree.CanvasHeight - 30)"
                         rx="@F(Tree.CanvasWidth * 0.45)" ry="60"
                         fill="#6D4C41" opacity="0.3"/>
                <ellipse cx="@F(Tree.CanvasWidth / 2)" cy="@F(Tree.CanvasHeight - 40)"
                         rx="@F(Tree.CanvasWidth * 0.35)" ry="30"
                         fill="#4CAF50" opacity="0.4"/>

                @if (!IsLeafView)
                {
                    @* ── TRUNK ── *@
                    <path d="@TrunkPath()" stroke="url(#bark-grad)" stroke-width="24"
                          fill="none" stroke-linecap="round" filter="url(#wood-shadow)"/>
                    @* Bark texture lines *@
                    <path d="@TrunkPath()" stroke="#4E342E" stroke-width="1"
                          fill="none" stroke-dasharray="8,12" opacity="0.3"/>

                    @* Roots at trunk base *@
                    @for (int ri = 0; ri < 5; ri++)
                    {
                        var rootAngle = -150 + ri * 30.0 + 60;
                        var rootRad = rootAngle * Math.PI / 180;
                        var rootLen = 40 + ri * 15;
                        var rx1 = Tree.Trunk.X1;
                        var ry1 = Tree.Trunk.Y1;
                        var rx2 = rx1 + Math.Cos(rootRad) * rootLen;
                        var ry2 = ry1 + Math.Sin(rootRad) * Math.Abs(rootLen * 0.3);
                        <path d="@($"M {F(rx1)},{F(ry1)} Q {F((rx1+rx2)/2)},{F(ry1 + 15)} {F(rx2)},{F(ry2)}")"
                              stroke="#5D4037" stroke-width="@(6 - ri)" fill="none" stroke-linecap="round" opacity="0.6"/>
                    }

                    @* ── BRANCHES (Tags) ── *@
                    @foreach (var branch in Tree.Branches)
                    {
                        var capturedBranch = branch;
                        var isSelectedBranch = SelectedBranch?.Id == branch.Id;
                        var branchOpacity = isSelectedBranch ? 1.0 : 0.85;

                        <g style="cursor:pointer;" @onclick="() => OnBranchClick(capturedBranch)">
                            @* Branch path *@
                            <path d="@BezierPath(branch.Segment, branch.Cp1X, branch.Cp1Y, branch.Cp2X, branch.Cp2Y)"
                                  stroke="url(#branch-grad)" stroke-width="@F(branch.StrokeWidth)"
                                  fill="none" stroke-linecap="round" filter="url(#wood-shadow)"
                                  opacity="@F(branchOpacity)"/>
                            @* Bark texture on branch *@
                            <path d="@BezierPath(branch.Segment, branch.Cp1X, branch.Cp1Y, branch.Cp2X, branch.Cp2Y)"
                                  stroke="#4E342E" stroke-width="0.8" fill="none"
                                  stroke-dasharray="5,10" opacity="0.2"/>

                            @* Tag label at branch midpoint *@
                            @{ var bMid = BezierMid(branch.Segment, branch.Cp1X, branch.Cp1Y, branch.Cp2X, branch.Cp2Y); }
                            @SvgText(bMid.x, bMid.y - 12, "middle", 11, "#3E2723",
                                Truncate(branch.TagName, 16), "700")
                            @SvgText(bMid.x, bMid.y + 2, "middle", 8, "#6D4C41",
                                $"{branch.LearnedWords}/{branch.TotalWords}")

                            @if (isSelectedBranch)
                            {
                                <circle cx="@F(bMid.x)" cy="@F(bMid.y - 5)" r="3" fill="#4CAF50" opacity="0.7">
                                    <animate attributeName="r" values="3;5;3" dur="1.5s" repeatCount="indefinite"/>
                                </circle>
                            }
                        </g>

                        @* ── TWIGS (Dictionaries) ── *@
                        @foreach (var twig in branch.Twigs)
                        {
                            var capturedTwig = twig;
                            var isSelectedTwig = SelectedTwig?.Id == twig.Id;

                            <g style="cursor:pointer;" @onclick="() => OnTwigClick(capturedTwig)"
                               @ondblclick="() => DrillIntoTwig(capturedTwig)">
                                <path d="@BezierPath(twig.Segment, twig.Cp1X, twig.Cp1Y, twig.Cp2X, twig.Cp2Y)"
                                      stroke="url(#twig-grad)" stroke-width="@F(twig.StrokeWidth)"
                                      fill="none" stroke-linecap="round"
                                      opacity="@(isSelectedTwig ? "1" : "0.7")"/>

                                @* Twig label *@
                                @SvgText(twig.Segment.X2, twig.Segment.Y2 - 18, "middle", 8, "#5D4037",
                                    Truncate(twig.DictionaryName, 14), "600")

                                @* ── SPRIGS (mini-branches) with leaves ── *@
                                @foreach (var sprig in twig.Sprigs)
                                {
                                    @* Curved mini-branch (quadratic Bezier) *@
                                    <path d="M @F(sprig.X1),@F(sprig.Y1) Q @F(sprig.CpX),@F(sprig.CpY) @F(sprig.X2),@F(sprig.Y2)"
                                          stroke="#7B5B3A" stroke-width="@F(sprig.StrokeWidth)"
                                          fill="none" stroke-linecap="round" opacity="0.75"/>

                                    @foreach (var leaf in sprig.Leaves)
                                    {
                                        var lColor = leaf.IsLearned ? "#388E3C" : "#A5D6A7";
                                        var lStroke = leaf.IsLearned ? "#1B5E20" : "#81C784";
                                        var lColor2 = leaf.IsLearned ? "#2E7D32" : "#C8E6C9";
                                        var lColor3 = leaf.IsLearned ? "#43A047" : "#81C784";
                                        <g transform="translate(@F(leaf.X),@F(leaf.Y))">
                                            <path d="M 0,1 C -5,-4 -7,-11 0,-15 C 7,-11 5,-4 0,1 Z"
                                                  fill="@lColor2" stroke="@lStroke" stroke-width="0.3"
                                                  opacity="0.5" transform="rotate(@F(leaf.Rotation - 25)) scale(1.1)"/>
                                            <path d="M 0,0 C -4,-4 -6,-10 0,-14 C 6,-10 4,-4 0,0 Z"
                                                  fill="@lColor" stroke="@lStroke" stroke-width="0.4"
                                                  opacity="0.85" transform="rotate(@F(leaf.Rotation))"/>
                                            <line x1="0" y1="0" x2="0" y2="-11"
                                                  stroke="@lStroke" stroke-width="0.3" opacity="0.4"
                                                  transform="rotate(@F(leaf.Rotation))"/>
                                            <path d="M 0,0 C -3,-3 -4,-7 0,-10 C 4,-7 3,-3 0,0 Z"
                                                  fill="@lColor3" stroke="none"
                                                  opacity="0.6" transform="rotate(@F(leaf.Rotation + 30)) scale(0.7)"/>
                                        </g>
                                    }
                                }
                                @* Twig-level leaves (20% for fullness) *@
                                @foreach (var leaf in twig.Leaves)
                                {
                                    var lColor = leaf.IsLearned ? "#388E3C" : "#A5D6A7";
                                    var lStroke = leaf.IsLearned ? "#1B5E20" : "#81C784";
                                    var lColor2 = leaf.IsLearned ? "#2E7D32" : "#C8E6C9";
                                    var lColor3 = leaf.IsLearned ? "#43A047" : "#81C784";
                                    <g transform="translate(@F(leaf.X),@F(leaf.Y))">
                                        <path d="M 0,1 C -5,-4 -7,-11 0,-15 C 7,-11 5,-4 0,1 Z"
                                              fill="@lColor2" stroke="@lStroke" stroke-width="0.3"
                                              opacity="0.5" transform="rotate(@F(leaf.Rotation - 25)) scale(1.1)"/>
                                        <path d="M 0,0 C -4,-4 -6,-10 0,-14 C 6,-10 4,-4 0,0 Z"
                                              fill="@lColor" stroke="@lStroke" stroke-width="0.4"
                                              opacity="0.85" transform="rotate(@F(leaf.Rotation))"/>
                                        <line x1="0" y1="0" x2="0" y2="-11"
                                              stroke="@lStroke" stroke-width="0.3" opacity="0.4"
                                              transform="rotate(@F(leaf.Rotation))"/>
                                        <path d="M 0,0 C -3,-3 -4,-7 0,-10 C 4,-7 3,-3 0,0 Z"
                                              fill="@lColor3" stroke="none"
                                              opacity="0.6" transform="rotate(@F(leaf.Rotation + 30)) scale(0.7)"/>
                                    </g>
                                }

                                @if (isSelectedTwig)
                                {
                                    <circle cx="@F(twig.Segment.X2)" cy="@F(twig.Segment.Y2)" r="4"
                                            fill="#FF9800" opacity="0.8">
                                        <animate attributeName="r" values="4;6;4" dur="1.2s" repeatCount="indefinite"/>
                                    </circle>
                                }
                            </g>
                        }
                    }
                }
                else
                {
                    @* ── LEAF VIEW: Zoomed-in word cloud for a single twig ── *@
                    @if (LeafViewTwig != null)
                    {
                        var cx = Tree.CanvasWidth / 2;
                        var cy = Tree.CanvasHeight / 2;

                        @* Central twig illustration *@
                        <line x1="@F(cx)" y1="@F(cy + 80)" x2="@F(cx)" y2="@F(cy - 60)"
                              stroke="#8D6E63" stroke-width="4" stroke-linecap="round"/>
                        @SvgText(cx, cy + 110, "middle", 14, "#3E2723", LeafViewTwig.DictionaryName, "700")
                        @SvgText(cx, cy + 130, "middle", 10, "#795548",
                            $"{LeafViewTwig.LearnedWords} / {LeafViewTwig.TotalWords} слов")

                        @* Words as leaf clusters *@
                        var leafWords = LeafViewTwig.Leaves;
                        var leafCount = Math.Min(leafWords.Count, 100);
                        var ringCount = (int)Math.Ceiling(leafCount / 16.0);
                        var idx = 0;
                        @for (int ring = 0; ring < ringCount && idx < leafCount; ring++)
                        {
                            var ringR = 90 + ring * 70;
                            var wordsInRing = Math.Min(16 + ring * 4, leafCount - idx);
                            @for (int wi = 0; wi < wordsInRing && idx < leafCount; wi++)
                            {
                                var leaf = leafWords[idx];
                                var angle = (360.0 / wordsInRing) * wi - 90;
                                var rad = angle * Math.PI / 180;
                                var lx = cx + Math.Cos(rad) * ringR;
                                var ly = cy + Math.Sin(rad) * ringR;
                                var lColor = leaf.IsLearned ? "#388E3C" : "#C8E6C9";
                                var lStroke = leaf.IsLearned ? "#1B5E20" : "#A5D6A7";

                                @* Tiny twig to leaf *@
                                <line x1="@F(cx)" y1="@F(cy)" x2="@F(lx)" y2="@F(ly)"
                                      stroke="#A1887F" stroke-width="0.5" opacity="0.15"/>

                                @* Leaf *@
                                <g transform="translate(@F(lx),@F(ly)) rotate(@F(angle)) scale(1.2)">
                                    <path d="M 0,-1 C -5,-6 -6,-12 0,-15 C 6,-12 5,-6 0,-1 Z"
                                          fill="@lColor" stroke="@lStroke" stroke-width="0.5"/>
                                    <line x1="0" y1="-1" x2="0" y2="-12"
                                          stroke="@lStroke" stroke-width="0.3" opacity="0.5"/>
                                </g>

                                @* Word label *@
                                @SvgText(lx, ly + 14, "middle", 7, leaf.IsLearned ? "#1B5E20" : "#999",
                                    Truncate(leaf.Word, 10))

                                idx++;
                            }
                        }

                        @* Back button *@
                        <g style="cursor:pointer;" @onclick="ExitLeafView">
                            <rect x="@F(cx - 50)" y="@F(Tree.CanvasHeight - 100)"
                                  width="100" height="32" rx="16" fill="#5D4037"/>
                            @SvgText(cx, Tree.CanvasHeight - 80, "middle", 12, "white", "← Назад", "600")
                        </g>
                    }
                }
            </svg>
        </div>
    </div>
}
else
{
    <div class="container text-center py-5">
        <h3>Не удалось загрузить Дерево Знаний</h3>
        <button class="btn btn-outline-primary mt-3" @onclick="LoadDataAsync">Попробовать снова</button>
    </div>
}

<style>
    .tree-layout {
        display: flex;
        height: calc(100vh - 60px);
        overflow: hidden;
        background: #f5f5f5;
    }
    .tree-sidebar {
        width: 260px;
        min-width: 260px;
        padding: 12px;
        overflow-y: auto;
        background: var(--card-bg, #fff);
        border-right: 1px solid var(--border-color, #e0e0e0);
        display: flex;
        flex-direction: column;
        gap: 10px;
    }
    .tree-canvas-wrap {
        flex: 1;
        position: relative;
        overflow: hidden;
        background: linear-gradient(180deg, #e3f2fd 0%, #e8f5e9 60%, #efebe9 100%);
    }
    .st-panel {
        padding: 10px 12px;
        border-radius: 10px;
        background: var(--bg-tertiary, #f9f9f9);
        border: 1px solid var(--border-color, #eee);
    }
    .st-panel-header {
        font-weight: 700;
        font-size: 0.85rem;
        margin-bottom: 8px;
    }
    .st-stat-row {
        display: flex;
        justify-content: space-between;
        font-size: 0.8rem;
        margin-bottom: 4px;
    }
    .st-progress-label {
        display: flex;
        justify-content: space-between;
        font-size: 0.75rem;
        color: #888;
        margin-bottom: 4px;
    }
    .wilt-banner {
        position: absolute;
        top: 8px;
        left: 50%;
        transform: translateX(-50%);
        z-index: 10;
        padding: 6px 16px;
        border-radius: 20px;
        background: rgba(255, 152, 0, 0.9);
        color: white;
        font-size: 0.82rem;
        font-weight: 600;
    }

    /* Cloud transition */
    .cloud-overlay {
        position: absolute; inset: 0; z-index: 50; pointer-events: none; display: flex;
    }
    .cloud-overlay.hidden { display: none; }
    .cloud-panel {
        width: 55%; height: 100%; position: absolute;
        background: linear-gradient(135deg, #e8f5e9 0%, white 50%, #efebe9 100%);
        opacity: 0.97;
    }
    .cloud-panel.cloud-left  { left: -55%; }
    .cloud-panel.cloud-right { right: -55%; }
    .cloud-overlay.clouds-in .cloud-left  { animation: cl-in-l 0.5s ease-out forwards; }
    .cloud-overlay.clouds-in .cloud-right { animation: cl-in-r 0.5s ease-out forwards; }
    .cloud-overlay.clouds-out .cloud-left  { animation: cl-out-l 0.5s ease-in forwards; }
    .cloud-overlay.clouds-out .cloud-right { animation: cl-out-r 0.5s ease-in forwards; }

    @@keyframes cl-in-l  { from { transform: translateX(0); } to { transform: translateX(100%); } }
    @@keyframes cl-in-r  { from { transform: translateX(0); } to { transform: translateX(-100%); } }
    @@keyframes cl-out-l { from { transform: translateX(100%); } to { transform: translateX(0); } }
    @@keyframes cl-out-r { from { transform: translateX(-100%); } to { transform: translateX(0); } }

    @@media (max-width: 768px) {
        .tree-sidebar {
            position: fixed; left: -280px; top: 60px; bottom: 0; z-index: 40; transition: left 0.3s;
        }
        .tree-sidebar.open { left: 0; }
    }
</style>

@code {
    // ─── State ───
    private KnowledgeTreeState? Tree;
    private bool IsLoading = true;
    private bool IsAuthenticated;

    // Selection
    private TreeBranch? SelectedBranch;
    private TreeTwig? SelectedTwig;

    // Leaf view drill-down
    private bool IsLeafView;
    private TreeTwig? LeafViewTwig;

    // Pour XP
    private long PourAmount;
    private bool IsPouringXp;
    private string PourMessage = "";
    private bool PourSuccess;

    // Pan state (viewBox manipulation)
    private double VX, VY, VW, VH;
    private bool IsDragging;
    private double DragStartX, DragStartY;
    private double DragVXStart, DragVYStart;

    private DotNetObjectReference<KnowledgeTree>? _selfRef;

    protected override async Task OnInitializedAsync()
    {
        _selfRef = DotNetObjectReference.Create(this);
        await AuthService.InitializeAsync();
        var session = await AuthService.GetCurrentSessionAsync();
        IsAuthenticated = session != null;

        if (IsAuthenticated)
            await LoadDataAsync();
        else
            IsLoading = false;
    }

    private async Task LoadDataAsync()
    {
        IsLoading = true;
        StateHasChanged();
        try
        {
            Tree = await TreeService.GetTreeStateAsync();
            if (Tree != null)
                ResetViewInternal();
        }
        finally
        {
            IsLoading = false;
            StateHasChanged();
        }
    }

    // ─── Interaction ───

    private void OnBranchClick(TreeBranch branch)
    {
        SelectedBranch = branch;
        SelectedTwig = null;
        ZoomToSegment(branch.Segment, 200);
    }

    private void OnTwigClick(TreeTwig twig)
    {
        SelectedTwig = twig;
        SelectedBranch = Tree?.Branches.FirstOrDefault(b => b.Twigs.Any(t => t.Id == twig.Id));
        ZoomToSegment(twig.Segment, 120);
    }

    private async Task DrillIntoTwig(TreeTwig twig)
    {
        if (twig.Leaves.Count == 0) return;

        IsLeafView = false;
        StateHasChanged();
        await JS.InvokeVoidAsync("KnowledgeTreeInterop.playCloudTransition", "cloud-overlay", _selfRef);

        LeafViewTwig = twig;
        IsLeafView = true;
        VX = Tree!.CanvasWidth / 2 - 500;
        VY = Tree.CanvasHeight / 2 - 400;
        VW = 1000;
        VH = 800;
        StateHasChanged();
    }

    private async Task ExitLeafView()
    {
        await JS.InvokeVoidAsync("KnowledgeTreeInterop.playCloudTransition", "cloud-overlay", _selfRef);
        IsLeafView = false;
        LeafViewTwig = null;
        ResetViewInternal();
        StateHasChanged();
    }

    [JSInvokable]
    public void OnCloudsCovered()
    {
        InvokeAsync(StateHasChanged);
    }

    private void ZoomToSegment(BotanicalSegment seg, double padding)
    {
        var minX = Math.Min(seg.X1, seg.X2) - padding;
        var minY = Math.Min(seg.Y1, seg.Y2) - padding;
        var w = Math.Abs(seg.X2 - seg.X1) + padding * 2;
        var h = Math.Abs(seg.Y2 - seg.Y1) + padding * 2;
        w = Math.Max(w, 400);
        h = Math.Max(h, 300);
        VX = minX; VY = minY; VW = w; VH = h;
        StateHasChanged();
    }

    private void ResetView()
    {
        SelectedBranch = null;
        SelectedTwig = null;
        IsLeafView = false;
        LeafViewTwig = null;
        ResetViewInternal();
    }

    private void ResetViewInternal()
    {
        if (Tree == null) return;
        VX = 0; VY = 0; VW = Tree.CanvasWidth; VH = Tree.CanvasHeight;
        StateHasChanged();
    }

    // ─── Pan ───

    private void OnPointerDown(MouseEventArgs e)
    {
        IsDragging = true;
        DragStartX = e.ClientX; DragStartY = e.ClientY;
        DragVXStart = VX; DragVYStart = VY;
    }

    private void OnPointerMove(MouseEventArgs e)
    {
        if (!IsDragging) return;
        var dx = (e.ClientX - DragStartX) * (VW / 800);
        var dy = (e.ClientY - DragStartY) * (VH / 600);
        VX = DragVXStart - dx;
        VY = DragVYStart - dy;
    }

    private void OnPointerUp(MouseEventArgs e) => IsDragging = false;

    // ─── Pour XP ───

    private async Task PourXpAsync()
    {
        if (PourAmount <= 0 || Tree == null) return;
        IsPouringXp = true; PourMessage = "";
        StateHasChanged();

        try
        {
            var result = await TreeService.PourXpAsync(PourAmount);
            if (result is { Success: true })
            {
                PourSuccess = true;
                PourMessage = result.Message;
                if (result.StageChanged)
                    await JS.InvokeVoidAsync("KnowledgeTreeInterop.playCloudTransition", "cloud-overlay", _selfRef);
                await LoadDataAsync();
                PourAmount = 0;
            }
            else
            {
                PourSuccess = false;
                PourMessage = result?.Message ?? "Ошибка";
            }
        }
        finally
        {
            IsPouringXp = false;
            StateHasChanged();
        }
    }

    private void GoToTraining() => Navigation.NavigateTo("/training");

    // ─── SVG Helpers ───

    private static string F(double v) =>
        v.ToString("F1", System.Globalization.CultureInfo.InvariantCulture);
    private static string Inv(double v) =>
        v.ToString("F1", System.Globalization.CultureInfo.InvariantCulture);
    private static string Truncate(string s, int max) =>
        s.Length <= max ? s : s[..(max - 1)] + "…";

    /// <summary>Builds the trunk as a slightly curved quadratic path</summary>
    private string TrunkPath()
    {
        if (Tree == null) return "";
        var t = Tree.Trunk;
        var cpx = (t.X1 + t.X2) / 2 + 12;
        var cpy = (t.Y1 + t.Y2) / 2;
        return $"M {F(t.X1)},{F(t.Y1)} Q {F(cpx)},{F(cpy)} {F(t.X2)},{F(t.Y2)}";
    }

    /// <summary>Cubic bezier path string</summary>
    private static string BezierPath(BotanicalSegment s, double cp1x, double cp1y, double cp2x, double cp2y) =>
        $"M {F(s.X1)},{F(s.Y1)} C {F(cp1x)},{F(cp1y)} {F(cp2x)},{F(cp2y)} {F(s.X2)},{F(s.Y2)}";

    /// <summary>Approximate midpoint on a cubic bezier at t=0.5</summary>
    private static (double x, double y) BezierMid(BotanicalSegment s, double cp1x, double cp1y, double cp2x, double cp2y)
    {
        const double t = 0.5;
        var u = 1 - t;
        var x = u*u*u*s.X1 + 3*u*u*t*cp1x + 3*u*t*t*cp2x + t*t*t*s.X2;
        var y = u*u*u*s.Y1 + 3*u*u*t*cp1y + 3*u*t*t*cp2y + t*t*t*s.Y2;
        return (x, y);
    }

    private static MarkupString SvgText(double x, double y, string anchor, int fontSize,
        string? fill, string content, string? fontWeight = null)
    {
        var fillAttr = fill != null ? " fill=\"" + System.Web.HttpUtility.HtmlAttributeEncode(fill) + "\"" : "";
        var weightAttr = fontWeight != null ? " font-weight=\"" + System.Web.HttpUtility.HtmlAttributeEncode(fontWeight) + "\"" : "";
        var enc = System.Web.HttpUtility.HtmlEncode(content);
        return new MarkupString(
            "<text x=\"" + F(x) + "\" y=\"" + F(y) + "\" text-anchor=\"" + anchor
            + "\" font-size=\"" + fontSize + "\"" + fillAttr + weightAttr + ">" + enc + "</text>");
    }

    public void Dispose() => _selfRef?.Dispose();
}
