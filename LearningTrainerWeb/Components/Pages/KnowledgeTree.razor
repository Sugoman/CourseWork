@page "/knowledge-tree"
@using LearningTrainerShared.Models
@using LearningTrainerShared.Models.KnowledgeTreeDto
@inject IKnowledgeTreeApiService TreeService
@inject IAuthService AuthService
@inject IJSRuntime JS
@inject NavigationManager Navigation
@implements IDisposable
@rendermode InteractiveServer

<PageTitle>Дерево знаний — Ingat</PageTitle>

@if (IsLoading)
{
    <div class="d-flex justify-content-center align-items-center" style="min-height: 60vh;">
        <div class="spinner-border text-success" role="status">
            <span class="visually-hidden">Загрузка...</span>
        </div>
    </div>
}
else if (!IsAuthenticated)
{
    <div class="container text-center py-5">
        <h3>Войдите, чтобы увидеть своё Дерево Знаний</h3>
        <a href="/login" class="btn btn-primary mt-3">Войти</a>
    </div>
}
else if (Tree != null)
{
    <div class="tree-layout">
        @* ── Side panel ── *@
        <aside class="tree-sidebar">
            @* Stage card *@
            <div class="st-card st-card-stage">
                <div class="st-stage-icon">@Tree.StageEmoji</div>
                <div class="st-stage-title">@Tree.StageName</div>
                <div class="st-stage-level">Уровень @Tree.TreeLevel</div>
                <div class="st-stage-stats">
                    <div class="st-mini-stat">
                        <span class="st-mini-val">@Tree.TreeXp.ToString("N0")</span>
                        <span class="st-mini-label">XP дерева</span>
                    </div>
                    <div class="st-mini-divider"></div>
                    <div class="st-mini-stat">
                        <span class="st-mini-val">@Tree.TotalWordsContributed</span>
                        <span class="st-mini-label">Слов</span>
                    </div>
                </div>
                <div class="st-progress-wrap">
                    <div class="st-progress-bar">
                        <div class="st-progress-fill" style="width: @Inv(Tree.ProgressToNextStage)%"></div>
                    </div>
                    <div class="st-progress-hint">@Tree.ProgressToNextStage.ToString("F0")% до следующей стадии</div>
                </div>
            </div>

            @* Pour XP *@
            <div class="st-card">
                <div class="st-card-header">
                    <span class="st-card-icon">💧</span> Влить XP
                </div>
                <p class="st-avail">Доступно: <strong>@Tree.AvailableUserXp.ToString("N0")</strong></p>
                <div class="st-pour-row">
                    <input type="number" class="st-pour-input" @bind="PourAmount" min="1" max="@Tree.AvailableUserXp" placeholder="0"/>
                    <button class="st-pour-btn" @onclick="PourXpAsync" disabled="@(IsPouringXp || PourAmount <= 0)">
                        @if (IsPouringXp) { <span class="spinner-border spinner-border-sm"></span> }
                        else { <span>💧</span> }
                    </button>
                </div>
                @if (!string.IsNullOrEmpty(PourMessage))
                {
                    <div class="st-msg @(PourSuccess ? "st-msg-ok" : "st-msg-err")">@PourMessage</div>
                }
            </div>

            @* Selected branch/twig info *@
            @if (SelectedBranch != null)
            {
                <div class="st-card st-card-sel">
                    <div class="st-card-header">
                        <span class="st-card-icon">🌿</span> @SelectedBranch.TagName
                    </div>
                    <div class="st-sel-stats">
                        <span>@SelectedBranch.Twigs.Count словарей</span>
                        <span class="st-sel-prog">@SelectedBranch.LearnedWords / @SelectedBranch.TotalWords</span>
                    </div>
                    <div class="st-progress-bar st-prog-sm">
                        <div class="st-progress-fill st-fill-blue" style="width: @Inv(SelectedBranch.Progress * 100)%"></div>
                    </div>
                </div>
            }
            @if (SelectedTwig != null)
            {
                <div class="st-card st-card-sel">
                    <div class="st-card-header">
                        <span class="st-card-icon">🍃</span> @SelectedTwig.DictionaryName
                    </div>
                    <div class="st-sel-stats">
                        <span class="st-sel-prog">@SelectedTwig.LearnedWords / @SelectedTwig.TotalWords слов</span>
                    </div>
                    <div class="st-progress-bar st-prog-sm">
                        <div class="st-progress-fill" style="width: @Inv(SelectedTwig.Progress * 100)%"></div>
                    </div>
                    <button class="st-btn st-btn-outline mt-2" @onclick="() => DrillIntoTwig(SelectedTwig)">
                        👁 Показать слова
                    </button>
                </div>
            }

            <div class="st-card st-card-actions">
                <button class="st-btn st-btn-ghost" @onclick="ResetView">
                    🌳 Всё дерево
                </button>
                <button class="st-btn st-btn-primary" @onclick="GoToTraining">
                    🎓 Тренировка
                </button>
            </div>
        </aside>

        @* ── Main SVG Canvas ── *@
        <div class="tree-canvas-wrap"
             @onmousedown="OnPointerDown" @onmousemove="OnPointerMove"
             @onmouseup="OnPointerUp" @onmouseleave="OnPointerUp">

            <div id="cloud-overlay" class="cloud-overlay hidden">
                <div class="cloud-panel cloud-left"></div>
                <div class="cloud-panel cloud-right"></div>
            </div>

            @if (Tree.IsWilting)
            {
                <div class="wilt-banner">
                    <i class="bi bi-exclamation-triangle"></i> Дерево увядает! @Tree.DaysSinceActivity дней без занятий.
                </div>
            }

            @{
                var svgZoomRatio = VW / (Tree?.CanvasWidth ?? 2000);
                var svgShapeRendering = svgZoomRatio > 0.55 ? "optimizeSpeed" : "auto";
            }
            <svg id="tree-svg"
                 viewBox="@($"{F(VX)} {F(VY)} {F(VW)} {F(VH)}")"
                 preserveAspectRatio="xMidYMid meet"
                 style="width:100%;height:100%;cursor:@(IsDragging?"grabbing":"grab");will-change:viewBox;"
                 shape-rendering="@svgShapeRendering"
                 xmlns="http://www.w3.org/2000/svg">

                <defs>
                    @* ── Sky gradient ── *@
                    <linearGradient id="sky-grad" x1="0" y1="0" x2="0" y2="1">
                        <stop offset="0%" stop-color="#a8d8ea"/>
                        <stop offset="35%" stop-color="#c5e8d5"/>
                        <stop offset="65%" stop-color="#dce8d0"/>
                        <stop offset="85%" stop-color="#e6dcc8"/>
                        <stop offset="100%" stop-color="#d4c4a8" stop-opacity="0.6"/>
                    </linearGradient>
                    @* ── Bark gradients ── *@
                    <linearGradient id="bark-grad" x1="0" y1="0" x2="1" y2="0">
                        <stop offset="0%" stop-color="#4E342E"/>
                        <stop offset="20%" stop-color="#5D4037"/>
                        <stop offset="40%" stop-color="#6D4C41"/>
                        <stop offset="55%" stop-color="#795548"/>
                        <stop offset="70%" stop-color="#6D4C41"/>
                        <stop offset="85%" stop-color="#5D4037"/>
                        <stop offset="100%" stop-color="#3E2723"/>
                    </linearGradient>
                    <linearGradient id="branch-grad" x1="0" y1="0" x2="1" y2="0">
                        <stop offset="0%" stop-color="#5D4037"/>
                        <stop offset="35%" stop-color="#795548"/>
                        <stop offset="65%" stop-color="#8D6E63"/>
                        <stop offset="100%" stop-color="#5D4037"/>
                    </linearGradient>
                    <linearGradient id="twig-grad" x1="0" y1="0" x2="1" y2="0">
                        <stop offset="0%" stop-color="#6D4C41"/>
                        <stop offset="50%" stop-color="#8D6E63"/>
                        <stop offset="100%" stop-color="#A1887F"/>
                    </linearGradient>
                    @* ── Ground gradient ── *@
                    <radialGradient id="ground-grad" cx="0.5" cy="0.3" r="0.7">
                        <stop offset="0%" stop-color="#7CB342" stop-opacity="0.5"/>
                        <stop offset="60%" stop-color="#8D6E63" stop-opacity="0.35"/>
                        <stop offset="100%" stop-color="#6D4C41" stop-opacity="0.15"/>
                    </radialGradient>
                    @* ── Filters ── *@
                    <filter id="wood-shadow">
                        <feDropShadow dx="1.5" dy="2.5" stdDeviation="2.5" flood-color="#2E1B0E" flood-opacity="0.25"/>
                    </filter>
                    <filter id="leaf-glow">
                        <feGaussianBlur stdDeviation="2" result="blur"/>
                        <feMerge>
                            <feMergeNode in="blur"/>
                            <feMergeNode in="SourceGraphic"/>
                        </feMerge>
                    </filter>
                    <filter id="soft-shadow">
                        <feGaussianBlur in="SourceAlpha" stdDeviation="8" result="blur"/>
                        <feOffset dx="0" dy="4" result="off"/>
                        <feFlood flood-color="#3E2723" flood-opacity="0.12" result="flood"/>
                        <feComposite in="flood" in2="off" operator="in" result="shadow"/>
                        <feMerge>
                            <feMergeNode in="shadow"/>
                            <feMergeNode in="SourceGraphic"/>
                        </feMerge>
                    </filter>
                </defs>

                @* Sky background *@
                <rect x="0" y="0" width="@F(Tree.CanvasWidth)" height="@F(Tree.CanvasHeight)" fill="url(#sky-grad)"/>

                @{
                    // ── LOD calculation based on zoom level (global scope) ──
                    var zoomRatio = VW / Tree.CanvasWidth;
                    var lod = zoomRatio > 0.55 ? 0 : zoomRatio > 0.25 ? 1 : 2;
                }

                @* Ground: layered ellipses for depth *@
                <ellipse cx="@F(Tree.CanvasWidth / 2)" cy="@F(Tree.CanvasHeight - 15)"
                         rx="@F(Tree.CanvasWidth * 0.52)" ry="80"
                         fill="#5D4037" opacity="0.15"/>
                <ellipse cx="@F(Tree.CanvasWidth / 2)" cy="@F(Tree.CanvasHeight - 25)"
                         rx="@F(Tree.CanvasWidth * 0.46)" ry="65"
                         fill="url(#ground-grad)"/>
                <ellipse cx="@F(Tree.CanvasWidth / 2)" cy="@F(Tree.CanvasHeight - 35)"
                         rx="@F(Tree.CanvasWidth * 0.38)" ry="35"
                         fill="#8BC34A" opacity="0.25"/>
                @* Grass tufts (only when zoomed enough to see them) *@
                @if (lod >= 1)
                {
                    var grassRng = new Random(42);
                    for (int gi = 0; gi < 12; gi++)
                    {
                        var gx = Tree.CanvasWidth * 0.15 + grassRng.NextDouble() * Tree.CanvasWidth * 0.7;
                        var gy = Tree.CanvasHeight - 45 - grassRng.NextDouble() * 20;
                        var gh = 8 + grassRng.NextDouble() * 14;
                        var gAngle = (grassRng.NextDouble() - 0.5) * 30;
                        <line x1="@F(gx)" y1="@F(gy)" x2="@F(gx + gAngle * 0.5)" y2="@F(gy - gh)"
                              stroke="#689F38" stroke-width="1.5" stroke-linecap="round" opacity="@F(0.3 + grassRng.NextDouble() * 0.3)"/>
                    }
                }

                @if (!IsLeafView)
                {
                    @if (Tree.CurrentStage == TreeStage.Seed)
                    {
                        @* ── SEED: small seed on the ground ── *@
                        var seedCx = Tree.CanvasWidth / 2;
                        var seedCy = Tree.CanvasHeight - 70;
                        <ellipse cx="@F(seedCx)" cy="@F(seedCy)" rx="18" ry="12"
                                 fill="#795548" stroke="#5D4037" stroke-width="1.5" opacity="0.9"/>
                        <ellipse cx="@F(seedCx - 3)" cy="@F(seedCy - 2)" rx="6" ry="4"
                                 fill="#8D6E63" opacity="0.6"/>
                        @SvgText(seedCx, seedCy - 28, "middle", 12, "#5D4037", "🌰 Зерно", "600")
                    }
                    else if (Tree.CurrentStage == TreeStage.Sprout)
                    {
                        @* ── SPROUT: thin stem with 2 small leaves ── *@
                        var sprCx = Tree.CanvasWidth / 2;
                        var sprBase = Tree.CanvasHeight - 65;
                        var sprTop = sprBase - 80;
                        <line x1="@F(sprCx)" y1="@F(sprBase)" x2="@F(sprCx)" y2="@F(sprTop)"
                              stroke="#66BB6A" stroke-width="4" stroke-linecap="round"/>
                        @* Left leaf *@
                        <path d="M @F(sprCx),@F(sprTop + 25) C @F(sprCx - 20),@F(sprTop + 10) @F(sprCx - 28),@F(sprTop - 5) @F(sprCx - 10),@F(sprTop + 5)"
                              fill="#81C784" stroke="#388E3C" stroke-width="0.5" opacity="0.9"/>
                        @* Right leaf *@
                        <path d="M @F(sprCx),@F(sprTop + 15) C @F(sprCx + 18),@F(sprTop) @F(sprCx + 25),@F(sprTop - 10) @F(sprCx + 8),@F(sprTop)"
                              fill="#A5D6A7" stroke="#388E3C" stroke-width="0.5" opacity="0.9"/>
                        @* Tip bud *@
                        <circle cx="@F(sprCx)" cy="@F(sprTop - 3)" r="4" fill="#66BB6A" stroke="#43A047" stroke-width="0.5"/>
                        @SvgText(sprCx, sprTop - 22, "middle", 12, "#388E3C", "🌱 Росток", "600")
                    }
                    else
                    {
                    @* ── TRUNK (Sapling and above) ── *@
                    var trunkFilter = lod >= 1 ? "url(#wood-shadow)" : "none";
                    <path d="@TrunkPath()" stroke="url(#bark-grad)" stroke-width="28"
                          fill="none" stroke-linecap="round" filter="@trunkFilter"/>
                    @if (lod >= 1)
                    {
                        @* Bark highlight (left edge) *@
                        <path d="@TrunkPath()" stroke="#8D6E63" stroke-width="6"
                              fill="none" stroke-linecap="round" opacity="0.2"
                              stroke-dasharray="0" transform="translate(-6, 0)"/>
                    }
                    @* Bark texture lines *@
                    <path d="@TrunkPath()" stroke="#3E2723" stroke-width="0.8"
                          fill="none" stroke-dasharray="6,14" opacity="0.25"/>
                    @if (lod >= 1)
                    {
                        <path d="@TrunkPath()" stroke="#3E2723" stroke-width="0.5"
                              fill="none" stroke-dasharray="3,20,8,15" opacity="0.18"/>
                    }

                    @* Roots at trunk base *@
                    @for (int ri = 0; ri < 5; ri++)
                    {
                        var rootAngle = -150 + ri * 30.0 + 60;
                        var rootRad = rootAngle * Math.PI / 180;
                        var rootLen = 40 + ri * 15;
                        var rx1 = Tree.Trunk.X1;
                        var ry1 = Tree.Trunk.Y1;
                        var rx2 = rx1 + Math.Cos(rootRad) * rootLen;
                        var ry2 = ry1 + Math.Sin(rootRad) * Math.Abs(rootLen * 0.3);
                        <path d="@($"M {F(rx1)},{F(ry1)} Q {F((rx1+rx2)/2)},{F(ry1 + 15)} {F(rx2)},{F(ry2)}")"
                              stroke="#5D4037" stroke-width="@(6 - ri)" fill="none" stroke-linecap="round" opacity="0.6"/>
                    }

                    @* ── BRANCHES (Tags) ── *@
                    @foreach (var branch in Tree.Branches)
                    {
                        @* ── Viewport culling: skip branches entirely outside view ── *@
                        var bMinX = Math.Min(branch.Segment.X1, branch.Segment.X2) - 80;
                        var bMaxX = Math.Max(branch.Segment.X1, branch.Segment.X2) + 80;
                        var bMinY = Math.Min(branch.Segment.Y1, branch.Segment.Y2) - 80;
                        var bMaxY = Math.Max(branch.Segment.Y1, branch.Segment.Y2) + 80;
                        if (bMaxX < VX || bMinX > VX + VW || bMaxY < VY || bMinY > VY + VH) { continue; }

                        var capturedBranch = branch;
                        var isSelectedBranch = SelectedBranch?.Id == branch.Id;
                        var hasAnySelection = SelectedBranch != null || SelectedTwig != null;
                        var branchContainsSelectedTwig = SelectedTwig != null
                            && branch.Twigs.Any(tw => tw.Id == SelectedTwig.Id);
                        var groupOpacity = !hasAnySelection ? 1.0
                            : (isSelectedBranch || branchContainsSelectedTwig) ? 1.0 : 0.10;

                        <g opacity="@F(groupOpacity)">
                        <g style="cursor:pointer;" @onclick="() => OnBranchClick(capturedBranch)">
                            @* Branch path *@
                            <path d="@BezierPath(branch.Segment, branch.Cp1X, branch.Cp1Y, branch.Cp2X, branch.Cp2Y)"
                                  stroke="url(#branch-grad)" stroke-width="@F(branch.StrokeWidth)"
                                  fill="none" stroke-linecap="round"
                                  filter="@(lod >= 1 ? "url(#wood-shadow)" : "none")"
                                  opacity="1"/>
                            @if (lod >= 1)
                            {
                                @* Branch bark texture *@
                                <path d="@BezierPath(branch.Segment, branch.Cp1X, branch.Cp1Y, branch.Cp2X, branch.Cp2Y)"
                                      stroke="#3E2723" stroke-width="0.6" fill="none"
                                      stroke-dasharray="4,12,7,9" opacity="0.18"/>
                                @* Branch highlight *@
                                <path d="@BezierPath(branch.Segment, branch.Cp1X, branch.Cp1Y, branch.Cp2X, branch.Cp2Y)"
                                      stroke="#A1887F" stroke-width="@F(Math.Max(branch.StrokeWidth * 0.25, 1.5))" fill="none"
                                      stroke-linecap="round" opacity="0.15"/>
                            }

                            @* Tag label at branch midpoint *@
                            @{ var bMid = BezierMid(branch.Segment, branch.Cp1X, branch.Cp1Y, branch.Cp2X, branch.Cp2Y); }
                            @SvgText(bMid.x, bMid.y - 12, "middle", 11, "#3E2723",
                                Truncate(branch.TagName, 16), "700")
                            @if (lod >= 1)
                            {
                                @SvgText(bMid.x, bMid.y + 2, "middle", 8, "#6D4C41",
                                    $"{branch.LearnedWords}/{branch.TotalWords}")
                            }

                            @if (isSelectedBranch)
                            {
                                <circle cx="@F(bMid.x)" cy="@F(bMid.y - 5)" r="3" fill="#4CAF50" opacity="0.7">
                                    <animate attributeName="r" values="3;5;3" dur="1.5s" repeatCount="indefinite"/>
                                </circle>
                            }
                        </g>

                        @* ── Branch-level decorative leaves ── *@
                        @foreach (var leaf in branch.Leaves)
                        {
                            var lColor = leaf.IsLearned ? "#388E3C" : "#A5D6A7";
                            @if (lod == 0)
                            {
                                <circle cx="@F(leaf.X)" cy="@F(leaf.Y)" r="14"
                                        fill="@lColor" opacity="0.55"/>
                            }
                            else
                            {
                                var lStroke = leaf.IsLearned ? "#1B5E20" : "#81C784";
                                <g transform="translate(@F(leaf.X),@F(leaf.Y)) scale(1.6)">
                                    <path d="M 0,0 C -4,-4 -6,-10 0,-14 C 6,-10 4,-4 0,0 Z"
                                          fill="@lColor" stroke="@lStroke" stroke-width="0.4"
                                          opacity="0.8" transform="rotate(@F(leaf.Rotation))"/>
                                </g>
                            }
                        }

                        @* ── TWIGS (Dictionaries) ── *@
                        @foreach (var twig in branch.Twigs)
                        {
                            var capturedTwig = twig;
                            var isSelectedTwig = SelectedTwig?.Id == twig.Id;
                            // Within a selected branch, dim non-selected twigs
                            var twigOpacity = SelectedTwig == null ? 1.0
                                : isSelectedTwig ? 1.0 : 0.10;

                            <g style="cursor:pointer;" opacity="@F(twigOpacity)"
                               @onclick="() => OnTwigClick(capturedTwig)"
                               @ondblclick="() => DrillIntoTwig(capturedTwig)">
                                <path d="@BezierPath(twig.Segment, twig.Cp1X, twig.Cp1Y, twig.Cp2X, twig.Cp2Y)"
                                      stroke="url(#twig-grad)" stroke-width="@F(twig.StrokeWidth)"
                                      fill="none" stroke-linecap="round"
                                      opacity="1"/>

                                @* Twig label (skip at LOD 0 to reduce DOM) *@
                                @if (lod >= 1)
                                {
                                    @SvgText(twig.Segment.X2, twig.Segment.Y2 - 18, "middle", 8, "#5D4037",
                                        Truncate(twig.DictionaryName, 14), "600")
                                }

                                @* ── SPRIGS + LEAVES ── *@
                                @if (lod == 0)
                                {
                                    @* LOD 0: Skip sprigs entirely. Render all leaves as simple circles *@
                                    @foreach (var sprig in twig.Sprigs)
                                    {
                                        @foreach (var leaf in sprig.Leaves)
                                        {
                                            <circle cx="@F(leaf.X)" cy="@F(leaf.Y)" r="14"
                                                    fill="@(leaf.IsLearned ? "#388E3C" : "#A5D6A7")"
                                                    opacity="0.7"/>
                                        }
                                    }
                                    @foreach (var leaf in twig.Leaves)
                                    {
                                        <circle cx="@F(leaf.X)" cy="@F(leaf.Y)" r="14"
                                                fill="@(leaf.IsLearned ? "#388E3C" : "#A5D6A7")"
                                                opacity="0.6"/>
                                    }
                                }
                                else if (lod == 1)
                                {
                                    @* LOD 1: Show sprigs, single-path leaves *@
                                    @foreach (var sprig in twig.Sprigs)
                                    {
                                        <path d="M @F(sprig.X1),@F(sprig.Y1) Q @F(sprig.CpX),@F(sprig.CpY) @F(sprig.X2),@F(sprig.Y2)"
                                              stroke="#6D4C41" stroke-width="@F(sprig.StrokeWidth)"
                                              fill="none" stroke-linecap="round" opacity="0.7"/>
                                        @foreach (var leaf in sprig.Leaves)
                                        {
                                            var lc = leaf.IsLearned ? "#388E3C" : "#A5D6A7";
                                            var ls = leaf.IsLearned ? "#1B5E20" : "#81C784";
                                            <path d="M @F(leaf.X),@F(leaf.Y + 1) C @F(leaf.X - 6),@F(leaf.Y - 5) @F(leaf.X - 8),@F(leaf.Y - 14) @F(leaf.X),@F(leaf.Y - 20) C @F(leaf.X + 8),@F(leaf.Y - 14) @F(leaf.X + 6),@F(leaf.Y - 5) @F(leaf.X),@F(leaf.Y + 1) Z"
                                                  fill="@lc" stroke="@ls" stroke-width="0.4" opacity="0.8"/>
                                        }
                                    }
                                    @foreach (var leaf in twig.Leaves)
                                    {
                                        var lc = leaf.IsLearned ? "#388E3C" : "#A5D6A7";
                                        var ls = leaf.IsLearned ? "#1B5E20" : "#81C784";
                                        <path d="M @F(leaf.X),@F(leaf.Y + 1) C @F(leaf.X - 6),@F(leaf.Y - 5) @F(leaf.X - 8),@F(leaf.Y - 14) @F(leaf.X),@F(leaf.Y - 20) C @F(leaf.X + 8),@F(leaf.Y - 14) @F(leaf.X + 6),@F(leaf.Y - 5) @F(leaf.X),@F(leaf.Y + 1) Z"
                                              fill="@lc" stroke="@ls" stroke-width="0.4" opacity="0.7"/>
                                    }
                                }
                                else
                                {
                                    @* LOD 2: Full detail — sprigs + multi-layer leaves *@
                                    @foreach (var sprig in twig.Sprigs)
                                    {
                                        <path d="M @F(sprig.X1),@F(sprig.Y1) Q @F(sprig.CpX),@F(sprig.CpY) @F(sprig.X2),@F(sprig.Y2)"
                                              stroke="#6D4C41" stroke-width="@F(sprig.StrokeWidth)"
                                              fill="none" stroke-linecap="round" opacity="0.7"/>
                                        @foreach (var leaf in sprig.Leaves)
                                        {
                                            var lColor = leaf.IsLearned ? "#388E3C" : "#A5D6A7";
                                            var lStroke = leaf.IsLearned ? "#1B5E20" : "#81C784";
                                            var lColor2 = leaf.IsLearned ? "#2E7D32" : "#C8E6C9";
                                            var lColor3 = leaf.IsLearned ? "#43A047" : "#81C784";
                                            <g transform="translate(@F(leaf.X),@F(leaf.Y)) scale(1.6)">
                                                <path d="M 0,1 C -5,-4 -7,-11 0,-15 C 7,-11 5,-4 0,1 Z"
                                                      fill="@lColor2" stroke="@lStroke" stroke-width="0.3"
                                                      opacity="0.5" transform="rotate(@F(leaf.Rotation - 25)) scale(1.1)"/>
                                                <path d="M 0,0 C -4,-4 -6,-10 0,-14 C 6,-10 4,-4 0,0 Z"
                                                      fill="@lColor" stroke="@lStroke" stroke-width="0.4"
                                                      opacity="0.85" transform="rotate(@F(leaf.Rotation))"/>
                                                <line x1="0" y1="0" x2="0" y2="-11"
                                                      stroke="@lStroke" stroke-width="0.3" opacity="0.4"
                                                      transform="rotate(@F(leaf.Rotation))"/>
                                                <path d="M 0,0 C -3,-3 -4,-7 0,-10 C 4,-7 3,-3 0,0 Z"
                                                      fill="@lColor3" stroke="none"
                                                      opacity="0.6" transform="rotate(@F(leaf.Rotation + 30)) scale(0.7)"/>
                                            </g>
                                        }
                                    }
                                    @foreach (var leaf in twig.Leaves)
                                    {
                                        var lColor = leaf.IsLearned ? "#388E3C" : "#A5D6A7";
                                        var lStroke = leaf.IsLearned ? "#1B5E20" : "#81C784";
                                        var lColor2 = leaf.IsLearned ? "#2E7D32" : "#C8E6C9";
                                        var lColor3 = leaf.IsLearned ? "#43A047" : "#81C784";
                                        <g transform="translate(@F(leaf.X),@F(leaf.Y)) scale(1.6)">
                                            <path d="M 0,1 C -5,-4 -7,-11 0,-15 C 7,-11 5,-4 0,1 Z"
                                                  fill="@lColor2" stroke="@lStroke" stroke-width="0.3"
                                                  opacity="0.5" transform="rotate(@F(leaf.Rotation - 25)) scale(1.1)"/>
                                            <path d="M 0,0 C -4,-4 -6,-10 0,-14 C 6,-10 4,-4 0,0 Z"
                                                  fill="@lColor" stroke="@lStroke" stroke-width="0.4"
                                                  opacity="0.85" transform="rotate(@F(leaf.Rotation))"/>
                                            <line x1="0" y1="0" x2="0" y2="-11"
                                                  stroke="@lStroke" stroke-width="0.3" opacity="0.4"
                                                  transform="rotate(@F(leaf.Rotation))"/>
                                            <path d="M 0,0 C -3,-3 -4,-7 0,-10 C 4,-7 3,-3 0,0 Z"
                                                  fill="@lColor3" stroke="none"
                                                  opacity="0.6" transform="rotate(@F(leaf.Rotation + 30)) scale(0.7)"/>
                                        </g>
                                    }
                                }

                                @if (isSelectedTwig)
                                {
                                    <circle cx="@F(twig.Segment.X2)" cy="@F(twig.Segment.Y2)" r="4"
                                            fill="#FF9800" opacity="0.8">
                                        <animate attributeName="r" values="4;6;4" dur="1.2s" repeatCount="indefinite"/>
                                    </circle>
                                }
                            </g>
                        }
                        </g>
                    }
                    } @* end else (Sapling+) *@
                }
                else
                {
                    @* ── LEAF VIEW: Redesigned word collection board ── *@
                    @if (LeafViewTwig != null)
                    {
                        var cx = Tree.CanvasWidth / 2.0;
                        var cy = Tree.CanvasHeight / 2.0;
                        var cardW = 920.0;
                        var cardH = 720.0;
                        var cardX = cx - cardW / 2;
                        var cardY = cy - cardH / 2 + 20;

                        @* ── Card shadow ── *@
                        <rect x="@F(cardX + 5)" y="@F(cardY + 5)" width="@F(cardW)" height="@F(cardH)"
                              rx="24" fill="#3E2723" opacity="0.10"/>
                        @* ── Card background (parchment) ── *@
                        <rect x="@F(cardX)" y="@F(cardY)" width="@F(cardW)" height="@F(cardH)"
                              rx="24" fill="#FDFAF3" stroke="#D7CCC8" stroke-width="1.2"/>
                        <rect x="@F(cardX + 3)" y="@F(cardY + 3)" width="@F(cardW - 6)" height="@F(cardH - 6)"
                              rx="22" fill="none" stroke="white" stroke-width="0.8" opacity="0.5"/>

                        @* ── Corner leaf decorations ── *@
                        <g opacity="0.2">
                            <path d="M @F(cardX + 30),@F(cardY + 18) C @F(cardX + 16),@F(cardY + 8) @F(cardX + 10),@F(cardY + 2) @F(cardX + 24),@F(cardY + 10)" fill="#81C784"/>
                            <path d="M @F(cardX + 38),@F(cardY + 28) C @F(cardX + 48),@F(cardY + 16) @F(cardX + 54),@F(cardY + 8) @F(cardX + 42),@F(cardY + 18)" fill="#A5D6A7"/>
                            <path d="M @F(cardX + cardW - 30),@F(cardY + cardH - 18) C @F(cardX + cardW - 16),@F(cardY + cardH - 8) @F(cardX + cardW - 10),@F(cardY + cardH - 2) @F(cardX + cardW - 24),@F(cardY + cardH - 10)" fill="#81C784"/>
                            <path d="M @F(cardX + cardW - 38),@F(cardY + cardH - 28) C @F(cardX + cardW - 48),@F(cardY + cardH - 16) @F(cardX + cardW - 54),@F(cardY + cardH - 8) @F(cardX + cardW - 42),@F(cardY + cardH - 18)" fill="#A5D6A7"/>
                        </g>

                        @* ── Header: decorative vine ── *@
                        var hy = cardY + 38;
                        <line x1="@F(cx - 80)" y1="@F(hy)" x2="@F(cx + 80)" y2="@F(hy)"
                              stroke="#A1887F" stroke-width="2.5" stroke-linecap="round"/>
                        <path d="M @F(cx - 55),@F(hy) C @F(cx - 65),@F(hy - 14) @F(cx - 72),@F(hy - 20) @F(cx - 58),@F(hy - 10)"
                              fill="#66BB6A" stroke="#388E3C" stroke-width="0.3" opacity="0.8"/>
                        <path d="M @F(cx - 25),@F(hy) C @F(cx - 32),@F(hy + 12) @F(cx - 38),@F(hy + 18) @F(cx - 26),@F(hy + 8)"
                              fill="#A5D6A7" stroke="#388E3C" stroke-width="0.3" opacity="0.7"/>
                        <path d="M @F(cx + 30),@F(hy) C @F(cx + 40),@F(hy - 14) @F(cx + 48),@F(hy - 20) @F(cx + 34),@F(hy - 10)"
                              fill="#81C784" stroke="#388E3C" stroke-width="0.3" opacity="0.8"/>
                        <path d="M @F(cx + 60),@F(hy) C @F(cx + 68),@F(hy + 10) @F(cx + 76),@F(hy + 16) @F(cx + 64),@F(hy + 6)"
                              fill="#C8E6C9" stroke="#388E3C" stroke-width="0.3" opacity="0.6"/>

                        @* ── Title ── *@
                        @SvgText(cx, hy + 34, "middle", 20, "#3E2723", LeafViewTwig.DictionaryName, "700")

                        @* ── Stats ── *@
                        var allWords = LeafViewTwig.Leaves
                            .Concat(LeafViewTwig.Sprigs.SelectMany(s => s.Leaves))
                            .ToList();
                        var totalW = allWords.Count;
                        var learnedW = allWords.Count(l => l.IsLearned);
                        @SvgText(cx, hy + 54, "middle", 12, "#8D6E63",
                            $"{learnedW} из {totalW} слов выучено")

                        @* ── Progress bar ── *@
                        var barW = 320.0;
                        var barH = 10.0;
                        var barX = cx - barW / 2;
                        var barY = hy + 66;
                        var pct = totalW > 0 ? (double)learnedW / totalW : 0;
                        <rect x="@F(barX)" y="@F(barY)" width="@F(barW)" height="@F(barH)"
                              rx="5" fill="#EFEBE9"/>
                        @if (pct > 0)
                        {
                            <rect x="@F(barX)" y="@F(barY)" width="@F(Math.Max(barW * pct, 10))" height="@F(barH)"
                                  rx="5" fill="#4CAF50"/>
                            <rect x="@F(barX)" y="@F(barY)" width="@F(Math.Max(barW * pct, 10))" height="@F(barH / 2)"
                                  rx="5" fill="white" opacity="0.2"/>
                        }

                        @* ── Divider ── *@
                        <line x1="@F(cardX + 50)" y1="@F(barY + 24)" x2="@F(cardX + cardW - 50)" y2="@F(barY + 24)"
                              stroke="#D7CCC8" stroke-width="0.6" opacity="0.5"/>

                        @* ── Word grid ── *@
                        var leafWords = allWords;
                        var leafCount = Math.Min(leafWords.Count, 100);
                        var cols = leafCount <= 9 ? 3 : leafCount <= 28 ? 4 : 5;
                        var numRows = (int)Math.Ceiling((double)leafCount / cols);
                        var gridPadX = 44.0;
                        var colW = (cardW - gridPadX * 2) / cols;
                        var availGridH = cardH - (barY + 24 - cardY) - 80;
                        var rowH = Math.Min(38.0, availGridH / Math.Max(numRows, 1));
                        var gridLeft = cardX + gridPadX;
                        var gridTop = barY + 42;

                        @for (int wi = 0; wi < leafCount; wi++)
                        {
                            var leaf = leafWords[wi];
                            var col = wi % cols;
                            var row = wi / cols;
                            var wx = gridLeft + col * colW + colW / 2;
                            var wy = gridTop + row * rowH;
                            var isL = leaf.IsLearned;
                            var pillFill = isL ? "#E8F5E9" : "#FFF8E1";
                            var pillStroke = isL ? "#66BB6A" : "#FFCC80";
                            var pillTextColor = isL ? "#2E7D32" : "#6D4C41";
                            var dotColor = isL ? "#4CAF50" : "#BDBDBD";

                            <g style="cursor:default;">
                                @* Pill background *@
                                <rect x="@F(wx - colW / 2 + 5)" y="@F(wy - 12)" width="@F(colW - 10)" height="@F(Math.Min(rowH - 4, 28))"
                                      rx="@F(Math.Min(rowH - 4, 28) / 2)" fill="@pillFill" stroke="@pillStroke" stroke-width="0.7"/>
                                @* Status dot *@
                                <circle cx="@F(wx - colW / 2 + 19)" cy="@F(wy + 2)" r="3.5"
                                        fill="@dotColor"/>
                                @if (isL)
                                {
                                    <path d="M @F(wx - colW / 2 + 16.5),@F(wy + 2) l 1.8,1.8 3.2,-3.6"
                                          stroke="white" stroke-width="1.2" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
                                }
                                @* Word text *@
                                @SvgText(wx + 6, wy + 5, "middle", 11, pillTextColor,
                                    Truncate(leaf.Word, 16))
                            </g>
                        }

                        @* ── Back button ── *@
                        var btnY = cardY + cardH - 52;
                        <g style="cursor:pointer;" @onclick="ExitLeafView">
                            <rect x="@F(cx - 70)" y="@F(btnY)" width="140" height="38" rx="19"
                                  fill="#5D4037"/>
                            <rect x="@F(cx - 70)" y="@F(btnY)" width="140" height="19" rx="19"
                                  fill="white" opacity="0.06"/>
                            @SvgText(cx, btnY + 25, "middle", 14, "white", "← Назад", "600")
                        </g>
                    }
                }
            </svg>
        </div>
    </div>
}
else
{
    <div class="container text-center py-5">
        <h3>Не удалось загрузить Дерево Знаний</h3>
        <button class="btn btn-outline-primary mt-3" @onclick="LoadDataAsync">Попробовать снова</button>
    </div>
}

<style>
    /* ═══ Layout ═══ */
    .tree-layout {
        display: flex;
        height: calc(100vh - 60px);
        overflow: hidden;
        background: #1a1a2e;
    }

    /* ═══ Sidebar ═══ */
    .tree-sidebar {
        width: 280px;
        min-width: 280px;
        padding: 16px 14px;
        overflow-y: auto;
        background: linear-gradient(180deg, #1e293b 0%, #0f172a 100%);
        border-right: 1px solid rgba(255,255,255,0.06);
        display: flex;
        flex-direction: column;
        gap: 12px;
        scrollbar-width: thin;
        scrollbar-color: rgba(255,255,255,0.15) transparent;
    }

    /* Cards */
    .st-card {
        padding: 14px 16px;
        border-radius: 14px;
        background: rgba(255,255,255,0.05);
        border: 1px solid rgba(255,255,255,0.08);
        backdrop-filter: blur(10px);
    }
    .st-card-stage {
        text-align: center;
        background: linear-gradient(135deg, rgba(76,175,80,0.12) 0%, rgba(139,195,74,0.08) 100%);
        border-color: rgba(76,175,80,0.2);
    }
    .st-stage-icon { font-size: 2rem; margin-bottom: 4px; }
    .st-stage-title { font-weight: 700; font-size: 1rem; color: #e2e8f0; }
    .st-stage-level { font-size: 0.75rem; color: #94a3b8; margin-bottom: 10px; }
    .st-stage-stats {
        display: flex; align-items: center; justify-content: center;
        gap: 0; margin-bottom: 12px;
    }
    .st-mini-stat { display: flex; flex-direction: column; align-items: center; flex: 1; }
    .st-mini-val { font-weight: 700; font-size: 0.9rem; color: #f1f5f9; }
    .st-mini-label { font-size: 0.65rem; color: #64748b; text-transform: uppercase; letter-spacing: 0.5px; }
    .st-mini-divider { width: 1px; height: 28px; background: rgba(255,255,255,0.1); margin: 0 8px; }

    /* Progress bar */
    .st-progress-wrap { width: 100%; }
    .st-progress-bar {
        width: 100%; height: 6px; border-radius: 3px;
        background: rgba(255,255,255,0.08); overflow: hidden;
