    .st-progress-hint { font-size: 0.65rem; color: #64748b; margin-top: 4px; text-align: center; }

    /* Card header */
    .st-card-header {
        font-weight: 600; font-size: 0.82rem; color: #cbd5e1;
        margin-bottom: 8px; display: flex; align-items: center; gap: 6px;
    }
    .st-card-icon { font-size: 1rem; }

    /* Pour XP */
    .st-avail { font-size: 0.75rem; color: #94a3b8; margin: 0 0 8px; }
    .st-pour-row { display: flex; gap: 8px; }
    .st-pour-input {
        flex: 1; padding: 6px 10px; border-radius: 8px;
        border: 1px solid rgba(255,255,255,0.12); background: rgba(255,255,255,0.06);
        color: #e2e8f0; font-size: 0.85rem; outline: none;
        transition: border-color 0.2s;
    }
    .st-pour-input:focus { border-color: rgba(76,175,80,0.5); }
    .st-pour-btn {
        padding: 6px 14px; border-radius: 8px; border: none;
        background: linear-gradient(135deg, #2e7d32, #43a047);
        color: white; font-size: 1rem; cursor: pointer;
        transition: transform 0.15s, box-shadow 0.15s;
    }
    .st-pour-btn:hover:not(:disabled) { transform: translateY(-1px); box-shadow: 0 4px 12px rgba(76,175,80,0.3); }
    .st-pour-btn:disabled { opacity: 0.4; cursor: not-allowed; }

    /* Messages */
    .st-msg { font-size: 0.75rem; padding: 6px 10px; border-radius: 8px; margin-top: 8px; }
    .st-msg-ok { background: rgba(76,175,80,0.15); color: #81C784; border: 1px solid rgba(76,175,80,0.3); }
    .st-msg-err { background: rgba(244,67,54,0.15); color: #ef9a9a; border: 1px solid rgba(244,67,54,0.3); }

    /* Selection cards */
    .st-card-sel { border-color: rgba(255,255,255,0.12); }
    .st-sel-stats { display: flex; justify-content: space-between; font-size: 0.78rem; color: #94a3b8; margin-bottom: 8px; }
    .st-sel-prog { color: #cbd5e1; font-weight: 600; }

    /* Buttons */
    .st-btn {
        display: block; width: 100%; padding: 8px 12px; border-radius: 10px;
        font-size: 0.82rem; font-weight: 600; border: none; cursor: pointer;
        transition: all 0.2s; text-align: center;
    }
    .st-btn-primary {
        background: linear-gradient(135deg, #2e7d32, #43a047);
        color: white;
    }
    .st-btn-primary:hover { box-shadow: 0 4px 16px rgba(76,175,80,0.35); transform: translateY(-1px); }
    .st-btn-ghost {
        background: rgba(255,255,255,0.06); color: #94a3b8;
        border: 1px solid rgba(255,255,255,0.1);
    }
    .st-btn-ghost:hover { background: rgba(255,255,255,0.1); color: #e2e8f0; }
    .st-btn-outline {
        background: transparent; color: #64b5f6;
        border: 1px solid rgba(100,181,246,0.3);
    }
    .st-btn-outline:hover { background: rgba(100,181,246,0.1); }
    .st-card-actions { display: flex; flex-direction: column; gap: 8px; background: transparent; border: none; padding: 0; }
    .mt-2 { margin-top: 8px; }

    /* ═══ Canvas ═══ */
    .tree-canvas-wrap {
        flex: 1;
        position: relative;
        overflow: hidden;
        background: linear-gradient(180deg, #c8e6f0 0%, #d4e8d0 45%, #d6cbb8 80%, #c4b49a 100%);
    }

    /* Wilt banner */
    .wilt-banner {
        position: absolute;
        top: 12px;
        left: 50%;
        transform: translateX(-50%);
        z-index: 10;
        padding: 8px 20px;
        border-radius: 24px;
        background: rgba(230, 126, 34, 0.92);
        color: white;
        font-size: 0.82rem;
        font-weight: 600;
        box-shadow: 0 4px 16px rgba(230, 126, 34, 0.3);
        backdrop-filter: blur(8px);
    }

    /* ═══ Cloud Transition ═══ */
    .cloud-overlay {
        position: absolute; inset: 0; z-index: 50; pointer-events: none; display: flex;
    }
    .cloud-overlay.hidden { display: none; }
    .cloud-panel {
        width: 55%; height: 100%; position: absolute;
        background: linear-gradient(135deg, #e8f5e9 0%, white 50%, #efebe9 100%);
        opacity: 0.97;
    }
    .cloud-panel.cloud-left  { left: -55%; }
    .cloud-panel.cloud-right { right: -55%; }
    .cloud-overlay.clouds-in .cloud-left  { animation: cl-in-l 0.5s ease-out forwards; }
    .cloud-overlay.clouds-in .cloud-right { animation: cl-in-r 0.5s ease-out forwards; }
    .cloud-overlay.clouds-out .cloud-left  { animation: cl-out-l 0.5s ease-in forwards; }
    .cloud-overlay.clouds-out .cloud-right { animation: cl-out-r 0.5s ease-in forwards; }

    @@keyframes cl-in-l  { from { transform: translateX(0); } to { transform: translateX(100%); } }
    @@keyframes cl-in-r  { from { transform: translateX(0); } to { transform: translateX(-100%); } }
    @@keyframes cl-out-l { from { transform: translateX(100%); } to { transform: translateX(0); } }
    @@keyframes cl-out-r { from { transform: translateX(-100%); } to { transform: translateX(0); } }

    /* ═══ Responsive ═══ */
    @@media (max-width: 768px) {
        .tree-sidebar {
            position: fixed; left: -290px; top: 60px; bottom: 0; z-index: 40;
            transition: left 0.3s ease;
        }
        .tree-sidebar.open { left: 0; }
    }
</style>

@code {
    // ─── State ───
    private KnowledgeTreeState? Tree;
    private bool IsLoading = true;
    private bool IsAuthenticated;

    // Selection
    private TreeBranch? SelectedBranch;
    private TreeTwig? SelectedTwig;

    // Leaf view drill-down
    private bool IsLeafView;
    private TreeTwig? LeafViewTwig;

    // Pour XP
    private long PourAmount;
    private bool IsPouringXp;
    private string PourMessage = "";
    private bool PourSuccess;

    // Pan state (viewBox manipulation)
    private double VX, VY, VW, VH;
    private bool IsDragging;
    private double DragStartX, DragStartY;
    private double DragVXStart, DragVYStart;

    private DotNetObjectReference<KnowledgeTree>? _selfRef;

    protected override async Task OnInitializedAsync()
    {
        _selfRef = DotNetObjectReference.Create(this);
        await AuthService.InitializeAsync();
        var session = await AuthService.GetCurrentSessionAsync();
        IsAuthenticated = session != null;

        if (IsAuthenticated)
            await LoadDataAsync();
        else
            IsLoading = false;
    }

    private async Task LoadDataAsync()
    {
        IsLoading = true;
        StateHasChanged();
        try
        {
            Tree = await TreeService.GetTreeStateAsync();
            if (Tree != null)
                ResetViewInternal();
        }
        finally
        {
            IsLoading = false;
            StateHasChanged();
        }
    }

    // ─── Interaction ───

    private void OnBranchClick(TreeBranch branch)
    {
        SelectedBranch = branch;
        SelectedTwig = null;
        ZoomToSegment(branch.Segment, 200);
    }

    private void OnTwigClick(TreeTwig twig)
    {
        SelectedTwig = twig;
        SelectedBranch = Tree?.Branches.FirstOrDefault(b => b.Twigs.Any(t => t.Id == twig.Id));
        ZoomToSegment(twig.Segment, 120);
    }

    private async Task DrillIntoTwig(TreeTwig twig)
    {
        var allLeaves = twig.Leaves.Concat(twig.Sprigs.SelectMany(s => s.Leaves)).ToList();
        if (allLeaves.Count == 0) return;

        IsLeafView = false;
        StateHasChanged();
        await JS.InvokeVoidAsync("KnowledgeTreeInterop.playCloudTransition", "cloud-overlay", _selfRef);

        LeafViewTwig = twig;
        IsLeafView = true;
        VX = Tree!.CanvasWidth / 2 - 500;
        VY = Tree.CanvasHeight / 2 - 400;
        VW = 1000;
        VH = 800;
        StateHasChanged();
    }

    private async Task ExitLeafView()
    {
        await JS.InvokeVoidAsync("KnowledgeTreeInterop.playCloudTransition", "cloud-overlay", _selfRef);
        IsLeafView = false;
        LeafViewTwig = null;
        ResetViewInternal();
        StateHasChanged();
    }

    [JSInvokable]
    public void OnCloudsCovered()
    {
        InvokeAsync(StateHasChanged);
    }

    private void ZoomToSegment(BotanicalSegment seg, double padding)
    {
        var minX = Math.Min(seg.X1, seg.X2) - padding;
        var minY = Math.Min(seg.Y1, seg.Y2) - padding;
        var w = Math.Abs(seg.X2 - seg.X1) + padding * 2;
        var h = Math.Abs(seg.Y2 - seg.Y1) + padding * 2;
        w = Math.Max(w, 400);
        h = Math.Max(h, 300);
        VX = minX; VY = minY; VW = w; VH = h;
        StateHasChanged();
    }

    private void ResetView()
    {
        SelectedBranch = null;
        SelectedTwig = null;
        IsLeafView = false;
        LeafViewTwig = null;
        ResetViewInternal();
    }

    private void ResetViewInternal()
    {
        if (Tree == null) return;
        VX = 0; VY = 0; VW = Tree.CanvasWidth; VH = Tree.CanvasHeight;
        StateHasChanged();
    }

    // ─── Pan ───

    private void OnPointerDown(MouseEventArgs e)
    {
        IsDragging = true;
        DragStartX = e.ClientX; DragStartY = e.ClientY;
        DragVXStart = VX; DragVYStart = VY;
    }

    private void OnPointerMove(MouseEventArgs e)
    {
        if (!IsDragging) return;
        var dx = (e.ClientX - DragStartX) * (VW / 800);
        var dy = (e.ClientY - DragStartY) * (VH / 600);
        VX = DragVXStart - dx;
        VY = DragVYStart - dy;
    }

    private void OnPointerUp(MouseEventArgs e) => IsDragging = false;

    // ─── Pour XP ───

    private async Task PourXpAsync()
    {
        if (PourAmount <= 0 || Tree == null) return;
        IsPouringXp = true; PourMessage = "";
        StateHasChanged();

        try
        {
            var result = await TreeService.PourXpAsync(PourAmount);
            if (result is { Success: true })
            {
                PourSuccess = true;
                PourMessage = result.Message;
                if (result.StageChanged)
                    await JS.InvokeVoidAsync("KnowledgeTreeInterop.playCloudTransition", "cloud-overlay", _selfRef);
                await LoadDataAsync();
                PourAmount = 0;
            }
            else
            {
                PourSuccess = false;
                PourMessage = result?.Message ?? "Ошибка";
            }
        }
        finally
        {
            IsPouringXp = false;
            StateHasChanged();
        }
    }

    private void GoToTraining() => Navigation.NavigateTo("/training");

    // ─── SVG Helpers ───

    private static string F(double v) =>
        v.ToString("F1", System.Globalization.CultureInfo.InvariantCulture);
    private static string Inv(double v) =>
        v.ToString("F1", System.Globalization.CultureInfo.InvariantCulture);
    private static string Truncate(string s, int max) =>
        s.Length <= max ? s : s[..(max - 1)] + "…";

    /// <summary>Builds the trunk as a slightly curved quadratic path</summary>
    private string TrunkPath()
    {
        if (Tree == null) return "";
        var t = Tree.Trunk;
        var cpx = (t.X1 + t.X2) / 2 + 12;
        var cpy = (t.Y1 + t.Y2) / 2;
        return $"M {F(t.X1)},{F(t.Y1)} Q {F(cpx)},{F(cpy)} {F(t.X2)},{F(t.Y2)}";
    }

    /// <summary>Cubic bezier path string</summary>
    private static string BezierPath(BotanicalSegment s, double cp1x, double cp1y, double cp2x, double cp2y) =>
        $"M {F(s.X1)},{F(s.Y1)} C {F(cp1x)},{F(cp1y)} {F(cp2x)},{F(cp2y)} {F(s.X2)},{F(s.Y2)}";

    /// <summary>Approximate midpoint on a cubic bezier at t=0.5</summary>
    private static (double x, double y) BezierMid(BotanicalSegment s, double cp1x, double cp1y, double cp2x, double cp2y)
    {
        const double t = 0.5;
        var u = 1 - t;
        var x = u*u*u*s.X1 + 3*u*u*t*cp1x + 3*u*t*t*cp2x + t*t*t*s.X2;
        var y = u*u*u*s.Y1 + 3*u*u*t*cp1y + 3*u*t*t*cp2y + t*t*t*s.Y2;
        return (x, y);
    }

    private static MarkupString SvgText(double x, double y, string anchor, int fontSize,
        string? fill, string content, string? fontWeight = null)
    {
        var fillAttr = fill != null ? " fill=\"" + System.Web.HttpUtility.HtmlAttributeEncode(fill) + "\"" : "";
        var weightAttr = fontWeight != null ? " font-weight=\"" + System.Web.HttpUtility.HtmlAttributeEncode(fontWeight) + "\"" : "";
        var enc = System.Web.HttpUtility.HtmlEncode(content);
        return new MarkupString(
            "<text x=\"" + F(x) + "\" y=\"" + F(y) + "\" text-anchor=\"" + anchor
            + "\" font-size=\"" + fontSize + "\"" + fillAttr + weightAttr + ">" + enc + "</text>");
    }

    public void Dispose() => _selfRef?.Dispose();
