@page "/dictionary/{Id:int}"
@inject IContentApiService ContentApi
@inject IAuthService AuthService
@inject ILogger<LearningTrainerWeb.Components.Pages.DictionaryDetails> Logger

<PageTitle>@(Dictionary?.Name ?? "Словарь") - Ingat</PageTitle>

<div class="container">
    @if (IsLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border" style="width: 3rem; height: 3rem;" role="status">
                <span class="visually-hidden">Загрузка...</span>
            </div>
            <p class="text-muted mt-3">Загрузка словаря...</p>
        </div>
    }
    else if (Dictionary == null)
    {
        <div class="text-center py-5">
            <div style="font-size: 4rem; margin-bottom: 1rem; color: var(--gray-400);"><i class="bi bi-emoji-frown"></i></div>
            <h2>Словарь не найден</h2>
            <p class="text-muted mb-4">Возможно, он был удалён или вы перешли по неверной ссылке</p>
            <a href="dictionaries" class="btn btn-primary">
                <i class="bi bi-arrow-left me-2"></i> К списку словарей
            </a>
        </div>
    }
    else
    {
        <!-- Breadcrumb -->
        <nav aria-label="breadcrumb" class="mb-4">
            <ol class="breadcrumb" style="background: transparent; padding: 0;">
                <li class="breadcrumb-item">
                    <a href="dictionaries" style="color: var(--primary-600);">
                        <i class="bi bi-book me-1"></i> Словари
                    </a>
                </li>
                <li class="breadcrumb-item active" style="color: var(--gray-500);">@Dictionary.Name</li>
            </ol>
        </nav>

        <div class="row g-4">
            <div class="col-lg-8">
                <!-- Main Info Card -->
                <div class="card mb-4" style="border-radius: var(--radius-xl); overflow: hidden;">
                    <div style="background: linear-gradient(135deg, var(--primary-600) 0%, var(--primary-800) 100%); padding: 1.5rem; color: white;">
                        <div class="d-flex flex-column gap-3">
                            <div>
                                <h1 style="color: white; margin-bottom: 0.5rem; font-size: clamp(1.25rem, 4vw, 2rem); word-break: break-word;">@Dictionary.Name</h1>
                                <p style="opacity: 0.9; margin-bottom: 0; font-size: clamp(0.875rem, 2.5vw, 1rem);">@Dictionary.Description</p>
                            </div>
                            <button class="btn btn-light btn-lg align-self-start" style="color: var(--primary-700); font-weight: 600;" @onclick="DownloadDictionary" disabled="@IsDownloading">
                                <i class="bi bi-download me-2"></i> @(IsDownloading ? "Скачивание..." : "Скачать")
                            </button>
                        </div>
                    </div>
                    <div class="card-body">
                        <div class="d-flex flex-wrap gap-2">
                            <div class="d-flex align-items-center gap-2 px-3 py-2" style="background: var(--accent-blue-light); border-radius: var(--radius-full);">
                                <i class="bi bi-collection" style="color: var(--accent-blue);"></i>
                                <span style="font-weight: 600; color: #1e40af;">@Dictionary.WordCount слов</span>
                            </div>
                            <div class="d-flex align-items-center gap-2 px-3 py-2" style="background: var(--gray-100); border-radius: var(--radius-full);">
                                <span style="font-weight: 500;">@Dictionary.LanguageFrom</span>
                                <i class="bi bi-arrow-right" style="color: var(--gray-400);"></i>
                                <span style="font-weight: 500;">@Dictionary.LanguageTo</span>
                            </div>
                            <div class="d-flex align-items-center gap-2 px-3 py-2" style="background: var(--accent-yellow-light); border-radius: var(--radius-full);">
                                <i class="bi bi-star-fill" style="color: var(--accent-yellow);"></i>
                                <span style="font-weight: 600; color: #92400e;">@Dictionary.Rating.ToString("F1")</span>
                                <span style="color: #92400e;">(@Dictionary.RatingCount оценок)</span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Preview Words -->
                <div class="card mb-4" style="border-radius: var(--radius-lg);">
                    <div class="card-body p-4">
                        <h5 class="d-flex align-items-center gap-2 mb-4">
                            <i class="bi bi-eye" style="color: var(--primary-500);"></i>
                            Предпросмотр слов
                        </h5>
                        @if (Dictionary.PreviewWords != null && Dictionary.PreviewWords.Any())
                        {
                            <div class="word-preview-grid">
                                @{ int wordIndex = 0; }
                                @foreach (var word in Dictionary.PreviewWords)
                                {
                                    var idx = wordIndex++;
                                    <div class="word-preview-card" style="animation-delay: @(idx * 0.04)s;">
                                        <div class="word-preview-index">@(idx + 1)</div>
                                        <div class="word-preview-content">
                                            <span class="word-preview-term">@word.Term</span>
                                            <i class="bi bi-arrow-right word-preview-arrow"></i>
                                            <span class="word-preview-translation">@word.Translation</span>
                                        </div>
                                    </div>
                                }
                            </div>
                            <p class="text-muted small mb-0 mt-3">
                                <i class="bi bi-info-circle me-1"></i>
                                Показаны первые @Dictionary.PreviewWords.Count слов из @Dictionary.WordCount
                            </p>
                        }
                        else
                        {
                            <div class="text-center py-4 text-muted">
                                <i class="bi bi-eye-slash" style="font-size: 2rem;"></i>
                                <p class="mt-2 mb-0">Предпросмотр недоступен</p>
                            </div>
                        }
                    </div>
                </div>

                <!-- Comments -->
                <LearningTrainerWeb.Components.Shared.CommentsSection 
                    EntityType="dictionary" 
                    EntityId="Id" 
                    IsAuthenticated="IsAuthenticated" />
            </div>

            <!-- Sidebar -->
            <div class="col-lg-4">
                <a href="/profile/@Dictionary.AuthorId" class="text-decoration-none">
                    <div class="card author-card" style="border-radius: var(--radius-lg); position: sticky; top: 1.5rem; transition: all 0.2s ease;">
                        <div class="card-body text-center py-4">
                            <div style="width: 100px; height: 100px; background: linear-gradient(135deg, var(--primary-400), var(--primary-700)); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 1rem; color: white; font-size: 2.5rem; font-weight: 700; box-shadow: var(--shadow-colored);">
                                @(Dictionary.AuthorName?.FirstOrDefault() ?? '?')
                            </div>
                            <h4 style="margin-bottom: 0.25rem; color: var(--gray-800);">@Dictionary.AuthorName</h4>
                            <p class="text-muted small mb-3">Автор словаря</p>
                            <div class="d-inline-flex align-items-center gap-2 px-3 py-2" style="background: var(--gray-100); border-radius: var(--radius-full);">
                                <i class="bi bi-folder" style="color: var(--primary-500);"></i>
                                <span style="font-weight: 500; color: var(--gray-700);">@Dictionary.AuthorContentCount материалов</span>
                            </div>
                            <div class="mt-3">
                                <span class="text-muted small"><i class="bi bi-box-arrow-up-right me-1"></i>Открыть профиль</span>
                            </div>
                        </div>
                    </div>
                </a>
            </div>
        </div>
    }
</div>

@if (!string.IsNullOrEmpty(DownloadMessage))
{
    <div class="position-fixed bottom-0 end-0 p-3" style="z-index: 1050">
        <div class="d-flex align-items-center gap-2 px-4 py-3 text-white" 
             style="background: @(DownloadSuccess ? "var(--accent-green)" : "var(--accent-red)"); border-radius: var(--radius); box-shadow: var(--shadow-lg);">
            <i class="bi @(DownloadSuccess ? "bi-check-circle" : "bi-exclamation-circle")"></i>
            @DownloadMessage
            <button type="button" class="btn-close btn-close-white ms-2" @onclick="() => DownloadMessage = null" style="font-size: 0.75rem;"></button>
        </div>
    </div>
}

<style>
    /* Word preview grid */
    .word-preview-grid {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .word-preview-card {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 0.75rem 1rem;
        background: var(--gray-50);
        border-radius: var(--radius);
        border: 1px solid transparent;
        transition: all 0.15s ease;
        animation: wordFadeIn 0.3s ease both;
    }

    .word-preview-card:hover {
        background: var(--primary-50);
        border-color: var(--primary-200);
    }

    .word-preview-index {
        width: 28px;
        height: 28px;
        background: var(--primary-100);
        color: var(--primary-600);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.75rem;
        font-weight: 700;
        flex-shrink: 0;
    }

    .word-preview-card:hover .word-preview-index {
        background: var(--primary-500);
        color: white;
    }

    .word-preview-content {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        flex: 1;
        min-width: 0;
    }

    .word-preview-term {
        font-weight: 600;
        color: var(--gray-800);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        flex: 1;
        min-width: 0;
    }

    .word-preview-arrow {
        color: var(--gray-300);
        flex-shrink: 0;
        font-size: 0.8rem;
    }

    .word-preview-card:hover .word-preview-arrow {
        color: var(--primary-400);
    }

    .word-preview-translation {
        color: var(--gray-500);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        flex: 1;
        min-width: 0;
        text-align: right;
    }

    @@keyframes wordFadeIn {
        from {
            opacity: 0;
            transform: translateY(4px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>

@code {
    [Parameter]
    public int Id { get; set; }

    private DictionaryDetailDto? Dictionary;
    private bool IsLoading = true;
    private bool IsAuthenticated;
    private bool IsDownloading;
    private string? DownloadMessage;
    private bool DownloadSuccess;

    protected override async Task OnInitializedAsync()
    {
        await AuthService.InitializeAsync();
        var session = await AuthService.GetCurrentSessionAsync();
        IsAuthenticated = session != null;
        await LoadDictionary();
    }

    private async Task LoadDictionary()
    {
        IsLoading = true;
        try
        {
            Dictionary = await ContentApi.GetDictionaryDetailsAsync(Id);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading dictionary {Id}", Id);
        }
        finally
        {
            IsLoading = false;
        }
    }

    private async Task DownloadDictionary()
    {
        if (IsDownloading) return;

        var session = await AuthService.GetCurrentSessionAsync();
        if (session == null)
        {
            DownloadMessage = "Войдите в аккаунт для скачивания";
            DownloadSuccess = false;
            return;
        }

        IsDownloading = true;
        try
        {
            var downloadTask = ContentApi.DownloadDictionaryAsync(Id);
            var delayTask = Task.Delay(800);

            await Task.WhenAll(downloadTask, delayTask);
            DownloadMessage = "Словарь успешно скачан!";
            DownloadSuccess = true;
        }
        catch (Exception ex)
        {
            DownloadMessage = $"Ошибка: {ex.Message}";
            DownloadSuccess = false;
        }
        finally
        {
            IsDownloading = false;
        }
    }
}
