@page "/statistics"
@using LearningTrainerShared.Models.Statistics
@using LearningTrainerWeb.Services
@inject IStatisticsApiService StatsService
@inject ITrainingApiService TrainingService
@inject IGrammarApiService GrammarService
@inject IAuthService AuthService
@inject NavigationManager NavigationManager

<PageTitle>Статистика | Ingat</PageTitle>

<div class="statistics-page">
    @if (IsLoading)
    {
        <div class="loading-container">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Загрузка...</span>
            </div>
            <p class="mt-3 text-muted">Загрузка статистики...</p>
        </div>
    }
    else if (Stats != null)
    {
        <!-- Заголовок -->
        <div class="stats-header">
            <h1><i class="bi bi-graph-up me-2"></i>Статистика</h1>
            <div class="period-selector">
                <select class="form-select " @bind="SelectedPeriod" @bind:after="LoadStats">
                    <option value="week">Неделя</option>
                    <option value="month">Месяц</option>
                    <option value="3months">3 месяца</option>
                    <option value="year">Год</option>
                    <option value="all">Всё время</option>
                </select>
            </div>
        </div>

        <!-- Основные метрики -->
        <div class="stats-cards">
            <div class="stat-card stat-card-success">
                <div class="stat-icon"><i class="bi bi-book-fill"></i></div>
                <div class="stat-content">
                    <div class="stat-value">@Stats.LearnedWords</div>
                    <div class="stat-label">Изучено слов</div>
                </div>
                <div class="stat-trend trend-up">
                    <i class="bi bi-arrow-up"></i> +@Stats.WordsLearnedThisWeek за неделю
                </div>
            </div>

            <div class="stat-card stat-card-warning">
                <div class="stat-icon"><i class="bi bi-fire"></i></div>
                <div class="stat-content">
                    <div class="stat-value">@Stats.CurrentStreak</div>
                    <div class="stat-label">Дней подряд</div>
                </div>
                <div class="stat-badge">
                    <i class="bi bi-trophy-fill"></i> Лучший: @Stats.BestStreak
                </div>
            </div>

            <div class="stat-card stat-card-primary">
                <div class="stat-icon"><i class="bi bi-bullseye"></i></div>
                <div class="stat-content">
                    <div class="stat-value">@(Stats.OverallAccuracy.ToString("P0"))</div>
                    <div class="stat-label">Точность</div>
                </div>
                <div class="stat-badge">
                    <i class="bi bi-check-circle text-success me-1"></i> @Stats.TotalCorrectAnswers
                    <i class="bi bi-x-circle text-danger ms-2 me-1"></i> @Stats.TotalWrongAnswers
                </div>
            </div>

            <div class="stat-card stat-card-purple">
                <div class="stat-icon"><i class="bi bi-clock-fill"></i></div>
                <div class="stat-content">
                    <div class="stat-value">@FormatTime(Stats.TotalLearningTime)</div>
                    <div class="stat-label">Время обучения</div>
                </div>
                <div class="stat-badge">
                    @Stats.TotalSessions сессий
                </div>
            </div>

            @if (Stats.LeaderboardPosition != null)
            {
                <div class="stat-card stat-card-pink">
                    <div class="stat-icon"><i class="bi bi-trophy-fill"></i></div>
                    <div class="stat-content">
                        <div class="stat-value">#@Stats.LeaderboardPosition.GlobalRank</div>
                        <div class="stat-label">Позиция</div>
                    </div>
                    <div class="stat-badge">
                        Топ @Stats.LeaderboardPosition.Percentile.ToString("F1")%
                    </div>
                </div>
            }

            @if (Stats.TotalXp > 0)
            {
                <div class="stat-card stat-card-xp">
                    <div class="stat-icon"><i class="bi bi-star-fill"></i></div>
                    <div class="stat-content">
                        <div class="stat-value">Ур. @Stats.Level</div>
                        <div class="stat-label">@Stats.TotalXp XP</div>
                    </div>
                    <div class="stat-badge">
                        <div class="progress" style="height: 6px; width: 80px;">
                            @{
                                var xpProgress = Stats.XpForNextLevel > Stats.XpForCurrentLevel
                                    ? (double)(Stats.TotalXp - Stats.XpForCurrentLevel) / (Stats.XpForNextLevel - Stats.XpForCurrentLevel) * 100
                                    : 0;
                            }
                            <div class="progress-bar bg-warning" style="width: @xpProgress.ToString("F0")%"></div>
                        </div>
                        <small class="text-muted">@(Stats.XpForNextLevel - Stats.TotalXp) до Ур.@(Stats.Level + 1)</small>
                    </div>
                </div>
            }
        </div>

        <!-- Графики -->
        <div class="charts-grid">
            <!-- Календарь активности (GitHub-style heatmap) -->
            @if (Stats.HeatmapActivity.Any())
            {
                <div class="chart-card chart-card-wide">
                    <div class="chart-header">
                        <h3><i class="bi bi-calendar3 me-2"></i>Календарь активности</h3>
                    </div>
                    <div class="chart-body">
                        <div class="heatmap-container">
                            @{
                                var totalWeeks = 52;
                                var today = DateTime.UtcNow.Date;
                                var todayWeekDay = ((int)today.DayOfWeek + 6) % 7; // Mon=0
                                var startDate = today.AddDays(-(totalWeeks - 1) * 7 - todayWeekDay);
                                var heatmapDays = Enumerable.Range(0, totalWeeks * 7 + todayWeekDay + 1)
                                    .Select(i => startDate.AddDays(i))
                                    .Where(d => d <= today)
                                    .ToList();
                                var activityLookup = Stats.HeatmapActivity.ToDictionary(d => d.Date.Date, d => d.WordsReviewed);
                                var maxActivity = Stats.HeatmapActivity.Where(d => d.WordsReviewed > 0).Select(d => d.WordsReviewed).DefaultIfEmpty(1).Max();

                                // Group days into weeks (columns)
                                var weeks = new List<List<(DateTime date, int weekDay)>>();
                                var currentWeek = new List<(DateTime date, int weekDay)>();
                                foreach (var day in heatmapDays)
                                {
                                    var wd = ((int)day.DayOfWeek + 6) % 7;
                                    if (wd == 0 && currentWeek.Count > 0)
                                    {
                                        weeks.Add(currentWeek);
                                        currentWeek = new List<(DateTime, int)>();
                                    }
                                    currentWeek.Add((day, wd));
                                }
                                if (currentWeek.Count > 0) weeks.Add(currentWeek);

                                // Month labels: find the first week where each month starts
                                var monthLabels = new Dictionary<int, string>();
                                var monthNames = new[] { "", "Янв", "Фев", "Мар", "Апр", "Май", "Июн", "Июл", "Авг", "Сен", "Окт", "Ноя", "Дек" };
                                var lastMonth = -1;
                                for (var wi = 0; wi < weeks.Count; wi++)
                                {
                                    var firstDay = weeks[wi].First().date;
                                    if (firstDay.Month != lastMonth)
                                    {
                                        monthLabels[wi] = monthNames[firstDay.Month];
                                        lastMonth = firstDay.Month;
                                    }
                                }
                            }
                            <div class="heatmap-graph" style="grid-template-columns: 28px repeat(@weeks.Count, 1fr);">
                                <!-- Month headers -->
                                <div class="heatmap-corner"></div>
                                @for (var wi = 0; wi < weeks.Count; wi++)
                                {
                                    <div class="heatmap-month-label">
                                        @if (monthLabels.ContainsKey(wi))
                                        {
                                            @monthLabels[wi]
                                        }
                                    </div>
                                }
                                <!-- Rows = weekdays -->
                                @for (int wd = 0; wd < 7; wd++)
                                {
                                    <div class="heatmap-day-label">@(wd switch { 0 => "Пн", 1 => "", 2 => "Ср", 3 => "", 4 => "Пт", 5 => "", _ => "Вс" })</div>
                                    @for (var wi = 0; wi < weeks.Count; wi++)
                                    {
                                        var cell = weeks[wi].FirstOrDefault(d => d.weekDay == wd);
                                        if (cell.date != default)
                                        {
                                            activityLookup.TryGetValue(cell.date, out var count);
                                            var level = maxActivity > 0 ? (int)Math.Ceiling((double)count / maxActivity * 4) : 0;
                                            if (count == 0) level = 0;
                                            <div class="heatmap-cell heatmap-level-@level"
                                                 title="@cell.date.ToString("dd.MM.yyyy"): @count слов"></div>
                                        }
                                        else
                                        {
                                            <div class="heatmap-cell heatmap-empty"></div>
                                        }
                                    }
                                }
                            </div>
                            <div class="heatmap-legend">
                                <span class="text-muted small">Меньше</span>
                                <div class="heatmap-cell heatmap-level-0"></div>
                                <div class="heatmap-cell heatmap-level-1"></div>
                                <div class="heatmap-cell heatmap-level-2"></div>
                                <div class="heatmap-cell heatmap-level-3"></div>
                                <div class="heatmap-cell heatmap-level-4"></div>
                                <span class="text-muted small">Больше</span>
                            </div>
                        </div>
                    </div>
                </div>
            }

            <!-- Распределение знаний -->
            <div class="chart-card">
                <div class="chart-header">
                    <h3><i class="bi bi-pie-chart-fill me-2"></i>Уровни знаний</h3>
                </div>
                <div class="chart-body">
                    <div class="knowledge-distribution">
                        @foreach (var level in Stats.KnowledgeDistribution.Where(k => k.Count > 0))
                        {
                            <div class="knowledge-level-row">
                                <div class="level-info">
                                    <span class="level-badge" style="background: @level.Color">@level.Level</span>
                                    <span class="level-name">@level.LevelName</span>
                                </div>
                                <div class="level-bar-container">
                                    <div class="level-bar" style="width: @level.Percentage%; background: @level.Color"></div>
                                </div>
                                <span class="level-count">@level.Count</span>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- Активность по часам -->
            <div class="chart-card">
                <div class="chart-header">
                    <h3><i class="bi bi-clock me-2"></i>Активность по часам</h3>
                </div>
                <div class="chart-body">
                    <div class="hourly-heatmap">
                        @{
                            var maxHourly = Stats.HourlyActivity.Max(h => h.WordsReviewed);
                        }
                        @foreach (var hour in Stats.HourlyActivity)
                        {
                            var intensity = maxHourly > 0 ? (double)hour.WordsReviewed / maxHourly : 0;
                            var textColor = intensity > 0.5 ? "#fff" : "var(--text-muted)";
                            <div class="hour-cell" 
                                 style="background: rgba(59, 130, 246, @intensity.ToString("F2", System.Globalization.CultureInfo.InvariantCulture)); color: @textColor"
                                 title="@hour.Hour:00 - @hour.WordsReviewed слов">
                                @hour.Hour
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        @* === Аналитика (§9 LEARNING_IMPROVEMENTS) === *@

        @* §9.3 Сравнение недель *@
        @if (Stats.WeekOverWeek != null && (Stats.WeekOverWeek.CurrentWeekWords > 0 || Stats.WeekOverWeek.PreviousWeekWords > 0))
        {
            <div class="section-card week-comparison-card">
                <div class="section-header">
                    <h3><i class="bi bi-arrow-left-right me-2"></i>Эта неделя vs прошлая</h3>
                    @if (Stats.WeekOverWeek.IsImproving)
                    {
                        <span class="badge bg-success-subtle text-success"><i class="bi bi-graph-up-arrow me-1"></i>Рост</span>
                    }
                    else if (Stats.WeekOverWeek.WordsDifference < 0)
                    {
                        <span class="badge bg-danger-subtle text-danger"><i class="bi bi-graph-down-arrow me-1"></i>Спад</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary-subtle text-secondary"><i class="bi bi-dash me-1"></i>Стабильно</span>
                    }
                </div>
                <div class="week-comparison-grid">
                    <div class="week-metric">
                        <div class="week-metric-label">Слов повторено</div>
                        <div class="week-metric-values">
                            <span class="week-current">@Stats.WeekOverWeek.CurrentWeekWords</span>
                            <span class="week-vs">vs</span>
                            <span class="week-previous">@Stats.WeekOverWeek.PreviousWeekWords</span>
                        </div>
                        <div class="week-diff @(Stats.WeekOverWeek.WordsDifference >= 0 ? "positive" : "negative")">
                            @(Stats.WeekOverWeek.WordsDifference >= 0 ? "+" : "")@Stats.WeekOverWeek.WordsDifference
                            (@(Stats.WeekOverWeek.PercentChange >= 0 ? "+" : "")@Stats.WeekOverWeek.PercentChange.ToString("F0")%)
                        </div>
                    </div>
                    <div class="week-metric">
                        <div class="week-metric-label">Дней активности</div>
                        <div class="week-metric-values">
                            <span class="week-current">@Stats.WeekOverWeek.CurrentWeekDaysActive</span>
                            <span class="week-vs">vs</span>
                            <span class="week-previous">@Stats.WeekOverWeek.PreviousWeekDaysActive</span>
                        </div>
                    </div>
                    <div class="week-metric">
                        <div class="week-metric-label">Точность</div>
                        <div class="week-metric-values">
                            <span class="week-current">@Stats.WeekOverWeek.CurrentWeekAccuracy.ToString("F0")%</span>
                            <span class="week-vs">vs</span>
                            <span class="week-previous">@Stats.WeekOverWeek.PreviousWeekAccuracy.ToString("F0")%</span>
                        </div>
                    </div>
                </div>
            </div>
        }

        @* §9.2 Оптимальное время *@
        @if (Stats.OptimalTime != null)
        {
            <div class="section-card optimal-time-card">
                <div class="section-header">
                    <h3><i class="bi bi-clock-fill me-2"></i>Оптимальное время</h3>
                </div>
                <div class="optimal-time-content">
                    <div class="optimal-best">
                        <i class="bi bi-check-circle-fill text-success"></i>
                        <div>
                            <strong>Лучшее время:</strong> @Stats.OptimalTime.BestHour:00–@(Stats.OptimalTime.BestHour + 1):00
                            <div class="text-muted small">Точность @Stats.OptimalTime.BestAccuracy%</div>
                        </div>
                    </div>
                    <div class="optimal-worst">
                        <i class="bi bi-exclamation-circle-fill text-warning"></i>
                        <div>
                            <strong>Худшее время:</strong> @Stats.OptimalTime.WorstHour:00–@(Stats.OptimalTime.WorstHour + 1):00
                            <div class="text-muted small">Точность @Stats.OptimalTime.WorstAccuracy%</div>
                        </div>
                    </div>
                </div>
            </div>
        }

        @* §9.1 Прогноз завершения *@
        @if (Stats.DictionaryForecasts.Any())
        {
            <div class="section-card forecast-card">
                <div class="section-header">
                    <h3><i class="bi bi-calendar-event me-2"></i>Прогноз завершения</h3>
                </div>
                <div class="forecast-list">
                    @foreach (var forecast in Stats.DictionaryForecasts.Take(5))
                    {
                        <div class="forecast-row">
                            <div class="forecast-info">
                                <span class="forecast-name">@forecast.DictionaryName</span>
                                <span class="forecast-progress text-muted small">
                                    @forecast.LearnedWords / @forecast.TotalWords слов
                                </span>
                            </div>
                            <div class="forecast-estimate">
                                @if (forecast.EstimatedDaysToComplete.HasValue)
                                {
                                    <span class="forecast-days">
                                        @if (forecast.EstimatedDaysToComplete.Value <= 7)
                                        {
                                            <span class="text-success fw-semibold">~@forecast.EstimatedDaysToComplete дн.</span>
                                        }
                                        else if (forecast.EstimatedDaysToComplete.Value <= 30)
                                        {
                                            <span class="text-primary fw-semibold">~@forecast.EstimatedDaysToComplete дн.</span>
                                        }
                                        else
                                        {
                                            <span class="text-warning fw-semibold">~@forecast.EstimatedDaysToComplete дн.</span>
                                        }
                                    </span>
                                }
                                else
                                {
                                    <span class="text-muted small">Нет данных о темпе</span>
                                }
                            </div>
                        </div>
                    }
                    @if (Stats.DictionaryForecasts.All(f => f.WordsPerDay > 0))
                    {
                        <div class="forecast-note text-muted small mt-2">
                            <i class="bi bi-info-circle me-1"></i>
                            Темп: ~@Stats.DictionaryForecasts.First().WordsPerDay слов/день (на основе последней недели)
                        </div>
                    }
                </div>
            </div>
        }

        <!-- Прогресс по словарям -->
        @if (Stats.DictionaryStatistics.Any())
        {
            <div class="section-card">
                <div class="section-header" >
                    <h3><i class="bi bi-collection me-2"></i>Прогресс по словарям</h3>
                </div>
                <div class="dictionaries-progress">
                    @foreach (var dict in Stats.DictionaryStatistics.Take(10))
                    {
                        <div class="dictionary-row">
                            <div class="dictionary-info">
                                <span class="dictionary-name">@dict.DictionaryName</span>
                                <span class="dictionary-stats">
                                    @dict.LearnedWords / @dict.TotalWords слов
                                </span>
                            </div>
                            <div class="progress-bar-container">
                                <div class="progress">
                                    <div class="progress-bar bg-success" 
                                         style="width: @dict.CompletionPercent%">
                                    </div>
                                </div>
                                <span class="progress-percent">@dict.CompletionPercent.ToString("F0")%</span>
                            </div>
                            <div class="dictionary-accuracy">
                                <i class="bi bi-bullseye"></i>
                                @dict.Accuracy.ToString("P0")
                            </div>
                            @if (dict.RetentionRate.HasValue)
                            {
                                <div class="dictionary-retention" title="Retention rate: доля запомненных слов спустя 30+ дней">
                                    <i class="bi bi-memory"></i>
                                    <span class="@(dict.RetentionRate >= 80 ? "text-success" : dict.RetentionRate >= 60 ? "text-warning" : "text-danger")">
                                        @dict.RetentionRate.Value.ToString("F0")%
                                    </span>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        }

        <!-- §19.3 Расписание повторений -->
        @if (ReviewForecast != null && ReviewForecast.Any())
        {
            <div class="section-card">
                <div class="section-header">
                    <h3><i class="bi bi-calendar-week me-2"></i>Расписание повторений</h3>
                </div>
                <div class="review-forecast">
                    @{
                        int maxCount = ReviewForecast.Max(f => f.Count);
                        maxCount = maxCount > 0 ? maxCount : 1;
                    }
                    @foreach (var day in ReviewForecast)
                    {
                        var pct = (double)day.Count / maxCount * 100;
                        var isToday = day.Date.Date == DateTime.UtcNow.Date;
                        <div class="forecast-row @(isToday ? "forecast-today" : "")">
                            <span class="forecast-label">
                                @if (isToday)
                                {
                                    <strong>Сегодня</strong>
                                }
                                else if (day.Date.Date == DateTime.UtcNow.Date.AddDays(1))
                                {
                                    <span>Завтра</span>
                                }
                                else
                                {
                                    <span>@day.Date.ToString("ddd dd.MM")</span>
                                }
                            </span>
                            <div class="forecast-bar-track">
                                <div class="forecast-bar-fill @(isToday ? "forecast-bar-today" : "")" style="width: @pct.ToString("F0")%"></div>
                            </div>
                            <span class="forecast-count @(isToday ? "fw-bold" : "")">@day.Count</span>
                        </div>
                    }
                    @if (ReviewForecast.Count > 1)
                    {
                        var total = ReviewForecast.Sum(f => f.Count);
                        var avg = total / ReviewForecast.Count;
                        <div class="forecast-tip">
                            <i class="bi bi-lightbulb me-1"></i>
                            Всего @total слов за @ReviewForecast.Count дн. (≈@avg/день)
                        </div>
                    }
                </div>
            </div>
        }

        <!-- Сложные слова -->
        @if (Stats.DifficultWords.Any())
        {
            <div class="section-card">
                <div class="section-header">
                    <h3><i class="bi bi-exclamation-triangle-fill me-2 text-warning"></i>Сложные слова</h3>
                    <button class="btn btn-primary btn-sm" @onclick="PracticeDifficultWords">
                        <i class="bi bi-play-circle me-1"></i>Тренировать
                    </button>
                </div>
                <div class="difficult-words-list">
                    @foreach (var word in Stats.DifficultWords.Take(10))
                    {
                        <div class="difficult-word-row">
                            <div class="word-main">
                                <span class="word-original">@word.OriginalWord</span>
                                <span class="word-translation">@word.Translation</span>
                            </div>
                            <div class="word-stats">
                                <span class="word-dictionary">@word.DictionaryName</span>
                                <span class="word-error-rate text-danger">
                                    <i class="bi bi-x-circle me-1"></i>@word.ErrorRate.ToString("P0") ошибок
                                </span>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }

        <!-- Грамматика (§17.7 LEARNING_IMPROVEMENTS) -->
        @if (GrammarSummary != null && GrammarSummary.TotalRules > 0)
        {
            <div class="section-card">
                <div class="section-header">
                    <h3><i class="bi bi-book-half me-2"></i>Грамматика</h3>
                    <a href="/grammar" class="btn btn-outline-primary btn-sm">
                        <i class="bi bi-arrow-right me-1"></i>Перейти
                    </a>
                </div>
                <div class="stats-cards" style="margin-top: 1rem;">
                    <div class="stat-card stat-card-primary">
                        <div class="stat-icon"><i class="bi bi-book"></i></div>
                        <div class="stat-content">
                            <div class="stat-value">@GrammarSummary.MasteredRules / @GrammarSummary.TotalRules</div>
                            <div class="stat-label">Правил освоено</div>
                        </div>
                    </div>
                    <div class="stat-card stat-card-success">
                        <div class="stat-icon"><i class="bi bi-bullseye"></i></div>
                        <div class="stat-content">
                            <div class="stat-value">@GrammarSummary.OverallAccuracy%</div>
                            <div class="stat-label">Точность</div>
                        </div>
                    </div>
                    <div class="stat-card stat-card-info">
                        <div class="stat-icon"><i class="bi bi-journal-check"></i></div>
                        <div class="stat-content">
                            <div class="stat-value">@GrammarSummary.TotalSessions</div>
                            <div class="stat-label">Сессий</div>
                        </div>
                    </div>
                    <div class="stat-card stat-card-warning">
                        <div class="stat-icon"><i class="bi bi-clock-history"></i></div>
                        <div class="stat-content">
                            <div class="stat-value">@GrammarSummary.DueForReview</div>
                            <div class="stat-label">К повторению</div>
                        </div>
                    </div>
                </div>
                @if (GrammarSummary.TotalRules > 0)
                {
                    <div class="progress mt-3" style="height: 20px; border-radius: 10px;">
                        @{
                            double gmPct = GrammarSummary.TotalRules > 0
                                ? (double)GrammarSummary.MasteredRules / GrammarSummary.TotalRules * 100 : 0;
                            double gipPct = GrammarSummary.TotalRules > 0
                                ? (double)GrammarSummary.InProgressRules / GrammarSummary.TotalRules * 100 : 0;
                        }
                        <div class="progress-bar bg-success" style="width: @gmPct.ToString("F0", System.Globalization.CultureInfo.InvariantCulture)%"
                             title="Освоено: @GrammarSummary.MasteredRules">
                            @if (gmPct > 15)
                            {
                                <span>✅ @GrammarSummary.MasteredRules</span>
                            }
                        </div>
                        <div class="progress-bar bg-warning" style="width: @gipPct.ToString("F0", System.Globalization.CultureInfo.InvariantCulture)%"
                             title="В процессе: @GrammarSummary.InProgressRules">
                            @if (gipPct > 15)
                            {
                                <span>🔄 @GrammarSummary.InProgressRules</span>
                            }
                        </div>
                    </div>
                }
            </div>
        }

        <!-- Достижения -->
        <div class="section-card">
            <div class="ach-header">
                <div class="ach-header-left">
                    <h3><i class="bi bi-award-fill me-2"></i>Достижения</h3>
                    <div class="ach-counter">
                        <div class="ach-counter-bar">
                            <div class="ach-counter-fill" style="width: @(Stats.Achievements.Count > 0 ? Stats.Achievements.Count(a => a.IsUnlocked) * 100 / Stats.Achievements.Count : 0)%"></div>
                        </div>
                        <span class="ach-counter-text">@Stats.Achievements.Count(a => a.IsUnlocked) из @Stats.Achievements.Count</span>
                    </div>
                </div>
                <div class="ach-filter-tabs">
                    <button class="ach-tab @(_achFilter == null ? "active" : "")" @onclick="() => _achFilter = null">Все</button>
                    <button class="ach-tab @(_achFilter == AchievementCategory.Learning ? "active" : "")" @onclick='() => _achFilter = AchievementCategory.Learning'>📚 Обучение</button>
                    <button class="ach-tab @(_achFilter == AchievementCategory.Consistency ? "active" : "")" @onclick='() => _achFilter = AchievementCategory.Consistency'>🔥 Серии</button>
                    <button class="ach-tab @(_achFilter == AchievementCategory.Accuracy ? "active" : "")" @onclick='() => _achFilter = AchievementCategory.Accuracy'>🎯 Точность</button>
                    <button class="ach-tab @(_achFilter == AchievementCategory.Speed ? "active" : "")" @onclick='() => _achFilter = AchievementCategory.Speed'>⚡ Скорость</button>
                    <button class="ach-tab @(_achFilter == AchievementCategory.Explorer ? "active" : "")" @onclick='() => _achFilter = AchievementCategory.Explorer'>🗺️ Исследование</button>
                    <button class="ach-tab @(_achFilter == AchievementCategory.Social ? "active" : "")" @onclick='() => _achFilter = AchievementCategory.Social'>🤝 Социальное</button>
                </div>
            </div>
            <div class="ach-grid">
                @foreach (var ach in Stats.Achievements
                    .Where(a => _achFilter == null || a.Category == _achFilter)
                    .OrderByDescending(a => a.IsUnlocked)
                    .ThenByDescending(a => a.Rarity)
                    .ThenBy(a => a.Title))
                {
                    var rarityClass = ach.Rarity.ToString().ToLower();
                    var stateClass = ach.IsUnlocked ? "ach-unlocked" : "ach-locked";
                    <div class="ach-card @stateClass ach-@rarityClass" title="@ach.Description">
                        <div class="ach-badge">
                            <svg class="ach-ring" viewBox="0 0 36 36">
                                <circle class="ach-ring-bg" cx="18" cy="18" r="16" />
                                @if (!ach.IsUnlocked && ach.Progress > 0)
                                {
                                    <circle class="ach-ring-fg" cx="18" cy="18" r="16"
                                            stroke-dasharray="@(ach.Progress.ToString("F1", System.Globalization.CultureInfo.InvariantCulture)) 100"
                                            transform="rotate(-90 18 18)" />
                                }
                                else if (ach.IsUnlocked)
                                {
                                    <circle class="ach-ring-fg ach-ring-full" cx="18" cy="18" r="16"
                                            stroke-dasharray="100 100"
                                            transform="rotate(-90 18 18)" />
                                }
                            </svg>
                            <span class="ach-emoji">@ach.Icon</span>
                            @if (ach.IsUnlocked)
                            {
                                <span class="ach-checkmark"><i class="bi bi-check-circle-fill"></i></span>
                            }
                        </div>
                        <div class="ach-name">@ach.Title</div>
                        <div class="ach-rarity-tag">@GetRarityLabel(ach.Rarity)</div>
                        @if (!ach.IsUnlocked && ach.TargetValue.HasValue && ach.TargetValue > 0)
                        {
                            <div class="ach-progress-text">@ach.CurrentValue / @ach.TargetValue</div>
                        }
                        @if (ach.IsUnlocked && ach.UnlockedAt.HasValue)
                        {
                            <div class="ach-date">@ach.UnlockedAt.Value.ToString("dd.MM.yy")</div>
                        }
                    </div>
                }
            </div>
        </div>
    }
    else if (!IsAuthenticated)
    {
        <div class="text-center py-5">
            <div style="font-size: 4rem; margin-bottom: 1rem; color: var(--primary-400);"><i class="bi bi-lock"></i></div>
            <h2>Требуется авторизация</h2>
            <p class="text-muted mb-4">Войдите в аккаунт, чтобы увидеть статистику обучения</p>
            <a href="login" class="btn btn-primary btn-lg">
                <i class="bi bi-box-arrow-in-right me-2"></i> Войти
            </a>
        </div>
    }
    else if (Stats == null)
    {
        <div class="empty-state">
            <i class="bi bi-bar-chart-line display-1 text-muted"></i>
            <h3 class="mt-3">Нет данных</h3>
            <p class="text-muted">Начните изучать слова, чтобы увидеть статистику</p>
            <a href="/training" class="btn btn-primary">
                <i class="bi bi-play-circle me-2"></i>Начать тренировку
            </a>
        </div>
    }
</div>

@code {
    private UserStatistics? Stats;
    private GrammarProgressSummaryDto? GrammarSummary;
    private List<ReviewForecastDay>? ReviewForecast;
    private bool IsLoading = true;
    private bool IsAuthenticated;
    private string SelectedPeriod = "week";
    private AchievementCategory? _achFilter;

    private static string GetRarityLabel(AchievementRarity rarity) => rarity switch
    {
        AchievementRarity.Common => "Обычное",
        AchievementRarity.Uncommon => "Необычное",
        AchievementRarity.Rare => "Редкое",
        AchievementRarity.Epic => "Эпическое",
        AchievementRarity.Legendary => "Легендарное",
        _ => ""
    };

    protected override async Task OnInitializedAsync()
    {
        await AuthService.InitializeAsync();
        var session = await AuthService.GetCurrentSessionAsync();
        IsAuthenticated = session != null;

        if (IsAuthenticated)
        {
            await LoadStats();
        }
        else
        {
            IsLoading = false;
        }
    }

    private async Task LoadStats()
    {
        IsLoading = true;
        StateHasChanged();

        try
        {
            var statsTask = StatsService.GetStatisticsAsync(SelectedPeriod);
            var grammarTask = GrammarService.GetProgressSummaryAsync();
            var forecastTask = TrainingService.GetReviewForecastAsync(7);
            await Task.WhenAll(statsTask, grammarTask, forecastTask);
            Stats = statsTask.Result;
            GrammarSummary = grammarTask.Result;
            ReviewForecast = forecastTask.Result;
        }
        finally
        {
            IsLoading = false;
            StateHasChanged();
        }
    }

    private void PracticeDifficultWords()
    {
        NavigationManager.NavigateTo("/training?mode=difficult");
    }

    private static string FormatTime(TimeSpan time)
    {
        if (time.TotalHours >= 1)
            return $"{time.TotalHours:F1}ч";
        if (time.TotalMinutes >= 1)
            return $"{time.TotalMinutes:F0}м";
        return "< 1м";
    }
}
