@page "/classroom"
@inject IClassroomApiService ClassroomApi
@inject IAuthService AuthService
@inject IJSRuntime JS
@rendermode InteractiveServer

<PageTitle>Класс - Ingat</PageTitle>

<div class="container py-4">
    @if (IsLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border" style="width: 3rem; height: 3rem;" role="status">
                <span class="visually-hidden">Загрузка...</span>
            </div>
            <p class="text-muted mt-3">Загрузка...</p>
        </div>
    }
    else if (!IsAuthenticated)
    {
        <div class="text-center py-5">
            <div style="font-size: 4rem; margin-bottom: 1rem; color: var(--primary-400);"><i class="bi bi-lock"></i></div>
            <h2>Требуется авторизация</h2>
            <p class="text-muted mb-4">Войдите, чтобы использовать систему классов</p>
            <a href="login" class="btn btn-primary btn-lg">
                <i class="bi bi-box-arrow-in-right me-2"></i> Войти
            </a>
        </div>
    }
    else
    {
        <div class="section-heading mb-4">
            <i class="bi bi-people-fill"></i>
            <h1 style="margin-bottom: 0;">Класс</h1>
        </div>

        @* === TEACHER VIEW === *@
        @if (UserRole == "Teacher")
        {
            <!-- Invite Code -->
            <div class="card mb-4" style="border-radius: var(--radius-lg);">
                <div class="card-body p-4">
                    <h5 class="d-flex align-items-center gap-2 mb-3">
                        <i class="bi bi-link-45deg" style="color: var(--primary-500);"></i>
                        Код приглашения
                    </h5>
                    <p class="text-muted small mb-3">Отправьте этот код ученикам, чтобы они присоединились к вашему классу</p>
                    <div class="d-flex align-items-center gap-3">
                        <div class="invite-code-display">
                            <code>@InviteCode</code>
                        </div>
                        <button class="btn btn-outline-primary btn-sm" @onclick="CopyInviteCode" title="Копировать">
                            <i class="bi @(CodeCopied ? "bi-check-lg text-success" : "bi-clipboard")"></i>
                            @(CodeCopied ? "Скопировано" : "Копировать")
                        </button>
                    </div>
                </div>
            </div>

            <!-- Students List -->
            <div class="card mb-4" style="border-radius: var(--radius-lg);">
                <div class="card-body p-4">
                    <h5 class="d-flex align-items-center gap-2 mb-3">
                        <i class="bi bi-mortarboard" style="color: var(--accent-purple);"></i>
                        Мои ученики
                        @if (Students.Any())
                        {
                            <span class="badge bg-secondary bg-opacity-10 text-secondary" style="font-size: 0.75rem;">@Students.Count</span>
                        }
                    </h5>

                    @if (Students.Any())
                    {
                        <div class="student-list">
                            @foreach (var student in Students)
                            {
                                var activityClass = student.DaysSinceLastPractice switch
                                {
                                    0 => "activity-active",
                                    >= 1 and <= 3 => "activity-recent",
                                    _ => "activity-inactive"
                                };
                                <div class="student-row">
                                    <a href="/profile/@student.Id" class="d-flex align-items-center gap-3 flex-grow-1 text-decoration-none" style="min-width: 0;">
                                        <div class="student-avatar @activityClass">
                                            @(student.Username.FirstOrDefault())
                                        </div>
                                        <div class="student-info">
                                            <div class="student-name">@student.Username</div>
                                            <div class="student-meta">
                                                <span><i class="bi bi-book me-1"></i>@student.WordsLearned / @student.TotalWords слов</span>
                                                @if (student.CurrentStreak > 0)
                                                {
                                                    <span class="ms-2"><i class="bi bi-fire me-1" style="color: var(--accent-orange, #f59e0b);"></i>@student.CurrentStreak дн.</span>
                                                }
                                                @if (student.TotalAttempts > 0)
                                                {
                                                    <span class="ms-2"><i class="bi bi-bullseye me-1"></i>@student.AccuracyPercent.ToString("F0")%</span>
                                                }
                                            </div>
                                            <div class="student-shared-info">
                                                @if (student.SharedDictionariesCount > 0 || student.SharedRulesCount > 0)
                                                {
                                                    <span class="text-muted" style="font-size: 0.7rem;">
                                                        Расшарено: @student.SharedDictionariesCount сл. · @student.SharedRulesCount пр.
                                                    </span>
                                                }
                                                @if (student.DaysSinceLastPractice >= 0)
                                                {
                                                    <span class="@(student.DaysSinceLastPractice == 0 ? "text-success" : student.DaysSinceLastPractice <= 3 ? "text-warning" : "text-danger")"
                                                          style="font-size: 0.7rem;">
                                                        @(student.DaysSinceLastPractice == 0 ? "Сегодня" : student.DaysSinceLastPractice == 1 ? "Вчера" : $"{student.DaysSinceLastPractice} дн. назад")
                                                    </span>
                                                }
                                            </div>
                                        </div>
                                    </a>
                                    @if (KickConfirmStudentId == student.Id)
                                    {
                                        <div class="d-flex align-items-center gap-1 flex-shrink-0">
                                            <button class="btn btn-sm px-2 py-1" style="background: var(--gray-100); font-size: 0.75rem;"
                                                    @onclick="() => KickConfirmStudentId = null">
                                                Нет
                                            </button>
                                            <button class="btn btn-sm px-2 py-1" style="background: var(--accent-red); color: white; font-size: 0.75rem;"
                                                    @onclick="() => KickStudent(student.Id)" disabled="@IsKicking">
                                                Удалить
                                            </button>
                                        </div>
                                    }
                                    else
                                    {
                                        <button class="btn btn-sm px-2 py-1 flex-shrink-0" style="background: transparent; color: var(--gray-400);"
                                                @onclick="() => KickConfirmStudentId = student.Id"
                                                title="Удалить ученика из класса">
                                            <i class="bi bi-x-lg"></i>
                                        </button>
                                    }
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-4 text-muted">
                            <i class="bi bi-people" style="font-size: 2.5rem; opacity: 0.4;"></i>
                            <p class="mt-2 mb-0">У вас пока нет учеников</p>
                            <p class="small">Отправьте код приглашения, чтобы ученики присоединились</p>
                        </div>
                    }
                </div>
            </div>
        }

        @* === STUDENT VIEW === *@
        @if (UserRole == "Student")
        {
            <div class="card mb-4" style="border-radius: var(--radius-lg);">
                <div class="card-body p-4">
                    <div class="text-center mb-3">
                        <i class="bi bi-mortarboard" style="font-size: 2.5rem; color: var(--primary-500);"></i>
                        <h5 class="mt-3">Вы ученик</h5>
                    </div>
                    @if (!string.IsNullOrEmpty(TeacherName))
                    {
                        <div class="d-flex align-items-center justify-content-center gap-2 mb-3">
                            <span class="text-muted">Учитель:</span>
                            <a href="/profile/@TeacherId" class="fw-semibold text-decoration-none">@TeacherName</a>
                        </div>
                    }
                    <p class="text-muted text-center mb-4">Словари и правила, которыми поделился ваш учитель, появятся в разделе «Мой контент»</p>

                    <div class="text-center">
                        @if (ShowLeaveConfirm)
                        {
                            <div class="leave-confirm-card">
                                <div class="leave-confirm-accent"></div>
                                <div class="leave-confirm-content">
                                    <div class="leave-confirm-header">
                                        <i class="bi bi-exclamation-triangle-fill" style="color: var(--accent-red); font-size: 1.1rem;"></i>
                                        <span class="leave-confirm-title">Выход из класса</span>
                                    </div>
                                    <p class="leave-confirm-text">Вы уверены? Вы потеряете доступ к словарям и правилам учителя.</p>
                                    <div class="leave-confirm-actions">
                                        <button class="leave-btn leave-btn-cancel"
                                                @onclick="() => ShowLeaveConfirm = false">
                                            Отмена
                                        </button>
                                        <button class="leave-btn leave-btn-danger"
                                                @onclick="LeaveClass" disabled="@IsLeaving">
                                            @if (IsLeaving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                            Выйти из класса
                                        </button>
                                    </div>
                                </div>
                            </div>
                        }
                        else
                        {
                            <button class="btn btn-outline-danger btn-sm" @onclick="() => ShowLeaveConfirm = true">
                                <i class="bi bi-box-arrow-left me-1"></i> Покинуть класс
                            </button>
                        }
                    </div>
                </div>
            </div>
        }

        @* === REGULAR USER VIEW: become teacher or join class === *@
        @if (UserRole != "Teacher" && UserRole != "Student")
        {
            <div class="row g-4">
                <!-- Become Teacher -->
                <div class="col-md-6">
                    <div class="card h-100" style="border-radius: var(--radius-lg);">
                        <div class="card-body p-4 text-center">
                            <div style="font-size: 3rem; margin-bottom: 1rem;">👨‍🏫</div>
                            <h5>Стать учителем</h5>
                            <p class="text-muted small mb-3">Создавайте классы, приглашайте учеников и делитесь своими словарями и правилами</p>
                            <button class="btn btn-primary" @onclick="UpgradeToTeacher" disabled="@IsUpgrading">
                                @if (IsUpgrading)
                                {
                                    <span class="spinner-border spinner-border-sm me-1"></span>
                                }
                                <i class="bi bi-arrow-up-circle me-1"></i> Стать учителем
                            </button>
                        </div>
                    </div>
                </div>

                <!-- Join Class -->
                <div class="col-md-6">
                    <div class="card h-100" style="border-radius: var(--radius-lg);">
                        <div class="card-body p-4 text-center">
                            <div style="font-size: 3rem; margin-bottom: 1rem;">🎓</div>
                            <h5>Присоединиться к классу</h5>
                            <p class="text-muted small mb-3">Введите код приглашения от учителя, чтобы получить доступ к учебным материалам</p>
                            <div class="d-flex gap-2 justify-content-center">
                                <input type="text" class="form-control" style="max-width: 200px;"
                                       placeholder="TR-xxxxxx" @bind="JoinCode" @bind:event="oninput" />
                                <button class="btn btn-success" @onclick="JoinClass"
                                        disabled="@(IsJoining || string.IsNullOrWhiteSpace(JoinCode))">
                                    @if (IsJoining)
                                    {
                                        <span class="spinner-border spinner-border-sm me-1"></span>
                                    }
                                    <i class="bi bi-box-arrow-in-right me-1"></i> Войти
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }

        @* === JOIN CLASS (also for students who want to join another — future) === *@
        @if (UserRole == "Teacher")
        {
            <!-- Teachers can also see the join section collapsed -->
        }

        @* === Toast notification === *@
        <LearningTrainerWeb.Components.Shared.AppToast
            Message="@ToastMessage"
            IsSuccess="@ToastSuccess"
            OnDismiss="() => ToastMessage = null" />
    }
</div>

<style>
    .invite-code-display {
        background: var(--gray-100);
        border: 2px dashed var(--gray-300);
        border-radius: var(--radius);
        padding: 0.75rem 1.25rem;
        font-size: 1.25rem;
        font-weight: 600;
        letter-spacing: 0.05em;
        color: var(--primary-600);
        user-select: all;
    }

    .student-list {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .student-row {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 0.75rem 1rem;
        background: var(--gray-50);
        border-radius: var(--radius);
        border: 1px solid transparent;
        transition: all 0.15s ease;
    }

    .student-row:hover {
        background: var(--primary-50);
        border-color: var(--primary-200);
    }

    .student-avatar {
        width: 40px;
        height: 40px;
        background: linear-gradient(135deg, var(--primary-400), var(--accent-purple));
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-weight: 700;
        font-size: 1rem;
        flex-shrink: 0;
    }

    .student-info {
        flex: 1;
        min-width: 0;
    }

    .student-name {
        font-weight: 600;
        color: var(--gray-800);
    }

    .student-meta {
        font-size: 0.8rem;
        color: var(--gray-500);
    }

    .student-shared-info {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        margin-top: 2px;
    }

    .student-avatar.activity-active {
        box-shadow: 0 0 0 3px rgba(16, 185, 129, 0.4);
    }

    .student-avatar.activity-recent {
        box-shadow: 0 0 0 3px rgba(245, 158, 11, 0.35);
    }

    .student-avatar.activity-inactive {
        box-shadow: 0 0 0 3px rgba(239, 68, 68, 0.3);
        opacity: 0.8;
    }

    @@media (max-width: 575px) {
        .invite-code-display {
            font-size: 1rem;
            padding: 0.5rem 1rem;
        }
    }

    /* Leave-class confirmation card */
    .leave-confirm-card {
        display: inline-flex;
        max-width: 400px;
        background: white;
        border-radius: var(--radius-lg);
        box-shadow: var(--shadow-xl), 0 0 0 1px rgb(0 0 0 / 0.04);
        overflow: hidden;
        text-align: left;
    }

    .leave-confirm-accent {
        width: 4px;
        flex-shrink: 0;
        background: linear-gradient(180deg, var(--accent-red), #dc2626);
    }

    .leave-confirm-content {
        flex: 1;
        padding: 1.25rem 1.5rem;
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
    }

    .leave-confirm-header {
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .leave-confirm-title {
        font-weight: 600;
        font-size: 0.9rem;
        color: var(--gray-800);
    }

    .leave-confirm-text {
        margin: 0;
        font-size: 0.875rem;
        color: var(--gray-600);
        line-height: 1.5;
    }

    .leave-confirm-actions {
        display: flex;
        gap: 0.5rem;
        justify-content: flex-end;
        padding-top: 0.25rem;
    }

    .leave-btn {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        padding: 0.5rem 1.1rem;
        border: none;
        border-radius: var(--radius);
        font-size: 0.825rem;
        font-weight: 600;
        cursor: pointer;
        transition: all var(--transition-fast);
    }

    .leave-btn-cancel {
        background: var(--gray-100);
        color: var(--gray-700);
    }

    .leave-btn-cancel:hover {
        background: var(--gray-200);
    }

    .leave-btn-danger {
        background: var(--accent-red);
        color: white;
        box-shadow: 0 2px 8px rgb(239 68 68 / 0.3);
    }

    .leave-btn-danger:hover {
        background: #dc2626;
        transform: translateY(-1px);
        box-shadow: 0 4px 12px rgb(239 68 68 / 0.4);
    }

    .leave-btn-danger:active {
        transform: translateY(0);
    }

    @@media (max-width: 480px) {
        .leave-confirm-card {
            max-width: 100%;
        }
    }
</style>

@code {
    private bool IsLoading = true;
    private bool IsAuthenticated;
    private string UserRole = "";
    private string InviteCode = "";
    private List<StudentInfo> Students = new();
    private bool CodeCopied;

    // Join class
    private string JoinCode = "";
    private bool IsJoining;

    // Upgrade
    private bool IsUpgrading;

    // Leave class
    private bool ShowLeaveConfirm;
    private bool IsLeaving;

    // Kick student
    private int? KickConfirmStudentId;
    private bool IsKicking;

    // Student view: teacher info
    private string? TeacherName;
    private int? TeacherId;

    // Toast
    private string? ToastMessage;
    private bool ToastSuccess;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var session = await AuthService.GetCurrentSessionAsync();
            IsAuthenticated = session != null;
            UserRole = session?.Role ?? "";

            if (IsAuthenticated && UserRole == "Teacher")
            {
                await LoadTeacherData();
            }
            else if (IsAuthenticated && UserRole == "Student")
            {
                await LoadStudentData();
            }
        }
        catch
        {
            IsAuthenticated = false;
        }
        finally
        {
            IsLoading = false;
        }
    }

    private async Task LoadTeacherData()
    {
        try
        {
            InviteCode = await ClassroomApi.GetMyInviteCodeAsync();
            Students = await ClassroomApi.GetMyStudentsAsync();
        }
        catch (Exception ex)
        {
            ShowToast($"Ошибка загрузки: {ex.Message}", false);
        }
    }

    private async Task LoadStudentData()
    {
        try
        {
            var teacher = await ClassroomApi.GetMyTeacherAsync();
            TeacherName = teacher.TeacherName;
            TeacherId = teacher.TeacherId;
        }
        catch { }
    }

    private async Task CopyInviteCode()
    {
        try
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", InviteCode);
            CodeCopied = true;
            StateHasChanged();
            await Task.Delay(2000);
            CodeCopied = false;
        }
        catch { }
    }

    private async Task UpgradeToTeacher()
    {
        IsUpgrading = true;
        try
        {
            var result = await ClassroomApi.UpgradeToTeacherAsync();
            if (result.Success)
            {
                if (!string.IsNullOrEmpty(result.AccessToken))
                {
                    await AuthService.UpdateSessionAsync(result.AccessToken, result.UserRole);
                }
                UserRole = result.UserRole;
                ShowToast("Вы стали учителем!", true);
                await LoadTeacherData();
            }
            else
            {
                ShowToast(result.Message, false);
            }
        }
        catch (Exception ex)
        {
            ShowToast($"Ошибка: {ex.Message}", false);
        }
        finally
        {
            IsUpgrading = false;
        }
    }

    private async Task JoinClass()
    {
        if (string.IsNullOrWhiteSpace(JoinCode)) return;
        IsJoining = true;
        try
        {
            var result = await ClassroomApi.JoinClassAsync(JoinCode.Trim());
            if (result.Success)
            {
                if (!string.IsNullOrEmpty(result.AccessToken))
                {
                    await AuthService.UpdateSessionAsync(result.AccessToken, result.UserRole);
                }
                UserRole = result.UserRole;
                JoinCode = "";
                ShowToast(result.Message, true);
                await LoadStudentData();
            }
            else
            {
                ShowToast(result.Message, false);
            }
        }
        catch (Exception ex)
        {
            ShowToast($"Ошибка: {ex.Message}", false);
        }
        finally
        {
            IsJoining = false;
        }
    }

    private async Task LeaveClass()
    {
        IsLeaving = true;
        try
        {
            var result = await ClassroomApi.LeaveClassAsync();
            if (result.Success)
            {
                if (!string.IsNullOrEmpty(result.AccessToken))
                {
                    await AuthService.UpdateSessionAsync(result.AccessToken, result.UserRole);
                }
                UserRole = result.UserRole;
                TeacherName = null;
                TeacherId = null;
                ShowLeaveConfirm = false;
                ShowToast(result.Message, true);
            }
            else
            {
                ShowToast(result.Message, false);
            }
        }
        catch (Exception ex)
        {
            ShowToast($"Ошибка: {ex.Message}", false);
        }
        finally
        {
            IsLeaving = false;
        }
    }

    private async Task KickStudent(int studentId)
    {
        IsKicking = true;
        try
        {
            var result = await ClassroomApi.KickStudentAsync(studentId);
            if (result.Success)
            {
                Students.RemoveAll(s => s.Id == studentId);
                KickConfirmStudentId = null;
                ShowToast(result.Message, true);
            }
            else
            {
                ShowToast(result.Message, false);
            }
        }
        catch (Exception ex)
        {
            ShowToast($"Ошибка: {ex.Message}", false);
        }
        finally
        {
            IsKicking = false;
        }
    }

    [Inject] private NavigationManager Navigation { get; set; } = default!;

    private void ShowToast(string message, bool success)
    {
        ToastMessage = message;
        ToastSuccess = success;
        _ = DismissToastAfterDelay();
    }

    private async Task DismissToastAfterDelay()
    {
        await Task.Delay(4000);
        ToastMessage = null;
        StateHasChanged();
    }
}
