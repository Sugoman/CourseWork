    private static string WordDeclension(int n)
    {
        var abs = Math.Abs(n) % 100;
        var last = abs % 10;
        if (abs > 10 && abs < 20) return "слов";
        if (last == 1) return "слово";
        if (last >= 2 && last <= 4) return "слова";
        return "слов";
    }

