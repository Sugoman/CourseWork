    // §19.10 Enhanced Leech Manager — AI mnemonics + train all
    private Dictionary<int, string> _leechMnemonics = new();
    private HashSet<int> _leechMnemonicLoading = new();

    private async Task LoadLeechMnemonic(TrainingWordDto leech)
    {
        if (_leechMnemonics.ContainsKey(leech.WordId) || _leechMnemonicLoading.Contains(leech.WordId)) return;
        if (DateTime.UtcNow < _aiCircuitBreakerUntil) return;

        _leechMnemonicLoading.Add(leech.WordId);
        StateHasChanged();

        try
        {
            var sourceLang = leech.LanguageFrom ?? "English";
            var targetLang = leech.LanguageTo ?? "Russian";
            var result = await AiService.GenerateMnemonicAsync(
                leech.OriginalWord, leech.Translation, sourceLang, targetLang);
            if (result != null)
            {
                var text = result.Mnemonic ?? "";
                if (!string.IsNullOrEmpty(result.Association))
                    text += " | " + result.Association;
                _leechMnemonics[leech.WordId] = text;
            }
        }
        catch
        {
            _aiCircuitBreakerUntil = DateTime.UtcNow.AddSeconds(60);
        }
        finally
        {
            _leechMnemonicLoading.Remove(leech.WordId);
            StateHasChanged();
        }
    }

