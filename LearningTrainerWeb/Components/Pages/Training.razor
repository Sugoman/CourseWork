    private async Task CheckClozeAnswer()
    {
        if (ClozeAnswered || CurrentWord == null) return;

        ClozeAnswered = true;

        var userAnswer = ClozeTypedAnswer.Trim().ToLowerInvariant();
        var correctAnswer = ClozeCorrectWord.Trim().ToLowerInvariant();

        ClozeWasCorrect = userAnswer == correctAnswer;

        // Also accept base form if the example uses conjugation
        if (!ClozeWasCorrect)
        {
            var baseWord = CurrentWord.OriginalWord.Trim().ToLowerInvariant();
            ClozeWasCorrect = userAnswer == baseWord;
        }

        var responseTimeMs = (int)(DateTime.UtcNow - _wordShownAt).TotalMilliseconds;
        var quality = ClozeWasCorrect
            ? (HintUsed ? ResponseQuality.Hard : ResponseQuality.Good)
            : ResponseQuality.Again;
        await TrainingService.UpdateProgressAsync(CurrentWord.WordId, quality, responseTimeMs, "cloze");

        TrackWordResult(ClozeWasCorrect, responseTimeMs, "cloze");

        if (ClozeWasCorrect)
        {
            CorrectCount++;
            SessionCorrectCount++;
        }
        else
        {
            SessionWrongCount++;
            if (!DifficultWordsList.Contains(CurrentWord.OriginalWord))
                DifficultWordsList.Add(CurrentWord.OriginalWord);
            _errorModes[CurrentWord.WordId] = "cloze";
            _againQueue.Enqueue(CurrentWord);
        }
    }

