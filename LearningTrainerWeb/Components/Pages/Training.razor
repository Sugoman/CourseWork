    private async Task CheckTypingAnswer()
    {
        if (TypingAnswered || CurrentWord == null) return;

        TypingAnswered = true;

        var userAnswer = TypedAnswer.Trim();
        var correctAnswer = ExpectedAnswer.Trim();

        // §1.4 Precision Typing Feedback
        var feedback = TypingFeedbackService.Analyze(userAnswer, correctAnswer);

        if (feedback.ErrorType == TypingErrorType.None)
        {
            TypingWasCorrect = true;
            TypingWasAlmostCorrect = false;
            TypingErrorCategory = "";
            TypingDiffUserSegments = new();
            TypingDiffCorrectSegments = new();
        }
        else
        {
            TypingDiffUserSegments = feedback.UserSegments;
            TypingDiffCorrectSegments = feedback.CorrectSegments;
            TypingErrorCategory = TypingFeedbackService.GetErrorLabel(feedback.ErrorType);

            if (TypingFeedbackService.IsTypo(feedback))
            {
                TypingWasCorrect = false;
                TypingWasAlmostCorrect = true;
            }
            else if (feedback.ErrorType == TypingErrorType.PartialRecall)
            {
                TypingWasCorrect = false;
                TypingWasAlmostCorrect = true;
            }
            else
            {
                TypingWasCorrect = false;
                TypingWasAlmostCorrect = false;
            }
        }

        // Update progress
        var responseTimeMs = (int)(DateTime.UtcNow - _wordShownAt).TotalMilliseconds;
        var quality = TypingWasCorrect
            ? (HintUsed ? ResponseQuality.Hard : ResponseQuality.Good)
            : TypingFeedbackService.IsTypo(feedback)
                ? (HintUsed ? ResponseQuality.Hard : ResponseQuality.Good)
                : TypingWasAlmostCorrect ? ResponseQuality.Hard
                : ResponseQuality.Again;
        await TrainingService.UpdateProgressAsync(CurrentWord.WordId, quality, responseTimeMs, "typing");

        TrackWordResult(TypingWasCorrect || TypingWasAlmostCorrect, responseTimeMs, "typing");

        if (TypingWasCorrect || TypingWasAlmostCorrect)
        {
            CorrectCount++;
            SessionCorrectCount++;
        }
        else
        {
            SessionWrongCount++;
            if (CurrentWord != null && !DifficultWordsList.Contains(CurrentWord.OriginalWord))
                DifficultWordsList.Add(CurrentWord.OriginalWord);
            if (quality == ResponseQuality.Again)
            {
                _errorModes[CurrentWord.WordId] = "typing";
                _againQueue.Enqueue(CurrentWord);
            }
            _ = LoadAiExplanation(CurrentWord.OriginalWord, TypedAnswer, ExpectedAnswer);
        }
    }

