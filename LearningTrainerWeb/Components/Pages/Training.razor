protected override async Task OnAfterRenderAsync(bool firstRender)
{
    if (firstRender)
    {
        IsEdgeBrowser = await JS.InvokeAsync<bool>("isEdgeBrowser");

        // Load saved preferences from localStorage (§12.2 LEARNING_IMPROVEMENTS)
        try
        {
            var vol = await JS.InvokeAsync<string?>("localStorage.getItem", "ingat-tts-volume");
            if (double.TryParse(vol, System.Globalization.NumberStyles.Float, System.Globalization.CultureInfo.InvariantCulture, out var v))
                TtsVolume = v;

            var dir = await JS.InvokeAsync<string?>("localStorage.getItem", "ingat-translation-dir");
            if (!string.IsNullOrEmpty(dir) && TranslationDirection == "direct")
            {
                if (dir == "normal") TranslationDirection = "direct";
                else if (dir == "reverse") TranslationDirection = "reverse";
                else if (dir == "auto") TranslationDirection = "auto";
            }

            // Load preferred exercise mode (§12.2 LEARNING_IMPROVEMENTS)
            // Skip if training already started via autostart query params
            if (!IsTrainingActive)
            {
                var prefMode = await JS.InvokeAsync<string?>("localStorage.getItem", "ingat-preferred-mode");
                if (!string.IsNullOrEmpty(prefMode))
                    SetExerciseType(prefMode);
            }
        }
        catch { }

        StateHasChanged();

        if (IsTrainingActive)
        {
            await FocusContainer();
        }
    }
}

private async Task FocusContainer()
{
    try
    {
        await trainingContainer.FocusAsync();
    }
    catch
    {
        // Ignore focus errors
    }
}

private async Task HandleKeyDown(KeyboardEventArgs e)
{
    if (!IsTrainingActive || CurrentWord == null) return;

    if (ActiveExerciseType == "flashcard")
    {
        await HandleFlashcardKeyDown(e);
    }
    else if (ActiveExerciseType == "mcq")
    {
        await HandleMcqKeyDown(e);
    }
    // Typing and listening modes handle their own key events
}

private async Task HandleFlashcardKeyDown(KeyboardEventArgs e)
{
    if (!IsAnswerRevealed)
    {
        // Space to reveal answer
        if (e.Key == " " || e.Key == "Enter")
        {
            RevealAnswer();
            StateHasChanged();
        }
    }
    else
    {
        // 1-4 to rate answer
        switch (e.Key)
        {
            case "1":
                await SubmitAnswer(ResponseQuality.Again);
                break;
            case "2":
                await SubmitAnswer(ResponseQuality.Hard);
                break;
            case "3":
                await SubmitAnswer(ResponseQuality.Good);
                break;
            case "4":
                await SubmitAnswer(ResponseQuality.Easy);
                break;
        }
    }
}

private async Task HandleMcqKeyDown(KeyboardEventArgs e)
{
    if (!McqAnswered)
    {
        // 1-4 to select option
        if (int.TryParse(e.Key, out int num) && num >= 1 && num <= McqOptions.Count)
        {
            await SelectMcqOption(McqOptions[num - 1]);
            StateHasChanged();
        }
    }
    else
    {
        // Enter or Space to continue
        if (e.Key == "Enter" || e.Key == " ")
        {
            await NextMcqWord();
            StateHasChanged();
        }
    }
}

protected override async Task OnInitializedAsync()
{
    await AuthService.InitializeAsync();
    var session = await AuthService.GetCurrentSessionAsync();
    IsAuthenticated = session != null;

    if (IsAuthenticated)
    {
        await LoadDailyPlan();
        AvailableTags = await ContentApi.GetDictionaryTagsAsync();
        await LoadAvailableDictionaries();
        _ = LoadGrammarDueCount(); // Fire-and-forget, не блокирует UI

        // §19.8 — Auto-start from Quick Actions panel
        if (string.Equals(QueryAutostart, "true", StringComparison.OrdinalIgnoreCase) && !string.IsNullOrEmpty(QueryMode))
        {
            SetExerciseType("mixed");
            await StartTraining(QueryMode);
        }
    }

    IsLoading = false;
}

private async Task LoadDailyPlan()
{
    DailyPlan = await TrainingService.GetDailyPlanAsync();
    DailyChallenge = await TrainingService.GetDailyChallengeAsync();
}

private async Task LoadAvailableDictionaries()
{
    try
    {
        var dicts = await ContentApi.GetMyDictionariesAsync();
        AvailableDictionaries = dicts
            .Where(d => d.WordCount > 0)
            .Select(d => new DictionaryOption { Id = d.Id, Name = d.Name, WordCount = d.WordCount })
            .ToList();
    }
    catch
    {
        AvailableDictionaries = new();
    }
}

private async Task InstallStarterPack()
{
    IsInstallingStarter = true;
    StarterMessage = null;
    StateHasChanged();

    var result = await TrainingService.InstallStarterPackAsync();

    if (result != null)
    {
        StarterSuccess = true;
        StarterMessage = result.Message;
            await LoadDailyPlan();
        }
        else
        {
            StarterSuccess = false;
            StarterMessage = "Не удалось установить стартовый набор. Возможно, у вас уже есть словари.";
        }

        IsInstallingStarter = false;
    }

    private void SetExerciseType(string type)
    {
        ExerciseType = type;
        _isMixedMode = type == "mixed";
    }

    private string DisplayedWord => CurrentWord == null ? "" : (IsReversed ? CurrentWord.Translation : CurrentWord.OriginalWord);
    private string ExpectedAnswer => CurrentWord == null ? "" : (IsReversed ? CurrentWord.OriginalWord : CurrentWord.Translation);

    private async Task StartTraining(string mode)
    {
        CurrentMode = mode;
        IsLoading = true;
        StateHasChanged();

        var limit = WordLimit > 0 ? WordLimit : 200;
        TrainingWords = await TrainingService.GetTrainingWordsAsync(mode, dictionaryId: SelectedDictionaryId, limit: limit, tag: SelectedTag);

        if (TrainingWords.Count > 0)
        {
            if (WordLimit > 0 && TrainingWords.Count > WordLimit)
                TrainingWords = TrainingWords.Take(WordLimit).ToList();

            CurrentIndex = 0;
            CorrectCount = 0;
            SessionCorrectCount = 0;
            SessionWrongCount = 0;
            DifficultWordsList.Clear();
            _againQueue.Clear();
            _errorModes.Clear();
            _isErrorReplay = false;
            _wordResults.Clear();
            _failedWordIds.Clear();
            _sessionXpEarned = 0;
            _avgResponseTimeSec = 0;
            _microGoalTracker.Reset();
            SessionStartedAt = DateTime.UtcNow;
            CurrentWord = TrainingWords[0];
            IsAnswerRevealed = false;
            IsTrainingActive = true;

            if (_isMixedMode)
                _activeExerciseType = PickRandomExerciseType();
            else
                _activeExerciseType = ExerciseType;

            PrepareCurrentWord();
            await FocusContainer();

            // §6.4 Proactive mnemonic for new complex words
            _ = TryLoadProactiveMnemonic();
        }
        else
        {
            IsTrainingActive = false;
            CurrentWord = null;
            CorrectCount = 0;
        }

        IsLoading = false;
    }

    private string PickRandomExerciseType()
    {
        // §14.4 LEARNING_IMPROVEMENTS — Adaptive exercise type selection
        // Choose exercise type based on word's KnowledgeLevel for optimal learning progression
        if (CurrentWord != null)
        {
            var level = CurrentWord.KnowledgeLevel;
            var hasExample = !string.IsNullOrWhiteSpace(CurrentWord.Example);

            // KnowledgeLevel 0 (new) → flashcard (introduction, low pressure)
            if (level == 0)
                return "flashcard";

            // KnowledgeLevel 1–2 → MCQ (recognition from options) with some flashcard
            if (level <= 2)
                return _random.NextDouble() < 0.7 ? "mcq" : "flashcard";

            // KnowledgeLevel 3 → typing (active recall) with some MCQ
            if (level == 3)
                return _random.NextDouble() < 0.6 ? "typing" : "mcq";

            // KnowledgeLevel 4 → cloze/listening (context & listening)
            if (level == 4)
            {
                var r = _random.NextDouble();
                if (r < 0.35 && hasExample) return "cloze";
                if (r < 0.65) return "listening";
                return "typing";
            }

            // KnowledgeLevel 5+ → spelling/reverse typing (mastery: exact reproduction)
            if (level >= 5)
            {
                var r = _random.NextDouble();
                if (r < 0.4) return "spelling";
                if (r < 0.7) return "typing";
                return "listening";
            }
        }

        // Fallback: pure random (original behavior)
        var types = new[] { "flashcard", "mcq", "typing", "listening", "matching", "cloze", "spelling" };
        var picked = types[_random.Next(types.Length)];
        if (picked == "cloze" && (CurrentWord == null || string.IsNullOrWhiteSpace(CurrentWord.Example)))
            picked = "typing";
        return picked;
    }

    private string ActiveExerciseType => (_isMixedMode || _isErrorReplay) ? _activeExerciseType : ExerciseType;

    private void PrepareCurrentWord()
    {
        // Start response time tracking (§1.3 LEARNING_IMPROVEMENTS)
        _wordShownAt = DateTime.UtcNow;

        // Reset states
        IsAnswerRevealed = false;
        McqAnswered = false;
        McqWasCorrect = false;
        SelectedMcqOption = null;
        TypingAnswered = false;
        TypingWasCorrect = false;
        TypingWasAlmostCorrect = false;
        TypedAnswer = "";
        TypingDiffUserSegments = new();
        TypingDiffCorrectSegments = new();
        TypingErrorCategory = "";
        ListeningAnswered = false;
        ListeningWasCorrect = false;
        ListeningWasAlmostCorrect = false;
        ListeningTypedAnswer = "";
        ListeningDiffUserSegments = new();
        ListeningDiffCorrectSegments = new();
        ListeningErrorCategory = "";

        // Reset cloze state (§3.1)
        ClozeAnswered = false;
        ClozeWasCorrect = false;
        ClozeTypedAnswer = "";
        ClozeSentenceHtml = "";
        ClozeCorrectWord = "";

        // Reset spelling bee state (§3.2)
        SpellingAnswered = false;
        SpellingWasCorrect = false;
        SpellingTyped = "";
        SpellingCorrectWord = "";

        // Reset note editor state (§8.3)
        IsEditingNote = false;
        EditingNoteText = "";

        // Reset hints (§1.1 Context-Aware Hints)
        _hintCount = 0;
        HintText = "";
        HintUsed = false;

        // Clear AI state
        AiExplanation = null;
        AiTip = null;
        AiMnemonic = null;
        AiEtymology = null;
        AiAssociation = null;
        IsLoadingAiExplanation = false;
        IsLoadingMnemonic = false;

        // Apply translation direction (§3.4 LEARNING_IMPROVEMENTS: auto-raise)
        IsReversed = TranslationDirection switch
        {
            "reverse" => true,
            "random" => _random.Next(2) == 0,
            "auto" => CurrentWord != null && CurrentWord.KnowledgeLevel >= 3,
            _ => false
        };

        // Pick exercise type for mixed mode (skip during error replay — mode already set)
        if (_isMixedMode && !_isErrorReplay)
            _activeExerciseType = PickRandomExerciseType();

        // Generate MCQ options if needed
        var effectiveType = _isMixedMode ? _activeExerciseType : ExerciseType;
        if (effectiveType == "mcq" && CurrentWord != null)
        {
            GenerateMcqOptions();
        }

        // Auto-play for listening mode
        if (effectiveType == "listening" && CurrentWord != null)
        {
            _ = SpeakWord();
        }

        // Prepare matching mode (#6 LEARNING_IMPROVEMENTS)
        if (effectiveType == "matching")
        {
            PrepareMatchingRound();
        }

        // Prepare cloze mode (§3.1 LEARNING_IMPROVEMENTS)
        if (effectiveType == "cloze" && CurrentWord != null)
        {
            PrepareCloze();
            // If no example available, fall back to typing
            if (string.IsNullOrEmpty(ClozeSentenceHtml))
            {
                if (_isMixedMode)
                    _activeExerciseType = "typing";
            }
        }

        // Prepare spelling bee mode (§3.2 LEARNING_IMPROVEMENTS)
        if (effectiveType == "spelling" && CurrentWord != null)
        {
            SpellingCorrectWord = CurrentWord.OriginalWord;
            _ = SpeakWord();
            _ = Task.Delay(100).ContinueWith(_ => InvokeAsync(FocusSpellingInput));
        }

        // Speed Round: auto-reveal flashcard (§3.3 LEARNING_IMPROVEMENTS)
        if (IsSpeedRound)
        {
            IsAnswerRevealed = true;
        }

        // §19.5 AI auto-examples: enrich word if Example is empty
        if (CurrentWord != null && string.IsNullOrEmpty(CurrentWord.Example))
        {
            _ = EnrichWordWithAiExample(CurrentWord);
        }
    }

    private void GenerateMcqOptions()
    {
        McqOptions.Clear();

        // Add correct answer
        McqOptions.Add(ExpectedAnswer);

        // Add distractors from other words based on direction
        List<string> distractors;
        if (IsReversed)
        {
            distractors = TrainingWords
                .Where(w => w.WordId != CurrentWord!.WordId && !string.IsNullOrEmpty(w.OriginalWord))
                .Select(w => w.OriginalWord)
                .Distinct()
                .OrderBy(_ => _random.Next())
                .Take(3)
                .ToList();
        }
        else
        {
            distractors = TrainingWords
                .Where(w => w.WordId != CurrentWord!.WordId && !string.IsNullOrEmpty(w.Translation))
                .Select(w => w.Translation)
                .Distinct()
                .OrderBy(_ => _random.Next())
                .Take(3)
                .ToList();
        }

        McqOptions.AddRange(distractors);
        
        // If we don't have enough options, add some generic ones
        var genericOptions = new[] { "слово", "ответ", "перевод", "значение" };
        while (McqOptions.Count < 4)
        {
            var option = genericOptions[_random.Next(genericOptions.Length)] + " " + (_random.Next(99) + 1);
            if (!McqOptions.Contains(option))
            {
                McqOptions.Add(option);
            }
        }
        
        // Shuffle options
        McqOptions = McqOptions.OrderBy(_ => _random.Next()).ToList();
    }

