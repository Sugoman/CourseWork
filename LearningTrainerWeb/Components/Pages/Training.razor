    // === Matching Mode (#6 LEARNING_IMPROVEMENTS) ===

    private void PrepareMatchingRound()
    {
        MatchedPairIds.Clear();
        MatchedTranslations.Clear();
        MatchingSelectedLeft = null;
        MatchingSelectedRight = null;
        MatchingWrongLeft = null;
        MatchingWrongRight = null;
        MatchingCompleted = false;
        MatchingErrors = 0;

        // Take a group of words starting from CurrentIndex
        var startIdx = CurrentIndex;
        var endIdx = Math.Min(startIdx + MatchingGroupSize, TrainingWords.Count);
        MatchingPairs = TrainingWords.GetRange(startIdx, endIdx - startIdx);

        // Shuffle translations
        ShuffledMatchingTranslations = MatchingPairs
            .OrderBy(_ => _random.Next())
            .ToList();
    }

    private void SelectMatchingLeft(int wordId)
    {
        if (MatchingCompleted) return;
        MatchingWrongLeft = null;
        MatchingWrongRight = null;
        MatchingSelectedLeft = wordId;

        if (MatchingSelectedRight != null)
        {
            _ = TryMatchPairAsync();
        }
    }

    private void SelectMatchingRight(string translation)
    {
        if (MatchingCompleted) return;
        MatchingWrongLeft = null;
        MatchingWrongRight = null;
        MatchingSelectedRight = translation;

        if (MatchingSelectedLeft != null)
        {
            _ = TryMatchPairAsync();
        }
    }

    private async Task TryMatchPairAsync()
    {
        if (MatchingSelectedLeft == null || MatchingSelectedRight == null) return;

        var leftWord = MatchingPairs.FirstOrDefault(p => p.WordId == MatchingSelectedLeft.Value);
        if (leftWord == null) return;

        var isCorrect = leftWord.Translation.Equals(MatchingSelectedRight, StringComparison.OrdinalIgnoreCase);

        if (isCorrect)
        {
            MatchedPairIds.Add(leftWord.WordId);
            MatchedTranslations.Add(MatchingSelectedRight);
            await TrainingService.UpdateProgressAsync(leftWord.WordId, ResponseQuality.Good);
            CorrectCount++;
            SessionCorrectCount++;
        }
        else
        {
            MatchingErrors++;
            MatchingWrongLeft = MatchingSelectedLeft;
            MatchingWrongRight = MatchingSelectedRight;
            await TrainingService.UpdateProgressAsync(leftWord.WordId, ResponseQuality.Again);
            SessionWrongCount++;
            if (!DifficultWordsList.Contains(leftWord.OriginalWord))
                DifficultWordsList.Add(leftWord.OriginalWord);
        }

        MatchingSelectedLeft = null;
        MatchingSelectedRight = null;

        // Check if all pairs are matched
        if (MatchedPairIds.Count == MatchingPairs.Count)
        {
            MatchingCompleted = true;
        }

        StateHasChanged();
    }

    private async Task NextMatchingRound()
    {
        // Advance CurrentIndex past the matching group
        CurrentIndex += MatchingPairs.Count;

        if (CurrentIndex < TrainingWords.Count)
        {
            CurrentWord = TrainingWords[CurrentIndex];
            PrepareCurrentWord();
        }
        else
        {
            CurrentWord = null;
            var finalElapsed = DateTime.UtcNow - SessionStartedAt;
            if (finalElapsed.TotalHours >= 1)
                _sessionDurationSnapshot = $"{(int)finalElapsed.TotalHours}ч {finalElapsed.Minutes}мин";
            else if (finalElapsed.TotalMinutes >= 1)
                _sessionDurationSnapshot = $"{finalElapsed.Minutes}мин {finalElapsed.Seconds}с";
            else
                _sessionDurationSnapshot = $"{finalElapsed.Seconds}с";
            await SaveTrainingSessionAsync();
        }
    }

