                    </div>
                }
                else if (ActiveExerciseType == "matching")
                {
                    <!-- Режим сопоставления (#6 LEARNING_IMPROVEMENTS) -->
                    <div class="matching-card">
                        <div class="matching-header">
                            <h3><i class="bi bi-link-45deg me-2"></i>Соедините пары</h3>
                            <p class="text-muted">Нажмите на слово слева, затем на его перевод справа</p>
                        </div>

                        <div class="matching-grid">
                            <div class="matching-column">
                                @foreach (var pair in MatchingPairs)
                                {
                                    var isMatched = MatchedPairIds.Contains(pair.WordId);
                                    var isSelected = MatchingSelectedLeft == pair.WordId;
                                    var isWrong = MatchingWrongLeft == pair.WordId;
                                    <button class="matching-item matching-left @(isMatched ? "matched" : "") @(isSelected ? "selected" : "") @(isWrong ? "wrong" : "")"
                                            @onclick="() => SelectMatchingLeft(pair.WordId)"
                                            disabled="@isMatched">
                                        @pair.OriginalWord
                                    </button>
                                }
                            </div>
                            <div class="matching-column">
                                @foreach (var item in ShuffledMatchingTranslations)
                                {
                                    var isMatched = MatchedTranslations.Contains(item.Translation);
                                    var isSelected = MatchingSelectedRight == item.Translation;
                                    var isWrong = MatchingWrongRight == item.Translation;
                                    <button class="matching-item matching-right @(isMatched ? "matched" : "") @(isSelected ? "selected" : "") @(isWrong ? "wrong" : "")"
                                            @onclick="() => SelectMatchingRight(item.Translation)"
                                            disabled="@isMatched">
                                        @item.Translation
                                    </button>
                                }
                            </div>
                        </div>

                        @if (MatchingCompleted)
                        {
                            <div class="matching-result mt-3">
                                <div class="mcq-feedback @(MatchingErrors == 0 ? "success" : "error")">
                                    @if (MatchingErrors == 0)
                                    {
                                        <i class="bi bi-check-circle"></i>
                                        <span>Отлично! Все пары верны!</span>
                                    }
                                    else
                                    {
                                        <i class="bi bi-x-circle"></i>
                                        <span>Ошибок: @MatchingErrors</span>
                                    }
                                </div>
                                <button class="btn btn-primary btn-lg mt-3" @onclick="NextMatchingRound">
                                    <i class="bi bi-arrow-right me-2"></i>Далее
                                </button>
                            </div>
                        }
                    </div>
                }
            }
            else
            {
                <!-- Результаты тренировки -->
                <div class="session-results">
                    <div class="results-icon">
                        @if (SessionAccuracy >= 90)
                        {
                            <span>🏆</span>
                        }
                        else if (SessionAccuracy >= 70)
                        {
                            <span>🎉</span>
                        }
                        else if (SessionAccuracy >= 50)
                        {
                            <span>👍</span>
                        }
                        else
                        {
                            <span>💪</span>
                        }
                    </div>
                    <h2>@SessionResultMessage</h2>

                    <div class="results-stats">
                        <div class="result-stat">
                            <span class="result-value">@TrainingWords.Count</span>
                            <span class="result-label">Всего слов</span>
                        </div>
                        <div class="result-stat result-correct">
                            <span class="result-value">@SessionCorrectCount</span>
                            <span class="result-label">Правильно</span>
                        </div>
                        <div class="result-stat result-wrong">
                            <span class="result-value">@SessionWrongCount</span>
                            <span class="result-label">С ошибками</span>
                        </div>
                        <div class="result-stat">
                            <span class="result-value">@SessionDurationFormatted</span>
                            <span class="result-label">Время</span>
                        </div>
                    </div>

                    <!-- Accuracy bar -->
                    <div class="results-accuracy">
                        <div class="accuracy-value">@SessionAccuracy.ToString("F0")%</div>
                        <div class="accuracy-label">Точность</div>
                        <div class="accuracy-bar-container mt-2">
                            <div class="progress" style="height: 10px; border-radius: 5px; max-width: 300px; margin: 0 auto;">
                                <div class="progress-bar bg-success" style="width: @SessionAccuracy%"></div>
                            </div>
                        </div>
                    </div>

                    <!-- Difficult words -->
                    @if (DifficultWordsList.Count > 0)
                    {
                        <div class="difficult-words-section">
                            <h5 class="text-muted mb-2"><i class="bi bi-exclamation-triangle me-1"></i>Слова с ошибками</h5>
                            <div class="difficult-words-list">
                                @foreach (var word in DifficultWordsList)
                                {
                                    <span class="badge bg-danger-subtle text-danger me-1 mb-1 px-3 py-2" style="font-size: 0.9rem;">@word</span>
                                }
                            </div>
                        </div>
                    }

                    <div class="results-actions">
                        <button class="btn btn-primary btn-lg" @onclick="ContinueTraining">
                            <i class="bi bi-arrow-repeat me-2"></i>Продолжить
                        </button>
                        <button class="btn btn-outline-secondary btn-lg" @onclick="BackToPlan">
                            <i class="bi bi-house me-2"></i>К плану
                        </button>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
private bool IsAuthenticated;
private bool IsLoading = true;
private bool IsTrainingActive;
private bool IsAnswerRevealed;
private bool IsInstallingStarter;
private string? StarterMessage;
private bool StarterSuccess;

private DailyPlanDto? DailyPlan;
private List<TrainingWordDto> TrainingWords = new();
private TrainingWordDto? CurrentWord;
private int CurrentIndex;
private int CorrectCount;
private string CurrentMode = "mixed";
private string ExerciseType = "flashcard";
private string _activeExerciseType = "flashcard";
private bool _isMixedMode;
private int WordLimit = 0;
private string TranslationDirection = "direct";
private bool IsReversed;

// Session tracking
private DateTime SessionStartedAt;
private int SessionCorrectCount;
private int SessionWrongCount;
private bool ShowPomodoroBreak;

// MCQ state
private List<string> McqOptions = new();
private string? SelectedMcqOption;
private bool McqAnswered;
private bool McqWasCorrect;

// Typing state
private string TypedAnswer = "";
private bool TypingAnswered;
private bool TypingWasCorrect;
private bool TypingWasAlmostCorrect;
private Random _random = new();

// Listening state
private string ListeningTypedAnswer = "";
private bool ListeningAnswered;
private bool ListeningWasCorrect;
private bool ListeningWasAlmostCorrect;

// Matching state (#6 LEARNING_IMPROVEMENTS)
private List<TrainingWordDto> MatchingPairs = new();
private List<TrainingWordDto> ShuffledMatchingTranslations = new();
private HashSet<int> MatchedPairIds = new();
private HashSet<string> MatchedTranslations = new();
private int? MatchingSelectedLeft;
private string? MatchingSelectedRight;
private int? MatchingWrongLeft;
private string? MatchingWrongRight;
private bool MatchingCompleted;
private int MatchingErrors;
private int MatchingRoundIndex;
private const int MatchingGroupSize = 5;

// Tags state (#9 LEARNING_IMPROVEMENTS)
private List<string> AvailableTags = new();
private string? SelectedTag;

// Leech manager state (P0 LEARNING_IMPROVEMENTS §1.1)
private bool IsLeechManagerVisible;
private List<TrainingWordDto> LeechWords = new();

// Daily goal editor state (P0 LEARNING_IMPROVEMENTS §1.2)
private bool ShowDailyGoalEditor;

// Response time tracking (§1.3 LEARNING_IMPROVEMENTS)
private DateTime _wordShownAt;

// Intra-session Again requeue (§10.4 LEARNING_IMPROVEMENTS)
private Queue<TrainingWordDto> _againQueue = new();

// TTS state
private double TtsVolume = 0.8;
private bool ShowVolumeSlider;

// Results tracking
private List<string> DifficultWordsList = new();
private string _sessionDurationSnapshot = "";

// AI explanation state (Phase 3)
private string? AiExplanation;
private string? AiTip;
private string? AiMnemonic;
private bool IsLoadingAiExplanation;
private bool IsLoadingMnemonic;

// Element reference for focus
private ElementReference trainingContainer;

protected override async Task OnAfterRenderAsync(bool firstRender)
{
    if (firstRender && IsTrainingActive)
    {
        await FocusContainer();
    }
}

private async Task FocusContainer()
{
    try
    {
        await trainingContainer.FocusAsync();
    }
    catch
    {
        // Ignore focus errors
    }
}

private async Task HandleKeyDown(KeyboardEventArgs e)
{
    if (!IsTrainingActive || CurrentWord == null) return;

    if (ActiveExerciseType == "flashcard")
    {
        await HandleFlashcardKeyDown(e);
    }
    else if (ActiveExerciseType == "mcq")
    {
        await HandleMcqKeyDown(e);
    }
    // Typing and listening modes handle their own key events
}

private async Task HandleFlashcardKeyDown(KeyboardEventArgs e)
{
    if (!IsAnswerRevealed)
    {
        // Space to reveal answer
        if (e.Key == " " || e.Key == "Enter")
        {
            RevealAnswer();
            StateHasChanged();
        }
    }
    else
    {
        // 1-4 to rate answer
        switch (e.Key)
        {
            case "1":
                await SubmitAnswer(ResponseQuality.Again);
                break;
            case "2":
                await SubmitAnswer(ResponseQuality.Hard);
                break;
            case "3":
                await SubmitAnswer(ResponseQuality.Good);
                break;
            case "4":
                await SubmitAnswer(ResponseQuality.Easy);
                break;
        }
    }
}

private async Task HandleMcqKeyDown(KeyboardEventArgs e)
{
    if (!McqAnswered)
    {
        // 1-4 to select option
        if (int.TryParse(e.Key, out int num) && num >= 1 && num <= McqOptions.Count)
        {
            await SelectMcqOption(McqOptions[num - 1]);
            StateHasChanged();
        }
    }
    else
    {
        // Enter or Space to continue
        if (e.Key == "Enter" || e.Key == " ")
        {
            await NextMcqWord();
            StateHasChanged();
        }
    }
}

protected override async Task OnInitializedAsync()
{
    await AuthService.InitializeAsync();
    var session = await AuthService.GetCurrentSessionAsync();
    IsAuthenticated = session != null;

    if (IsAuthenticated)
    {
        await LoadDailyPlan();
        AvailableTags = await ContentApi.GetDictionaryTagsAsync();
    }

    IsLoading = false;
}

private async Task LoadDailyPlan()
{
    DailyPlan = await TrainingService.GetDailyPlanAsync();
}

private async Task InstallStarterPack()
{
    IsInstallingStarter = true;
    StarterMessage = null;
    StateHasChanged();

    var result = await TrainingService.InstallStarterPackAsync();

    if (result != null)
    {
        StarterSuccess = true;
        StarterMessage = result.Message;
            await LoadDailyPlan();
        }
        else
        {
            StarterSuccess = false;
            StarterMessage = "Не удалось установить стартовый набор. Возможно, у вас уже есть словари.";
        }

        IsInstallingStarter = false;
    }

    private void SetExerciseType(string type)
    {
        ExerciseType = type;
        _isMixedMode = type == "mixed";
    }

    private string DisplayedWord => CurrentWord == null ? "" : (IsReversed ? CurrentWord.Translation : CurrentWord.OriginalWord);
    private string ExpectedAnswer => CurrentWord == null ? "" : (IsReversed ? CurrentWord.OriginalWord : CurrentWord.Translation);

    private async Task StartTraining(string mode)
    {
        CurrentMode = mode;
        IsLoading = true;
        StateHasChanged();

        var limit = WordLimit > 0 ? WordLimit : 200;
        TrainingWords = await TrainingService.GetTrainingWordsAsync(mode, limit: limit);

        // Фильтрация по тегу (#9 LEARNING_IMPROVEMENTS)
        if (!string.IsNullOrEmpty(SelectedTag) && TrainingWords.Count > 0)
        {
            TrainingWords = TrainingWords
                .Where(w => !string.IsNullOrEmpty(w.DictionaryTags) &&
                    w.DictionaryTags.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
                        .Any(t => t.Equals(SelectedTag, StringComparison.OrdinalIgnoreCase)))
                .ToList();
        }

        if (TrainingWords.Count > 0)
        {
            if (WordLimit > 0 && TrainingWords.Count > WordLimit)
                TrainingWords = TrainingWords.Take(WordLimit).ToList();

            CurrentIndex = 0;
            CorrectCount = 0;
            SessionCorrectCount = 0;
            SessionWrongCount = 0;
            DifficultWordsList.Clear();
            _againQueue.Clear();
            SessionStartedAt = DateTime.UtcNow;
            CurrentWord = TrainingWords[0];
            IsAnswerRevealed = false;
            IsTrainingActive = true;

            if (_isMixedMode)
                _activeExerciseType = PickRandomExerciseType();
            else
                _activeExerciseType = ExerciseType;

            PrepareCurrentWord();
            await FocusContainer();
        }
        else
        {
            IsTrainingActive = false;
            CurrentWord = null;
            CorrectCount = 0;
        }

        IsLoading = false;
    }

    private string PickRandomExerciseType()
    {
        var types = new[] { "flashcard", "mcq", "typing", "listening", "matching" };
        return types[_random.Next(types.Length)];
    }

    private string ActiveExerciseType => _isMixedMode ? _activeExerciseType : ExerciseType;

    private void PrepareCurrentWord()
    {
        // Start response time tracking (§1.3 LEARNING_IMPROVEMENTS)
        _wordShownAt = DateTime.UtcNow;

        // Reset states
        IsAnswerRevealed = false;
        McqAnswered = false;
        McqWasCorrect = false;
        SelectedMcqOption = null;
        TypingAnswered = false;
        TypingWasCorrect = false;
        TypingWasAlmostCorrect = false;
        TypedAnswer = "";
        ListeningAnswered = false;
        ListeningWasCorrect = false;
        ListeningWasAlmostCorrect = false;
        ListeningTypedAnswer = "";

        // Clear AI state
        AiExplanation = null;
        AiTip = null;
        AiMnemonic = null;
        IsLoadingAiExplanation = false;
        IsLoadingMnemonic = false;

        // Apply translation direction
        IsReversed = TranslationDirection switch
        {
            "reverse" => true,
            "random" => _random.Next(2) == 0,
            _ => false
        };

        // Pick exercise type for mixed mode
        if (_isMixedMode)
            _activeExerciseType = PickRandomExerciseType();

        // Generate MCQ options if needed
        var effectiveType = _isMixedMode ? _activeExerciseType : ExerciseType;
        if (effectiveType == "mcq" && CurrentWord != null)
        {
            GenerateMcqOptions();
        }

        // Auto-play for listening mode
        if (effectiveType == "listening" && CurrentWord != null)
        {
            _ = SpeakWord();
        }

        // Prepare matching mode (#6 LEARNING_IMPROVEMENTS)
        if (effectiveType == "matching")
        {
            PrepareMatchingRound();
        }
    }

    private void GenerateMcqOptions()
    {
        McqOptions.Clear();

        // Add correct answer
        McqOptions.Add(ExpectedAnswer);

        // Add distractors from other words based on direction
        List<string> distractors;
        if (IsReversed)
        {
            distractors = TrainingWords
                .Where(w => w.WordId != CurrentWord!.WordId && !string.IsNullOrEmpty(w.OriginalWord))
                .Select(w => w.OriginalWord)
                .Distinct()
                .OrderBy(_ => _random.Next())
                .Take(3)
                .ToList();
        }
        else
        {
            distractors = TrainingWords
                .Where(w => w.WordId != CurrentWord!.WordId && !string.IsNullOrEmpty(w.Translation))
                .Select(w => w.Translation)
                .Distinct()
                .OrderBy(_ => _random.Next())
                .Take(3)
                .ToList();
        }

        McqOptions.AddRange(distractors);
        
        // If we don't have enough options, add some generic ones
        var genericOptions = new[] { "слово", "ответ", "перевод", "значение" };
        while (McqOptions.Count < 4)
        {
            var option = genericOptions[_random.Next(genericOptions.Length)] + " " + (_random.Next(99) + 1);
            if (!McqOptions.Contains(option))
            {
                McqOptions.Add(option);
            }
        }
        
        // Shuffle options
        McqOptions = McqOptions.OrderBy(_ => _random.Next()).ToList();
    }

