    private async Task SubmitAnswer(ResponseQuality quality)
    {
        if (CurrentWord == null) return;

        var responseTimeMs = (int)(DateTime.UtcNow - _wordShownAt).TotalMilliseconds;

        // Отправляем результат на сервер с временем ответа и режимом упражнения
        await TrainingService.UpdateProgressAsync(CurrentWord.WordId, quality, responseTimeMs, ActiveExerciseType);

        TrackWordResult(quality >= ResponseQuality.Good, responseTimeMs, ActiveExerciseType);

        // Считаем правильные ответы
        if (quality >= ResponseQuality.Good)
        {
            CorrectCount++;
            SessionCorrectCount++;
        }
        else
        {
            SessionWrongCount++;
            if (CurrentWord != null && !DifficultWordsList.Contains(CurrentWord.OriginalWord))
                DifficultWordsList.Add(CurrentWord.OriginalWord);

            // §1.2 Error Replay Queue: record mode and enqueue
            if (quality == ResponseQuality.Again)
            {
                _errorModes[CurrentWord.WordId] = ActiveExerciseType;
                _againQueue.Enqueue(CurrentWord);
            }
        }

        // Переход к следующему слову
        await MoveToNextWord();
    }

    private async Task SelectMcqOption(string option)
    {
        if (McqAnswered || CurrentWord == null) return;

        var responseTimeMs = (int)(DateTime.UtcNow - _wordShownAt).TotalMilliseconds;
        SelectedMcqOption = option;
        McqAnswered = true;
        McqWasCorrect = option.Equals(ExpectedAnswer, StringComparison.OrdinalIgnoreCase);

        // Update progress
        var quality = McqWasCorrect ? ResponseQuality.Good : ResponseQuality.Again;
        await TrainingService.UpdateProgressAsync(CurrentWord.WordId, quality, responseTimeMs, "mcq");

        TrackWordResult(McqWasCorrect, responseTimeMs, "mcq");

        if (McqWasCorrect)
            {
                CorrectCount++;
                SessionCorrectCount++;
            }
            else
            {
                SessionWrongCount++;
                if (CurrentWord != null && !DifficultWordsList.Contains(CurrentWord.OriginalWord))
                    DifficultWordsList.Add(CurrentWord.OriginalWord);
                _errorModes[CurrentWord.WordId] = "mcq";
                _againQueue.Enqueue(CurrentWord);
                _ = LoadAiExplanation(CurrentWord.OriginalWord, option, ExpectedAnswer);
            }
    }

