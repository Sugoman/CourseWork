            var targetLang = word.LanguageTo ?? "Russian";
            var examples = await AiService.GetExamplesAsync(
                word.OriginalWord, sourceLang, targetLang, count: 1);
            if (examples != null && examples.Count > 0)
            {
                word.Example = examples[0].Sentence;
                await InvokeAsync(StateHasChanged);
            }
        }
        catch
        {
            _aiCircuitBreakerUntil = DateTime.UtcNow.AddSeconds(60);
        }
    }

