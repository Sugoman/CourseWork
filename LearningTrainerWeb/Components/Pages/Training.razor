    private async Task MoveToNextWord()
    {
        CurrentIndex++;

        // Помодоро: предложить перерыв каждые 25 минут (#19 LEARNING_IMPROVEMENTS)
        var elapsed = DateTime.UtcNow - SessionStartedAt;
        if (!ShowPomodoroBreak && elapsed.TotalMinutes >= 25 && CurrentIndex < TrainingWords.Count)
        {
            ShowPomodoroBreak = true;
            return; // Покажем уведомление, не переключая слово
        }

        if (CurrentIndex < TrainingWords.Count)
        {
            CurrentWord = TrainingWords[CurrentIndex];
            PrepareCurrentWord();
        }
        else if (_againQueue.Count > 0)
        {
            // Intra-session Again: повторяем слова, на которые ответили Again (§10.4)
            CurrentWord = _againQueue.Dequeue();
            PrepareCurrentWord();
        }
        else
        {
            // Тренировка завершена — фиксируем время и сохраняем сессию
            CurrentWord = null;
            var finalElapsed = DateTime.UtcNow - SessionStartedAt;
            if (finalElapsed.TotalHours >= 1)
                _sessionDurationSnapshot = $"{(int)finalElapsed.TotalHours}ч {finalElapsed.Minutes}мин";
            else if (finalElapsed.TotalMinutes >= 1)
                _sessionDurationSnapshot = $"{finalElapsed.Minutes}мин {finalElapsed.Seconds}с";
            else
                _sessionDurationSnapshot = $"{finalElapsed.Seconds}с";
            await SaveTrainingSessionAsync();
        }
    }

    private void DismissPomodoroBreak()
    {
        ShowPomodoroBreak = false;
        // Сбрасываем таймер, чтобы следующее напоминание было через 25 минут
        SessionStartedAt = DateTime.UtcNow;

        if (CurrentIndex < TrainingWords.Count)
        {
            CurrentWord = TrainingWords[CurrentIndex];
            PrepareCurrentWord();
        }
    }

    private async Task SaveTrainingSessionAsync()
    {
        try
        {
            var request = new LearningTrainerWeb.Services.SaveSessionRequest
            {
                StartedAt = SessionStartedAt,
                CompletedAt = DateTime.UtcNow,
                WordsReviewed = TrainingWords.Count,
                CorrectAnswers = SessionCorrectCount,
                WrongAnswers = SessionWrongCount,
                Mode = ExerciseType switch
                {
                    "flashcard" => "Flashcards",
                    "mcq" => "MultipleChoice",
                    "typing" => "Typing",
                    "listening" => "Listening",
                    "matching" => "Matching",
                    "mixed" => "Mixed",
                    _ => "Mixed"
                },
                DictionaryId = TrainingWords.FirstOrDefault()?.DictionaryId
            };

            await StatsService.SaveSessionAsync(request);
        }
        catch (Exception ex)
        {
            // Не блокируем UI при ошибке сохранения сессии
            Console.WriteLine($"Failed to save training session: {ex.Message}");
        }
    }

