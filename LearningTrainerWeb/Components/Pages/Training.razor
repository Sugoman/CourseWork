    // === Speed Round (§3.3 LEARNING_IMPROVEMENTS) ===

    private async Task StartSpeedRound()
    {
        IsSpeedRound = true;
        SpeedRoundScore = 0;
        SpeedRoundTimeLeft = 60;
        ExerciseType = "flashcard";
        _isMixedMode = false;
        _activeExerciseType = "flashcard";

        await StartTraining("mixed");

        _speedTimer = new System.Timers.Timer(1000);
        _speedTimer.Elapsed += async (_, _) =>
        {
            SpeedRoundTimeLeft--;
            if (SpeedRoundTimeLeft <= 0)
            {
                _speedTimer?.Stop();
                _speedTimer?.Dispose();
                _speedTimer = null;
                await InvokeAsync(() => EndSpeedRound());
            }
            else
            {
                await InvokeAsync(StateHasChanged);
            }
        };
        _speedTimer.Start();
    }

    private async Task SpeedRoundAnswer(bool known)
    {
        if (CurrentWord == null) return;

        var quality = known ? ResponseQuality.Good : ResponseQuality.Again;
        await TrainingService.UpdateProgressAsync(CurrentWord.WordId, quality, exerciseMode: "flashcard");

        if (known)
        {
            SpeedRoundScore += 10;
            CorrectCount++;
            SessionCorrectCount++;
        }
        else
        {
            SessionWrongCount++;
        }

        // Auto-reveal and advance immediately
        IsAnswerRevealed = false;
        await MoveToNextWord();
    }

    private async Task EndSpeedRound()
    {
        _speedTimer?.Stop();
        _speedTimer?.Dispose();
        _speedTimer = null;

        // Force finish the session
        CurrentWord = null;
        var finalElapsed = DateTime.UtcNow - SessionStartedAt;
        _sessionDurationSnapshot = "60с";
        await SaveTrainingSessionAsync();
        StateHasChanged();
    }

    public void Dispose()
    {
        _speedTimer?.Stop();
        _speedTimer?.Dispose();
    }

