@page "/training"
@using LearningTrainerWeb.Services
@using LearningTrainerShared.Models
@using LearningTrainerShared.Services
@using Microsoft.AspNetCore.Components
@inject ITrainingApiService TrainingService
@inject IStatisticsApiService StatsService
@inject IAuthService AuthService
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject IAiApiService AiService
@inject IContentApiService ContentApi
@inject IGrammarApiService GrammarService
@implements IDisposable

<PageTitle>Тренировка - Ingat</PageTitle>

<div class="training-container" @onkeydown="HandleKeyDown" tabindex="0" @ref="trainingContainer">
    @if (!IsAuthenticated)
    {
        <!-- Неавторизованный пользователь -->
        <div class="training-guest">
            <div class="guest-hero">
                <div class="guest-icon">
                    <i class="bi bi-mortarboard"></i>
                </div>
                <h1>Начните изучать слова прямо сейчас!</h1>
                <p>Войдите в систему, чтобы начать тренировку и отслеживать свой прогресс</p>
                <div class="guest-actions">
                    <a href="login" class="btn btn-primary btn-lg">
                        <i class="bi bi-box-arrow-in-right me-2"></i>Войти
                    </a>
                    <a href="register" class="btn btn-outline-primary btn-lg">
                        <i class="bi bi-person-plus me-2"></i>Регистрация
                    </a>
                </div>
            </div>
        </div>
    }
    else if (IsLoading)
    {
        <!-- Загрузка -->
        <div class="training-loading">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Загрузка...</span>
            </div>
            <p>Подготовка тренировки...</p>
        </div>
    }
    else if (!IsTrainingActive && (DailyPlan == null || (DailyPlan.Stats.TotalReviewCount == 0 && DailyPlan.Stats.TotalNewCount == 0 && DailyPlan.Stats.TotalDifficultCount == 0)))
    {
        <!-- Пустое состояние - нет слов -->
        <div class="training-empty">
            <div class="empty-icon">
                <i class="bi bi-journal-x"></i>
            </div>
            <h2>У вас пока нет слов для изучения</h2>
            <p>Добавьте словарь или установите стартовый набор, чтобы начать тренировку</p>
            <div class="empty-actions">
                <button class="btn btn-primary btn-lg" @onclick="InstallStarterPack" disabled="@IsInstallingStarter">
                    @if (IsInstallingStarter)
                    {
                        <span class="spinner-border spinner-border-sm me-2"></span>
                    }
                    else
                    {
                        <i class="bi bi-lightning-charge me-2"></i>
                    }
                    Установить стартовый набор
                </button>
                <a href="dictionaries" class="btn btn-outline-primary btn-lg">
                    <i class="bi bi-book me-2"></i>Найти словари
                </a>
            </div>
            @if (!string.IsNullOrEmpty(StarterMessage))
            {
                <div class="alert @(StarterSuccess ? "alert-success" : "alert-danger") mt-3">
                    @StarterMessage
                </div>
            }
        </div>
    }
    else if (!IsTrainingActive)
    {
        <!-- Обзор плана на сегодня -->
        <div class="daily-plan">

            <!-- §12.3 LEARNING_IMPROVEMENTS — Onboarding for new users -->
            <OnboardingOverlay />

            <div class="plan-header">
                <h1>
                    <i class="bi bi-calendar-check me-2"></i>
                    Тренировка на сегодня
                </h1>
                @if (DailyPlan.Stats.CurrentStreak > 0)
                {
                    <div class="streak-badge">
                        <i class="bi bi-fire"></i>
                        <span>@DailyPlan.Stats.CurrentStreak дней подряд!</span>
                    </div>
                }
            </div>

            <div class="plan-stats">
                <div class="stat-card stat-review">
                    <div class="stat-icon">
                        <i class="bi bi-arrow-repeat"></i>
                    </div>
                    <div class="stat-info">
                        <span class="stat-value">@DailyPlan.Stats.TotalReviewCount</span>
                        <span class="stat-label">К повторению</span>
                    </div>
                </div>
                <div class="stat-card stat-new">
                    <div class="stat-icon">
                        <i class="bi bi-plus-circle"></i>
                    </div>
                    <div class="stat-info">
                        <span class="stat-value">@DailyPlan.Stats.TotalNewCount</span>
                        <span class="stat-label">Новых слов</span>
                    </div>
                </div>
                <div class="stat-card stat-difficult">
                    <div class="stat-icon">
                        <i class="bi bi-exclamation-triangle"></i>
                    </div>
                    <div class="stat-info">
                        <span class="stat-value">@DailyPlan.Stats.TotalDifficultCount</span>
                        <span class="stat-label">Сложных</span>
                    </div>
                </div>
                <div class="stat-card stat-completed">
                    <div class="stat-icon">
                        <i class="bi bi-check-circle"></i>
                    </div>
                    <div class="stat-info">
                        <span class="stat-value">@DailyPlan.Stats.CompletedToday</span>
                        <span class="stat-label">Сделано сегодня</span>
                    </div>
                </div>
            </div>

            @* === Дневная цель (P0 LEARNING_IMPROVEMENTS §1.2) === *@
            @if (DailyPlan.Stats.DailyGoal > 0)
            {
                var goalDone = DailyPlan.Stats.CompletedToday;
                var goalTarget = DailyPlan.Stats.DailyGoal;
                var goalPercent = Math.Min(100, goalDone * 100.0 / goalTarget);
                var goalMet = goalDone >= goalTarget;
                var circumference = 2 * Math.PI * 38;
                var dashOffset = circumference - (circumference * goalPercent / 100.0);

                <div class="daily-goal-section @(goalMet ? "daily-goal--done" : "")">
                    <div class="daily-goal-ring">
                        <svg viewBox="0 0 88 88" class="goal-svg">
                            <circle cx="44" cy="44" r="38" fill="none"
                                    stroke="var(--goal-track)" stroke-width="6" />
                            <circle cx="44" cy="44" r="38" fill="none"
                                    stroke="var(--goal-fill)" stroke-width="6"
                                    stroke-linecap="round"
                                    stroke-dasharray="@circumference.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                                    stroke-dashoffset="@dashOffset.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                                    transform="rotate(-90 44 44)"
                                    class="goal-progress-ring" />
                        </svg>
                        <div class="goal-ring-label">
                            @if (goalMet)
                            {
                                <i class="bi bi-check-lg goal-ring-check"></i>
                            }
                            else
                            {
                                <span class="goal-ring-number">@goalDone</span>
                                <span class="goal-ring-of">из @goalTarget</span>
                            }
                        </div>
                    </div>

                    <div class="daily-goal-body">
                        <div class="daily-goal-title">
                            Дневная цель
                            @if (goalMet)
                            {
                                <span class="goal-done-badge"><i class="bi bi-check-circle-fill me-1"></i>Выполнено!</span>
                            }
                        </div>
                        <div class="daily-goal-subtitle">
                            @if (goalMet)
                            {
                                <span>Отлично! Вы повторили <strong>@goalDone</strong> слов сегодня 🎉</span>
                            }
                            else
                            {
                                var remaining = goalTarget - goalDone;
                                <span>Осталось <strong>@remaining</strong> @WordDeclension(remaining) до цели</span>
                            }
                        </div>
                        <div class="daily-goal-bar-wrap">
                            <div class="daily-goal-bar">
                                <div class="daily-goal-bar-fill @(goalMet ? "done" : "")" style="width: @goalPercent.ToString(System.Globalization.CultureInfo.InvariantCulture)%"></div>
                            </div>
                            <span class="daily-goal-bar-label">@((int)goalPercent)%</span>
                        </div>
                    </div>

                    <button class="daily-goal-edit-btn" @onclick="ToggleDailyGoalEditor" title="Изменить цель">
                        <i class="bi bi-pencil"></i>
                    </button>
                </div>

                @if (ShowDailyGoalEditor)
                {
                    <div class="daily-goal-editor">
                        <span class="daily-goal-editor-label">Установить цель:</span>
                        <div class="daily-goal-editor-pills">
                            @foreach (var g in new[] { 5, 10, 15, 20, 30, 50 })
                            {
                                <button class="goal-pill @(goalTarget == g ? "active" : "")"
                                        @onclick="() => UpdateDailyGoal(g)">@g</button>
                            }
                        </div>
                    </div>
                }
            }

            @* === Ежедневный челлендж (§5.2 LEARNING_IMPROVEMENTS) === *@
            @if (DailyChallenge != null)
            {
                <div class="daily-challenge-card @(DailyChallenge.IsCompleted ? "challenge-completed" : "")">
                    <div class="challenge-header">
                        <span class="challenge-icon">@DailyChallenge.Icon</span>
                        <div class="challenge-info">
                            <strong>@DailyChallenge.Title</strong>
                            <span class="text-muted small">@DailyChallenge.Description</span>
                        </div>
                        <span class="challenge-reward">+@DailyChallenge.XpReward XP</span>
                    </div>
                    <div class="progress" style="height: 6px; border-radius: 3px;">
                        <div class="progress-bar @(DailyChallenge.IsCompleted ? "bg-success" : "bg-info")" 
                             style="width: @DailyChallenge.Progress%"></div>
                    </div>
                    <div class="challenge-status small">
                        @if (DailyChallenge.IsCompleted)
                        {
                            <span class="text-success"><i class="bi bi-check-circle-fill me-1"></i>Челлендж выполнен!</span>
                        }
                        else
                        {
                            <span class="text-muted">@DailyChallenge.CurrentValue / @DailyChallenge.TargetValue</span>
                        }
                    </div>
                </div>
            }

            @* === Кнопка быстрой тренировки (§7.3 LEARNING_IMPROVEMENTS) === *@
            @if (DailyPlan.Stats.TotalReviewCount > 0 || DailyPlan.Stats.TotalNewCount > 0)
            {
                <button class="btn btn-outline-primary btn-quick-session" @onclick="StartQuickSession">
                    <i class="bi bi-lightning-charge me-1"></i>Быстрая тренировка (1 мин)
                </button>
            }

            @* === Grammar Due Reviews Widget (§17.7.2 LEARNING_IMPROVEMENTS) === *@
            @if (GrammarDueCount > 0 && GrammarDueReviews?.Rules.Any() == true)
            {
                <div class="grammar-due-widget" @onclick="NavigateToGrammarReview">
                    <div class="grammar-due-icon">
                        <i class="bi bi-book-half"></i>
                    </div>
                    <div class="grammar-due-body">
                        <div class="grammar-due-title">
                            <i class="bi bi-clock-history text-warning me-1"></i>
                            Грамматика: <strong>@GrammarDueCount</strong> @GrammarDueWordForm(GrammarDueCount) к повторению
                        </div>
                        <div class="grammar-due-subtitle text-muted">
                            Следующее: <strong>@GrammarDueReviews.Rules.First().RuleTitle</strong>
                            @if (GrammarDueReviews.Rules.First().OverdueDays > 0)
                            {
                                <span class="text-warning ms-1">(просрочено @GrammarDueReviews.Rules.First().OverdueDays дн.)</span>
                            }
                        </div>
                    </div>
                    <div class="grammar-due-action">
                        <i class="bi bi-play-fill"></i> Повторить
                    </div>
                </div>
            }

            @* === Leech-предупреждение (P0 LEARNING_IMPROVEMENTS §1.1) === *@
            @if (DailyPlan.Stats.LeechCount > 0)
            {
                <div class="leech-alert">
                    <div class="leech-alert-content">
                        <i class="bi bi-bug-fill me-2"></i>
                        <span>
                            <strong>@DailyPlan.Stats.LeechCount</strong> @(DailyPlan.Stats.LeechCount == 1 ? "слово заморожено" : "слов заморожено") 
                            — @(DailyPlan.Stats.LeechCount == 1 ? "оно вызывает" : "они вызывают") постоянные трудности.
                        </span>
                    </div>
                    <button class="btn btn-sm btn-outline-warning" @onclick="ShowLeechManager">
                        <i class="bi bi-tools me-1"></i>Управление
                    </button>
                </div>
            }

            @* === §19.10 Enhanced Leech Manager with AI === *@
            @if (IsLeechManagerVisible && LeechWords.Count > 0)
            {
                <div class="leech-manager">
                    <div class="leech-manager-header">
                        <h4><i class="bi bi-bug me-2"></i>Проблемные слова (@LeechWords.Count)</h4>
                        <button class="btn btn-sm btn-outline-warning" @onclick="TrainAllLeeches" title="Тренировать все">
                            <i class="bi bi-play-fill me-1"></i>Тренировать все
                        </button>
                    </div>
                    <p class="text-muted small mb-3">Эти слова вызывают постоянные трудности. AI подскажет стратегию запоминания.</p>
                    <div class="leech-list">
                        @foreach (var leech in LeechWords)
                        {
                            var accuracy = leech.TotalAttempts > 0
                                ? (double)leech.CorrectAnswers / leech.TotalAttempts * 100
                                : 0;
                            <div class="leech-item">
                                <div class="leech-item-top">
                                    <div class="leech-word">
                                        <strong>@leech.OriginalWord</strong>
                                        <span class="text-muted mx-1">→</span>
                                        <span>@leech.Translation</span>
                                    </div>
                                    <div class="leech-badges">
                                        <span class="badge bg-danger-subtle text-danger">@leech.LapseCount сбросов</span>
                                        <span class="badge bg-warning-subtle text-warning">@accuracy.ToString("F0")%</span>
                                    </div>
                                </div>
                                @if (_leechMnemonics.TryGetValue(leech.WordId, out var mnemonic))
                                {
                                    <div class="leech-ai-tip">
                                        <i class="bi bi-robot me-1"></i>@mnemonic
                                    </div>
                                }
                                else if (_leechMnemonicLoading.Contains(leech.WordId))
                                {
                                    <div class="leech-ai-tip leech-ai-loading">
                                        <span class="spinner-border spinner-border-sm me-1"></span>AI думает...
                                    </div>
                                }
                                <div class="leech-actions">
                                    <button class="btn btn-sm btn-outline-primary" @onclick="() => LoadLeechMnemonic(leech)" title="AI мнемоника">
                                        <i class="bi bi-robot me-1"></i>Мнемоника
                                    </button>
                                    <button class="btn btn-sm btn-outline-success" @onclick="() => UnsuspendWord(leech.WordId)" title="Разморозить">
                                        <i class="bi bi-arrow-counterclockwise me-1"></i>Разморозить
                                    </button>
                                    <button class="btn btn-sm btn-outline-danger" @onclick="() => RemoveFromLearning(leech.WordId)" title="Убрать из обучения">
                                        <i class="bi bi-trash me-1"></i>Убрать
                                    </button>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }

            <div class="training-modes">
                <h3>Выберите режим тренировки</h3>
                <div class="modes-grid">
                    <button class="mode-card" @onclick='() => StartTraining("mixed")' 
                            disabled="@(DailyPlan.Stats.TotalReviewCount == 0 && DailyPlan.Stats.TotalNewCount == 0)">
                        <div class="mode-icon">
                            <i class="bi bi-shuffle"></i>
                        </div>
                        <h4>Смешанный</h4>
                        <p>Повторение + новые слова</p>
                    </button>
                    <button class="mode-card" @onclick='() => StartTraining("review")'
                            disabled="@(DailyPlan.Stats.TotalReviewCount == 0)">
                        <div class="mode-icon">
                            <i class="bi bi-arrow-repeat"></i>
                        </div>
                        <h4>Повторение</h4>
                        <p>Только слова к повторению</p>
                    </button>
                    <button class="mode-card" @onclick='() => StartTraining("new")'
                            disabled="@(DailyPlan.Stats.TotalNewCount == 0)">
                        <div class="mode-icon">
                            <i class="bi bi-plus-circle"></i>
                        </div>
                        <h4>Новые слова</h4>
                        <p>Изучение новых слов</p>
                    </button>
                    <button class="mode-card mode-difficult" @onclick='() => StartTraining("difficult")'
                            disabled="@(DailyPlan.Stats.TotalDifficultCount == 0)">
                        <div class="mode-icon">
                            <i class="bi bi-lightning"></i>
                        </div>
                        <h4>Сложные</h4>
                        <p>Слова с ошибками</p>
                    </button>
                    <button class="mode-card mode-weakness" @onclick='() => StartTraining("weakness")'>
                        <div class="mode-icon">
                            <i class="bi bi-bullseye"></i>
                        </div>
                        <h4>Слабые места</h4>
                        <p>Слова с низкой точностью</p>
                    </button>
                    <button class="mode-card mode-speed" @onclick='() => StartSpeedRound()'
                            disabled="@(DailyPlan.Stats.TotalReviewCount == 0 && DailyPlan.Stats.TotalNewCount == 0)">
                        <div class="mode-icon">
                            <i class="bi bi-stopwatch"></i>
                        </div>
                        <h4>Скорость</h4>
                        <p>60 секунд — максимум слов!</p>
                    </button>
                    <button class="mode-card mode-grammar" @onclick="NavigateToGrammar">
                        <div class="mode-icon">
                            <i class="bi bi-book-half"></i>
                        </div>
                        <h4>Грамматика</h4>
                        <p>Интерактивные упражнения</p>
                        @if (GrammarDueCount > 0)
                        {
                            <span class="badge bg-warning text-dark mt-1">@GrammarDueCount к повторению</span>
                        }
                    </button>
                </div>
                
                <h3 class="mt-4">Тип упражнений</h3>
                <div class="exercise-types-grid">
                    <button class="ex-card @(ExerciseType == "flashcard" ? "ex-card--active" : "")"
                            @onclick='() => SetExerciseType("flashcard")'>
                        <span class="ex-card__emoji">🃏</span>
                        <span class="ex-card__name">Карточки</span>
                        <span class="ex-card__desc">Показал — вспомнил</span>
                        <span class="ex-card__accent ex-card__accent--blue"></span>
                    </button>
                    <button class="ex-card @(ExerciseType == "mcq" ? "ex-card--active" : "")"
                            @onclick='() => SetExerciseType("mcq")'>
                        <span class="ex-card__emoji">🎯</span>
                        <span class="ex-card__name">Тест</span>
                        <span class="ex-card__desc">Выбери верный вариант</span>
                        <span class="ex-card__accent ex-card__accent--green"></span>
                    </button>
                    <button class="ex-card @(ExerciseType == "typing" ? "ex-card--active" : "")"
                            @onclick='() => SetExerciseType("typing")'>
                        <span class="ex-card__emoji">⌨️</span>
                        <span class="ex-card__name">Ввод</span>
                        <span class="ex-card__desc">Напиши перевод сам</span>
                        <span class="ex-card__accent ex-card__accent--purple"></span>
                    </button>
                    <button class="ex-card @(ExerciseType == "listening" ? "ex-card--active" : "")"
                            @onclick='() => SetExerciseType("listening")'>
                        <span class="ex-card__emoji">🎧</span>
                        <span class="ex-card__name">Аудирование</span>
                        <span class="ex-card__desc">Распознай на слух</span>
                        <span class="ex-card__accent ex-card__accent--orange"></span>
                    </button>
                    <button class="ex-card @(ExerciseType == "matching" ? "ex-card--active" : "")"
                            @onclick='() => SetExerciseType("matching")'>
                        <span class="ex-card__emoji">🔗</span>
                        <span class="ex-card__name">Пары</span>
                        <span class="ex-card__desc">Свяжи слово с переводом</span>
                        <span class="ex-card__accent ex-card__accent--pink"></span>
                    </button>
                    <button class="ex-card @(ExerciseType == "cloze" ? "ex-card--active" : "")"
                            @onclick='() => SetExerciseType("cloze")'>
                        <span class="ex-card__emoji">🧩</span>
                        <span class="ex-card__name">Пропуск</span>
                        <span class="ex-card__desc">Заполни пробел в контексте</span>
                        <span class="ex-card__accent ex-card__accent--teal"></span>
                    </button>
                    <button class="ex-card @(ExerciseType == "spelling" ? "ex-card--active" : "")"
                            @onclick='() => SetExerciseType("spelling")'>
                        <span class="ex-card__emoji">🐝</span>
                        <span class="ex-card__name">Spelling Bee</span>
                        <span class="ex-card__desc">Введи слово по буквам</span>
                        <span class="ex-card__accent ex-card__accent--amber"></span>
                    </button>
                    <button class="ex-card ex-card--rainbow @(ExerciseType == "mixed" ? "ex-card--active" : "")"
                            @onclick='() => SetExerciseType("mixed")'>
                        <span class="ex-card__emoji">🎲</span>
                        <span class="ex-card__name">Микс</span>
                        <span class="ex-card__desc">Всё и сразу — рандом!</span>
                        <span class="ex-card__accent ex-card__accent--rainbow"></span>
                    </button>
                </div>

                <!-- Settings -->
                <h3 class="mt-4"><i class="bi bi-sliders me-2"></i>Настройки</h3>
                <div class="training-settings-panel">
                    <div class="setting-group">
                        <span class="setting-label"><i class="bi bi-hash me-1"></i>Количество слов</span>
                        <div class="setting-options">
                            <button class="setting-pill @(WordLimit == 10 ? "active" : "")" @onclick="() => WordLimit = 10">10</button>
                            <button class="setting-pill @(WordLimit == 20 ? "active" : "")" @onclick="() => WordLimit = 20">20</button>
                            <button class="setting-pill @(WordLimit == 50 ? "active" : "")" @onclick="() => WordLimit = 50">50</button>
                            <button class="setting-pill @(WordLimit == 100 ? "active" : "")" @onclick="() => WordLimit = 100">100</button>
                            <button class="setting-pill @(WordLimit == 0 ? "active" : "")" @onclick="() => WordLimit = 0">Все</button>
                        </div>
                    </div>

                    <div class="setting-group">
                        <span class="setting-label"><i class="bi bi-arrow-left-right me-1"></i>Направление</span>
                        <div class="setting-options">
                            <button class="setting-pill @(TranslationDirection == "direct" ? "active" : "")" @onclick='() => TranslationDirection = "direct"'>Прямой</button>
                            <button class="setting-pill @(TranslationDirection == "reverse" ? "active" : "")" @onclick='() => TranslationDirection = "reverse"'>Обратный</button>
                            <button class="setting-pill @(TranslationDirection == "random" ? "active" : "")" @onclick='() => TranslationDirection = "random"'>Случайный</button>
                            <button class="setting-pill @(TranslationDirection == "auto" ? "active" : "")" @onclick='() => TranslationDirection = "auto"' title="Слова с высоким уровнем автоматически переключаются на обратный перевод">Авто ↑</button>
                        </div>
                    </div>

                    @if (AvailableTags.Count > 0)
                    {
                        <div class="setting-group setting-group--dropdown">
                            <span class="setting-label"><i class="bi bi-tags me-1"></i>Тег</span>
                            <div class="filter-dropdown">
                                <button class="filter-dropdown-toggle" @onclick="() => ToggleDropdown(nameof(_tagDropdownOpen))">
                                    <span class="filter-dropdown-value">@(SelectedTag ?? "Все")</span>
                                    <i class="bi bi-chevron-down filter-dropdown-arrow @(_tagDropdownOpen ? "open" : "")"></i>
                                </button>
                                @if (_tagDropdownOpen)
                                {
                                    <div class="filter-dropdown-backdrop" @onclick="() => CloseDropdown(nameof(_tagDropdownOpen))"></div>
                                    <div class="filter-dropdown-menu">
                                        @if (AvailableTags.Count > 5)
                                        {
                                            <div class="filter-dropdown-search">
                                                <i class="bi bi-search"></i>
                                                <input type="text" placeholder="Поиск тега..." @bind="_tagSearch" @bind:event="oninput" />
                                            </div>
                                        }
                                        <div class="filter-dropdown-items">
                                            <button class="filter-dropdown-item @(SelectedTag == null ? "active" : "")"
                                                    @onclick="() => { SelectedTag = null; _tagDropdownOpen = false; _tagSearch = string.Empty; }">
                                                <span>Все</span>
                                                <span class="filter-dropdown-count">@AvailableTags.Count</span>
                                            </button>
                                            @foreach (var tag in FilteredTags)
                                            {
                                                <button class="filter-dropdown-item @(SelectedTag == tag ? "active" : "")"
                                                        @onclick="() => { SelectedTag = tag; SelectedDictionaryId = null; _tagDropdownOpen = false; _tagSearch = string.Empty; }">
                                                    <span>@tag</span>
                                                </button>
                                            }
                                            @if (!FilteredTags.Any())
                                            {
                                                <div class="filter-dropdown-empty">Ничего не найдено</div>
                                            }
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    }

                    @if (AvailableDictionaries.Count > 1)
                    {
                        <div class="setting-group setting-group--dropdown">
                            <span class="setting-label"><i class="bi bi-book me-1"></i>Словарь</span>
                            <div class="filter-dropdown">
                                <button class="filter-dropdown-toggle" @onclick="() => ToggleDropdown(nameof(_dictDropdownOpen))">
                                    <span class="filter-dropdown-value">@(SelectedDictionaryId.HasValue ? AvailableDictionaries.FirstOrDefault(d => d.Id == SelectedDictionaryId.Value)?.Name ?? "Все" : "Все")</span>
                                    <i class="bi bi-chevron-down filter-dropdown-arrow @(_dictDropdownOpen ? "open" : "")"></i>
                                </button>
                                @if (_dictDropdownOpen)
                                {
                                    <div class="filter-dropdown-backdrop" @onclick="() => CloseDropdown(nameof(_dictDropdownOpen))"></div>
                                    <div class="filter-dropdown-menu">
                                        @if (AvailableDictionaries.Count > 5)
                                        {
                                            <div class="filter-dropdown-search">
                                                <i class="bi bi-search"></i>
                                                <input type="text" placeholder="Поиск словаря..." @bind="_dictSearch" @bind:event="oninput" />
                                            </div>
                                        }
                                        <div class="filter-dropdown-items">
                                            <button class="filter-dropdown-item @(SelectedDictionaryId == null ? "active" : "")"
                                                    @onclick="() => { SelectedDictionaryId = null; _dictDropdownOpen = false; _dictSearch = string.Empty; }">
                                                <span>Все</span>
                                                <span class="filter-dropdown-count">@AvailableDictionaries.Sum(d => d.WordCount) слов</span>
                                            </button>
                                            @foreach (var dict in FilteredDictionaries)
                                            {
                                                <button class="filter-dropdown-item @(SelectedDictionaryId == dict.Id ? "active" : "")"
                                                        @onclick="() => { SelectedDictionaryId = dict.Id; SelectedTag = null; _dictDropdownOpen = false; _dictSearch = string.Empty; }">
                                                    <span>@dict.Name</span>
                                                    <span class="filter-dropdown-count">@dict.WordCount слов</span>
                                                </button>
                                            }
                                            @if (!FilteredDictionaries.Any())
                                            {
                                                <div class="filter-dropdown-empty">Ничего не найдено</div>
                                            }
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    }

                    <div class="setting-group">
                        <span class="setting-label"><i class="bi bi-shield me-1"></i>Режим</span>
                        <div class="setting-options">
                            <button class="setting-pill @(!IsExamMode ? "active" : "")" @onclick="() => IsExamMode = false">Обычный</button>
                            <button class="setting-pill @(IsExamMode ? "active" : "")" @onclick="() => IsExamMode = true" title="Без подсказок: скрывает транскрипцию, словарь и TTS до ответа">🔒 Экзамен</button>
                        </div>
                    </div>
                </div>
            </div>

            @if (!IsEdgeBrowser && !TtsTipDismissed)
            {
                <div class="tts-browser-tip">
                    <div class="tts-browser-tip-content">
                        <i class="bi bi-volume-up-fill me-2"></i>
                        <span>Для лучшего звучания (нейросетевые голоса) рекомендуем использовать браузер <strong>Microsoft Edge</strong>.</span>
                    </div>
                    <button class="tts-browser-tip-close" @onclick="DismissTtsTip" title="Закрыть">
                        <i class="bi bi-x-lg"></i>
                    </button>
                </div>
            }

            <div class="quick-start">
                <button class="btn btn-primary btn-xl" @onclick='() => StartTraining("mixed")'
                        disabled="@(DailyPlan.Stats.TotalReviewCount == 0 && DailyPlan.Stats.TotalNewCount == 0)">
                    <i class="bi bi-play-fill me-2"></i>
                    Начать тренировку
                </button>
            </div>
        </div>
    }
    else
    {
        <!-- Активная тренировка -->
        <div class="training-session">
            @if (ShowPomodoroBreak)
            {
                <!-- Помодоро-напоминание (#19 LEARNING_IMPROVEMENTS) -->
                <div class="pomodoro-break">
                    <div class="pomodoro-icon">🧘</div>
                    <h2>Время для перерыва!</h2>
                    <p>Вы занимаетесь уже 25 минут. Короткий отдых улучшит запоминание.</p>
                    <div class="pomodoro-stats">
                        <span><i class="bi bi-check-circle text-success"></i> @CorrectCount правильно</span>
                        <span><i class="bi bi-journal-text"></i> @(CurrentIndex) из @TrainingWords.Count слов</span>
                    </div>
                    <div class="pomodoro-actions">
                        <button class="btn btn-primary btn-lg" @onclick="DismissPomodoroBreak">
                            <i class="bi bi-play-fill me-2"></i>Продолжить
                        </button>
                        <button class="btn btn-outline-secondary btn-lg" @onclick="BackToPlan">
                            <i class="bi bi-house me-2"></i>Завершить
                        </button>
                    </div>
                </div>
            }
            else if (CurrentWord != null)
            {
                <div class="session-progress">
                    <div class="progress-info">
                        @if (IsSpeedRound)
                        {
                            <span class="speed-timer @(SpeedRoundTimeLeft <= 10 ? "speed-timer-danger" : "")">
                                <i class="bi bi-stopwatch me-1"></i>@SpeedRoundTimeLeft с
                            </span>
                            <span class="speed-score">
                                <i class="bi bi-lightning-fill text-warning"></i> @SpeedRoundScore очков
                            </span>
                        }
                        else if (_isErrorReplay)
                        {
                            <span><i class="bi bi-arrow-repeat me-1"></i>Работа над ошибками</span>
                        }
                        else
                        {
                            <span>Слово @(CurrentIndex + 1) из @TrainingWords.Count</span>
                        }
                        <span class="correct-count">
                            <i class="bi bi-check-circle text-success"></i> @CorrectCount
                        </span>
                    </div>
                    @if (!IsSpeedRound)
                    {
                        <div class="progress">
                            <div class="progress-bar" style="width: @((CurrentIndex + 1) * 100.0 / TrainingWords.Count)%"></div>
                        </div>
                    }
                    else
                    {
                        <div class="progress">
                            <div class="progress-bar bg-warning" style="width: @(SpeedRoundTimeLeft * 100.0 / 60)%"></div>
                        </div>
                    }
                    @* §1.2 Error Replay Queue: banner during error replay phase *@
                    @if (_isErrorReplay)
                    {
                        <div class="alert alert-info py-2 mb-2 mt-2 d-flex align-items-center gap-2" style="font-size: 0.9rem;">
                            <i class="bi bi-arrow-repeat"></i>
                            <span><strong>Работа над ошибками:</strong> @(_againQueue.Count + 1) @GetWordDeclension(_againQueue.Count + 1) — другой режим для лучшего запоминания</span>
                        </div>
                    }
                    <!-- Индикатор мастерства текущего слова (#10 LEARNING_IMPROVEMENTS) -->
                    <div class="word-mastery-indicator">
                        <span class="mastery-stars" title="Уровень знания: @CurrentWord.KnowledgeLevel">
                            @for (int i = 0; i < 5; i++)
                            {
                                if (i < CurrentWord.MasteryStars)
                                {
                                    <i class="bi bi-circle-fill mastery-star-@GetMasteryColor(CurrentWord.MasteryStars)"></i>
                                }
                                else
                                {
                                    <i class="bi bi-circle mastery-star-empty"></i>
                                }
                            }
                        </span>
                        @if (CurrentWord.SuccessRate.HasValue)
                        {
                            <span class="mastery-rate" title="Точность ответов">@CurrentWord.SuccessRate.Value.ToString("F0")%</span>
                        }
                        else
                        {
                            <span class="mastery-rate new-word">новое</span>
                        }
                    </div>
                </div>

                @if (ActiveExerciseType == "flashcard")
                {
                    <!-- Режим карточек -->
                    <div class="flashcard @(IsAnswerRevealed ? "revealed" : "")">
                        <div class="card-front">
                            @if (!IsExamMode)
                            {
                                <div class="word-dictionary">
                                    <i class="bi bi-book"></i> @CurrentWord.DictionaryName
                                </div>
                            }
                            <div class="word-main">@DisplayedWord</div>
                            @if (!IsExamMode && !IsReversed && !string.IsNullOrEmpty(CurrentWord.Transcription))
                            {
                                <div class="word-transcription">@CurrentWord.Transcription</div>
                            }
                            @if (!IsExamMode || IsAnswerRevealed)
                            {
                            <div class="audio-group">
                                <button class="btn-tts" @onclick="SpeakWord" title="Прослушать">
                                    <i class="bi bi-volume-up-fill"></i>
                                </button>

                                <div class="volume-wrapper">
                                    <button class="btn-volume-toggle" @onclick="ToggleVolumeSlider" title="Громкость">
                                        <i class="@VolumeIcon"></i>
                                    </button>

                                    @if (ShowVolumeSlider)
                                    {
                                        <div class="volume-popover">
                                            <input type="range" 
                                                   min="0" max="1" step="0.01" 
                                                   value="@TtsVolumeFormatted" 
                                                   @oninput="OnVolumeChanged" />
                                            <span class="volume-value">@TtsVolumePercent%</span>
                                        </div>
                                    }
                                </div>
                            </div>
                            }
                            @if (!IsAnswerRevealed)
                            {
                                <button class="btn btn-outline-primary btn-lg mt-4" @onclick="RevealAnswer">
                                    <i class="bi bi-eye me-2"></i>Показать ответ
                                </button>
                            }
                        </div>

                        @if (IsAnswerRevealed)
                        {
                            <div class="card-back">
                                <div class="translation">@ExpectedAnswer</div>
                                @if (!string.IsNullOrEmpty(CurrentWord.Example))
                                {
                                    <div class="example">
                                        <i class="bi bi-chat-quote"></i> @CurrentWord.Example
                                        <button class="btn-tts-sm" @onclick="SpeakExample" title="Прослушать пример">
                                            <i class="bi bi-volume-up"></i>
                                        </button>
                                    </div>
                                }

                                @* === Персональная заметка (§8.3 LEARNING_IMPROVEMENTS) === *@
                                <div class="user-note-section">
                                    @if (IsEditingNote)
                                    {
                                        <div class="user-note-editor">
                                            <textarea class="form-control form-control-sm" rows="2" maxlength="500"
                                                      placeholder="Мнемоника, ассоциация, заметка..."
                                                      @bind="EditingNoteText"></textarea>
                                            <div class="user-note-editor-actions">
                                                <button class="btn btn-sm btn-primary" @onclick="SaveNote" disabled="@IsSavingNote">
                                                    @if (IsSavingNote) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                                    <i class="bi bi-check-lg me-1"></i>Сохранить
                                                </button>
                                                <button class="btn btn-sm btn-outline-secondary" @onclick="CancelNoteEdit">Отмена</button>
                                            </div>
                                        </div>
                                    }
                                    else if (!string.IsNullOrEmpty(CurrentWord.UserNote))
                                    {
                                        <div class="user-note-display" @onclick="StartNoteEdit">
                                            <i class="bi bi-sticky me-1"></i>
                                            <span>@CurrentWord.UserNote</span>
                                            <button class="btn-note-edit" title="Редактировать заметку">
                                                <i class="bi bi-pencil"></i>
                                            </button>
                                        </div>
                                    }
                                    else
                                    {
                                        <button class="btn-add-note" @onclick="StartNoteEdit" title="Добавить заметку">
                                            <i class="bi bi-sticky me-1"></i>Добавить заметку
                                        </button>
                                    }
                                </div>

                                @if (CurrentWord.RelatedRuleId.HasValue)
                                {
                                    <a href="/grammar/@CurrentWord.RelatedRuleId" class="btn btn-sm btn-outline-info mt-1" title="Связанное грамматическое правило">
                                        <i class="bi bi-journal-bookmark me-1"></i>@(CurrentWord.RelatedRuleTitle ?? "Правило")
                                    </a>
                                }
                            </div>

                            <div class="answer-buttons">
                                @if (IsSpeedRound)
                                {
                                    <button class="btn btn-answer btn-again btn-lg" @onclick="() => SpeedRoundAnswer(false)" title="Клавиша 1">
                                        <i class="bi bi-x-lg"></i>
                                        <span>Не знаю</span>
                                        <small>1</small>
                                    </button>
                                    <button class="btn btn-answer btn-good btn-lg" @onclick="() => SpeedRoundAnswer(true)" title="Клавиша 2">
                                        <i class="bi bi-check-lg"></i>
                                        <span>Знаю</span>
                                        <small>2</small>
                                    </button>
                                }
                                else
                                {
                                <button class="btn btn-answer btn-again" @onclick="() => SubmitAnswer(ResponseQuality.Again)" title="Клавиша 1">
                                    <i class="bi bi-x-lg"></i>
                                    <span>Не знаю</span>
                                    <small>1</small>
                                </button>
                                <button class="btn btn-answer btn-hard" @onclick="() => SubmitAnswer(ResponseQuality.Hard)" title="Клавиша 2">
                                    <i class="bi bi-emoji-frown"></i>
                                    <span>Сложно</span>
                                    <small>2</small>
                                </button>
                                <button class="btn btn-answer btn-good" @onclick="() => SubmitAnswer(ResponseQuality.Good)" title="Клавиша 3">
                                    <i class="bi bi-emoji-smile"></i>
                                    <span>Хорошо</span>
                                    <small>3</small>
                                </button>
                                <button class="btn btn-answer btn-easy" @onclick="() => SubmitAnswer(ResponseQuality.Easy)" title="Клавиша 4">
                                    <i class="bi bi-emoji-laughing"></i>
                                    <span>Легко</span>
                                    <small>4</small>
                                </button>
                                }
                            </div>
                            <div class="keyboard-hints">
                                <span><kbd>Space</kbd> показать ответ</span>
                                <span><kbd>1-4</kbd> выбор оценки</span>
                            </div>
                        }
                    </div>
                }
                else if (ActiveExerciseType == "mcq")
                {
                    <!-- Режим выбора ответа (MCQ) -->
                    <div class="mcq-card">
                        <div class="mcq-question">
                            <div class="word-dictionary">
                                <i class="bi bi-book"></i> @CurrentWord.DictionaryName
                            </div>
                            <div class="word-main">@DisplayedWord</div>
                            @if (!IsReversed && !string.IsNullOrEmpty(CurrentWord.Transcription))
                            {
                                <div class="word-transcription">@CurrentWord.Transcription</div>
                            }
                            <div class="audio-group">
                                <button class="btn-tts" @onclick="SpeakWord" title="Прослушать">
                                    <i class="bi bi-volume-up-fill"></i>
                                </button>
                                <div class="volume-wrapper">
                                    <button class="btn-volume-toggle" @onclick="ToggleVolumeSlider" title="Громкость">
                                        <i class="@VolumeIcon"></i>
                                    </button>
                                    @if (ShowVolumeSlider)
                                    {
                                        <div class="volume-popover">
                                            <input type="range" min="0" max="1" step="0.01"
                                                   value="@TtsVolumeFormatted"
                                                   @oninput="OnVolumeChanged" />
                                            <span class="volume-value">@TtsVolumePercent%</span>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>

                        <div class="mcq-options">
                            @foreach (var option in McqOptions)
                            {
                                var isSelected = SelectedMcqOption == option;
                                var isCorrect = option == ExpectedAnswer;
                                var cssClass = "";
                                
                                if (McqAnswered)
                                {
                                    if (isCorrect)
                                        cssClass = "correct";
                                    else if (isSelected && !isCorrect)
                                        cssClass = "incorrect";
                                }
                                else if (isSelected)
                                {
                                    cssClass = "selected";
                                }

                                <button class="mcq-option @cssClass" 
                                        @onclick="() => SelectMcqOption(option)"
                                        disabled="@McqAnswered">
                                    <span class="option-text">@option</span>
                                    @if (McqAnswered && isCorrect)
                                    {
                                        <i class="bi bi-check-circle-fill"></i>
                                    }
                                    else if (McqAnswered && isSelected && !isCorrect)
                                    {
                                        <i class="bi bi-x-circle-fill"></i>
                                    }
                                </button>
                            }
                        </div>

                        @if (McqAnswered)
                        {
                            <div class="mcq-feedback @(McqWasCorrect ? "success" : "error")">
                                @if (McqWasCorrect)
                                {
                                    <i class="bi bi-check-circle"></i>
                                    <span>Правильно!</span>
                                }
                                else
                                {
                                    <i class="bi bi-x-circle"></i>
                                    <span>Неверно. Правильный ответ: @ExpectedAnswer</span>
                                }
                            </div>
                            @if (!McqWasCorrect)
                            {
                                <div class="ai-card mt-3">
                                    <div class="ai-card-header">
                                        <i class="bi bi-stars"></i>
                                        <span>Помощник ИИ</span>
                                    </div>

                                    @if (IsLoadingAiExplanation)
                                    {
                                        <div class="ai-card-loading">
                                            <span class="spinner-border spinner-border-sm"></span>
                                            Анализирую ошибку...
                                        </div>
                                    }
                                    else if (!string.IsNullOrEmpty(AiExplanation))
                                    {
                                        <div class="ai-section ai-section-explanation">
                                            <div class="ai-section-icon"><i class="bi bi-chat-left-text"></i></div>
                                            <div class="ai-section-content">
                                                <div class="ai-section-label">Разбор ошибки</div>
                                                <div>@AiExplanation</div>
                                            </div>
                                        </div>
                                        @if (!string.IsNullOrEmpty(AiTip))
                                        {
                                            <div class="ai-section ai-section-tip">
                                                <div class="ai-section-icon"><i class="bi bi-translate"></i></div>
                                                <div class="ai-section-content">
                                                    <div class="ai-section-label">Пример</div>
                                                    <div>@AiTip</div>
                                                </div>
                                            </div>
                                        }
                                    }

                                    @if (!IsLoadingMnemonic && string.IsNullOrEmpty(AiMnemonic))
                                    {
                                        <div class="ai-section-action">
                                            <button class="btn btn-sm btn-outline-secondary" @onclick="LoadMnemonic">
                                                <i class="bi bi-magic me-1"></i>Подсказка для запоминания
                                            </button>
                                        </div>
                                    }
                                    else if (IsLoadingMnemonic)
                                    {
                                        <div class="ai-card-loading">
                                            <span class="spinner-border spinner-border-sm"></span>
                                            Генерация мнемоники...
                                        </div>
                                    }
                                    else if (!string.IsNullOrEmpty(AiMnemonic))
                                    {
                                        <div class="ai-section ai-section-mnemonic">
                                            <div class="ai-section-icon"><i class="bi bi-lightbulb"></i></div>
                                            <div class="ai-section-content">
                                                <div class="ai-section-label">Запоминание</div>
                                                <div>@AiMnemonic</div>
                                            </div>
                                        </div>
                                        @if (!string.IsNullOrEmpty(AiEtymology))
                                        {
                                            <div class="ai-section ai-section-etymology">
                                                <div class="ai-section-icon"><i class="bi bi-book"></i></div>
                                                <div class="ai-section-content">
                                                    <div class="ai-section-label">Происхождение</div>
                                                    <div>@AiEtymology</div>
                                                </div>
                                            </div>
                                        }
                                        @if (!string.IsNullOrEmpty(AiAssociation))
                                        {
                                            <div class="ai-section ai-section-association">
                                                <div class="ai-section-icon"><i class="bi bi-link-45deg"></i></div>
                                                <div class="ai-section-content">
                                                    <div class="ai-section-label">Ассоциация</div>
                                                    <div>@AiAssociation</div>
                                                </div>
                                            </div>
                                        }
                                    }
                                </div>
                            }
                            @if (!string.IsNullOrEmpty(CurrentWord.Example))
                            {
                                <div class="example mt-2">
                                    <i class="bi bi-chat-quote"></i> @CurrentWord.Example
                                    <button class="btn-tts-sm" @onclick="SpeakExample" title="Прослушать пример">
                                        <i class="bi bi-volume-up"></i>
                                    </button>
                                </div>
                            }

                            @* === Grammar Hint on Error (§17.6.1 LEARNING_IMPROVEMENTS) === *@
                            @if (!McqWasCorrect && CurrentWord.RelatedRuleId.HasValue)
                            {
                                <div class="grammar-hint-block mt-2">
                                    <i class="bi bi-journal-bookmark me-1"></i>
                                    <span>Связанное правило: <strong>@(CurrentWord.RelatedRuleTitle ?? "Грамматика")</strong></span>
                                    <a href="/grammar/@CurrentWord.RelatedRuleId?mode=review" class="btn btn-sm btn-outline-info ms-2">
                                        <i class="bi bi-arrow-right me-1"></i>Повторить
                                    </a>
                                </div>
                            }

                            @* === Персональная заметка (§8.3) — MCQ === *@
                            <div class="user-note-section">
                                @if (IsEditingNote)
                                {
                                    <div class="user-note-editor">
                                        <textarea class="form-control form-control-sm" rows="2" maxlength="500"
                                                  placeholder="Мнемоника, ассоциация, заметка..."
                                                  @bind="EditingNoteText"></textarea>
                                        <div class="user-note-editor-actions">
                                            <button class="btn btn-sm btn-primary" @onclick="SaveNote" disabled="@IsSavingNote">
                                                @if (IsSavingNote) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                                <i class="bi bi-check-lg me-1"></i>Сохранить
                                            </button>
                                            <button class="btn btn-sm btn-outline-secondary" @onclick="CancelNoteEdit">Отмена</button>
                                        </div>
                                    </div>
                                }
                                else if (!string.IsNullOrEmpty(CurrentWord.UserNote))
                                {
                                    <div class="user-note-display" @onclick="StartNoteEdit">
                                        <i class="bi bi-sticky me-1"></i>
                                        <span>@CurrentWord.UserNote</span>
                                        <button class="btn-note-edit" title="Редактировать заметку">
                                            <i class="bi bi-pencil"></i>
                                        </button>
                                    </div>
                                }
                                else
                                {
                                    <button class="btn-add-note" @onclick="StartNoteEdit" title="Добавить заметку">
                                        <i class="bi bi-sticky me-1"></i>Добавить заметку
                                    </button>
                                }
                            </div>

                            <button class="btn btn-primary btn-lg mt-3" @onclick="NextMcqWord">
                                <i class="bi bi-arrow-right me-2"></i>Далее
                            </button>
                        }
                    </div>
                }
                else if (ActiveExerciseType == "typing")
                {
                    <!-- Режим ввода ответа -->
                    <div class="typing-card">
                        <div class="typing-question">
                            <div class="word-dictionary">
                                <i class="bi bi-book"></i> @CurrentWord.DictionaryName
                            </div>
                            <div class="word-main">@DisplayedWord</div>
                            @if (!IsReversed && !string.IsNullOrEmpty(CurrentWord.Transcription))
                            {
                                <div class="word-transcription">@CurrentWord.Transcription</div>
                            }
                            <div class="audio-group">
                                <button class="btn-tts" @onclick="SpeakWord" title="Прослушать">
                                    <i class="bi bi-volume-up-fill"></i>
                                </button>
                                <div class="volume-wrapper">
                                    <button class="btn-volume-toggle" @onclick="ToggleVolumeSlider" title="Громкость">
                                        <i class="@VolumeIcon"></i>
                                    </button>
                                    @if (ShowVolumeSlider)
                                    {
                                        <div class="volume-popover">
                                            <input type="range" min="0" max="1" step="0.01"
                                                   value="@TtsVolumeFormatted"
                                                   @oninput="OnVolumeChanged" />
                                            <span class="volume-value">@TtsVolumePercent%</span>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>

                        <div class="typing-input">
                            <input type="text" class="form-control form-control-lg @(TypingAnswered ? (TypingWasCorrect ? "is-valid" : (TypingWasAlmostCorrect ? "is-almost" : "is-invalid")) : "")"
                                   placeholder="Введите перевод..."
                                   @bind="TypedAnswer"
                                   @bind:event="oninput"
                                   @onkeypress="HandleTypingKeyPress"
                                   disabled="@TypingAnswered" />

                            @if (!TypingAnswered)
                            {
                                <div class="d-flex align-items-center gap-2 justify-content-center">
                                    <button class="btn btn-outline-secondary" @onclick="UseHint" disabled="@(!CanUseHint)" title="Контекстная подсказка (снижает оценку до «Сложно»)">
                                        <i class="bi bi-lightbulb me-1"></i>Подсказка
                                        @if (_hintCount > 0) { <span class="badge bg-warning text-dark ms-1">@_hintCount/4</span> }
                                    </button>
                                    <button class="btn btn-primary btn-lg" @onclick="CheckTypingAnswer">
                                        <i class="bi bi-check-lg me-2"></i>Проверить
                                    </button>
                                </div>
                            }
                        </div>
                        @if (HintUsed && !TypingAnswered)
                        {
                            <div class="hint-display mt-2 p-2 rounded" style="background: var(--bs-primary-bg-subtle, #e7f1ff); border-left: 3px solid var(--bs-primary, #0d6efd);">
                                <span style="font-style: italic;">@HintText</span>
                            </div>
                        }

                        @if (TypingAnswered)
                        {
                            <div class="typing-feedback @(TypingWasCorrect ? "success" : (TypingWasAlmostCorrect ? "almost" : "error"))">
                                @if (TypingWasCorrect)
                                {
                                    <i class="bi bi-check-circle"></i>
                                    <span>Правильно!</span>
                                }
                                else if (TypingWasAlmostCorrect)
                                {
                                    <i class="bi bi-lightning-charge"></i>
                                    <span>Почти правильно! Ответ: <strong>@ExpectedAnswer</strong></span>
                                }
                                else
                                {
                                    <i class="bi bi-x-circle"></i>
                                    <span>Неверно. Правильный ответ: <strong>@ExpectedAnswer</strong></span>
                                }
                            </div>
                            @if (!TypingWasCorrect && TypingDiffUserSegments.Count > 0)
                            {
                                <div class="diff-feedback mt-2">
                                    @if (!string.IsNullOrEmpty(TypingErrorCategory))
                                    {
                                        <div class="diff-category-badge mb-2">
                                            <span class="badge bg-warning-subtle text-warning">@TypingErrorCategory</span>
                                        </div>
                                    }
                                    <div class="diff-line">
                                        <span class="diff-label">Ваш ввод:</span>
                                        @foreach (var seg in TypingDiffUserSegments)
                                        {
                                            <span class="diff-char diff-@seg.Status.ToString().ToLowerInvariant()">@seg.Text</span>
                                        }
                                    </div>
                                    <div class="diff-line">
                                        <span class="diff-label">Верно:</span>
                                        @foreach (var seg in TypingDiffCorrectSegments)
                                        {
                                            <span class="diff-char diff-@seg.Status.ToString().ToLowerInvariant()">@seg.Text</span>
                                        }
                                    </div>
                                </div>
                            }
                            @if (!TypingWasCorrect)
                            {
                                <div class="ai-card mt-3">
                                    <div class="ai-card-header">
                                        <i class="bi bi-stars"></i>
                                        <span>Помощник ИИ</span>
                                    </div>

                                    @if (IsLoadingAiExplanation)
                                    {
                                        <div class="ai-card-loading">
                                            <span class="spinner-border spinner-border-sm"></span>
                                            Анализирую ошибку...
                                        </div>
                                    }
                                    else if (!string.IsNullOrEmpty(AiExplanation))
                                    {
                                        <div class="ai-section ai-section-explanation">
                                            <div class="ai-section-icon"><i class="bi bi-chat-left-text"></i></div>
                                            <div class="ai-section-content">
                                                <div class="ai-section-label">Разбор ошибки</div>
                                                <div>@AiExplanation</div>
                                            </div>
                                        </div>
                                        @if (!string.IsNullOrEmpty(AiTip))
                                        {
                                            <div class="ai-section ai-section-tip">
                                                <div class="ai-section-icon"><i class="bi bi-translate"></i></div>
                                                <div class="ai-section-content">
                                                    <div class="ai-section-label">Пример</div>
                                                    <div>@AiTip</div>
                                                </div>
                                            </div>
                                        }
                                    }

                                    @if (!IsLoadingMnemonic && string.IsNullOrEmpty(AiMnemonic))
                                    {
                                        <div class="ai-section-action">
                                            <button class="btn btn-sm btn-outline-secondary" @onclick="LoadMnemonic">
                                                <i class="bi bi-magic me-1"></i>Подсказка для запоминания
                                            </button>
                                        </div>
                                    }
                                    else if (IsLoadingMnemonic)
                                    {
                                        <div class="ai-card-loading">
                                            <span class="spinner-border spinner-border-sm"></span>
                                            Генерация мнемоники...
                                        </div>
                                    }
                                    else if (!string.IsNullOrEmpty(AiMnemonic))
                                    {
                                        <div class="ai-section ai-section-mnemonic">
                                            <div class="ai-section-icon"><i class="bi bi-lightbulb"></i></div>
                                            <div class="ai-section-content">
                                                <div class="ai-section-label">Запоминание</div>
                                                <div>@AiMnemonic</div>
                                            </div>
                                        </div>
                                        @if (!string.IsNullOrEmpty(AiEtymology))
                                        {
                                            <div class="ai-section ai-section-etymology">
                                                <div class="ai-section-icon"><i class="bi bi-book"></i></div>
                                                <div class="ai-section-content">
                                                    <div class="ai-section-label">Происхождение</div>
                                                    <div>@AiEtymology</div>
                                                </div>
                                            </div>
                                        }
                                        @if (!string.IsNullOrEmpty(AiAssociation))
                                        {
                                            <div class="ai-section ai-section-association">
                                                <div class="ai-section-icon"><i class="bi bi-link-45deg"></i></div>
                                                <div class="ai-section-content">
                                                    <div class="ai-section-label">Ассоциация</div>
                                                    <div>@AiAssociation</div>
                                                </div>
                                            </div>
                                        }
                                    }
                                </div>
                            }
                            @if (!string.IsNullOrEmpty(CurrentWord.Example))
                            {
                                <div class="example mt-2">
                                    <i class="bi bi-chat-quote"></i> @CurrentWord.Example
                                    <button class="btn-tts-sm" @onclick="SpeakExample" title="Прослушать пример">
                                        <i class="bi bi-volume-up"></i>
                                    </button>
                                </div>
                            }

                            @* === Grammar Hint on Error (§17.6.1 LEARNING_IMPROVEMENTS) — Typing === *@
                            @if (!TypingWasCorrect && CurrentWord.RelatedRuleId.HasValue)
                            {
                                <div class="grammar-hint-block mt-2">
                                    <i class="bi bi-journal-bookmark me-1"></i>
                                    <span>Связанное правило: <strong>@(CurrentWord.RelatedRuleTitle ?? "Грамматика")</strong></span>
                                    <a href="/grammar/@CurrentWord.RelatedRuleId?mode=review" class="btn btn-sm btn-outline-info ms-2">
                                        <i class="bi bi-arrow-right me-1"></i>Повторить
                                    </a>
                                </div>
                            }

                            <button class="btn btn-primary btn-lg mt-3" @onclick="NextTypingWord">
                                <i class="bi bi-arrow-right me-2"></i>Далее
                            </button>
                        }
                    </div>
                }
                else if (ActiveExerciseType == "listening")
                {
                    <!-- Режим аудирования -->
                    <div class="typing-card">
                        <div class="typing-question">
                            <div class="word-dictionary">
                                <i class="bi bi-book"></i> @CurrentWord.DictionaryName
                            </div>
                            <div class="listening-icon" style="font-size: 3rem; margin: 1rem 0;">
                                <i class="bi bi-headphones" style="color: var(--bs-primary);"></i>
                            </div>
                            <p class="text-muted mb-3">Прослушайте слово и введите его</p>
                            <div class="audio-group">
                                <button class="btn btn-outline-primary btn-lg" @onclick="SpeakWord" title="Прослушать">
                                    <i class="bi bi-play-fill me-2"></i>Прослушать
                                </button>
                                <div class="volume-wrapper ms-2">
                                    <button class="btn-volume-toggle" @onclick="ToggleVolumeSlider" title="Громкость">
                                        <i class="@VolumeIcon"></i>
                                    </button>
                                    @if (ShowVolumeSlider)
                                    {
                                        <div class="volume-popover">
                                            <input type="range" min="0" max="1" step="0.01"
                                                   value="@TtsVolumeFormatted"
                                                   @oninput="OnVolumeChanged" />
                                            <span class="volume-value">@TtsVolumePercent%</span>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>

                        <div class="typing-input">
                            <input type="text" class="form-control form-control-lg @(ListeningAnswered ? (ListeningWasCorrect ? "is-valid" : (ListeningWasAlmostCorrect ? "is-almost" : "is-invalid")) : "")"
                                   placeholder="Введите услышанное слово..."
                                   @bind="ListeningTypedAnswer"
                                   @bind:event="oninput"
                                   @onkeypress="HandleListeningKeyPress"
                                   disabled="@ListeningAnswered" />

                            @if (!ListeningAnswered)
                            {
                                <button class="btn btn-primary btn-lg" @onclick="CheckListeningAnswer">
                                    <i class="bi bi-check-lg me-2"></i>Проверить
                                </button>
                            }
                        </div>

                        @if (ListeningAnswered)
                        {
                            <div class="typing-feedback @(ListeningWasCorrect ? "success" : (ListeningWasAlmostCorrect ? "almost" : "error"))">
                                @if (ListeningWasCorrect)
                                {
                                    <i class="bi bi-check-circle"></i>
                                    <span>Правильно!</span>
                                }
                                else if (ListeningWasAlmostCorrect)
                                {
                                    <i class="bi bi-lightning-charge"></i>
                                    <span>Почти правильно! Ответ: <strong>@CurrentWord.OriginalWord</strong></span>
                                }
                                else
                                {
                                    <i class="bi bi-x-circle"></i>
                                    <span>Неверно. Правильный ответ: <strong>@CurrentWord.OriginalWord</strong></span>
                                }
                            </div>
                            @if (!ListeningWasCorrect && ListeningDiffUserSegments.Count > 0)
                            {
                                <div class="diff-feedback mt-2">
                                    @if (!string.IsNullOrEmpty(ListeningErrorCategory))
                                    {
                                        <div class="diff-category-badge mb-2">
                                            <span class="badge bg-warning-subtle text-warning">@ListeningErrorCategory</span>
                                        </div>
                                    }
                                    <div class="diff-line">
                                        <span class="diff-label">Ваш ввод:</span>
                                        @foreach (var seg in ListeningDiffUserSegments)
                                        {
                                            <span class="diff-char diff-@seg.Status.ToString().ToLowerInvariant()">@seg.Text</span>
                                        }
                                    </div>
                                    <div class="diff-line">
                                        <span class="diff-label">Верно:</span>
                                        @foreach (var seg in ListeningDiffCorrectSegments)
                                        {
                                            <span class="diff-char diff-@seg.Status.ToString().ToLowerInvariant()">@seg.Text</span>
                                        }
                                    </div>
                                </div>
                            }
                            @if (!string.IsNullOrEmpty(CurrentWord.Translation))
                            {
                                <div class="mt-2 text-muted">
                                    <i class="bi bi-translate me-1"></i> @CurrentWord.Translation
                                </div>
                            }
                            @if (!string.IsNullOrEmpty(CurrentWord.Example))
                            {
                                <div class="example mt-2">
                                    <i class="bi bi-chat-quote"></i> @CurrentWord.Example
                                    <button class="btn-tts-sm" @onclick="SpeakExample" title="Прослушать пример">
                                        <i class="bi bi-volume-up"></i>
                                    </button>
                                </div>
                            }

                            @* === Grammar Hint on Error (§17.6.1 LEARNING_IMPROVEMENTS) — Listening === *@
                            @if (!ListeningWasCorrect && CurrentWord.RelatedRuleId.HasValue)
                            {
                                <div class="grammar-hint-block mt-2">
                                    <i class="bi bi-journal-bookmark me-1"></i>
                                    <span>Связанное правило: <strong>@(CurrentWord.RelatedRuleTitle ?? "Грамматика")</strong></span>
                                    <a href="/grammar/@CurrentWord.RelatedRuleId?mode=review" class="btn btn-sm btn-outline-info ms-2">
                                        <i class="bi bi-arrow-right me-1"></i>Повторить
                                    </a>
                                </div>
                            }

                            <button class="btn btn-primary btn-lg mt-3" @onclick="NextListeningWord">
                                <i class="bi bi-arrow-right me-2"></i>Далее
                            </button>
                        }
                    </div>
                }
                else if (ActiveExerciseType == "matching")
                {
                    <!-- Режим сопоставления (#6 LEARNING_IMPROVEMENTS) -->
                    <div class="matching-card">
                        <div class="matching-header">
                            <h3><i class="bi bi-link-45deg me-2"></i>Соедините пары</h3>
                            <p class="text-muted">Нажмите на слово слева, затем на его перевод справа</p>
                        </div>

                        <div class="matching-grid">
                            <div class="matching-column">
                                @foreach (var pair in MatchingPairs)
                                {
                                    var isMatched = MatchedPairIds.Contains(pair.WordId);
                                    var isSelected = MatchingSelectedLeft == pair.WordId;
                                    var isWrong = MatchingWrongLeft == pair.WordId;
                                    <button class="matching-item matching-left @(isMatched ? "matched" : "") @(isSelected ? "selected" : "") @(isWrong ? "wrong" : "")"
                                            @onclick="() => SelectMatchingLeft(pair.WordId)"
                                            disabled="@isMatched">
                                        @pair.OriginalWord
                                    </button>
                                }
                            </div>
                            <div class="matching-column">
                                @foreach (var item in ShuffledMatchingTranslations)
                                {
                                    var isMatched = MatchedTranslations.Contains(item.Translation);
                                    var isSelected = MatchingSelectedRight == item.Translation;
                                    var isWrong = MatchingWrongRight == item.Translation;
                                    <button class="matching-item matching-right @(isMatched ? "matched" : "") @(isSelected ? "selected" : "") @(isWrong ? "wrong" : "")"
                                            @onclick="() => SelectMatchingRight(item.Translation)"
                                            disabled="@isMatched">
                                        @item.Translation
                                    </button>
                                }
                            </div>
                        </div>

                        @if (MatchingCompleted)
                        {
                            <div class="matching-result mt-3">
                                <div class="mcq-feedback @(MatchingErrors == 0 ? "success" : "error")">
                                    @if (MatchingErrors == 0)
                                    {
                                        <i class="bi bi-check-circle"></i>
                                        <span>Отлично! Все пары верны!</span>
                                    }
                                    else
                                    {
                                        <i class="bi bi-x-circle"></i>
                                        <span>Ошибок: @MatchingErrors</span>
                                    }
                                </div>
                                <button class="btn btn-primary btn-lg mt-3" @onclick="NextMatchingRound">
                                    <i class="bi bi-arrow-right me-2"></i>Далее
                                </button>
                            </div>
                        }
                    </div>
                }
                else if (ActiveExerciseType == "cloze")
                {
                    <!-- Режим пропуска (§3.1 LEARNING_IMPROVEMENTS) -->
                    <div class="typing-card">
                        <div class="typing-question">
                            <div class="word-dictionary">
                                <i class="bi bi-book"></i> @CurrentWord.DictionaryName
                            </div>
                            <p class="text-muted mb-2"><i class="bi bi-input-cursor-text me-1"></i>Заполните пропуск в предложении</p>
                            @if (!string.IsNullOrEmpty(CurrentWord.Translation))
                            {
                                <div class="cloze-hint mb-3">
                                    <span class="badge bg-primary-subtle text-primary px-3 py-2" style="font-size: 1rem;">
                                        <i class="bi bi-translate me-1"></i> @CurrentWord.Translation
                                    </span>
                                </div>
                            }
                            <div class="cloze-sentence" style="font-size: 1.15rem; line-height: 1.8; margin-bottom: 1rem;">
                                @((MarkupString)ClozeSentenceHtml)
                            </div>
                        </div>

                        <div class="typing-input">
                            <input type="text" class="form-control form-control-lg @(ClozeAnswered ? (ClozeWasCorrect ? "is-valid" : "is-invalid") : "")"
                                   placeholder="Введите пропущенное слово..."
                                   @bind="ClozeTypedAnswer"
                                   @bind:event="oninput"
                                   @onkeypress="HandleClozeKeyPress"
                                   disabled="@ClozeAnswered" />

                            @if (!ClozeAnswered)
                            {
                                <div class="d-flex align-items-center gap-2 justify-content-center">
                                    <button class="btn btn-outline-secondary" @onclick="UseHint" disabled="@(!CanUseHint)" title="Контекстная подсказка (снижает оценку до «Сложно»)">
                                        <i class="bi bi-lightbulb me-1"></i>Подсказка
                                        @if (_hintCount > 0) { <span class="badge bg-warning text-dark ms-1">@_hintCount/4</span> }
                                    </button>
                                    <button class="btn btn-primary btn-lg" @onclick="CheckClozeAnswer">
                                        <i class="bi bi-check-lg me-2"></i>Проверить
                                    </button>
                                </div>
                            }
                        </div>
                        @if (HintUsed && !ClozeAnswered)
                        {
                            <div class="hint-display mt-2 p-2 rounded" style="background: var(--bs-primary-bg-subtle, #e7f1ff); border-left: 3px solid var(--bs-primary, #0d6efd);">
                                <span style="font-style: italic;">@HintText</span>
                            </div>
                        }

                        @if (ClozeAnswered)
                        {
                            <div class="typing-feedback @(ClozeWasCorrect ? "success" : "error")">
                                @if (ClozeWasCorrect)
                                {
                                    <i class="bi bi-check-circle"></i>
                                    <span>Правильно! <strong>@ClozeCorrectWord</strong></span>
                                }
                                else
                                {
                                    <i class="bi bi-x-circle"></i>
                                    <span>Неверно. Правильный ответ: <strong>@ClozeCorrectWord</strong></span>
                                }
                            </div>
                            @if (!string.IsNullOrEmpty(CurrentWord.Example))
                            {
                                <div class="example mt-2">
                                    <i class="bi bi-chat-quote"></i> @CurrentWord.Example
                                </div>
                            }

                            @* === Grammar Hint on Error (§17.6.1 LEARNING_IMPROVEMENTS) — Cloze === *@
                            @if (!ClozeWasCorrect && CurrentWord.RelatedRuleId.HasValue)
                            {
                                <div class="grammar-hint-block mt-2">
                                    <i class="bi bi-journal-bookmark me-1"></i>
                                    <span>Связанное правило: <strong>@(CurrentWord.RelatedRuleTitle ?? "Грамматика")</strong></span>
                                    <a href="/grammar/@CurrentWord.RelatedRuleId?mode=review" class="btn btn-sm btn-outline-info ms-2">
                                        <i class="bi bi-arrow-right me-1"></i>Повторить
                                    </a>
                                </div>
                            }

                            <button class="btn btn-primary btn-lg mt-3" @onclick="NextClozeWord">
                                <i class="bi bi-arrow-right me-2"></i>Далее
                            </button>
                        }
                    </div>
                }
                else if (ActiveExerciseType == "spelling")
                {
                    <!-- Spelling Bee (§3.2 LEARNING_IMPROVEMENTS) -->
                    <div class="spelling-card" @onclick="SpellingCardClicked">
                        <div class="spelling-header">
                            <span class="spelling-bee-icon">🐝</span>
                            <h3>Spelling Bee</h3>
                            <p class="text-muted">Прослушайте слово и введите его по буквам</p>
                        </div>

                        <div class="spelling-tts-area">
                            <button class="btn-tts-big" tabindex="-1" @onclick="SpeakWord" @onclick:stopPropagation="true" title="Прослушать слово">
                                <i class="bi bi-volume-up-fill"></i>
                            </button>
                            <div class="spelling-tts-controls">
                                <span class="text-muted small">Нажмите, чтобы прослушать</span>
                                <div class="volume-wrapper">
                                    <button class="btn-volume-toggle" tabindex="-1" @onclick="ToggleVolumeSlider" @onclick:stopPropagation="true" title="Громкость">
                                        <i class="@VolumeIcon"></i>
                                    </button>
                                    @if (ShowVolumeSlider)
                                    {
                                        <div class="volume-popover" @onclick:stopPropagation="true">
                                            <input type="range" min="0" max="1" step="0.01"
                                                   tabindex="-1"
                                                   value="@TtsVolumeFormatted"
                                                   @oninput="OnVolumeChanged" />
                                            <span class="volume-value">@TtsVolumePercent%</span>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>

                        @if (!string.IsNullOrEmpty(CurrentWord.Translation))
                        {
                            <div class="spelling-hint mb-3">
                                <span class="badge bg-primary-subtle text-primary px-3 py-2" style="font-size: 1rem;">
                                    <i class="bi bi-translate me-1"></i> @CurrentWord.Translation
                                </span>
                            </div>
                        }

                        <div class="spelling-letters">
                            @{
                                var correctWord = CurrentWord.OriginalWord;
                                for (int i = 0; i < correctWord.Length; i++)
                                {
                                    var idx = i;
                                    char? typed = idx < SpellingTyped.Length ? SpellingTyped[idx] : null;
                                    char expected = correctWord[idx];
                                    var cellClass = "spelling-cell";
                                    if (typed != null)
                                    {
                                        cellClass += char.ToLowerInvariant(typed.Value) == char.ToLowerInvariant(expected)
                                            ? " spelling-cell--correct"
                                            : " spelling-cell--wrong";
                                    }
                                    else if (idx == SpellingTyped.Length && !SpellingAnswered)
                                    {
                                        cellClass += " spelling-cell--cursor";
                                    }
                                    <span class="@cellClass">
                                        @if (typed != null)
                                        {
                                            @typed
                                        }
                                        else if (SpellingAnswered)
                                        {
                                            <span class="spelling-cell__reveal">@expected</span>
                                        }
                                    </span>
                                }
                            }
                        </div>

                        @if (!SpellingAnswered)
                        {
                            <div class="spelling-input-area">
                                <input type="text" class="spelling-visible-input"
                                       placeholder="Введите слово..."
                                       @oninput="OnSpellingInput"
                                       @onkeydown="HandleSpellingKeyDown"
                                       maxlength="@CurrentWord.OriginalWord.Length"
                                       autocomplete="off"
                                       autocapitalize="off"
                                       spellcheck="false"
                                       @ref="spellingInput" />
                                <button class="btn btn-primary btn-lg" tabindex="-1"
                                        @onclick="CheckSpellingAnswer" @onclick:stopPropagation="true"
                                        disabled="@(SpellingTyped.Length == 0)">
                                    <i class="bi bi-check-lg me-2"></i>Проверить
                                </button>
                            </div>
                            <div class="d-flex justify-content-center mt-2">
                                <button class="btn btn-outline-secondary btn-sm" @onclick="UseHint" disabled="@(!CanUseHint)" title="Контекстная подсказка (снижает оценку до «Сложно»)">
                                    <i class="bi bi-lightbulb me-1"></i>Подсказка
                                    @if (_hintCount > 0) { <span class="badge bg-warning text-dark ms-1">@_hintCount/4</span> }
                                </button>
                            </div>
                            @if (HintUsed)
                            {
                                <div class="hint-display mt-2 p-2 rounded" style="background: var(--bs-primary-bg-subtle, #e7f1ff); border-left: 3px solid var(--bs-primary, #0d6efd);">
                                    <span style="font-style: italic;">@HintText</span>
                                </div>
                            }
                        }

                        @if (SpellingAnswered)
                        {
                            <div class="typing-feedback @(SpellingWasCorrect ? "success" : "error") mt-3">
                                @if (SpellingWasCorrect)
                                {
                                    <i class="bi bi-check-circle"></i>
                                    <span>Отлично! <strong>@SpellingCorrectWord</strong></span>
                                }
                                else
                                {
                                    <i class="bi bi-x-circle"></i>
                                    <span>Неверно. Правильно: <strong>@SpellingCorrectWord</strong></span>
                                }
                            </div>
                            @if (!string.IsNullOrEmpty(CurrentWord.Translation))
                            {
                                <div class="mt-2 text-muted">
                                    <i class="bi bi-translate me-1"></i> @CurrentWord.Translation
                                </div>
                            }
                            @if (!string.IsNullOrEmpty(CurrentWord.Transcription))
                            {
                                <div class="mt-2 text-muted">
                                    <i class="bi bi-mic me-1"></i> @CurrentWord.Transcription
                                </div>
                            }
                            @if (!string.IsNullOrEmpty(CurrentWord.Example))
                            {
                                <div class="example mt-2">
                                    <i class="bi bi-chat-quote"></i> @CurrentWord.Example
                                    <button class="btn-tts-sm" @onclick="SpeakExample" title="Прослушать пример">
                                        <i class="bi bi-volume-up"></i>
                                    </button>
                                </div>
                            }

                            @* === Grammar Hint on Error (§17.6.1 LEARNING_IMPROVEMENTS) — Spelling === *@
                            @if (!SpellingWasCorrect && CurrentWord.RelatedRuleId.HasValue)
                            {
                                <div class="grammar-hint-block mt-2">
                                    <i class="bi bi-journal-bookmark me-1"></i>
                                    <span>Связанное правило: <strong>@(CurrentWord.RelatedRuleTitle ?? "Грамматика")</strong></span>
                                    <a href="/grammar/@CurrentWord.RelatedRuleId?mode=review" class="btn btn-sm btn-outline-info ms-2">
                                        <i class="bi bi-arrow-right me-1"></i>Повторить
                                    </a>
                                </div>
                            }

                            <button class="btn btn-primary btn-lg mt-3" @onclick="NextSpellingWord">
                                <i class="bi bi-arrow-right me-2"></i>Далее
                            </button>
                        }
                    </div>
                }
            }
            else
            {
                <!-- Результаты тренировки (§19.1 LEARNING_IMPROVEMENTS) -->
                <div class="session-results">
                    <div class="results-icon">
                        @if (SessionAccuracy >= 90)
                        {
                            <span>🏆</span>
                        }
                        else if (SessionAccuracy >= 70)
                        {
                            <span>🎉</span>
                        }
                        else if (SessionAccuracy >= 50)
                        {
                            <span>👍</span>
                        }
                        else
                        {
                            <span>💪</span>
                        }
                    </div>
                    <h2>@SessionResultMessage</h2>

                    <div class="results-stats">
                        <div class="result-stat">
                            <span class="result-value">@TrainingWords.Count</span>
                            <span class="result-label">Всего слов</span>
                        </div>
                        <div class="result-stat result-correct">
                            <span class="result-value">@SessionCorrectCount</span>
                            <span class="result-label">Правильно</span>
                        </div>
                        <div class="result-stat result-wrong">
                            <span class="result-value">@SessionWrongCount</span>
                            <span class="result-label">С ошибками</span>
                        </div>
                        <div class="result-stat">
                            <span class="result-value">@SessionDurationFormatted</span>
                            <span class="result-label">Время</span>
                        </div>
                        <div class="result-stat" style="color: var(--bs-warning);">
                            <span class="result-value">+@_sessionXpEarned</span>
                            <span class="result-label">XP</span>
                        </div>
                    </div>

                    <!-- Accuracy bar -->
                    <div class="results-accuracy">
                        <div class="accuracy-value">@SessionAccuracy.ToString("F0")%</div>
                        <div class="accuracy-label">Точность</div>
                        <div class="accuracy-bar-container mt-2">
                            <div class="progress" style="height: 10px; border-radius: 5px; max-width: 300px; margin: 0 auto;">
                                <div class="progress-bar bg-success" style="width: @SessionAccuracy%"></div>
                            </div>
                        </div>
                    </div>

                    @if (_microGoalTracker.TotalBonusXp > 0)
                    {
                        <div class="mt-2" style="font-size: 0.9rem; color: var(--bs-warning);">
                            ⭐ Бонус за микро-цели: +@_microGoalTracker.TotalBonusXp XP
                        </div>
                    }

                    @if (_avgResponseTimeSec > 0)
                    {
                        <div class="text-muted mt-2" style="font-size: 0.9rem;">
                            <i class="bi bi-stopwatch me-1"></i>Среднее время ответа: @_avgResponseTimeSec с/слово
                        </div>
                    }

                    @* §19.1 — Level changes *@
                    @{
                        var levelUps = _wordResults.Where(r => r.WasCorrect && r.NewLevel > r.OldLevel).ToList();
                        var levelDowns = _wordResults.Where(r => !r.WasCorrect && r.NewLevel < r.OldLevel).ToList();
                    }
                    @if (levelUps.Count > 0 || levelDowns.Count > 0)
                    {
                        <div class="word-progress-section mt-3">
                            @if (levelUps.Count > 0)
                            {
                                <div class="mb-2">
                                    <span class="badge bg-success-subtle text-success me-1">
                                        <i class="bi bi-arrow-up-circle me-1"></i>@levelUps.Count @(levelUps.Count == 1 ? "слово повысило уровень" : "слов повысили уровень")
                                    </span>
                                </div>
                                <div class="level-changes-list">
                                    @foreach (var w in levelUps.Take(5))
                                    {
                                        <div class="level-change-item">
                                            <span class="fw-medium">@w.Word</span>
                                            <span class="text-muted mx-1">
                                                @for (int i = 0; i < w.OldLevel; i++) { <i class="bi bi-star-fill text-warning" style="font-size: 0.65rem;"></i> }
                                                →
                                                @for (int i = 0; i < w.NewLevel; i++) { <i class="bi bi-star-fill text-warning" style="font-size: 0.65rem;"></i> }
                                            </span>
                                        </div>
                                    }
                                    @if (levelUps.Count > 5)
                                    {
                                        <div class="text-muted" style="font-size: 0.85rem;">и ещё @(levelUps.Count - 5)...</div>
                                    }
                                </div>
                            }
                            @if (levelDowns.Count > 0)
                            {
                                <div class="mb-2 mt-2">
                                    <span class="badge bg-danger-subtle text-danger me-1">
                                        <i class="bi bi-arrow-down-circle me-1"></i>@levelDowns.Count @(levelDowns.Count == 1 ? "слово понизило уровень" : "слов понизили уровень")
                                    </span>
                                </div>
                            }
                        </div>
                    }

                    <!-- Difficult words with details -->
                    @if (DifficultWordsList.Count > 0)
                    {
                        <div class="difficult-words-section">
                            <h5 class="text-muted mb-2"><i class="bi bi-exclamation-triangle me-1"></i>Слова с ошибками</h5>
                            <div class="difficult-words-list">
                                @foreach (var w in _wordResults.Where(r => !r.WasCorrect).DistinctBy(r => r.WordId).Take(10))
                                {
                                    <div class="difficult-word-detail">
                                        <span class="badge bg-danger-subtle text-danger px-3 py-2" style="font-size: 0.9rem;">
                                            @w.Word <span class="text-muted mx-1">→</span> @w.Translation
                                        </span>
                                    </div>
                                }
                            </div>
                        </div>
                    }

                    <div class="results-actions">
                        @* §19.2 — Retry failed words *@
                        @if (_failedWordIds.Count > 0)
                        {
                            <button class="btn btn-warning btn-lg" @onclick="RetryFailedWords">
                                <i class="bi bi-arrow-counterclockwise me-2"></i>Перетренировать ошибки (@_failedWordIds.Count)
                            </button>
                        }
                        <button class="btn btn-primary btn-lg" @onclick="ContinueTraining">
                            <i class="bi bi-arrow-repeat me-2"></i>Продолжить
                        </button>
                        <button class="btn btn-outline-secondary btn-lg" @onclick="BackToPlan">
                            <i class="bi bi-house me-2"></i>К плану
                        </button>
                    </div>
                </div>
            }
        </div>
    }
</div>

