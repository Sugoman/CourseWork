    // === Cloze mode (§3.1 LEARNING_IMPROVEMENTS) ===

    private void PrepareCloze()
    {
        if (CurrentWord == null || string.IsNullOrWhiteSpace(CurrentWord.Example))
        {
            ClozeSentenceHtml = "";
            return;
        }

        var example = CurrentWord.Example;
        var word = CurrentWord.OriginalWord;

        // Find the target word in the example (case-insensitive)
        var idx = example.IndexOf(word, StringComparison.OrdinalIgnoreCase);
        if (idx >= 0)
        {
            ClozeCorrectWord = example.Substring(idx, word.Length);
            var blank = new string('_', Math.Max(word.Length, 3));
            ClozeSentenceHtml = System.Net.WebUtility.HtmlEncode(example[..idx])
                + $"<strong style=\"color: var(--bs-primary); border-bottom: 2px dashed var(--bs-primary); padding: 0 4px;\">{blank}</strong>"
                + System.Net.WebUtility.HtmlEncode(example[(idx + word.Length)..]);
        }
        else
        {
            // Word not found in example — show example with blank at end
            ClozeCorrectWord = word;
            var blank = new string('_', Math.Max(word.Length, 3));
            ClozeSentenceHtml = System.Net.WebUtility.HtmlEncode(example) 
                + $" (<strong style=\"color: var(--bs-primary); border-bottom: 2px dashed var(--bs-primary); padding: 0 4px;\">{blank}</strong>)";
        }
    }

