    private async Task TryLoadProactiveMnemonic()
    {
        if (CurrentWord == null || IsExamMode || IsSpeedRound) return;
        if (IsLoadingMnemonic || !string.IsNullOrEmpty(AiMnemonic)) return;

        // Проактивная мнемоника: при первом показе слова (TotalAttempts == 0)
        // и если слово сложное (>= 7 букв или есть транскрипция)
        if (CurrentWord.TotalAttempts == 0 &&
            (CurrentWord.OriginalWord.Length >= 7 || !string.IsNullOrEmpty(CurrentWord.Transcription)))
        {
            await LoadMnemonic();
        }
    }

