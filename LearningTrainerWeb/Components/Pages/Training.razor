    // §19.1 — Track per-word result for enhanced session summary
    private void TrackWordResult(bool wasCorrect, int responseTimeMs, string exerciseType)
    {
        if (CurrentWord == null) return;
        var oldLevel = CurrentWord.KnowledgeLevel;
        _wordResults.Add(new WordSessionResult
        {
            WordId = CurrentWord.WordId,
            Word = CurrentWord.OriginalWord,
            Translation = CurrentWord.Translation,
            WasCorrect = wasCorrect,
            OldLevel = oldLevel,
            NewLevel = wasCorrect ? Math.Min(oldLevel + 1, 5) : Math.Max(oldLevel - 1, 0),
            ExerciseType = exerciseType,
            ResponseTimeMs = responseTimeMs
        });
        if (!wasCorrect && !_failedWordIds.Contains(CurrentWord.WordId))
            _failedWordIds.Add(CurrentWord.WordId);

        // §1.6 — Micro-goals
        var microRewards = _microGoalTracker.RecordAnswer(wasCorrect);
        foreach (var reward in microRewards)
            _microGoalQueue.Enqueue(reward);
        if (microRewards.Count > 0)
            ShowNextMicroGoal();
    }

