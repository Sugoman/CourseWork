@page "/my-dictionary/{Id:int}"
@inject IContentApiService ContentApi
@inject IAuthService AuthService
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>@(DictName ?? "Словарь") - Ingat</PageTitle>

<div class="container py-4">
    @if (!IsAuthenticated)
    {
        <div class="text-center py-5">
            <div style="font-size: 4rem; color: var(--primary-400);"><i class="bi bi-lock"></i></div>
            <h2>Требуется авторизация</h2>
            <a href="login" class="btn btn-primary btn-lg mt-3">Войти</a>
        </div>
    }
    else if (IsLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border" style="width: 3rem; height: 3rem;" role="status">
                <span class="visually-hidden">Загрузка...</span>
            </div>
            <p class="text-muted mt-3">Загрузка словаря...</p>
        </div>
    }
    else if (Dict == null)
    {
        <div class="text-center py-5">
            <div style="font-size: 4rem; color: var(--gray-400);"><i class="bi bi-emoji-frown"></i></div>
            <h2>Словарь не найден</h2>
            <p class="text-muted mb-4">Возможно, он был удалён</p>
            <a href="my-content" class="btn btn-primary"><i class="bi bi-arrow-left me-2"></i>Мой контент</a>
        </div>
    }
    else
    {
        <!-- Breadcrumb -->
        <nav aria-label="breadcrumb" class="mb-4">
            <ol class="breadcrumb" style="background: transparent; padding: 0;">
                <li class="breadcrumb-item">
                    <a href="my-content" style="color: var(--primary-600);"><i class="bi bi-folder2-open me-1"></i>Мой контент</a>
                </li>
                <li class="breadcrumb-item active" style="color: var(--gray-500);">@Dict.Name</li>
            </ol>
        </nav>

        <!-- Header -->
        <div class="card mb-4" style="border-radius: 1rem; overflow: hidden;">
            <div style="background: linear-gradient(135deg, var(--primary-600), var(--primary-800)); padding: 1.5rem 2rem; color: white;">
                <div class="d-flex justify-content-between align-items-start flex-wrap gap-3">
                    <div style="flex: 1;">
                        @if (IsEditingDict)
                        {
                            <input type="text" class="form-control form-control-lg mb-2" style="font-size: 1.5rem; font-weight: bold;"
                                   @bind="EditDictName" @bind:event="oninput" placeholder="Название словаря" />
                            <input type="text" class="form-control mb-2" @bind="EditDictDescription" @bind:event="oninput"
                                   placeholder="Описание (необязательно)" />
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-tags"></i></span>
                                <input type="text" class="form-control" @bind="EditDictTags" @bind:event="oninput"
                                       placeholder="Теги через запятую" />
                            </div>
                        }
                        else
                        {
                            <h1 style="color: white; margin-bottom: 0.25rem; font-size: 1.75rem;">@Dict.Name</h1>
                            @if (!string.IsNullOrWhiteSpace(Dict.Description))
                            {
                                <p style="opacity: 0.9; margin-bottom: 0;">@Dict.Description</p>
                            }
                            @if (!string.IsNullOrWhiteSpace(Dict.Tags))
                            {
                                <div class="mt-2 d-flex flex-wrap gap-1">
                                    @foreach (var tag in Dict.Tags.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries))
                                    {
                                        <span class="badge" style="background: rgba(255,255,255,0.2); font-size: 0.8rem;">
                                            <i class="bi bi-tag me-1"></i>@tag
                                        </span>
                                    }
                                </div>
                            }
                        }
                    </div>
                    <div class="d-flex gap-2">
                        @if (IsEditingDict)
                        {
                            <button class="btn btn-light" @onclick="SaveDictEdit" disabled="@(IsSavingDict || string.IsNullOrWhiteSpace(EditDictName))">
                                @if (IsSavingDict) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                <i class="bi bi-check-lg me-1"></i>Сохранить
                            </button>
                            <button class="btn btn-outline-light" @onclick="CancelDictEdit" disabled="@IsSavingDict">
                                <i class="bi bi-x-lg"></i>
                            </button>
                        }
                        else
                        {
                            <button class="btn btn-outline-light" @onclick="StartDictEdit" title="Редактировать словарь">
                                <i class="bi bi-pencil me-1"></i>Редактировать
                            </button>
                            <a href="training" class="btn btn-light">
                                <i class="bi bi-play-fill me-1"></i>Тренировка
                            </a>
                        }
                    </div>
                </div>
                @if (!string.IsNullOrEmpty(DictEditMessage))
                {
                    <div class="mt-2 small @(DictEditSuccess ? "text-light" : "text-warning")">@DictEditMessage</div>
                }
            </div>
            <div class="card-body">
                <div class="d-flex flex-wrap gap-2">
                    <span class="badge bg-primary-subtle text-primary px-3 py-2" style="font-size: 0.9rem;">
                        <i class="bi bi-collection me-1"></i>@Words.Count слов
                    </span>
                    <span class="badge bg-light text-dark px-3 py-2" style="font-size: 0.9rem;">
                        @Dict.LanguageFrom → @Dict.LanguageTo
                    </span>
                </div>
            </div>
        </div>

        <!-- Add word form -->
        <div class="card mb-4" style="border-radius: 1rem;">
            <div class="card-body">
                <h5 class="mb-3"><i class="bi bi-plus-circle me-2"></i>Добавить слово</h5>
                <div class="d-flex gap-2 flex-wrap">
                    <input type="text" class="form-control" style="max-width: 250px;" placeholder="Слово" @bind="NewOriginal" @bind:event="oninput" />
                    <input type="text" class="form-control" style="max-width: 250px;" placeholder="Перевод" @bind="NewTranslation" @bind:event="oninput" />
                    <input type="text" class="form-control" style="max-width: 300px;" placeholder="Пример (необязательно)" @bind="NewExample" @bind:event="oninput" />
                    <button class="btn btn-primary" @onclick="AddWord"
                            disabled="@(IsAddingWord || string.IsNullOrWhiteSpace(NewOriginal) || string.IsNullOrWhiteSpace(NewTranslation))">
                        @if (IsAddingWord) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        <i class="bi bi-plus-lg me-1"></i>Добавить
                    </button>
                </div>
                @if (!string.IsNullOrEmpty(AddWordMessage))
                {
                    <div class="mt-2 small @(AddWordSuccess ? "text-success" : "text-danger")">@AddWordMessage</div>
                }
            </div>
        </div>

        <!-- Words list -->
        <div class="card" style="border-radius: 1rem;">
            <div class="card-body p-0">
                <div class="p-3 d-flex justify-content-between align-items-center border-bottom">
                    <h5 class="mb-0"><i class="bi bi-list-ul me-2"></i>Слова</h5>
                    <input type="text" class="form-control" style="max-width: 250px;" placeholder="Поиск..."
                           @bind="SearchQuery" @bind:event="oninput" />
                </div>

                @if (FilteredWords.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead>
                                <tr>
                                    <th style="width: 4%; padding-left: 1rem;">#</th>
                                    <th style="width: 22%;">Слово</th>
                                    <th style="width: 22%;">Перевод</th>
                                    <th style="width: 15%;">Транскрипция</th>
                                    <th style="width: 22%;">Пример</th>
                                    <th style="width: 15%; text-align: right; padding-right: 1rem;">Действия</th>
                                </tr>
                            </thead>
                            <tbody>
                                @{ var idx = 0; }
                                @foreach (var w in FilteredWords)
                                {
                                    idx++;
                                    var wordId = w.Id;
                                    @if (EditingWordId == wordId)
                                    {
                                        <tr style="background: var(--primary-50, #f0f7ff);">
                                            <td style="padding-left: 1rem; color: var(--gray-400); vertical-align: middle;">@idx</td>
                                            <td><input type="text" class="form-control form-control-sm" @bind="EditWordOriginal" @bind:event="oninput" /></td>
                                            <td><input type="text" class="form-control form-control-sm" @bind="EditWordTranslation" @bind:event="oninput" /></td>
                                            <td class="text-muted" style="font-family: serif; vertical-align: middle;">@w.Transcription</td>
                                            <td><input type="text" class="form-control form-control-sm" @bind="EditWordExample" @bind:event="oninput" /></td>
                                            <td style="text-align: right; padding-right: 1rem; white-space: nowrap;">
                                                <button class="btn btn-success btn-sm me-1" @onclick="SaveWordEdit"
                                                        disabled="@(IsSavingWord || string.IsNullOrWhiteSpace(EditWordOriginal) || string.IsNullOrWhiteSpace(EditWordTranslation))"
                                                        title="Сохранить">
                                                    @if (IsSavingWord) { <span class="spinner-border spinner-border-sm"></span> }
                                                    else { <i class="bi bi-check-lg"></i> }
                                                </button>
                                                <button class="btn btn-outline-secondary btn-sm" @onclick="CancelWordEdit" disabled="@IsSavingWord" title="Отменить">
                                                    <i class="bi bi-x-lg"></i>
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                    else
                                    {
                                        <tr>
                                            <td style="padding-left: 1rem; color: var(--gray-400);">@idx</td>
                                            <td><strong>@w.OriginalWord</strong></td>
                                            <td>@w.Translation</td>
                                            <td class="text-muted" style="font-family: serif;">@w.Transcription</td>
                                            <td>
                                                @if (!string.IsNullOrWhiteSpace(w.Example))
                                                {
                                                    <span class="text-muted small" title="@w.Example">
                                                        <i class="bi bi-chat-quote me-1"></i>@TruncateText(w.Example, 40)
                                                    </span>
                                                }
                                            </td>
                                            <td style="text-align: right; padding-right: 1rem; white-space: nowrap;">
                                                <button class="btn btn-outline-primary btn-sm me-1" @onclick="() => StartWordEdit(w)" title="Редактировать">
                                                    <i class="bi bi-pencil"></i>
                                                </button>
                                                <button class="btn btn-outline-danger btn-sm" @onclick="() => DeleteWord(w)" title="Удалить"
                                                        disabled="@(DeletingWordId == wordId)">
                                                    @if (DeletingWordId == wordId) { <span class="spinner-border spinner-border-sm"></span> }
                                                    else { <i class="bi bi-trash"></i> }
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                    @if (!string.IsNullOrEmpty(WordEditMessage))
                    {
                        <div class="px-3 py-2 small @(WordEditSuccess ? "text-success" : "text-danger")">@WordEditMessage</div>
                    }
                }
                else
                {
                    <div class="text-center py-4 text-muted">
                        <i class="bi bi-search" style="font-size: 2rem;"></i>
                        <p class="mt-2 mb-0">Слова не найдены</p>
                    </div>
                }
            </div>
        </div>
    }
</div>

@code {
    [Parameter]
    public int Id { get; set; }

    private bool IsAuthenticated;
    private bool IsLoading = true;
    private MyDictionaryFullDto? Dict;
    private List<MyDictionaryWordDto> Words = new();
    private string SearchQuery = "";

    // Add word state
    private string NewOriginal = "";
    private string NewTranslation = "";
    private string NewExample = "";
    private bool IsAddingWord;
    private string? AddWordMessage;
    private bool AddWordSuccess;

    // Edit dictionary state
    private bool IsEditingDict;
    private bool IsSavingDict;
    private string EditDictName = "";
    private string EditDictDescription = "";
    private string EditDictTags = "";
    private string? DictEditMessage;
    private bool DictEditSuccess;

    // Edit word state
    private int? EditingWordId;
    private string EditWordOriginal = "";
    private string EditWordTranslation = "";
    private string EditWordExample = "";
    private bool IsSavingWord;
    private int? DeletingWordId;
    private string? WordEditMessage;
    private bool WordEditSuccess;

    private string? DictName => Dict?.Name;

    private IEnumerable<MyDictionaryWordDto> FilteredWords =>
        string.IsNullOrWhiteSpace(SearchQuery)
            ? Words
            : Words.Where(w =>
                (w.OriginalWord?.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (w.Translation?.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase) ?? false));

    protected override async Task OnInitializedAsync()
    {
        await AuthService.InitializeAsync();
        var session = await AuthService.GetCurrentSessionAsync();
        IsAuthenticated = session != null;

        if (IsAuthenticated)
            await LoadDictionary();

        IsLoading = false;
    }

    private async Task LoadDictionary()
    {
        try
        {
            Dict = await ContentApi.GetMyDictionaryFullAsync(Id);
            Words = Dict?.Words ?? new();
        }
        catch
        {
            Dict = null;
        }
    }

    private async Task AddWord()
    {
        if (string.IsNullOrWhiteSpace(NewOriginal) || string.IsNullOrWhiteSpace(NewTranslation)) return;

        IsAddingWord = true;
        AddWordMessage = null;
        StateHasChanged();

        try
        {
            var result = await ContentApi.AddWordAsync(Id, NewOriginal.Trim(), NewTranslation.Trim(),
                string.IsNullOrWhiteSpace(NewExample) ? null : NewExample.Trim());

            Words.Add(new MyDictionaryWordDto
            {
                Id = result.Id,
                OriginalWord = NewOriginal.Trim(),
                Translation = NewTranslation.Trim(),
                Example = NewExample?.Trim()
            });

            NewOriginal = "";
            NewTranslation = "";
            NewExample = "";
            AddWordSuccess = true;
            AddWordMessage = "Слово добавлено!";
        }
        catch (Exception ex)
        {
            AddWordSuccess = false;
            AddWordMessage = $"Ошибка: {ex.Message}";
        }
        finally
        {
            IsAddingWord = false;
        }
    }

    // --- Dictionary editing ---

    private void StartDictEdit()
    {
        EditDictName = Dict!.Name;
        EditDictDescription = Dict.Description ?? "";
        EditDictTags = Dict.Tags ?? "";
        DictEditMessage = null;
        IsEditingDict = true;
    }

    private void CancelDictEdit()
    {
        IsEditingDict = false;
        DictEditMessage = null;
    }

    private async Task SaveDictEdit()
    {
        if (string.IsNullOrWhiteSpace(EditDictName)) return;

        IsSavingDict = true;
        DictEditMessage = null;
        StateHasChanged();

        try
        {
            await ContentApi.UpdateDictionaryAsync(Id, EditDictName.Trim(),
                string.IsNullOrWhiteSpace(EditDictDescription) ? null : EditDictDescription.Trim(),
                Dict!.LanguageFrom, Dict.LanguageTo,
                string.IsNullOrWhiteSpace(EditDictTags) ? null : EditDictTags.Trim());

            Dict.Name = EditDictName.Trim();
            Dict.Description = string.IsNullOrWhiteSpace(EditDictDescription) ? null : EditDictDescription.Trim();
            Dict.Tags = string.IsNullOrWhiteSpace(EditDictTags) ? null : EditDictTags.Trim();
            IsEditingDict = false;
            DictEditSuccess = true;
            DictEditMessage = "Словарь обновлён!";
        }
        catch (Exception ex)
        {
            DictEditSuccess = false;
            DictEditMessage = $"Ошибка: {ex.Message}";
        }
        finally
        {
            IsSavingDict = false;
        }
    }

    // --- Word editing ---

    private void StartWordEdit(MyDictionaryWordDto word)
    {
        EditingWordId = word.Id;
        EditWordOriginal = word.OriginalWord;
        EditWordTranslation = word.Translation;
        EditWordExample = word.Example ?? "";
        WordEditMessage = null;
    }

    private void CancelWordEdit()
    {
        EditingWordId = null;
        WordEditMessage = null;
    }

    private async Task SaveWordEdit()
    {
        if (EditingWordId == null || string.IsNullOrWhiteSpace(EditWordOriginal) || string.IsNullOrWhiteSpace(EditWordTranslation)) return;

        IsSavingWord = true;
        WordEditMessage = null;
        StateHasChanged();

        try
        {
            await ContentApi.UpdateWordAsync(EditingWordId.Value, EditWordOriginal.Trim(), EditWordTranslation.Trim(),
                string.IsNullOrWhiteSpace(EditWordExample) ? null : EditWordExample.Trim());

            var word = Words.FirstOrDefault(w => w.Id == EditingWordId.Value);
            if (word != null)
            {
                word.OriginalWord = EditWordOriginal.Trim();
                word.Translation = EditWordTranslation.Trim();
                word.Example = string.IsNullOrWhiteSpace(EditWordExample) ? null : EditWordExample.Trim();
            }

            EditingWordId = null;
            WordEditSuccess = true;
            WordEditMessage = "Слово обновлено!";
        }
        catch (Exception ex)
        {
            WordEditSuccess = false;
            WordEditMessage = $"Ошибка: {ex.Message}";
        }
        finally
        {
            IsSavingWord = false;
        }
    }

    private async Task DeleteWord(MyDictionaryWordDto word)
    {
        DeletingWordId = word.Id;
        WordEditMessage = null;
        StateHasChanged();

        try
        {
            await ContentApi.DeleteWordAsync(word.Id);
            Words.Remove(word);
            WordEditSuccess = true;
            WordEditMessage = $"Слово «{word.OriginalWord}» удалено.";
        }
        catch (Exception ex)
        {
            WordEditSuccess = false;
            WordEditMessage = $"Ошибка: {ex.Message}";
        }
        finally
        {
            DeletingWordId = null;
        }
    }

    private static string TruncateText(string text, int maxLength)
        => text.Length <= maxLength ? text : text[..maxLength] + "…";
}
