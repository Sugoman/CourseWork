@page "/dictionaries"
@using LearningTrainerWeb.Services
@inject IContentApiService ContentApi
@inject ITrainingApiService TrainingService
@inject IAuthService AuthService
@inject ILogger<LearningTrainerWeb.Components.Pages.Dictionaries> Logger

<PageTitle>Словари - Ingat</PageTitle>

<div class="container">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div class="section-heading" style="margin-bottom: 0;">
            <i class="bi bi-book"></i>
            <h1 style="margin-bottom: 0;">Словари</h1>
        </div>
    </div>

    <!-- Filters -->
    <div class="card mb-4" style="border-radius: var(--radius-lg);">
        <div class="card-body p-4">
            <div class="row g-3 align-items-end">
                <div class="col-12 col-md-5">
                    <label class="form-label small fw-bold text-muted">Поиск</label>

                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0 text-muted">
                            <i class="bi bi-search"></i>
                        </span>
                        <input type="text"
                               class="form-control border-start-0 ps-0"
                               placeholder="Название словаря..."
                               @bind="SearchQuery"
                               @bind:event="oninput"
                               @onkeyup="OnSearchKeyUp" />
                    </div>
                </div>
                <div class="col-6 col-md-3">
                    <label class="form-label small text-muted">
                        <i class="bi bi-translate me-1"></i> Язык оригинала
                    </label>
                    <select class="form-select" @bind="SelectedLanguageFrom" @bind:after="ApplyFilters">
                        <option value="">Все языки</option>
                        <option value="English">English</option>
                        <option value="Russian">Русский</option>
                        <option value="German">Deutsch</option>
                        <option value="French">Français</option>
                        <option value="Spanish">Español</option>
                        <option value="Italian">Italiano</option>
                        <option value="Portuguese">Português</option>
                        <option value="Chinese">中文</option>
                        <option value="Japanese">日本語</option>
                        <option value="Korean">한국어</option>
                        <option value="Arabic">العربية</option>
                        <option value="Turkish">Türkçe</option>
                        <option value="Polish">Polski</option>
                        <option value="Dutch">Nederlands</option>
                        <option value="Swedish">Svenska</option>
                        <option value="Norwegian">Norsk</option>
                        <option value="Danish">Dansk</option>
                        <option value="Finnish">Suomi</option>
                        <option value="Czech">Čeština</option>
                        <option value="Greek">Ελληνικά</option>
                        <option value="Hindi">हिन्दी</option>
                        <option value="Ukrainian">Українська</option>
                        <option value="Hungarian">Magyar</option>
                    </select>
                </div>
                <div class="col-6 col-md-3">
                    <label class="form-label small text-muted">
                        <i class="bi bi-arrow-right-circle me-1"></i> Язык перевода
                    </label>
                    <select class="form-select" @bind="SelectedLanguageTo" @bind:after="ApplyFilters">
                        <option value="">Все языки</option>
                        <option value="English">English</option>
                        <option value="Russian">Русский</option>
                        <option value="German">Deutsch</option>
                        <option value="French">Français</option>
                        <option value="Spanish">Español</option>
                        <option value="Italian">Italiano</option>
                        <option value="Portuguese">Português</option>
                        <option value="Chinese">中文</option>
                        <option value="Japanese">日本語</option>
                        <option value="Korean">한국어</option>
                        <option value="Arabic">العربية</option>
                        <option value="Turkish">Türkçe</option>
                        <option value="Polish">Polski</option>
                        <option value="Dutch">Nederlands</option>
                        <option value="Swedish">Svenska</option>
                        <option value="Norwegian">Norsk</option>
                        <option value="Danish">Dansk</option>
                        <option value="Finnish">Suomi</option>
                        <option value="Czech">Čeština</option>
                        <option value="Greek">Ελληνικά</option>
                        <option value="Hindi">हिन्दी</option>
                        <option value="Ukrainian">Українська</option>
                        <option value="Hungarian">Magyar</option>
                    </select>
                </div>
                <div class="col-12 col-md-2 d-flex align-items-end">
                    <button class="btn btn-primary w-100 gap-2" @onclick="ApplyFilters">
                        <i class="bi me-1"></i> Найти
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Content -->
    @if (IsLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border" style="width: 3rem; height: 3rem;" role="status">
                <span class="visually-hidden">Загрузка...</span>
            </div>
            <p class="text-muted mt-3">Загрузка словарей...</p>
        </div>
    }
    else if (DictionaryItems == null || !DictionaryItems.Any())
    {
        <!-- Улучшенное пустое состояние -->
        <div class="empty-state-card">
            <div class="empty-state-icon">
                <i class="bi bi-book"></i>
            </div>
            <h3>Словари не найдены</h3>
            <p class="text-muted mb-4">
                @if (!string.IsNullOrEmpty(SearchQuery) || !string.IsNullOrEmpty(SelectedLanguageFrom) || !string.IsNullOrEmpty(SelectedLanguageTo))
                {
                    <span>По вашему запросу ничего не найдено. Попробуйте изменить параметры поиска.</span>
                }
                else
                {
                    <span>В маркетплейсе пока нет опубликованных словарей.</span>
                }
            </p>
            
            <div class="empty-state-actions">
                @if (!string.IsNullOrEmpty(SearchQuery) || !string.IsNullOrEmpty(SelectedLanguageFrom) || !string.IsNullOrEmpty(SelectedLanguageTo))
                {
                    <button class="btn btn-outline-primary" @onclick="ClearFilters">
                        <i class="bi bi-x-circle me-2"></i>Сбросить фильтры
                    </button>
                }
                
                @if (IsAuthenticated)
                {
                    <button class="btn btn-primary" @onclick="InstallStarterPack" disabled="@IsInstallingStarter">
                        @if (IsInstallingStarter)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                        }
                        else
                        {
                            <i class="bi bi-lightning-charge me-2"></i>
                        }
                        Установить стартовый набор
                    </button>
                }
                else
                {
                    <a href="register" class="btn btn-primary">
                        <i class="bi bi-person-plus me-2"></i>Зарегистрироваться
                    </a>
                }
            </div>
            
            @if (!string.IsNullOrEmpty(StarterMessage))
            {
                <div class="alert @(StarterSuccess ? "alert-success" : "alert-danger") mt-3" style="max-width: 500px; margin: 1rem auto 0;">
                    @StarterMessage
                </div>
            }
            
            <div class="empty-state-tips mt-4">
                <h6 class="text-muted">Что можно сделать:</h6>
                <div class="tips-grid">
                    <div class="tip-item">
                        <i class="bi bi-lightning-charge text-warning"></i>
                        <span>Установить стартовый набор с базовыми словами</span>
                    </div>
                    <div class="tip-item">
                        <i class="bi bi-upload text-primary"></i>
                        <span>Импортировать свой словарь из CSV файла</span>
                    </div>
                    <div class="tip-item">
                        <i class="bi bi-mortarboard text-success"></i>
                        <span>Перейти к <a href="training">тренировке</a> имеющихся слов</span>
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var dict in DictionaryItems)
            {
                <div class="col-sm-6 col-md-4">
                    <div class="card h-100">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <h5 class="fw-bold mb-0" style="color: var(--gray-900);">@dict.Name</h5>
                                <span class="badge rounded-pill px-3 py-2" style="background-color: #eef2ff; color: #4f46e5;">
                                    @dict.WordCount слов
                                </span>
                            </div>

                            <p class="text-muted small mb-3" style="min-height: 45px; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                                @dict.Description
                            </p>

                            <div class="d-flex gap-2 mb-3">
                                <span class="badge bg-secondary">@dict.LanguageFrom</span>
                                <span style="color: var(--gray-400);"><i class="bi bi-arrow-right"></i></span>
                                <span class="badge bg-secondary">@dict.LanguageTo</span>
                            </div>

                            <div class="d-flex justify-content-between align-items-center">
                                <div class="d-flex align-items-center gap-2">
                                    <i class="bi bi-star-fill text-warning"></i>
                                    <span class="fw-bold">@dict.Rating.ToString("F1")</span>
                                </div>
                                <div class="d-flex gap-2">
                                    <a href="dictionary/@dict.Id" class="btn btn-link btn-sm text-decoration-none text-primary fw-medium">
                                        Детали
                                    </a>
                                    <button class="btn btn-primary btn-sm px-3 rounded-pill gap-2" @onclick="() => DownloadDictionary(dict.Id)">
                                        <i class="bi bi-download me-1"></i> Скачать
                                    </button>
                                </div>
                            </div>
                        </div>
                        <div class="card-footer">
                            <div class="d-flex align-items-center justify-content-between text-muted small">

                                <div class="d-flex align-items-center gap-2">
                                    <i class="bi bi-person-circle" style="font-size: 1.2rem;"></i>
                                    <span>@dict.AuthorName</span>
                                </div>

                                <span>
                                    <i class="bi bi-download me-1"></i>
                                    @dict.Downloads
                                </span>

                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- Pagination -->
        @if (TotalPages > 1)
        {
            <nav class="mt-5">
                <ul class="pagination justify-content-center">
                    <li class="page-item @(CurrentPage == 1 ? "disabled" : "")">
                        <button class="page-link" @onclick="() => LoadPage(CurrentPage - 1)">
                            <i class="bi bi-chevron-left"></i>
                        </button>
                    </li>
                    @for (int i = 1; i <= TotalPages; i++)
                    {
                        var pageNum = i;
                        <li class="page-item @(pageNum == CurrentPage ? "active" : "")">
                            <button class="page-link" @onclick="() => LoadPage(pageNum)">@pageNum</button>
                        </li>
                    }
                    <li class="page-item @(CurrentPage == TotalPages ? "disabled" : "")">
                        <button class="page-link" @onclick="() => LoadPage(CurrentPage + 1)">
                            <i class="bi bi-chevron-right"></i>
                        </button>
                    </li>
                </ul>
            </nav>
        }
    }
</div>

<LearningTrainerWeb.Components.Shared.AppToast
    Message="@DownloadMessage"
    IsSuccess="@DownloadSuccess"
    OnDismiss="() => DownloadMessage = null" />

@code {
    private List<DictionaryListItem>? DictionaryItems;
    private bool IsLoading = true;
    private bool IsAuthenticated;
    private bool IsInstallingStarter;
    private string? StarterMessage;
    private bool StarterSuccess;
    private string SearchQuery = "";
    private string SelectedLanguageFrom = "";
    private string SelectedLanguageTo = "";
    private int CurrentPage = 1;
    private int TotalPages = 1;
    private const int PageSize = 9;

    protected override async Task OnInitializedAsync()
    {
        await AuthService.InitializeAsync();
        var session = await AuthService.GetCurrentSessionAsync();
        IsAuthenticated = session != null;

        await LoadDictionaries();
    }

    private async Task LoadDictionaries()
    {
        IsLoading = true;
        try
        {
            var result = await ContentApi.GetPublicDictionariesAsync(
                SearchQuery, SelectedLanguageFrom, SelectedLanguageTo, CurrentPage, PageSize);
            DictionaryItems = result.Items;
            TotalPages = result.TotalPages;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading dictionaries");
            DictionaryItems = new List<DictionaryListItem>();
        }
        finally
        {
            IsLoading = false;
        }
    }

    private async Task OnSearchKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await ApplyFilters();
        }
    }

    private async Task ApplyFilters()
    {
        CurrentPage = 1;
        await LoadDictionaries();
    }

    private async Task ClearFilters()
    {
        SearchQuery = "";
        SelectedLanguageFrom = "";
        SelectedLanguageTo = "";
        CurrentPage = 1;
        await LoadDictionaries();
    }

    private async Task LoadPage(int page)
    {
        if (page < 1 || page > TotalPages) return;
        CurrentPage = page;
        await LoadDictionaries();
    }

    private string? DownloadMessage;
    private bool DownloadSuccess;
    private bool IsDownloading;

    private async Task DownloadDictionary(int dictionaryId)
    {
        if (IsDownloading) return;

        if (!IsAuthenticated)
        {
            DownloadMessage = "Войдите в аккаунт для скачивания";
            DownloadSuccess = false;
            StateHasChanged();
            await Task.Delay(3000);
            DownloadMessage = null;
            return;
        }

        IsDownloading = true;
        StateHasChanged();
        try
        {
            await ContentApi.DownloadDictionaryAsync(dictionaryId);
            DownloadMessage = "Словарь успешно скачан!";
            DownloadSuccess = true;
        }
        catch (Exception ex)
        {
            DownloadMessage = $"Ошибка: {ex.Message}";
            DownloadSuccess = false;
        }
        finally
        {
            IsDownloading = false;
        }
        StateHasChanged();
        await Task.Delay(3000);
        DownloadMessage = null;
    }

    private async Task InstallStarterPack()
    {
        IsInstallingStarter = true;
        StarterMessage = null;
        StateHasChanged();

        var result = await TrainingService.InstallStarterPackAsync();

        if (result != null)
        {
            StarterSuccess = true;
            StarterMessage = result.Message + " Теперь вы можете начать тренировку!";
        }
        else
        {
            StarterSuccess = false;
            StarterMessage = "Не удалось установить стартовый набор. Возможно, у вас уже есть словари.";
        }

        IsInstallingStarter = false;
    }
}
