@page "/grammar/{RuleId:int}"
@using LearningTrainerWeb.Services
@inject IGrammarApiService GrammarApi
@inject IAuthService AuthService
@inject IHtmlSanitizerService HtmlSanitizer
@inject NavigationManager Navigation
@inject ILogger<GrammarPractice> Logger
@inject IJSRuntime JS

<PageTitle>@(RuleDetail?.Title ?? "Грамматика") - Ingat</PageTitle>

<div class="container" style="max-width: 800px;">
    @if (IsLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border" style="width: 3rem; height: 3rem;" role="status">
                <span class="visually-hidden">Загрузка...</span>
            </div>
            <p class="text-muted mt-3">Загрузка...</p>
        </div>
    }
    else if (RuleDetail == null)
    {
        <div class="empty-state-card">
            <div class="empty-state-icon">
                <i class="bi bi-journal-x"></i>
            </div>
            <h3>Правило не найдено</h3>
            <p class="text-muted mb-4">Возможно, оно было удалено или у вас нет доступа.</p>
            <a href="/grammar" class="btn btn-primary">
                <i class="bi bi-arrow-left me-2"></i> К грамматике
            </a>
        </div>
    }
    else
    {
        <!-- Breadcrumb -->
        <nav aria-label="breadcrumb" class="mb-3">
            <ol class="breadcrumb" style="background: transparent; padding: 0; margin: 0;">
                <li class="breadcrumb-item">
                    <a href="/grammar" style="color: var(--primary-600, #4f46e5);">
                        <i class="bi bi-book-half me-1"></i> Грамматика
                    </a>
                </li>
                <li class="breadcrumb-item active" style="color: var(--gray-500, #6b7280);">@RuleDetail.Title</li>
            </ol>
        </nav>

        <!-- Header -->
        <div class="d-flex align-items-center gap-3 mb-4">
            @if (!string.IsNullOrEmpty(RuleDetail.IconEmoji))
            {
                <span class="fs-1">@RuleDetail.IconEmoji</span>
            }
            <div class="flex-grow-1">
                <h2 class="mb-1">@RuleDetail.Title</h2>
                <div class="d-flex align-items-center gap-2 flex-wrap">
                    @if (!string.IsNullOrEmpty(RuleDetail.Category))
                    {
                        <span class="badge bg-secondary">@RuleDetail.Category</span>
                    }
                    <span class="badge @GetDifficultyBadgeClass(RuleDetail.DifficultyLevel)">
                        @GetDifficultyText(RuleDetail.DifficultyLevel)
                    </span>
                    <span class="badge bg-primary bg-opacity-10 text-primary">+@RuleDetail.XpReward XP</span>
                </div>
            </div>
            <div class="text-end">
                @for (int i = 1; i <= 5; i++)
                {
                    if (i <= RuleDetail.KnowledgeLevel)
                    {
                        <i class="bi bi-star-fill text-warning fs-5"></i>
                    }
                    else
                    {
                        <i class="bi bi-star text-muted fs-5"></i>
                    }
                }
            </div>
        </div>

        <!-- Tabs -->
        <ul class="nav nav-tabs grammar-tabs mb-4">
            <li class="nav-item">
                <button class="nav-link @(ActiveTab == "theory" ? "active" : "")"
                        @onclick='() => SwitchTab("theory")'>
                    <i class="bi bi-book me-1"></i> Теория
                </button>
            </li>
            <li class="nav-item">
                <button class="nav-link @(ActiveTab == "practice" ? "active" : "")"
                        @onclick="StartPracticeTab"
                        disabled="@(RuleDetail.ExerciseCount == 0)">
                    <i class="bi bi-pencil-square me-1"></i> Практика
                    @if (RuleDetail.ExerciseCount > 0)
                    {
                        <span class="badge bg-secondary bg-opacity-25 text-secondary ms-1">@RuleDetail.ExerciseCount</span>
                    }
                </button>
            </li>
            <li class="nav-item">
                <button class="nav-link @(ActiveTab == "progress" ? "active" : "")"
                        @onclick='() => SwitchTab("progress")'>
                    <i class="bi bi-graph-up me-1"></i> Прогресс
                </button>
            </li>
        </ul>

        <!-- Tab: Theory -->
        @if (ActiveTab == "theory")
        {
            <div class="card" style="border-radius: var(--radius-lg, 12px);">
                <div class="card-body p-4">
                    @if (!string.IsNullOrEmpty(RuleDetail.Description))
                    {
                        <p class="text-muted mb-4" style="font-size: 1.05rem;">@RuleDetail.Description</p>
                    }
                    @if (!string.IsNullOrEmpty(RuleDetail.HtmlContent))
                    {
                        <div class="markdown-content">
                            @((MarkupString)HtmlSanitizer.Sanitize(RuleDetail.HtmlContent))
                        </div>
                    }
                    else
                    {
                        <p class="text-muted text-center py-4">Теория для этого правила пока не добавлена.</p>
                    }
                </div>
            </div>

            @if (RuleDetail.ExerciseCount > 0)
            {
                <div class="text-center mt-4">
                    <button class="btn btn-primary btn-lg" @onclick="StartPracticeTab">
                        <i class="bi bi-pencil-square me-2"></i> Перейти к практике
                    </button>
                </div>
            }
        }

        <!-- Tab: Practice -->
        @if (ActiveTab == "practice")
        {
            @if (IsPracticeLoading)
            {
                <div class="text-center py-5">
                    <div class="spinner-border" role="status">
                        <span class="visually-hidden">Загрузка...</span>
                    </div>
                    <p class="text-muted mt-3">Подготовка упражнений...</p>
                </div>
            }
            else if (Session == null || !Session.Exercises.Any())
            {
                <div class="empty-state-card">
                    <div class="empty-state-icon">
                        <i class="bi bi-journal-x"></i>
                    </div>
                    <h3>Нет упражнений</h3>
                    <p class="text-muted mb-4">Для этого правила ещё нет упражнений. Можно сгенерировать их через AI.</p>

                    <div class="ai-generation-panel mx-auto text-start">
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Тип упражнения</label>
                            <select class="form-select" @bind="GenerateExerciseType" disabled="@IsGeneratingExercises">
                                @foreach (var exerciseType in ExerciseTypeOptions)
                                {
                                    <option value="@exerciseType.Key">@exerciseType.Value</option>
                                }
                            </select>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Количество</label>
                            <input type="number" class="form-control" min="1" max="20"
                                   @bind="GenerateExerciseCount"
                                   @bind:event="oninput"
                                   disabled="@IsGeneratingExercises" />
                        </div>

                        @if (!string.IsNullOrEmpty(GenerateExercisesMessage))
                        {
                            <div class="alert @(IsGenerateError ? "alert-danger" : "alert-success") py-2">
                                @GenerateExercisesMessage
                            </div>
                        }

                        <div class="d-grid">
                            <button class="btn btn-primary" @onclick="GenerateExercisesWithAi" disabled="@IsGeneratingExercises">
                                @if (IsGeneratingExercises)
                                {
                                    <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                                    <span>Генерация...</span>
                                }
                                else
                                {
                                    <span><i class="bi bi-stars me-2"></i>Сгенерировать упражнения</span>
                                }
                            </button>
                        </div>
                    </div>
                </div>
            }
            else if (ShowResults)
            {
                <!-- Results screen -->
                <div class="card" style="border-radius: var(--radius-lg, 12px);">
                    <div class="card-body text-center p-5">
                        <div class="fs-1 mb-3">
                            @if (SessionResult != null && SessionResult.AccuracyPercent >= 80)
                            {
                                <span>🎉</span>
                            }
                            else if (SessionResult != null && SessionResult.AccuracyPercent >= 50)
                            {
                                <span>👍</span>
                            }
                            else
                            {
                                <span>💪</span>
                            }
                        </div>
                        <h2 class="mb-3">@Session.RuleTitle</h2>

                        @if (SessionResult != null)
                        {
                            <div class="row g-3 mb-4 justify-content-center">
                                <div class="col-auto">
                                    <div class="stat-pill">
                                        <span class="stat-value text-success">@SessionResult.CorrectAnswers</span>
                                        <span class="stat-label">Верно</span>
                                    </div>
                                </div>
                                <div class="col-auto">
                                    <div class="stat-pill">
                                        <span class="stat-value text-danger">@(SessionResult.TotalAnswers - SessionResult.CorrectAnswers)</span>
                                        <span class="stat-label">Ошибок</span>
                                    </div>
                                </div>
                                <div class="col-auto">
                                    <div class="stat-pill">
                                        <span class="stat-value">@SessionResult.AccuracyPercent%</span>
                                        <span class="stat-label">Точность</span>
                                    </div>
                                </div>
                                <div class="col-auto">
                                    <div class="stat-pill">
                                        <span class="stat-value text-primary">+@SessionResult.XpEarned XP</span>
                                        <span class="stat-label">Опыт</span>
                                    </div>
                                </div>
                            </div>

                            <!-- Level display -->
                            <div class="mb-4">
                                <div class="d-flex justify-content-center align-items-center gap-2 mb-2">
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        if (i <= SessionResult.KnowledgeLevel)
                                        {
                                            <i class="bi bi-star-fill text-warning fs-4"></i>
                                        }
                                        else
                                        {
                                            <i class="bi bi-star text-muted fs-4"></i>
                                        }
                                    }
                                </div>
                                @if (SessionResult.LevelUp)
                                {
                                    <div class="badge bg-success fs-6 px-3 py-2">
                                        🎯 Уровень повышен! ⭐@SessionResult.PreviousLevel → ⭐@SessionResult.KnowledgeLevel
                                    </div>
                                }
                                @if (SessionResult.NextReview.HasValue)
                                {
                                    <p class="text-muted mt-2 small">
                                        Следующее повторение: @SessionResult.NextReview.Value.ToLocalTime().ToString("dd.MM.yyyy")
                                    </p>
                                }
                            </div>
                        }

                        <div class="d-flex justify-content-center gap-3">
                            <button class="btn btn-primary" @onclick="RetryPractice">
                                <i class="bi bi-arrow-repeat me-1"></i> Ещё раз
                            </button>
                            <button class="btn btn-outline-primary" @onclick='() => SwitchTab("progress")'>
                                <i class="bi bi-graph-up me-1"></i> Прогресс
                            </button>
                        </div>
                    </div>
                </div>
            }
            else
            {
                <!-- Practice session -->
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <span class="text-muted">Вопрос</span>
                    <div class="d-flex align-items-center gap-2">
                        <button class="btn btn-sm btn-outline-secondary"
                                @onclick="ToggleAiToolsPanel"
                                disabled="@IsGeneratingExercises">
                            <i class="bi bi-stars me-1"></i> Пополнить AI-банк
                        </button>
                        <span class="badge bg-primary fs-6">
                            @(CurrentExerciseIndex + 1) / @Session.Exercises.Count
                        </span>
                    </div>
                </div>

                @if (ShowAiToolsPanel)
                {
                    <div class="card ai-tools-card mb-3">
                        <div class="card-body py-3">
                            <div class="row g-2 align-items-end">
                                <div class="col-12 col-md-5">
                                    <label class="form-label mb-1 small text-muted">Тип</label>
                                    <select class="form-select form-select-sm" @bind="GenerateExerciseType" disabled="@IsGeneratingExercises">
                                        @foreach (var exerciseType in ExerciseTypeOptions)
                                        {
                                            <option value="@exerciseType.Key">@exerciseType.Value</option>
                                        }
                                    </select>
                                </div>
                                <div class="col-6 col-md-3">
                                    <label class="form-label mb-1 small text-muted">Количество</label>
                                    <input type="number" class="form-control form-control-sm" min="1" max="20"
                                           @bind="GenerateExerciseCount"
                                           @bind:event="oninput"
                                           disabled="@IsGeneratingExercises" />
                                </div>
                                <div class="col-6 col-md-4 d-grid">
                                    <button class="btn btn-sm btn-primary" @onclick="GenerateExercisesWithAi" disabled="@IsGeneratingExercises">
                                        @if (IsGeneratingExercises)
                                        {
                                            <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                                            <span>Генерация...</span>
                                        }
                                        else
                                        {
                                            <span>Сгенерировать</span>
                                        }
                                    </button>
                                </div>
                            </div>

                            @if (!string.IsNullOrEmpty(GenerateExercisesMessage))
                            {
                                <div class="alert @(IsGenerateError ? "alert-danger" : "alert-success") py-2 mt-2 mb-0">
                                    @GenerateExercisesMessage
                                </div>
                            }
                        </div>
                    </div>
                }

                <!-- Progress bar -->
                <div class="progress mb-4" style="height: 8px; border-radius: 4px;">
                    <div class="progress-bar" style="width: @(((double)(CurrentExerciseIndex) / Session.Exercises.Count * 100).ToString("F0"))%"></div>
                </div>

                <div class="card" style="border-radius: var(--radius-lg, 12px);">
                    <div class="card-body p-4">
                        <!-- Exercise type badge -->
                        <div class="mb-3">
                            <span class="badge bg-secondary">@GetExerciseTypeLabel(CurrentExercise.ExerciseType)</span>
                            @if (CurrentExercise.DifficultyTier > 1)
                            {
                                <span class="badge bg-warning text-dark ms-1">
                                    @(CurrentExercise.DifficultyTier == 2 ? "Средний" : "Сложный")
                                </span>
                            }
                        </div>

                        <!-- Question -->
                        <h5 class="mb-4">@CurrentExercise.Question</h5>

                        @switch (CurrentExercise.ExerciseType)
                        {
                            case "mcq":
                                <div class="d-grid gap-2">
                                    @for (int i = 0; i < CurrentExercise.GetOptions().Length; i++)
                                    {
                                        var idx = i;
                                        var option = CurrentExercise.GetOptions()[idx];
                                        string btnClass = "btn btn-outline-secondary btn-lg text-start";
                                        bool isDisabled = HasAnswered;

                                        if (HasAnswered)
                                        {
                                            if (idx == CurrentExercise.CorrectIndex)
                                                btnClass = "btn btn-success btn-lg text-start";
                                            else if (idx == SelectedMcqIndex)
                                                btnClass = "btn btn-danger btn-lg text-start";
                                        }
                                        else if (idx == SelectedMcqIndex)
                                        {
                                            btnClass = "btn btn-primary btn-lg text-start";
                                        }

                                        <button class="@btnClass" disabled="@isDisabled"
                                                @onclick="() => SelectMcqOption(idx)">
                                            @option
                                        </button>
                                    }
                                </div>
                                break;

                            case "error_correction":
                                @if (!string.IsNullOrEmpty(CurrentExercise.IncorrectSentence))
                                {
                                    <div class="alert alert-warning mb-3">
                                        <i class="bi bi-exclamation-triangle me-2"></i>
                                        <strong>@CurrentExercise.IncorrectSentence</strong>
                                    </div>
                                }
                                <div class="mb-3">
                                    <input type="text" class="form-control form-control-lg"
                                           placeholder="Исправьте ошибку..."
                                           @bind="TextAnswer"
                                           @bind:event="oninput"
                                           @onkeydown="OnTextKeyDown"
                                           disabled="@HasAnswered" />
                                </div>
                                if (!HasAnswered)
                                {
                                    <button class="btn btn-primary" @onclick="SubmitTextAnswer" disabled="@string.IsNullOrWhiteSpace(TextAnswer)">
                                        Проверить
                                    </button>
                                }
                                break;

                            case "transformation":
                            case "translation":
                                <div class="mb-3">
                                    <input type="text" class="form-control form-control-lg"
                                           placeholder="@(CurrentExercise.ExerciseType == "translation" ? "Введите перевод..." : "Введите преобразованное предложение...")"
                                           @bind="TextAnswer"
                                           @bind:event="oninput"
                                           @onkeydown="OnTextKeyDown"
                                           disabled="@HasAnswered" />
                                </div>
                                if (!HasAnswered)
                                {
                                    <button class="btn btn-primary" @onclick="SubmitTextAnswer" disabled="@string.IsNullOrWhiteSpace(TextAnswer)">
                                        Проверить
                                    </button>
                                }
                                break;

                            case "word_order":
                                <div class="mb-3">
                                    @if (!HasAnswered)
                                    {
                                        <div class="wo-available">
                                            @foreach (var word in AvailableWords)
                                            {
                                                var w = word;
                                                <button class="wo-word wo-word-available" @onclick="() => AddWordToOrder(w)">
                                                    @w
                                                </button>
                                            }
                                        </div>
                                    }
                                    <div class="wo-sentence @(HasAnswered ? "wo-sentence-answered" : "")">
                                        @if (OrderedWords.Any())
                                        {
                                            @for (int i = 0; i < OrderedWords.Count; i++)
                                            {
                                                var idx = i;
                                                var w = OrderedWords[idx];
                                                string wordClass = "wo-word wo-word-placed";
                                                if (HasAnswered)
                                                {
                                                    wordClass += (idx < CorrectWordOrder.Length &&
                                                                  string.Equals(w.TrimEnd('.', ',', '!', '?', ';', ':'),
                                                                                CorrectWordOrder[idx].TrimEnd('.', ',', '!', '?', ';', ':'),
                                                                                StringComparison.OrdinalIgnoreCase))
                                                        ? " wo-word-correct" : " wo-word-wrong";
                                                }
                                                <button class="@wordClass" @onclick="() => RemoveWordFromOrder(w)" disabled="@HasAnswered">
                                                    @if (HasAnswered)
                                                    {
                                                        <span class="wo-word-pos">@(idx + 1)</span>
                                                    }
                                                    @w
                                                    @if (!HasAnswered)
                                                    {
                                                        <i class="bi bi-x ms-1"></i>
                                                    }
                                                </button>
                                            }
                                        }
                                        else
                                        {
                                            <span class="text-muted">Нажимайте на слова для составления предложения...</span>
                                        }
                                    </div>
                                </div>
                                if (!HasAnswered && OrderedWords.Any())
                                {
                                    <button class="btn btn-primary" @onclick="SubmitWordOrder">
                                        Проверить
                                    </button>
                                }
                                break;

                            case "matching":
                                <!-- Matching: сопоставление левых и правых элементов -->
                                <div class="matching-container">
                                    <div class="matching-column matching-left-col">
                                        <div class="matching-col-header">
                                            <i class="bi bi-arrow-right-circle"></i> Начало
                                        </div>
                                        @for (int i = 0; i < GetMatchingLeftItems().Length; i++)
                                        {
                                            var li = i;
                                            var leftArr = GetMatchingLeftItems();
                                            var isPaired = MatchingPairs.ContainsKey(li);
                                            var pairNum = isPaired ? MatchingPairs.Keys.ToList().IndexOf(li) + 1 : 0;
                                            string leftClass = "matching-item matching-item-left";
                                            if (MatchingSelectedLeft == li)
                                                leftClass += " matching-item-selected";
                                            else if (isPaired && !HasAnswered)
                                                leftClass += " matching-item-paired";
                                            if (HasAnswered && isPaired)
                                            {
                                                leftClass += MatchingPairs[li] == MatchingCorrectMap[li]
                                                    ? " matching-item-correct"
                                                    : " matching-item-wrong";
                                            }
                                            <button class="@leftClass" disabled="@HasAnswered"
                                                    @onclick="() => SelectMatchingLeft(li)">
                                                @if (isPaired && !HasAnswered)
                                                {
                                                    <span class="matching-badge">@pairNum</span>
                                                }
                                                <span class="matching-text">@leftArr[li]</span>
                                            </button>
                                        }
                                    </div>

                                    <div class="matching-divider">
                                        <i class="bi bi-link-45deg"></i>
                                    </div>

                                    <div class="matching-column matching-right-col">
                                        <div class="matching-col-header">
                                            <i class="bi bi-arrow-left-circle"></i> Продолжение
                                        </div>
                                        @for (int i = 0; i < GetMatchingRightItems().Length; i++)
                                        {
                                            var ri = i;
                                            var rightArr = GetMatchingRightItems();
                                            var isPaired = MatchingPairs.ContainsValue(ri);
                                            var pairNum = isPaired ? MatchingPairs.Values.ToList().IndexOf(ri) + 1 : 0;
                                            string rightClass = "matching-item matching-item-right";
                                            if (isPaired && !HasAnswered)
                                                rightClass += " matching-item-paired";
                                            if (HasAnswered && isPaired)
                                            {
                                                var leftIdx = MatchingPairs.First(p => p.Value == ri).Key;
                                                rightClass += MatchingCorrectMap[leftIdx] == ri
                                                    ? " matching-item-correct"
                                                    : " matching-item-wrong";
                                            }
                                            <button class="@rightClass" disabled="@(HasAnswered || MatchingSelectedLeft == null)"
                                                    @onclick="() => SelectMatchingRight(ri)">
                                                @if (isPaired && !HasAnswered)
                                                {
                                                    <span class="matching-badge">@pairNum</span>
                                                }
                                                <span class="matching-text">@rightArr[ri]</span>
                                            </button>
                                        }
                                    </div>
                                </div>

                                @if (!HasAnswered && MatchingPairs.Count > 0)
                                {
                                    <div class="matching-status mt-3 text-center">
                                        <small class="text-muted">
                                            Соединено: @MatchingPairs.Count / @GetMatchingLeftItems().Length
                                        </small>
                                    </div>
                                }

                                if (!HasAnswered && MatchingPairs.Count > 0 && MatchingPairs.Count == GetMatchingLeftItems().Length)
                                {
                                    <div class="text-center mt-2">
                                        <button class="btn btn-primary px-4" @onclick="SubmitMatching">
                                            <i class="bi bi-check2-circle me-1"></i> Проверить
                                        </button>
                                    </div>
                                }
                                break;

                            case "dictation":
                                <div class="text-center mb-4">
                                    <button class="btn btn-outline-primary btn-lg rounded-circle" style="width: 80px; height: 80px; font-size: 2rem;"
                                            @onclick="SpeakDictation">
                                        <i class="bi bi-volume-up-fill"></i>
                                    </button>
                                    <div class="mt-2">
                                        <button class="btn btn-outline-secondary btn-sm" @onclick="SpeakDictationSlow">
                                            <i class="bi bi-skip-forward me-1"></i> Медленнее
                                        </button>
                                    </div>
                                    <p class="text-muted small mt-2">Прослушайте и запишите предложение</p>
                                </div>
                                <div class="mb-3">
                                    <input type="text" class="form-control form-control-lg"
                                           placeholder="Запишите то, что слышите..."
                                           @bind="TextAnswer"
                                           @bind:event="oninput"
                                           @onkeydown="OnTextKeyDown"
                                           disabled="@HasAnswered" />
                                </div>
                                if (!HasAnswered)
                                {
                                    <button class="btn btn-primary" @onclick="SubmitTextAnswer" disabled="@string.IsNullOrWhiteSpace(TextAnswer)">
                                        Проверить
                                    </button>
                                }
                                break;

                            default:
                                <div class="mb-3">
                                    <input type="text" class="form-control form-control-lg"
                                           placeholder="Введите ответ..."
                                           @bind="TextAnswer"
                                           @bind:event="oninput"
                                           @onkeydown="OnTextKeyDown"
                                           disabled="@HasAnswered" />
                                </div>
                                if (!HasAnswered)
                                {
                                    <button class="btn btn-primary" @onclick="SubmitTextAnswer" disabled="@string.IsNullOrWhiteSpace(TextAnswer)">
                                        Проверить
                                    </button>
                                }
                                break;
                        }

                        <!-- Feedback -->
                        @if (HasAnswered)
                        {
                            <div class="mt-4">
                                @if (CurrentAnswerCorrect)
                                {
                                    <div class="alert alert-success">
                                        <i class="bi bi-check-circle-fill me-2"></i>
                                        <strong>Правильно!</strong>
                                    </div>
                                }
                                else
                                {
                                    <div class="alert alert-danger">
                                        <i class="bi bi-x-circle-fill me-2"></i>
                                        <strong>Неверно.</strong>
                                        @if (CurrentExercise.ExerciseType == "matching")
                                        {
                                            <div class="mt-2">
                                                <small>Правильные пары:</small>
                                                <ul class="mb-0 mt-1">
                                                    @for (int i = 0; i < MatchingLeft.Length; i++)
                                                    {
                                                        <li><strong>@MatchingLeft[i]</strong> ↔ <strong>@MatchingRight[MatchingCorrectMap[i]]</strong></li>
                                                    }
                                                </ul>
                                            </div>
                                        }
                                        else if (!string.IsNullOrEmpty(CurrentExercise.CorrectAnswer))
                                        {
                                            <span> Правильный ответ: <strong>@CurrentExercise.CorrectAnswer</strong></span>
                                        }
                                        else if (CurrentExercise.ExerciseType == "mcq")
                                        {
                                            var opts = CurrentExercise.GetOptions();
                                            if (CurrentExercise.CorrectIndex >= 0 && CurrentExercise.CorrectIndex < opts.Length)
                                            {
                                                <span> Правильный ответ: <strong>@opts[CurrentExercise.CorrectIndex]</strong></span>
                                            }
                                        }
                                    </div>
                                }
                                @if (!string.IsNullOrEmpty(CurrentExercise.Explanation))
                                {
                                    <div class="alert alert-info">
                                        <i class="bi bi-lightbulb me-2"></i>
                                        @CurrentExercise.Explanation
                                    </div>
                                }

                                <button class="btn btn-primary btn-lg w-100 mt-2" @onclick="NextExercise">
                                    @(CurrentExerciseIndex < Session.Exercises.Count - 1 ? "Далее →" : "Завершить 🏁")
                                </button>
                            </div>
                        }
                    </div>
                </div>
            }
        }

        <!-- Tab: Progress -->
        @if (ActiveTab == "progress")
        {
            <div class="card" style="border-radius: var(--radius-lg, 12px);">
                <div class="card-body p-4">
                    @if (RuleDetail.TotalSessions == 0)
                    {
                        <div class="text-center py-4">
                            <div class="fs-1 mb-3">📊</div>
                            <h5>Пока нет данных</h5>
                            <p class="text-muted mb-3">Пройдите хотя бы одну сессию практики, чтобы увидеть прогресс.</p>
                            @if (RuleDetail.ExerciseCount > 0)
                            {
                                <button class="btn btn-primary" @onclick="StartPracticeTab">
                                    <i class="bi bi-pencil-square me-1"></i> Начать практику
                                </button>
                            }
                        </div>
                    }
                    else
                    {
                        <!-- Level & Stars -->
                        <div class="text-center mb-4">
                            <h5 class="mb-2">Уровень мастерства</h5>
                            <div class="d-flex justify-content-center align-items-center gap-2 mb-2">
                                @for (int i = 1; i <= 5; i++)
                                {
                                    if (i <= RuleDetail.KnowledgeLevel)
                                    {
                                        <i class="bi bi-star-fill text-warning fs-3"></i>
                                    }
                                    else
                                    {
                                        <i class="bi bi-star text-muted fs-3"></i>
                                    }
                                }
                            </div>
                            <span class="badge @GetLevelBadgeClass(RuleDetail.KnowledgeLevel) fs-6">
                                @GetLevelText(RuleDetail.KnowledgeLevel)
                            </span>
                        </div>

                        <hr />

                        <!-- Stats grid -->
                        <div class="row g-3 mb-4">
                            <div class="col-6 col-md-3">
                                <div class="stat-pill text-center">
                                    <span class="stat-value">@RuleDetail.AccuracyPercent%</span>
                                    <span class="stat-label">Точность</span>
                                </div>
                            </div>
                            <div class="col-6 col-md-3">
                                <div class="stat-pill text-center">
                                    <span class="stat-value">@RuleDetail.TotalSessions</span>
                                    <span class="stat-label">Сессий</span>
                                </div>
                            </div>
                            <div class="col-6 col-md-3">
                                <div class="stat-pill text-center">
                                    <span class="stat-value text-success">@RuleDetail.CorrectAnswers</span>
                                    <span class="stat-label">Верных</span>
                                </div>
                            </div>
                            <div class="col-6 col-md-3">
                                <div class="stat-pill text-center">
                                    <span class="stat-value text-danger">@(RuleDetail.TotalAnswers - RuleDetail.CorrectAnswers)</span>
                                    <span class="stat-label">Ошибок</span>
                                </div>
                            </div>
                        </div>

                        <!-- Details -->
                        <div class="list-group list-group-flush">
                            @if (RuleDetail.LastPracticeDate.HasValue)
                            {
                                <div class="list-group-item d-flex justify-content-between px-0">
                                    <span class="text-muted"><i class="bi bi-calendar-check me-2"></i>Последнее занятие</span>
                                    <strong>@RuleDetail.LastPracticeDate.Value.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</strong>
                                </div>
                            }
                            @if (RuleDetail.NextReview.HasValue)
                            {
                                var daysUntil = (RuleDetail.NextReview.Value - DateTime.UtcNow).TotalDays;
                                <div class="list-group-item d-flex justify-content-between px-0">
                                    <span class="text-muted"><i class="bi bi-clock-history me-2"></i>Следующее повторение</span>
                                    <strong class="@(daysUntil <= 0 ? "text-warning" : "")">
                                        @if (daysUntil <= 0)
                                        {
                                            <span>Сейчас!</span>
                                        }
                                        else
                                        {
                                            @RuleDetail.NextReview.Value.ToLocalTime().ToString("dd.MM.yyyy")
                                        }
                                    </strong>
                                </div>
                            }
                            <div class="list-group-item d-flex justify-content-between px-0">
                                <span class="text-muted"><i class="bi bi-arrow-repeat me-2"></i>Интервал повторения</span>
                                <strong>@FormatInterval(RuleDetail.IntervalDays)</strong>
                            </div>
                            @if (RuleDetail.LapseCount > 0)
                            {
                                <div class="list-group-item d-flex justify-content-between px-0">
                                    <span class="text-muted"><i class="bi bi-exclamation-triangle me-2"></i>Провалов</span>
                                    <strong class="text-danger">@RuleDetail.LapseCount</strong>
                                </div>
                            }
                        </div>

                        <div class="text-center mt-4">
                            <button class="btn btn-primary" @onclick="StartPracticeTab">
                                <i class="bi bi-pencil-square me-1"></i> Практиковать
                            </button>
                        </div>
                    }
                </div>
            </div>
        }
    }
</div>

@code {
    [Parameter] public int RuleId { get; set; }
    [SupplyParameterFromQuery] public string? Mode { get; set; }

    private GrammarRuleDetailDto? RuleDetail;
    private GrammarPracticeSession? Session;
    private GrammarSessionResultDto? SessionResult;
    private bool IsLoading = true;
    private bool IsPracticeLoading;
    private bool IsGeneratingExercises;
    private bool IsGenerateError;
    private bool ShowAiToolsPanel;
    private bool ShowResults;
    private string ActiveTab = "theory";
    private string GenerateExerciseType = "mcq";
    private int GenerateExerciseCount = 8;
    private string? GenerateExercisesMessage;

    // Practice state
    private int CurrentExerciseIndex;
    private bool HasAnswered;
    private bool CurrentAnswerCorrect;
    private int? SelectedMcqIndex;
    private string TextAnswer = "";
    private List<string> OrderedWords = new();
    private List<string> AvailableWords = new();
    private string[] CorrectWordOrder = Array.Empty<string>();
    private System.Diagnostics.Stopwatch _stopwatch = new();

    // Matching state
    private int? MatchingSelectedLeft;
    private Dictionary<int, int> MatchingPairs = new();
    private string[] MatchingLeft = Array.Empty<string>();
    private string[] MatchingRight = Array.Empty<string>();
    private int[] MatchingCorrectMap = Array.Empty<int>(); // MatchingCorrectMap[leftIdx] = rightIdx

    // TTS state
    private bool DictationAutoPlayed;

    private GrammarPracticeExerciseDto CurrentExercise =>
        Session!.Exercises[CurrentExerciseIndex];

    private static readonly IReadOnlyList<KeyValuePair<string, string>> ExerciseTypeOptions =
        new List<KeyValuePair<string, string>>
        {
            new("mcq", "MCQ - выбор правильного ответа"),
            new("transformation", "Transformation - преобразование"),
            new("error_correction", "Error correction - исправление ошибки"),
            new("word_order", "Word order - порядок слов"),
            new("translation", "Translation - перевод"),
            new("matching", "Matching - сопоставление"),
            new("dictation", "Dictation - диктант")
        };

    private List<GrammarAnswerSubmission> Answers = new();

    protected override async Task OnInitializedAsync()
    {
        await AuthService.InitializeAsync();
        await LoadRuleDetail();
    }

    private async Task LoadRuleDetail()
    {
        IsLoading = true;
        try
        {
            RuleDetail = await GrammarApi.GetRuleDetailAsync(RuleId);

            // If navigated with ?mode=review or ?mode=practice, go straight to practice
            if (RuleDetail != null && (Mode == "review" || Mode == "practice"))
            {
                ActiveTab = "practice";
                await LoadPractice();
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading grammar rule detail");
        }
        finally
        {
            IsLoading = false;
        }
    }

    private void SwitchTab(string tab)
    {
        ActiveTab = tab;
    }

    private async Task StartPracticeTab()
    {
        ActiveTab = "practice";
        if (Session == null || ShowResults)
        {
            await LoadPractice();
        }
    }

    private async Task LoadPractice()
    {
        IsPracticeLoading = true;
        ShowResults = false;
        ShowAiToolsPanel = false;
        GenerateExercisesMessage = null;
        IsGenerateError = false;
        CurrentExerciseIndex = 0;
        Answers.Clear();
        try
        {
            Session = await GrammarApi.StartPracticeAsync(RuleId);
            if (Session?.Exercises.Any() == true)
            {
                InitializeExercise();
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading grammar practice");
        }
        finally
        {
            IsPracticeLoading = false;
        }
    }

    private void InitializeExercise()
    {
        HasAnswered = false;
        CurrentAnswerCorrect = false;
        SelectedMcqIndex = null;
        TextAnswer = "";
        OrderedWords.Clear();
        MatchingSelectedLeft = null;
        MatchingPairs.Clear();
        _stopwatch.Restart();

        var ex = Session?.Exercises[CurrentExerciseIndex];
        if (ex is { ExerciseType: "word_order" })
        {
            AvailableWords = ex.GetShuffledWords().ToList();
            if (!AvailableWords.Any() && !string.IsNullOrEmpty(ex.CorrectAnswer))
            {
                AvailableWords = ex.CorrectAnswer.Split(' ', StringSplitOptions.RemoveEmptyEntries).ToList();
            }
            // Always shuffle to ensure randomness
            var rng = new Random();
            for (int i = AvailableWords.Count - 1; i > 0; i--)
            {
                int j = rng.Next(i + 1);
                (AvailableWords[i], AvailableWords[j]) = (AvailableWords[j], AvailableWords[i]);
            }
            // Store correct order for per-word highlighting
            CorrectWordOrder = (ex.CorrectAnswer ?? "").Split(' ', StringSplitOptions.RemoveEmptyEntries);
        }

        // Auto-play TTS for dictation
        if (ex is { ExerciseType: "dictation" })
        {
            DictationAutoPlayed = false;
        }

        // Parse matching pairs from pipe-delimited options and shuffle right column
        if (ex is { ExerciseType: "matching" })
        {
            var opts = ex.GetOptions();
            var left = new List<string>();
            var right = new List<string>();
            foreach (var opt in opts)
            {
                var parts = opt.Split('|', 2);
                left.Add(parts[0].Trim());
                right.Add(parts.Length > 1 ? parts[1].Trim() : parts[0].Trim());
            }
            // Shuffle right column and track correct mapping
            var indices = Enumerable.Range(0, right.Count).ToList();
            var rng = new Random();
            for (int i = indices.Count - 1; i > 0; i--)
            {
                int j = rng.Next(i + 1);
                (indices[i], indices[j]) = (indices[j], indices[i]);
            }
            MatchingLeft = left.ToArray();
            MatchingRight = indices.Select(i => right[i]).ToArray();
            // MatchingCorrectMap[leftIdx] = shuffled rightIdx
            MatchingCorrectMap = new int[left.Count];
            for (int li = 0; li < left.Count; li++)
            {
                MatchingCorrectMap[li] = indices.IndexOf(li);
            }
        }
        else
        {
            MatchingLeft = Array.Empty<string>();
            MatchingRight = Array.Empty<string>();
            MatchingCorrectMap = Array.Empty<int>();
        }
    }

    private void SelectMcqOption(int index)
    {
        if (HasAnswered) return;
        SelectedMcqIndex = index;
        CurrentAnswerCorrect = index == CurrentExercise.CorrectIndex;
        RecordAnswer(CurrentAnswerCorrect, CurrentExercise.GetOptions().ElementAtOrDefault(index));
        HasAnswered = true;
    }

    // TTS for dictation exercises
    private async Task SpeakDictation()
    {
        if (CurrentExercise?.CorrectAnswer != null)
        {
            await JS.InvokeVoidAsync("speakText", CurrentExercise.CorrectAnswer, "en-US");
        }
    }

    private async Task SpeakDictationSlow()
    {
        if (CurrentExercise?.CorrectAnswer != null)
        {
            await JS.InvokeVoidAsync("speakTextSlow", CurrentExercise.CorrectAnswer, "en-US", 0.6);
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // Auto-play dictation on exercise load
        if (Session != null && CurrentExerciseIndex < Session.Exercises.Count)
        {
            var ex = Session.Exercises[CurrentExerciseIndex];
            if (ex.ExerciseType == "dictation" && !DictationAutoPlayed && !HasAnswered)
            {
                DictationAutoPlayed = true;
                await SpeakDictation();
            }
        }
    }

    private void SubmitTextAnswer()
    {
        if (HasAnswered || string.IsNullOrWhiteSpace(TextAnswer)) return;
        CurrentAnswerCorrect = CheckTextAnswer(CurrentExercise, TextAnswer.Trim());
        RecordAnswer(CurrentAnswerCorrect, TextAnswer.Trim());
        HasAnswered = true;
    }

    private void SubmitWordOrder()
    {
        if (HasAnswered || !OrderedWords.Any()) return;
        var userSentence = string.Join(" ", OrderedWords);
        TextAnswer = userSentence;
        CurrentAnswerCorrect = CheckTextAnswer(CurrentExercise, userSentence);
        RecordAnswer(CurrentAnswerCorrect, userSentence);
        HasAnswered = true;
    }

    // === Matching logic ===
    private void SelectMatchingLeft(int index)
    {
        if (HasAnswered) return;
        MatchingSelectedLeft = index;
    }

    private void SelectMatchingRight(int index)
    {
        if (HasAnswered || MatchingSelectedLeft == null) return;
        MatchingPairs[MatchingSelectedLeft.Value] = index;
        MatchingSelectedLeft = null;
    }

    private void SubmitMatching()
    {
        if (HasAnswered) return;
        // Check each pair: user mapped left[i] -> right[j], correct is MatchingCorrectMap[i]
        int correctPairs = MatchingPairs.Count(p => p.Value == MatchingCorrectMap[p.Key]);
        CurrentAnswerCorrect = correctPairs == MatchingPairs.Count;
        RecordAnswer(CurrentAnswerCorrect, $"matched:{correctPairs}/{MatchingPairs.Count}");
        HasAnswered = true;
    }

    private bool CheckTextAnswer(GrammarPracticeExerciseDto exercise, string userAnswer)
    {
        if (string.IsNullOrWhiteSpace(userAnswer)) return false;
        var trimmed = userAnswer.Trim().TrimEnd('.');

        if (!string.IsNullOrEmpty(exercise.CorrectAnswer))
        {
            if (AnswersMatch(trimmed, exercise.CorrectAnswer))
                return true;
        }

        foreach (var alt in exercise.GetAlternativeAnswers())
        {
            if (AnswersMatch(trimmed, alt))
                return true;
        }

        if (exercise.ExerciseType == "mcq")
        {
            var options = exercise.GetOptions();
            if (exercise.CorrectIndex >= 0 && exercise.CorrectIndex < options.Length)
            {
                return string.Equals(trimmed, options[exercise.CorrectIndex].Trim(), StringComparison.OrdinalIgnoreCase);
            }
        }

        return false;
    }

    private static bool AnswersMatch(string userAnswer, string correctAnswer)
    {
        var a = userAnswer.Trim().TrimEnd('.');
        var b = correctAnswer.Trim().TrimEnd('.');
        if (string.Equals(a, b, StringComparison.OrdinalIgnoreCase))
            return true;
        // Compare with contractions expanded
        return string.Equals(ExpandContractions(a), ExpandContractions(b), StringComparison.OrdinalIgnoreCase);
    }

    private static string ExpandContractions(string text)
    {
        // Order matters: longer patterns first to avoid partial replacements
        var result = System.Text.RegularExpressions.Regex.Replace(text, @"\bwon't\b", "will not", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
        result = System.Text.RegularExpressions.Regex.Replace(result, @"\bcan't\b", "cannot", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
        result = System.Text.RegularExpressions.Regex.Replace(result, @"\bshan't\b", "shall not", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
        result = System.Text.RegularExpressions.Regex.Replace(result, @"\blet's\b", "let us", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
        result = System.Text.RegularExpressions.Regex.Replace(result, @"\b(\w+)'re\b", "$1 are", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
        result = System.Text.RegularExpressions.Regex.Replace(result, @"\b(\w+)'ve\b", "$1 have", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
        result = System.Text.RegularExpressions.Regex.Replace(result, @"\b(\w+)'ll\b", "$1 will", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
        result = System.Text.RegularExpressions.Regex.Replace(result, @"\b(\w+)'d\b", "$1 would", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
        result = System.Text.RegularExpressions.Regex.Replace(result, @"\b(\w+)n't\b", "$1 not", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
        result = System.Text.RegularExpressions.Regex.Replace(result, @"\b(I|he|she|it|that|there|here|what|who|how)'s\b", "$1 is", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
        result = System.Text.RegularExpressions.Regex.Replace(result, @"\bI'm\b", "I am", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
        return result;
    }

    private void RecordAnswer(bool isCorrect, string? userAnswer)
    {
        _stopwatch.Stop();
        Answers.Add(new GrammarAnswerSubmission
        {
            ExerciseId = CurrentExercise.Id,
            UserAnswer = userAnswer,
            IsCorrect = isCorrect,
            ResponseTimeMs = (int)_stopwatch.ElapsedMilliseconds
        });
    }

    private void AddWordToOrder(string word)
    {
        if (HasAnswered) return;
        AvailableWords.Remove(word);
        OrderedWords.Add(word);
    }

    private void RemoveWordFromOrder(string word)
    {
        if (HasAnswered) return;
        OrderedWords.Remove(word);
        AvailableWords.Add(word);
    }

    private async Task NextExercise()
    {
        if (CurrentExerciseIndex < Session!.Exercises.Count - 1)
        {
            CurrentExerciseIndex++;
            InitializeExercise();
        }
        else
        {
            await FinishSession();
        }
    }

    private async Task FinishSession()
    {
        try
        {
            var submission = new GrammarSessionSubmission { Answers = Answers };
            SessionResult = await GrammarApi.SubmitSessionAsync(RuleId, submission);

            // Update local detail with new progress
            if (SessionResult != null && RuleDetail != null)
            {
                RuleDetail.KnowledgeLevel = SessionResult.KnowledgeLevel;
                RuleDetail.TotalSessions++;
                RuleDetail.CorrectAnswers += SessionResult.CorrectAnswers;
                RuleDetail.TotalAnswers += SessionResult.TotalAnswers;
                RuleDetail.AccuracyPercent = RuleDetail.TotalAnswers > 0
                    ? Math.Round((double)RuleDetail.CorrectAnswers / RuleDetail.TotalAnswers * 100, 1)
                    : 0;
                RuleDetail.NextReview = SessionResult.NextReview;
                RuleDetail.LastPracticeDate = DateTime.UtcNow;
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error submitting grammar session");
        }
        ShowResults = true;
    }

    private async Task RetryPractice()
    {
        await LoadPractice();
    }

    private async Task GenerateExercisesWithAi()
    {
        if (IsGeneratingExercises || RuleDetail == null)
            return;

        GenerateExerciseCount = Math.Clamp(GenerateExerciseCount, 1, 20);
        IsGeneratingExercises = true;
        GenerateExercisesMessage = null;
        IsGenerateError = false;

        try
        {
            int difficultyTier = GetRecommendedDifficultyTier(RuleDetail.KnowledgeLevel);
            var response = await GrammarApi.GenerateExercisesAsync(RuleId, GenerateExerciseType, GenerateExerciseCount, difficultyTier);

            if (response == null)
            {
                IsGenerateError = true;
                GenerateExercisesMessage = "Не удалось сгенерировать упражнения. Попробуйте позже.";
                return;
            }

            if (response.AiServiceUnavailable)
            {
                GenerateExercisesMessage = response.ReturnedCount > 0
                    ? $"AI недоступен. Использован существующий банк ({response.ReturnedCount} упражнений)."
                    : "AI недоступен и в банке нет упражнений.";
            }
            else
            {
                GenerateExercisesMessage = response.GeneratedCount > 0
                    ? $"Готово: добавлено {response.GeneratedCount} упражнений, доступно {response.ReturnedCount}."
                    : (response.Warning ?? "Новых упражнений не добавлено: использован существующий банк.");
            }

            var refreshed = await GrammarApi.GetRuleDetailAsync(RuleId);
            if (refreshed != null)
                RuleDetail = refreshed;

            await LoadPractice();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error generating grammar exercises for rule {RuleId}", RuleId);
            IsGenerateError = true;
            GenerateExercisesMessage = "Ошибка при генерации упражнений.";
        }
        finally
        {
            IsGeneratingExercises = false;
        }
    }

    private static int GetRecommendedDifficultyTier(int knowledgeLevel) => knowledgeLevel switch
    {
        <= 1 => 1,
        <= 3 => 2,
        _ => 3
    };

    private void ToggleAiToolsPanel()
    {
        ShowAiToolsPanel = !ShowAiToolsPanel;
    }

    private void OnTextKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !HasAnswered && !string.IsNullOrWhiteSpace(TextAnswer))
        {
            SubmitTextAnswer();
        }
    }

    private string GetExerciseTypeLabel(string type) => type switch
    {
        "mcq" => "📝 Выберите правильный ответ",
        "transformation" => "🔄 Трансформация предложения",
        "error_correction" => "❌ Исправьте ошибку",
        "word_order" => "🔀 Составьте предложение",
        "translation" => "🌐 Перевод",
        "matching" => "🔗 Сопоставление",
        "dictation" => "🎧 Диктант",
        _ => "📝 Упражнение"
    };

    // Matching helpers
    private string[] GetMatchingLeftItems() => MatchingLeft;

    private string[] GetMatchingRightItems() => MatchingRight;

    private string GetDifficultyBadgeClass(int level) => level switch
    {
        1 => "bg-success",
        2 => "bg-warning text-dark",
        3 => "bg-danger",
        _ => "bg-secondary"
    };

    private string GetDifficultyText(int level) => level switch
    {
        1 => "Начальный",
        2 => "Средний",
        3 => "Продвинутый",
        _ => "Неизвестно"
    };

    private string GetLevelBadgeClass(int level) => level switch
    {
        0 => "bg-secondary",
        1 or 2 => "bg-warning text-dark",
        3 => "bg-info",
        4 or 5 => "bg-success",
        _ => "bg-secondary"
    };

    private string GetLevelText(int level) => level switch
    {
        0 => "Не начато",
        1 => "Новичок",
        2 => "Знакомство",
        3 => "Понимание",
        4 => "Уверенность",
        5 => "Мастерство",
        _ => $"Уровень {level}"
    };

    private string FormatInterval(double days)
    {
        if (days < 1) return "менее 1 дня";
        if (days < 2) return "1 день";
        if (days < 7) return $"{(int)days} дн.";
        if (days < 30) return $"{(int)(days / 7)} нед.";
        return $"{(int)(days / 30)} мес.";
    }
}
