<LearningTrainerWeb.Components.Shared.ShareDialog
    IsVisible="ShareDialogVisible"
    ContentId="ShareContentId"
    ContentName="@ShareContentName"
    ContentType="@ShareContentType"
    OnClose="CloseShareDialog" />

@code {
    private bool IsAuthenticated = false;
    private bool IsTeacher = false;
    private bool IsExporting = false;
    private string ActiveTab = "dictionaries";
    private string? ExportMessage;
    private bool ExportSuccess;

    // Import state
    private bool ShowImportModal = false;
    private bool IsImporting = false;
    private IBrowserFile? ImportFile;
    private string? ImportDictionaryName;
    private string? ImportLanguageFrom;
    private string? ImportLanguageTo;
    private string? ImportError;

    // Create dictionary state
    private bool ShowCreateDictModal;
    private bool IsCreatingDict;
    private string NewDictName = "";
    private string NewDictDescription = "";
    private string NewDictLangFrom = "English";
    private string NewDictLangTo = "Russian";
    private string? NewDictTags;
    private string? CreateDictError;
    private string NewWordOriginal = "";
    private string NewWordTranslation = "";
    private List<(string Original, string Translation)> NewWords = new();

    // Create rule state
    private bool ShowCreateRuleModal;
    private bool IsCreatingRule;
    private string NewRuleTitle = "";
    private string NewRuleDescription = "";
    private string NewRuleCategory = "Grammar";
    private int NewRuleDifficulty = 1;
    private string NewRuleContent = "";
    private string? CreateRuleError;

    // Exercise builder state
    private List<CreateExerciseInput> NewExercises = new();
    private string ExQuestion = "";
    private string ExOption0 = "";
    private string ExOption1 = "";
    private string ExOption2 = "";
    private string ExOption3 = "";
    private int ExCorrectIndex = 0;
    private string ExExplanation = "";

    private static readonly string[] LanguageOptions = {
        "English", "Russian", "German", "French", "Spanish", "Italian", "Portuguese",
        "Chinese", "Japanese", "Korean", "Arabic", "Turkish", "Polish", "Dutch",
        "Swedish", "Norwegian", "Danish", "Finnish", "Czech", "Greek", "Hindi",
        "Thai", "Vietnamese", "Indonesian", "Ukrainian", "Hungarian", "Romanian",
        "Hebrew", "Croatian", "Bulgarian"
    };

    // Share dialog state
    private bool ShareDialogVisible;
    private int ShareContentId;
    private string ShareContentName = "";
    private string ShareContentType = "dictionary";

    private List<MyDictionaryItem>? MyDictionaries;
    private List<MyRuleItem>? MyRules;
    private List<DownloadedItem>? DownloadedContent;

    // Pagination
    private const int MyContentPageSize = 9;
    private int DictionaryPage = 1;
    private int RulePage = 1;
    private int DownloadPage = 1;

    private int DictionaryTotalPages => MyDictionaries == null || !MyDictionaries.Any() ? 1 : (int)Math.Ceiling(MyDictionaries.Count / (double)MyContentPageSize);
    private int RuleTotalPages => MyRules == null || !MyRules.Any() ? 1 : (int)Math.Ceiling(MyRules.Count / (double)MyContentPageSize);
    private int DownloadTotalPages => DownloadedContent == null || !DownloadedContent.Any() ? 1 : (int)Math.Ceiling(DownloadedContent.Count / (double)MyContentPageSize);

    private IEnumerable<MyDictionaryItem> PagedDictionaries => MyDictionaries?.Skip((DictionaryPage - 1) * MyContentPageSize).Take(MyContentPageSize) ?? Enumerable.Empty<MyDictionaryItem>();
    private IEnumerable<MyRuleItem> PagedRules => MyRules?.Skip((RulePage - 1) * MyContentPageSize).Take(MyContentPageSize) ?? Enumerable.Empty<MyRuleItem>();
    private IEnumerable<DownloadedItem> PagedDownloads => DownloadedContent?.Skip((DownloadPage - 1) * MyContentPageSize).Take(MyContentPageSize) ?? Enumerable.Empty<DownloadedItem>();

    private IEnumerable<int> GetPageWindow(int current, int total)
    {
        const int wing = 2;
        var pages = new List<int> { 1 };

        var rangeStart = Math.Max(2, current - wing);
        var rangeEnd = Math.Min(total - 1, current + wing);

        if (rangeStart > 2)
            pages.Add(-1);

        for (int p = rangeStart; p <= rangeEnd; p++)
            pages.Add(p);

        if (rangeEnd < total - 1)
            pages.Add(-1);

        if (total > 1)
            pages.Add(total);

        return pages;
    }

    protected override async Task OnInitializedAsync()
    {
        var session = await AuthService.GetCurrentSessionAsync();
        IsAuthenticated = session != null;
        IsTeacher = session?.Role == "Teacher";

        if (IsAuthenticated)
        {
            await LoadMyContent();
        }
    }

    private async Task LoadMyContent()
    {
        try
        {
            MyDictionaries = await ContentApi.GetMyDictionariesAsync();
            MyRules = await ContentApi.GetMyRulesAsync();
            DownloadedContent = await ContentApi.GetDownloadedContentAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error: {ex.Message}");
        }
    }

    private async Task PublishDictionary(int id)
    {
        try
        {
            await ContentApi.PublishDictionaryAsync(id);
            await LoadMyContent();
        }
        catch (Exception ex)
        {
            ExportMessage = $"Ошибка публикации: {ex.Message}";
            ExportSuccess = false;
            StateHasChanged();
            await Task.Delay(3000);
            ExportMessage = null;
        }
    }

    private async Task UnpublishDictionary(int id)
    {
        try
        {
            await ContentApi.UnpublishDictionaryAsync(id);
            await LoadMyContent();
        }
        catch (Exception ex)
        {
            ExportMessage = $"Ошибка: {ex.Message}";
            ExportSuccess = false;
            StateHasChanged();
            await Task.Delay(3000);
            ExportMessage = null;
        }
    }

    private async Task PublishRule(int id)
    {
        try
        {
            await ContentApi.PublishRuleAsync(id);
            await LoadMyContent();
        }
        catch (Exception ex)
        {
            ExportMessage = $"Ошибка публикации: {ex.Message}";
            ExportSuccess = false;
            StateHasChanged();
            await Task.Delay(3000);
            ExportMessage = null;
        }
    }

    private async Task UnpublishRule(int id)
    {
        try
        {
            await ContentApi.UnpublishRuleAsync(id);
            await LoadMyContent();
        }
        catch (Exception ex)
        {
            ExportMessage = $"Ошибка: {ex.Message}";
            ExportSuccess = false;
            StateHasChanged();
            await Task.Delay(3000);
            ExportMessage = null;
        }
    }

    private void ShowImportDialog()
    {
        ShowImportModal = true;
        ImportFile = null;
        ImportDictionaryName = null;
        ImportLanguageFrom = null;
        ImportLanguageTo = null;
        ImportError = null;
    }

    private void CloseImportDialog()
    {
        ShowImportModal = false;
        ImportError = null;
    }

    private void OnImportFileSelected(InputFileChangeEventArgs e)
    {
        ImportFile = e.File;
        ImportError = null;
    }

    private async Task ImportDictionary()
    {
        if (ImportFile == null) return;

        IsImporting = true;
        ImportError = null;
        StateHasChanged();

        try
        {
            using var stream = ImportFile.OpenReadStream(maxAllowedSize: 50 * 1024 * 1024);
            var name = string.IsNullOrWhiteSpace(ImportDictionaryName) ? null : ImportDictionaryName;
            var langFrom = string.IsNullOrWhiteSpace(ImportLanguageFrom) ? null : ImportLanguageFrom;
            var langTo = string.IsNullOrWhiteSpace(ImportLanguageTo) ? null : ImportLanguageTo;

            ImportResult result;

            if (ImportFile.Name.EndsWith(".apkg", StringComparison.OrdinalIgnoreCase) ||
                ImportFile.Name.EndsWith(".colpkg", StringComparison.OrdinalIgnoreCase))
            {
                result = await ContentApi.ImportDictionaryFromAnkiAsync(stream, ImportFile.Name, name, langFrom, langTo);
            }
            else
            {
                result = await ContentApi.ImportDictionaryFromFileAsync(stream, ImportFile.Name, name, langFrom, langTo);
            }

            ShowImportModal = false;
            ExportMessage = $"Словарь «{result.Name}» ({result.WordCount} слов) успешно импортирован!";
            ExportSuccess = true;
            await LoadMyContent();
            StateHasChanged();
            await Task.Delay(4000);
            ExportMessage = null;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            ImportError = ex.Message;
        }
        finally
        {
            IsImporting = false;
            StateHasChanged();
        }
    }

    private async Task ExportDictionaryAsJson(int dictionaryId, string name)
    {
        try
        {
            var result = await ContentApi.ExportDictionaryAsJsonAsync(dictionaryId);
            await DownloadFile(result.Data, result.FileName, result.ContentType);
            ExportMessage = $"Словарь '{name}' успешно экспортирован!";
            ExportSuccess = true;
        }
        catch (Exception ex)
        {
            ExportMessage = $"Ошибка экспорта: {ex.Message}";
            ExportSuccess = false;
        }
        StateHasChanged();
        await Task.Delay(3000);
        ExportMessage = null;
        StateHasChanged();
    }

    private async Task ExportDictionaryAsCsv(int dictionaryId, string name)
    {
        try
        {
            var result = await ContentApi.ExportDictionaryAsCsvAsync(dictionaryId);
            await DownloadFile(result.Data, result.FileName, result.ContentType);
            ExportMessage = $"Словарь '{name}' успешно экспортирован!";
            ExportSuccess = true;
        }
        catch (Exception ex)
        {
            ExportMessage = $"Ошибка экспорта: {ex.Message}";
            ExportSuccess = false;
        }
        StateHasChanged();
        await Task.Delay(3000);
        ExportMessage = null;
        StateHasChanged();
    }

    private async Task ExportAllDictionaries()
    {
        IsExporting = true;
        StateHasChanged();

        try
        {
            var result = await ContentApi.ExportAllDictionariesAsZipAsync();
            await DownloadFile(result.Data, result.FileName, result.ContentType);
            ExportMessage = "Все словари успешно экспортированы!";
            ExportSuccess = true;
        }
        catch (Exception ex)
        {
            ExportMessage = $"Ошибка экспорта: {ex.Message}";
            ExportSuccess = false;
        }
        finally
        {
            IsExporting = false;
        }

        StateHasChanged();
        await Task.Delay(3000);
        ExportMessage = null;
        StateHasChanged();
    }

    private async Task DownloadFile(byte[] data, string fileName, string contentType)
    {
        var base64 = Convert.ToBase64String(data);
        await JS.InvokeVoidAsync("downloadFile", fileName, contentType, base64);
    }

