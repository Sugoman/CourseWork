    // === Create Dictionary ===

    private void ShowCreateDictionaryDialog()
    {
        NewDictName = "";
        NewDictDescription = "";
        NewDictLangFrom = "English";
        NewDictLangTo = "Russian";
        NewDictTags = null;
        CreateDictError = null;
        NewWords.Clear();
        NewWordOriginal = "";
        NewWordTranslation = "";
        ShowCreateDictModal = true;
    }

    private void AddWordToList()
    {
        if (string.IsNullOrWhiteSpace(NewWordOriginal) || string.IsNullOrWhiteSpace(NewWordTranslation)) return;
        NewWords.Add((NewWordOriginal.Trim(), NewWordTranslation.Trim()));
        NewWordOriginal = "";
        NewWordTranslation = "";
    }

    private void OnWordKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            AddWordToList();
        }
    }

    private async Task CreateDictionary()
    {
        if (string.IsNullOrWhiteSpace(NewDictName)) return;

        IsCreatingDict = true;
        CreateDictError = null;
        StateHasChanged();

        try
        {
            var result = await ContentApi.CreateDictionaryAsync(
                NewDictName.Trim(), NewDictDescription.Trim(),
                NewDictLangFrom, NewDictLangTo, NewDictTags?.Trim());

            // Add words if any
            int added = 0;
            foreach (var (original, translation) in NewWords)
            {
                try
                {
                    await ContentApi.AddWordAsync(result.Id, original, translation);
                    added++;
                }
                catch { /* skip individual word errors */ }
            }

            ShowCreateDictModal = false;
            ExportMessage = added > 0
                ? $"Словарь «{result.Name}» создан ({added} слов добавлено)!"
                : $"Словарь «{result.Name}» создан!";
            ExportSuccess = true;
            await LoadMyContent();
            StateHasChanged();
            await Task.Delay(4000);
            ExportMessage = null;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            CreateDictError = ex.Message;
        }
        finally
        {
            IsCreatingDict = false;
            StateHasChanged();
        }
    }

    // === Create Rule ===

    private void ShowCreateRuleDialog()
    {
        NewRuleTitle = "";
        NewRuleDescription = "";
        NewRuleCategory = "Grammar";
        NewRuleDifficulty = 1;
        NewRuleContent = "";
        CreateRuleError = null;
        NewExercises.Clear();
        ResetExerciseForm();
        ShowCreateRuleModal = true;
    }

    // Exercise builder helpers

    private bool CanAddExercise
    {
        get
        {
            var opts = new[] { ExOption0, ExOption1, ExOption2, ExOption3 };
            return !string.IsNullOrWhiteSpace(ExQuestion)
                && opts.Count(o => !string.IsNullOrWhiteSpace(o)) >= 2
                && ExCorrectIndex < 4
                && !string.IsNullOrWhiteSpace(opts[ExCorrectIndex]);
        }
    }

    private string GetExOption(int idx) => idx switch { 0 => ExOption0, 1 => ExOption1, 2 => ExOption2, _ => ExOption3 };

    private void SetExOption(int idx, string value)
    {
        switch (idx) { case 0: ExOption0 = value; break; case 1: ExOption1 = value; break; case 2: ExOption2 = value; break; case 3: ExOption3 = value; break; }
    }

    private void SetCorrect0() => ExCorrectIndex = 0;
    private void SetCorrect1() => ExCorrectIndex = 1;
    private void SetCorrect2() => ExCorrectIndex = 2;
    private void SetCorrect3() => ExCorrectIndex = 3;

    private static string GetStringValue(ChangeEventArgs e) => e.Value?.ToString() ?? "";

    private Action<ChangeEventArgs> CreateOptionHandler(int idx) =>
        (ChangeEventArgs e) => SetExOption(idx, e.Value?.ToString() ?? "");

    private static string GetOptionPlaceholder(int idx) => "Вариант " + (idx + 1);

    private void AddExerciseToList()
    {
        if (!CanAddExercise) return;

        var allOptions = new[] { ExOption0, ExOption1, ExOption2, ExOption3 };
        var nonEmptyOptions = allOptions.Where(o => !string.IsNullOrWhiteSpace(o)).ToArray();
        var correctedIndex = Array.IndexOf(nonEmptyOptions, allOptions[ExCorrectIndex]);

        NewExercises.Add(new CreateExerciseInput
        {
            Question = ExQuestion.Trim(),
            Options = nonEmptyOptions.Select(o => o.Trim()).ToArray(),
            CorrectIndex = correctedIndex >= 0 ? correctedIndex : 0,
            Explanation = ExExplanation.Trim()
        });

        ResetExerciseForm();
    }

    private void ResetExerciseForm()
    {
        ExQuestion = "";
        ExOption0 = "";
        ExOption1 = "";
        ExOption2 = "";
        ExOption3 = "";
        ExCorrectIndex = 0;
        ExExplanation = "";
    }

    private async Task CreateRule()
    {
        if (string.IsNullOrWhiteSpace(NewRuleTitle) || string.IsNullOrWhiteSpace(NewRuleContent)) return;

        IsCreatingRule = true;
        CreateRuleError = null;
        StateHasChanged();

        try
        {
            var result = await ContentApi.CreateRuleAsync(
                NewRuleTitle.Trim(), NewRuleContent.Trim(),
                NewRuleDescription.Trim(), NewRuleCategory, NewRuleDifficulty,
                NewExercises.Count > 0 ? NewExercises : null);

            ShowCreateRuleModal = false;
            var msg = $"Правило «{result.Title}» создано!";
            if (NewExercises.Count > 0) msg = $"Правило «{result.Title}» создано ({NewExercises.Count} упражнений)!";
            ExportMessage = msg;
            ExportSuccess = true;
            ActiveTab = "rules";
            await LoadMyContent();
            StateHasChanged();
            await Task.Delay(4000);
            ExportMessage = null;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            CreateRuleError = ex.Message;
        }
        finally
        {
            IsCreatingRule = false;
            StateHasChanged();
        }
    }
}
