@page "/my-content"
@inject IContentApiService ContentApi
@inject IAuthService AuthService
@inject IClassroomApiService ClassroomApi
@inject NavigationManager Navigation
@inject IJSRuntime JS
@using Microsoft.AspNetCore.Components.Forms

<PageTitle>Мой контент - Ingat</PageTitle>

<div class="container">
    @if (!IsAuthenticated)
    {
        <div class="text-center py-5">
            <div style="font-size: 4rem; margin-bottom: 1rem; color: var(--primary-400);"><i class="bi bi-lock"></i></div>
            <h2>Требуется авторизация</h2>
            <p class="text-muted mb-4">Войдите, чтобы управлять своим контентом</p>
            <a href="login" class="btn btn-primary btn-lg">
                <i class="bi bi-box-arrow-in-right me-2"></i> Войти
            </a>
        </div>
    }
    else
    {
        <!-- Header -->
        <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
            <div class="section-heading" style="margin-bottom: 0;">
                <i class="bi bi-folder2-open"></i>
                <h1 style="margin-bottom: 0;">Мой контент</h1>
            </div>
            <div class="d-flex gap-2">
                <button class="btn btn-outline-success gap-2" @onclick="ShowImportDialog">
                    <i class="bi bi-upload me-1"></i>
                    Импорт
                </button>
                <button class="btn btn-outline-primary gap-2" @onclick="ExportAllDictionaries" disabled="@IsExporting">
                    @if (IsExporting)
                    {
                        <span class="spinner-border spinner-border-sm me-1"></span>
                    }
                    else
                    {
                        <i class="bi bi-file-earmark-zip me-1"></i>
                    }
                    Экспорт всех
                </button>
            </div>
        </div>

        <!-- Tabs -->
        <ul class="nav nav-tabs mb-4">
            <li class="nav-item">
                <button class="nav-link  @(ActiveTab == "dictionaries" ? "active" : "")" 
                        @onclick="@(() => ActiveTab = "dictionaries")">
                    <i class="bi bi-book me-1"></i> Мои словари
                </button>
            </li>
            <li class="nav-item">
                <button class="nav-link @(ActiveTab == "rules" ? "active" : "")" 
                        @onclick="@(() => ActiveTab = "rules")">
                    <i class="bi bi-journal-text me-1"></i> Мои правила
                </button>
            </li>
            <li class="nav-item">
                <button class="nav-link @(ActiveTab == "downloaded" ? "active" : "")" 
                        @onclick="@(() => ActiveTab = "downloaded")">
                    <i class="bi bi-download me-1"></i> Скачанное
                </button>
            </li>
        </ul>

        @if (ActiveTab == "dictionaries")
        {
            <div class="row g-4">
                @if (MyDictionaries != null && MyDictionaries.Any())
                {
                    @foreach (var dict in PagedDictionaries)
                    {
                        <div class="col-sm-6 col-md-4">
                            <div class="card h-100">
                                <div class="card-body">
                                    <div class="d-flex justify-content-between align-items-start mb-2">
                                        <h5 class="card-title mb-0">@dict.Name</h5>
                                        <span class="badge rounded-pill @(dict.IsPublished ? "bg-success bg-opacity-10 text-success" : "bg-secondary bg-opacity-10 text-secondary")" style="font-size: 0.75rem;">
                                            @(dict.IsPublished ? "✔ Опубликован" : "Черновик")
                                        </span>
                                    </div>

                                    @if (!string.IsNullOrWhiteSpace(dict.Description))
                                    {
                                        <p class="card-text text-muted small mb-2" style="min-height: 36px; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                                            @dict.Description
                                        </p>
                                    }

                                    <p class="text-muted small mb-3">
                                        <i class="bi bi-collection me-1"></i> @dict.WordCount слов
                                    </p>

                                    <div class="mc-actions">
                                        @if (!dict.IsPublished)
                                        {
                                            <button class="btn btn-primary btn-sm" @onclick="() => PublishDictionary(dict.Id)">
                                                <i class="bi bi-cloud-upload me-1"></i> Опубликовать
                                            </button>
                                        }
                                        else
                                        {
                                            <button class="btn btn-outline-danger btn-sm" @onclick="() => UnpublishDictionary(dict.Id)">
                                                <i class="bi bi-x-circle me-1"></i> Снять
                                            </button>
                                        }
                                        <div class="mc-icon-group">
                                            <button class="mc-icon-btn" title="Экспорт JSON"
                                                    @onclick="() => ExportDictionaryAsJson(dict.Id, dict.Name)">
                                                <i class="bi bi-filetype-json"></i>
                                            </button>
                                            <button class="mc-icon-btn" title="Экспорт CSV"
                                                    @onclick="() => ExportDictionaryAsCsv(dict.Id, dict.Name)">
                                                <i class="bi bi-filetype-csv"></i>
                                            </button>
                                            @if (IsTeacher)
                                            {
                                                <button class="mc-icon-btn mc-icon-btn--share" title="Поделиться с учениками"
                                                        @onclick="() => OpenShareDictionary(dict.Id, dict.Name)">
                                                    <i class="bi bi-people-fill"></i>
                                                </button>
                                            }
                                        </div>
                                    </div>
                                </div>

                                <div class="card-footer">
                                    <div class="d-flex justify-content-between align-items-center text-muted small">
                                        <span>
                                            <i class="bi bi-star-fill me-1" style="color: var(--accent-yellow);"></i>
                                            @dict.Rating.ToString("F1")
                                        </span>
                                        <span>
                                            <i class="bi bi-download me-1"></i>
                                            @dict.Downloads
                                        </span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="col-12">
                        <div class="text-center py-5">
                            <div style="font-size: 3rem; margin-bottom: 1rem; color: var(--primary-400);"><i class="bi bi-book"></i></div>
                            <p class="text-muted">У вас пока нет словарей</p>
                            <a href="dictionaries" class="btn btn-primary">
                                <i class="bi bi-search me-1"></i> Найти словари
                            </a>
                        </div>
                    </div>
                }
            </div>
            @if (DictionaryTotalPages > 1)
            {
                <nav class="mt-4">
                    <ul class="pagination justify-content-center">
                        <li class="page-item @(DictionaryPage == 1 ? "disabled" : "")">
                            <button class="page-link" @onclick="() => DictionaryPage--">
                                <i class="bi bi-chevron-left"></i>
                            </button>
                        </li>
                        @foreach (var pageNum in GetPageWindow(DictionaryPage, DictionaryTotalPages))
                        {
                            @if (pageNum == -1)
                            {
                                <li class="page-item disabled"><span class="page-link">&hellip;</span></li>
                            }
                            else
                            {
                                var p = pageNum;
                                <li class="page-item @(p == DictionaryPage ? "active" : "")">
                                    <button class="page-link" @onclick="() => DictionaryPage = p">@p</button>
                                </li>
                            }
                        }
                        <li class="page-item @(DictionaryPage == DictionaryTotalPages ? "disabled" : "")">
                            <button class="page-link" @onclick="() => DictionaryPage++">
                                <i class="bi bi-chevron-right"></i>
                            </button>
                        </li>
                    </ul>
                </nav>
            }
        }

        @if (ActiveTab == "rules")
        {
            <div class="row g-4">
                @if (MyRules != null && MyRules.Any())
                {
                    @foreach (var rule in PagedRules)
                    {
                        <div class="col-md-4">
                            <div class="card h-100">
                                <div class="card-body">
                                    <div class="d-flex justify-content-between align-items-start mb-2">
                                        <h5 class="card-title mb-0">@rule.Title</h5>
                                        <span class="badge @(rule.IsPublished ? "bg-success" : "bg-secondary")">
                                            @(rule.IsPublished ? "✔ Опубликовано" : "Черновик")
                                        </span>
                                    </div>
                                    <span class="badge bg-info mb-3">@rule.Category</span>
                                    <div class="mc-actions">
                                        <a href="my-content/rule/@rule.Id" class="btn btn-sm btn-outline-primary">
                                            <i class="bi bi-eye me-1"></i> Просмотр
                                        </a>
                                        @if (!rule.IsPublished)
                                        {
                                            <button class="btn btn-sm btn-primary" @onclick="() => PublishRule(rule.Id)">
                                                <i class="bi bi-cloud-upload me-1"></i> Опубликовать
                                            </button>
                                        }
                                        else
                                        {
                                            <button class="btn btn-sm btn-outline-danger" @onclick="() => UnpublishRule(rule.Id)">
                                                <i class="bi bi-x-circle me-1"></i> Снять
                                            </button>
                                        }
                                        @if (IsTeacher)
                                        {
                                            <div class="mc-icon-group">
                                                <button class="mc-icon-btn mc-icon-btn--share" title="Поделиться с учениками"
                                                        @onclick="() => OpenShareRule(rule.Id, rule.Title)">
                                                    <i class="bi bi-people-fill"></i>
                                                </button>
                                            </div>
                                        }
                                    </div>
                                </div>
                                <div class="card-footer">
                                    <div class="d-flex justify-content-between align-items-center text-muted small">
                                        <span>
                                            <i class="bi bi-star-fill me-1" style="color: var(--accent-yellow);"></i>
                                            @rule.Rating.ToString("F1")
                                        </span>
                                        <span>
                                            <i class="bi bi-download me-1"></i>
                                            @rule.Downloads
                                        </span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="col-12">
                        <div class="text-center py-5">
                            <div style="font-size: 3rem; margin-bottom: 1rem; color: var(--primary-400);"><i class="bi bi-journal-text"></i></div>
                            <p class="text-muted">У вас пока нет правил</p>
                            <a href="rules" class="btn btn-primary">
                                <i class="bi bi-search me-1"></i> Найти правила
                            </a>
                        </div>
                    </div>
                }
            </div>
            @if (RuleTotalPages > 1)
            {
                <nav class="mt-4">
                    <ul class="pagination justify-content-center">
                        <li class="page-item @(RulePage == 1 ? "disabled" : "")">
                            <button class="page-link" @onclick="() => RulePage--">
                                <i class="bi bi-chevron-left"></i>
                            </button>
                        </li>
                        @foreach (var pageNum in GetPageWindow(RulePage, RuleTotalPages))
                        {
                            @if (pageNum == -1)
                            {
                                <li class="page-item disabled"><span class="page-link">&hellip;</span></li>
                            }
                            else
                            {
                                var p = pageNum;
                                <li class="page-item @(p == RulePage ? "active" : "")">
                                    <button class="page-link" @onclick="() => RulePage = p">@p</button>
                                </li>
                            }
                        }
                        <li class="page-item @(RulePage == RuleTotalPages ? "disabled" : "")">
                            <button class="page-link" @onclick="() => RulePage++">
                                <i class="bi bi-chevron-right"></i>
                            </button>
                        </li>
                    </ul>
                </nav>
            }
        }

        @if (ActiveTab == "downloaded")
        {
            <div class="row g-4">
                @if (DownloadedContent != null && DownloadedContent.Any())
                {
                    @foreach (var item in PagedDownloads)
                    {
                        <div class="col-md-4">
                            <div class="card h-100">
                                <div class="card-body">
                                    <span class="badge @(item.Type == "Dictionary" ? "bg-info" : "bg-warning") mb-2">
                                        @(item.Type == "Dictionary" ? "Словарь" : "Правило")
                                    </span>
                                    <h5 class="card-title">@item.Title</h5>
                                    <p class="text-muted small mb-0">
                                        <i class="bi bi-person-circle me-1"></i> @item.AuthorName
                                    </p>
                                </div>
                                <div class="card-footer text-muted small">
                                    <i class="bi bi-calendar3 me-1"></i>
                                    Скачано: @item.DownloadedAt.ToString("dd.MM.yyyy")
                                </div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="col-12">
                        <div class="text-center py-5">
                            <div style="font-size: 3rem; margin-bottom: 1rem; color: var(--primary-400);"><i class="bi bi-download"></i></div>
                            <p class="text-muted">Вы ещё ничего не скачивали</p>
                            <a href="dictionaries" class="btn btn-primary">
                                <i class="bi bi-search me-1"></i> Найти контент
                            </a>
                        </div>
                    </div>
                }
            </div>
            @if (DownloadTotalPages > 1)
            {
                <nav class="mt-4">
                    <ul class="pagination justify-content-center">
                        <li class="page-item @(DownloadPage == 1 ? "disabled" : "")">
                            <button class="page-link" @onclick="() => DownloadPage--">
                                <i class="bi bi-chevron-left"></i>
                            </button>
                        </li>
                        @foreach (var pageNum in GetPageWindow(DownloadPage, DownloadTotalPages))
                        {
                            @if (pageNum == -1)
                            {
                                <li class="page-item disabled"><span class="page-link">&hellip;</span></li>
                            }
                            else
                            {
                                var p = pageNum;
                                <li class="page-item @(p == DownloadPage ? "active" : "")">
                                    <button class="page-link" @onclick="() => DownloadPage = p">@p</button>
                                </li>
                            }
                        }
                        <li class="page-item @(DownloadPage == DownloadTotalPages ? "disabled" : "")">
                            <button class="page-link" @onclick="() => DownloadPage++">
                                <i class="bi bi-chevron-right"></i>
                            </button>
                        </li>
                    </ul>
                </nav>
            }
        }
    }
</div>

@if (ShowImportModal)
{
    <div class="import-modal-overlay" @onclick="CloseImportDialog">
        <div class="import-modal" @onclick:stopPropagation="true">
            <!-- Gradient accent bar -->
            <div class="import-modal-accent"></div>

            <!-- Header -->
            <div class="import-modal-header">
                <div class="import-modal-icon">
                    <i class="bi bi-cloud-arrow-up"></i>
                </div>
                <div>
                    <h4 class="import-modal-title">Импорт словаря</h4>
                    <p class="import-modal-subtitle">Загрузите JSON или CSV файл — структура распознается автоматически</p>
                </div>
                <button type="button" class="import-modal-close" @onclick="CloseImportDialog">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>

            <!-- Body -->
            <div class="import-modal-body">
                <!-- Drop zone -->
                <div class="import-dropzone-wrap">
                    <label class="import-field-label">Файл словаря</label>
                    <div class="import-dropzone @(ImportFile != null ? "import-dropzone--filled" : "")">
                        <div class="import-dropzone-content">
                            @if (ImportFile == null)
                            {
                                <div class="import-dropzone-icon">
                                    <i class="bi bi-file-earmark-arrow-up"></i>
                                </div>
                                <span class="import-dropzone-title">Выберите файл</span>
                                <span class="import-dropzone-hint">или перетащите сюда · JSON, CSV</span>
                            }
                            else
                            {
                                <div class="import-dropzone-icon import-dropzone-icon--success">
                                    <i class="bi bi-file-earmark-check-fill"></i>
                                </div>
                                <span class="import-dropzone-title">@ImportFile.Name</span>
                                <span class="import-dropzone-hint">@((ImportFile.Size / 1024.0).ToString("F1")) KB</span>
                            }
                        </div>
                        <InputFile OnChange="OnImportFileSelected" accept=".json,.csv"
                                   class="import-dropzone-input" />
                    </div>
                </div>

                <!-- Name field -->
                <div class="import-field">
                    <label class="import-field-label">Название</label>
                    <input type="text" class="form-control" @bind="ImportDictionaryName"
                           placeholder="Название словаря (необязательно)" />
                </div>

                <!-- Language selectors -->
                <div class="import-lang-row">
                    <div class="import-field">
                        <label class="import-field-label">
                            <i class="bi bi-translate me-1"></i> Оригинал
                        </label>
                        <select class="form-select" @bind="ImportLanguageFrom">
                            <option value="">Автоопределение</option>
                            <option value="English">English</option>
                            <option value="Russian">Русский</option>
                            <option value="German">Deutsch</option>
                            <option value="Spanish">Español</option>
                        </select>
                    </div>
                    <div class="import-lang-arrow">
                        <i class="bi bi-arrow-right"></i>
                    </div>
                    <div class="import-field">
                        <label class="import-field-label">
                            <i class="bi bi-translate me-1"></i> Перевод
                        </label>
                        <select class="form-select" @bind="ImportLanguageTo">
                            <option value="">Автоопределение</option>
                            <option value="English">English</option>
                            <option value="Russian">Русский</option>
                            <option value="German">Deutsch</option>
                            <option value="Spanish">Español</option>
                        </select>
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(ImportError))
                {
                    <div class="alert alert-danger d-flex align-items-center gap-2 mt-3 mb-0">
                        <i class="bi bi-exclamation-triangle-fill"></i>
                        <div>@ImportError</div>
                    </div>
                }
            </div>

            <!-- Footer -->
            <div class="import-modal-footer">
                <button class="btn import-btn-cancel" @onclick="CloseImportDialog">Отмена</button>
                <button class="btn btn-primary import-btn-submit" @onclick="ImportDictionary"
                        disabled="@(IsImporting || ImportFile == null)">
                    @if (IsImporting)
                    {
                        <span class="spinner-border spinner-border-sm me-2"></span>
                        <span>Импорт...</span>
                    }
                    else
                    {
                        <i class="bi bi-upload me-2"></i>
                        <span>Импортировать</span>
                    }
                </button>
            </div>
        </div>
    </div>
}
<LearningTrainerWeb.Components.Shared.AppToast
    Message="@ExportMessage"
    IsSuccess="@ExportSuccess"
    OnDismiss="() => ExportMessage = null" />

<LearningTrainerWeb.Components.Shared.ShareDialog
    IsVisible="ShareDialogVisible"
    ContentId="ShareContentId"
    ContentName="@ShareContentName"
    ContentType="@ShareContentType"
    OnClose="CloseShareDialog" />

@code {
    private bool IsAuthenticated = false;
    private bool IsTeacher = false;
    private bool IsExporting = false;
    private string ActiveTab = "dictionaries";
    private string? ExportMessage;
    private bool ExportSuccess;

    // Import state
    private bool ShowImportModal = false;
    private bool IsImporting = false;
    private IBrowserFile? ImportFile;
    private string? ImportDictionaryName;
    private string? ImportLanguageFrom;
    private string? ImportLanguageTo;
    private string? ImportError;

    // Share dialog state
    private bool ShareDialogVisible;
    private int ShareContentId;
    private string ShareContentName = "";
    private string ShareContentType = "dictionary";

    private List<MyDictionaryItem>? MyDictionaries;
    private List<MyRuleItem>? MyRules;
    private List<DownloadedItem>? DownloadedContent;

    // Pagination
    private const int MyContentPageSize = 9;
    private int DictionaryPage = 1;
    private int RulePage = 1;
    private int DownloadPage = 1;

    private int DictionaryTotalPages => MyDictionaries == null || !MyDictionaries.Any() ? 1 : (int)Math.Ceiling(MyDictionaries.Count / (double)MyContentPageSize);
    private int RuleTotalPages => MyRules == null || !MyRules.Any() ? 1 : (int)Math.Ceiling(MyRules.Count / (double)MyContentPageSize);
    private int DownloadTotalPages => DownloadedContent == null || !DownloadedContent.Any() ? 1 : (int)Math.Ceiling(DownloadedContent.Count / (double)MyContentPageSize);

    private IEnumerable<MyDictionaryItem> PagedDictionaries => MyDictionaries?.Skip((DictionaryPage - 1) * MyContentPageSize).Take(MyContentPageSize) ?? Enumerable.Empty<MyDictionaryItem>();
    private IEnumerable<MyRuleItem> PagedRules => MyRules?.Skip((RulePage - 1) * MyContentPageSize).Take(MyContentPageSize) ?? Enumerable.Empty<MyRuleItem>();
    private IEnumerable<DownloadedItem> PagedDownloads => DownloadedContent?.Skip((DownloadPage - 1) * MyContentPageSize).Take(MyContentPageSize) ?? Enumerable.Empty<DownloadedItem>();

    private IEnumerable<int> GetPageWindow(int current, int total)
    {
        const int wing = 2;
        var pages = new List<int> { 1 };

        var rangeStart = Math.Max(2, current - wing);
        var rangeEnd = Math.Min(total - 1, current + wing);

        if (rangeStart > 2)
            pages.Add(-1);

        for (int p = rangeStart; p <= rangeEnd; p++)
            pages.Add(p);

        if (rangeEnd < total - 1)
            pages.Add(-1);

        if (total > 1)
            pages.Add(total);

        return pages;
    }

    protected override async Task OnInitializedAsync()
    {
        var session = await AuthService.GetCurrentSessionAsync();
        IsAuthenticated = session != null;
        IsTeacher = session?.Role == "Teacher";

        if (IsAuthenticated)
        {
            await LoadMyContent();
        }
    }

    private async Task LoadMyContent()
    {
        try
        {
            MyDictionaries = await ContentApi.GetMyDictionariesAsync();
            MyRules = await ContentApi.GetMyRulesAsync();
            DownloadedContent = await ContentApi.GetDownloadedContentAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error: {ex.Message}");
        }
    }

    private async Task PublishDictionary(int id)
    {
        try
        {
            await ContentApi.PublishDictionaryAsync(id);
            await LoadMyContent();
        }
        catch (Exception ex)
        {
            ExportMessage = $"Ошибка публикации: {ex.Message}";
            ExportSuccess = false;
            StateHasChanged();
            await Task.Delay(3000);
            ExportMessage = null;
        }
    }

    private async Task UnpublishDictionary(int id)
    {
        try
        {
            await ContentApi.UnpublishDictionaryAsync(id);
            await LoadMyContent();
        }
        catch (Exception ex)
        {
            ExportMessage = $"Ошибка: {ex.Message}";
            ExportSuccess = false;
            StateHasChanged();
            await Task.Delay(3000);
            ExportMessage = null;
        }
    }

    private async Task PublishRule(int id)
    {
        try
        {
            await ContentApi.PublishRuleAsync(id);
            await LoadMyContent();
        }
        catch (Exception ex)
        {
            ExportMessage = $"Ошибка публикации: {ex.Message}";
            ExportSuccess = false;
            StateHasChanged();
            await Task.Delay(3000);
            ExportMessage = null;
        }
    }

    private async Task UnpublishRule(int id)
    {
        try
        {
            await ContentApi.UnpublishRuleAsync(id);
            await LoadMyContent();
        }
        catch (Exception ex)
        {
            ExportMessage = $"Ошибка: {ex.Message}";
            ExportSuccess = false;
            StateHasChanged();
            await Task.Delay(3000);
            ExportMessage = null;
        }
    }

    private void ShowImportDialog()
    {
        ShowImportModal = true;
        ImportFile = null;
        ImportDictionaryName = null;
        ImportLanguageFrom = null;
        ImportLanguageTo = null;
        ImportError = null;
    }

    private void CloseImportDialog()
    {
        ShowImportModal = false;
        ImportError = null;
    }

    private void OnImportFileSelected(InputFileChangeEventArgs e)
    {
        ImportFile = e.File;
        ImportError = null;
    }

    private async Task ImportDictionary()
    {
        if (ImportFile == null) return;

        IsImporting = true;
        ImportError = null;
        StateHasChanged();

        try
        {
            using var stream = ImportFile.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
            var result = await ContentApi.ImportDictionaryFromFileAsync(
                stream,
                ImportFile.Name,
                string.IsNullOrWhiteSpace(ImportDictionaryName) ? null : ImportDictionaryName,
                string.IsNullOrWhiteSpace(ImportLanguageFrom) ? null : ImportLanguageFrom,
                string.IsNullOrWhiteSpace(ImportLanguageTo) ? null : ImportLanguageTo);

            ShowImportModal = false;
            ExportMessage = $"Словарь «{result.Name}» ({result.WordCount} слов) успешно импортирован!";
            ExportSuccess = true;
            await LoadMyContent();
            StateHasChanged();
            await Task.Delay(4000);
            ExportMessage = null;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            ImportError = ex.Message;
        }
        finally
        {
            IsImporting = false;
            StateHasChanged();
        }
    }

    private async Task ExportDictionaryAsJson(int dictionaryId, string name)
    {
        try
        {
            var result = await ContentApi.ExportDictionaryAsJsonAsync(dictionaryId);
            await DownloadFile(result.Data, result.FileName, result.ContentType);
            ExportMessage = $"Словарь '{name}' успешно экспортирован!";
            ExportSuccess = true;
        }
        catch (Exception ex)
        {
            ExportMessage = $"Ошибка экспорта: {ex.Message}";
            ExportSuccess = false;
        }
        StateHasChanged();
        await Task.Delay(3000);
        ExportMessage = null;
        StateHasChanged();
    }

