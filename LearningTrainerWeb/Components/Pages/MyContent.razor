@page "/my-content"
@inject IContentApiService ContentApi
@inject IAuthService AuthService
@inject IClassroomApiService ClassroomApi
@inject NavigationManager Navigation
@inject IJSRuntime JS
@using Microsoft.AspNetCore.Components.Forms

<PageTitle>Мой контент - Ingat</PageTitle>

<div class="container">
    @if (!IsAuthenticated)
    {
        <div class="text-center py-5">
            <div style="font-size: 4rem; margin-bottom: 1rem; color: var(--primary-400);"><i class="bi bi-lock"></i></div>
            <h2>Требуется авторизация</h2>
            <p class="text-muted mb-4">Войдите, чтобы управлять своим контентом</p>
            <a href="login" class="btn btn-primary btn-lg">
                <i class="bi bi-box-arrow-in-right me-2"></i> Войти
            </a>
        </div>
    }
    else
    {
        <!-- Header -->
        <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
            <div class="section-heading" style="margin-bottom: 0;">
                <i class="bi bi-folder2-open"></i>
                <h1 style="margin-bottom: 0;">Мой контент</h1>
            </div>
            <div class="d-flex gap-2 flex-wrap">
                @if (ActiveTab == "dictionaries")
                {
                    <button class="btn btn-success gap-2" @onclick="ShowCreateDictionaryDialog">
                        <i class="bi bi-plus-lg me-1"></i>
                        Создать словарь
                    </button>
                }
                else if (ActiveTab == "rules")
                {
                    <button class="btn btn-success gap-2" @onclick="ShowCreateRuleDialog">
                        <i class="bi bi-plus-lg me-1"></i>
                        Создать правило
                    </button>
                }
                <button class="btn btn-outline-success gap-2" @onclick="ShowImportDialog">
                    <i class="bi bi-upload me-1"></i>
                    Импорт
                </button>
                <button class="btn btn-outline-primary gap-2" @onclick="ExportAllDictionaries" disabled="@IsExporting">
                    @if (IsExporting)
                    {
                        <span class="spinner-border spinner-border-sm me-1"></span>
                    }
                    else
                    {
                        <i class="bi bi-file-earmark-zip me-1"></i>
                    }
                    Экспорт всех
                </button>
            </div>
        </div>

        <!-- Tabs -->
        <ul class="nav nav-tabs mb-4">
            <li class="nav-item">
                <button class="nav-link  @(ActiveTab == "dictionaries" ? "active" : "")" 
                        @onclick="@(() => ActiveTab = "dictionaries")">
                    <i class="bi bi-book me-1"></i> Мои словари
                </button>
            </li>
            <li class="nav-item">
                <button class="nav-link @(ActiveTab == "rules" ? "active" : "")" 
                        @onclick="@(() => ActiveTab = "rules")">
                    <i class="bi bi-journal-text me-1"></i> Мои правила
                </button>
            </li>
            <li class="nav-item">
                <button class="nav-link @(ActiveTab == "downloaded" ? "active" : "")" 
                        @onclick="@(() => ActiveTab = "downloaded")">
                    <i class="bi bi-download me-1"></i> Скачанное
                </button>
            </li>
        </ul>

        @if (ActiveTab == "dictionaries")
        {
            <div class="row g-4">
                @if (MyDictionaries != null && MyDictionaries.Any())
                {
                    @foreach (var dict in PagedDictionaries)
                    {
                        <div class="col-sm-6 col-md-4">
                            <div class="card h-100 @(dict.IsFromTeacher ? "card-from-teacher" : dict.IsSharedWithStudents ? "card-shared" : "")">
                                <div class="card-body">
                                    <div class="d-flex justify-content-between align-items-start mb-2">
                                        <a href="my-dictionary/@dict.Id" class="card-title-link">
                                            <h5 class="card-title mb-0">@dict.Name</h5>
                                        </a>
                                        <div class="d-flex gap-1 flex-wrap justify-content-end">
                                            @if (dict.IsFromTeacher)
                                            {
                                                <span class="badge rounded-pill bg-warning bg-opacity-15 text-warning" style="font-size: 0.7rem;">
                                                    <i class="bi bi-mortarboard-fill me-1"></i>От учителя
                                                </span>
                                            }
                                            else if (dict.IsSharedWithStudents)
                                            {
                                                <span class="badge rounded-pill bg-primary bg-opacity-10 text-primary" style="font-size: 0.7rem;"
                                                      title="Расшарено @dict.SharedStudentCount уч.">
                                                    <i class="bi bi-people-fill me-1"></i>@dict.SharedStudentCount
                                                </span>
                                            }
                                            @if (!dict.IsFromTeacher)
                                            {
                                                <span class="badge rounded-pill @(dict.IsPublished ? "bg-success bg-opacity-10 text-success" : "bg-secondary bg-opacity-10 text-secondary")" style="font-size: 0.75rem;">
                                                    @(dict.IsPublished ? "✔ Опубликован" : "Черновик")
                                                </span>
                                            }
                                        </div>
                                    </div>

                                    @if (dict.IsFromTeacher)
                                    {
                                        <p class="text-muted small mb-2">
                                            <i class="bi bi-person-circle me-1"></i> @dict.TeacherName
                                        </p>
                                    }

                                    @if (!string.IsNullOrWhiteSpace(dict.Description))
                                    {
                                        <p class="card-text text-muted small mb-2" style="min-height: 36px; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                                            @dict.Description
                                        </p>
                                    }

                                    <p class="text-muted small mb-3">
                                        <i class="bi bi-collection me-1"></i> @dict.WordCount слов
                                    </p>

                                    @if (dict.IsFromTeacher)
                                    {
                                        <div class="mc-actions">
                                            <span class="badge bg-secondary bg-opacity-10 text-secondary" style="font-size: 0.75rem;">
                                                <i class="bi bi-eye me-1"></i>Только чтение
                                            </span>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="mc-actions">
                                            @if (dict.IsSharedWithStudents)
                                            {
                                                <span class="btn btn-outline-secondary btn-sm disabled" title="Снимите доступ учеников, чтобы опубликовать">
                                                    <i class="bi bi-lock me-1"></i> Расшарено
                                                </span>
                                            }
                                            else if (!dict.IsPublished)
                                            {
                                                <button class="btn btn-primary btn-sm" @onclick="() => PublishDictionary(dict.Id)">
                                                    <i class="bi bi-cloud-upload me-1"></i> Опубликовать
                                                </button>
                                            }
                                            else
                                            {
                                                <button class="btn btn-outline-danger btn-sm" @onclick="() => UnpublishDictionary(dict.Id)">
                                                    <i class="bi bi-x-circle me-1"></i> Снять
                                                </button>
                                            }
                                            <div class="mc-icon-group">
                                                <button class="mc-icon-btn" title="Экспорт JSON"
                                                        @onclick="() => ExportDictionaryAsJson(dict.Id, dict.Name)">
                                                    <i class="bi bi-filetype-json"></i>
                                                </button>
                                                <button class="mc-icon-btn" title="Экспорт CSV"
                                                        @onclick="() => ExportDictionaryAsCsv(dict.Id, dict.Name)">
                                                    <i class="bi bi-filetype-csv"></i>
                                                </button>
                                                @if (IsTeacher)
                                                {
                                                    <button class="mc-icon-btn mc-icon-btn--share @(dict.IsSharedWithStudents ? "mc-icon-btn--shared-active" : "")" title="Поделиться с учениками"
                                                            @onclick="() => OpenShareDictionary(dict.Id, dict.Name)">
                                                        <i class="bi bi-people-fill"></i>
                                                    </button>
                                                }
                                            </div>
                                        </div>
                                    }
                                </div>

                                <div class="card-footer">
                                    <div class="d-flex justify-content-between align-items-center text-muted small">
                                        <span>
                                            <i class="bi bi-star-fill me-1" style="color: var(--accent-yellow);"></i>
                                            @dict.Rating.ToString("F1")
                                        </span>
                                        <span>
                                            <i class="bi bi-download me-1"></i>
                                            @dict.Downloads
                                        </span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="col-12">
                        <div class="text-center py-5">
                            <div style="font-size: 3rem; margin-bottom: 1rem; color: var(--primary-400);"><i class="bi bi-book"></i></div>
                            <p class="text-muted">У вас пока нет словарей</p>
                            <div class="d-flex gap-2 justify-content-center flex-wrap">
                                <button class="btn btn-primary" @onclick="ShowCreateDictionaryDialog">
                                    <i class="bi bi-plus-lg me-1"></i> Создать словарь
                                </button>
                                <button class="btn btn-outline-primary" @onclick="ShowImportDialog">
                                    <i class="bi bi-upload me-1"></i> Импортировать
                                </button>
                                <a href="dictionaries" class="btn btn-outline-secondary">
                                    <i class="bi bi-search me-1"></i> Найти в маркетплейсе
                                </a>
                            </div>
                        </div>
                    </div>
                }
            </div>
            @if (DictionaryTotalPages > 1)
            {
                <nav class="mt-4">
                    <ul class="pagination justify-content-center">
                        <li class="page-item @(DictionaryPage == 1 ? "disabled" : "")">
                            <button class="page-link" @onclick="() => DictionaryPage--">
                                <i class="bi bi-chevron-left"></i>
                            </button>
                        </li>
                        @foreach (var pageNum in GetPageWindow(DictionaryPage, DictionaryTotalPages))
                        {
                            @if (pageNum == -1)
                            {
                                <li class="page-item disabled"><span class="page-link">&hellip;</span></li>
                            }
                            else
                            {
                                var p = pageNum;
                                <li class="page-item @(p == DictionaryPage ? "active" : "")">
                                    <button class="page-link" @onclick="() => DictionaryPage = p">@p</button>
                                </li>
                            }
                        }
                        <li class="page-item @(DictionaryPage == DictionaryTotalPages ? "disabled" : "")">
                            <button class="page-link" @onclick="() => DictionaryPage++">
                                <i class="bi bi-chevron-right"></i>
                            </button>
                        </li>
                    </ul>
                </nav>
            }
        }

        @if (ActiveTab == "rules")
        {
            <div class="row g-4">
                @if (MyRules != null && MyRules.Any())
                {
                    @foreach (var rule in PagedRules)
                    {
                        <div class="col-md-4">
                            <div class="card h-100 @(rule.IsFromTeacher ? "card-from-teacher" : rule.IsSharedWithStudents ? "card-shared" : "")">
                                <div class="card-body">
                                    <div class="d-flex justify-content-between align-items-start mb-2">
                                        <h5 class="card-title mb-0">@rule.Title</h5>
                                        <div class="d-flex gap-1 flex-wrap justify-content-end">
                                            @if (rule.IsFromTeacher)
                                            {
                                                <span class="badge rounded-pill bg-warning bg-opacity-15 text-warning" style="font-size: 0.7rem;">
                                                    <i class="bi bi-mortarboard-fill me-1"></i>От учителя
                                                </span>
                                            }
                                            else if (rule.IsSharedWithStudents)
                                            {
                                                <span class="badge rounded-pill bg-primary bg-opacity-10 text-primary" style="font-size: 0.7rem;"
                                                      title="Расшарено @rule.SharedStudentCount уч.">
                                                    <i class="bi bi-people-fill me-1"></i>@rule.SharedStudentCount
                                                </span>
                                            }
                                            @if (!rule.IsFromTeacher)
                                            {
                                                <span class="badge @(rule.IsPublished ? "bg-success" : "bg-secondary")">
                                                    @(rule.IsPublished ? "✔ Опубликовано" : "Черновик")
                                                </span>
                                            }
                                        </div>
                                    </div>
                                    @if (rule.IsFromTeacher)
                                    {
                                        <p class="text-muted small mb-2">
                                            <i class="bi bi-person-circle me-1"></i> @rule.TeacherName
                                        </p>
                                    }
                                    <span class="badge bg-info mb-3">@rule.Category</span>
                                    @if (rule.IsFromTeacher)
                                    {
                                        <div class="mc-actions">
                                            <a href="my-content/rule/@rule.Id" class="btn btn-sm btn-outline-primary">
                                                <i class="bi bi-eye me-1"></i> Просмотр
                                            </a>
                                            <span class="badge bg-secondary bg-opacity-10 text-secondary" style="font-size: 0.75rem;">
                                                <i class="bi bi-eye me-1"></i>Только чтение
                                            </span>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="mc-actions">
                                            <a href="my-content/rule/@rule.Id" class="btn btn-sm btn-outline-primary">
                                                <i class="bi bi-eye me-1"></i> Просмотр
                                            </a>
                                            @if (rule.IsSharedWithStudents)
                                            {
                                                <span class="btn btn-outline-secondary btn-sm disabled" title="Снимите доступ учеников, чтобы опубликовать">
                                                    <i class="bi bi-lock me-1"></i> Расшарено
                                                </span>
                                            }
                                            else if (!rule.IsPublished)
                                            {
                                                <button class="btn btn-sm btn-primary" @onclick="() => PublishRule(rule.Id)">
                                                    <i class="bi bi-cloud-upload me-1"></i> Опубликовать
                                                </button>
                                            }
                                            else
                                            {
                                                <button class="btn btn-sm btn-outline-danger" @onclick="() => UnpublishRule(rule.Id)">
                                                    <i class="bi bi-x-circle me-1"></i> Снять
                                                </button>
                                            }
                                            @if (IsTeacher)
                                            {
                                                <div class="mc-icon-group">
                                                    <button class="mc-icon-btn mc-icon-btn--share @(rule.IsSharedWithStudents ? "mc-icon-btn--shared-active" : "")" title="Поделиться с учениками"
                                                            @onclick="() => OpenShareRule(rule.Id, rule.Title)">
                                                        <i class="bi bi-people-fill"></i>
                                                    </button>
                                                </div>
                                            }
                                        </div>
                                    }
                                </div>
                                <div class="card-footer">
                                    <div class="d-flex justify-content-between align-items-center text-muted small">
                                        <span>
                                            <i class="bi bi-star-fill me-1" style="color: var(--accent-yellow);"></i>
                                            @rule.Rating.ToString("F1")
                                        </span>
                                        <span>
                                            <i class="bi bi-download me-1"></i>
                                            @rule.Downloads
                                        </span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="col-12">
                        <div class="text-center py-5">
                            <div style="font-size: 3rem; margin-bottom: 1rem; color: var(--primary-400);"><i class="bi bi-journal-text"></i></div>
                            <p class="text-muted">У вас пока нет правил</p>
                            <div class="d-flex gap-2 justify-content-center flex-wrap">
                                <button class="btn btn-primary" @onclick="ShowCreateRuleDialog">
                                    <i class="bi bi-plus-lg me-1"></i> Создать правило
                                </button>
                                <a href="rules" class="btn btn-outline-secondary">
                                    <i class="bi bi-search me-1"></i> Найти в маркетплейсе
                                </a>
                            </div>
                        </div>
                    </div>
                }
            </div>
            @if (RuleTotalPages > 1)
            {
                <nav class="mt-4">
                    <ul class="pagination justify-content-center">
                        <li class="page-item @(RulePage == 1 ? "disabled" : "")">
                            <button class="page-link" @onclick="() => RulePage--">
                                <i class="bi bi-chevron-left"></i>
                            </button>
                        </li>
                        @foreach (var pageNum in GetPageWindow(RulePage, RuleTotalPages))
                        {
                            @if (pageNum == -1)
                            {
                                <li class="page-item disabled"><span class="page-link">&hellip;</span></li>
                            }
                            else
                            {
                                var p = pageNum;
                                <li class="page-item @(p == RulePage ? "active" : "")">
                                    <button class="page-link" @onclick="() => RulePage = p">@p</button>
                                </li>
                            }
                        }
                        <li class="page-item @(RulePage == RuleTotalPages ? "disabled" : "")">
                            <button class="page-link" @onclick="() => RulePage++">
                                <i class="bi bi-chevron-right"></i>
                            </button>
                        </li>
                    </ul>
                </nav>
            }
        }

        @if (ActiveTab == "downloaded")
        {
            <div class="row g-4">
                @if (DownloadedContent != null && DownloadedContent.Any())
                {
                    @foreach (var item in PagedDownloads)
                    {
                        <div class="col-md-4">
                            <div class="card h-100">
                                <div class="card-body">
                                    <span class="badge @(item.Type == "Dictionary" ? "bg-info" : "bg-warning") mb-2">
                                        @(item.Type == "Dictionary" ? "Словарь" : "Правило")
                                    </span>
                                    <h5 class="card-title">@item.Title</h5>
                                    <p class="text-muted small mb-0">
                                        <i class="bi bi-person-circle me-1"></i> @item.AuthorName
                                    </p>
                                </div>
                                <div class="card-footer text-muted small">
                                    <i class="bi bi-calendar3 me-1"></i>
                                    Скачано: @item.DownloadedAt.ToString("dd.MM.yyyy")
                                </div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="col-12">
                        <div class="text-center py-5">
                            <div style="font-size: 3rem; margin-bottom: 1rem; color: var(--primary-400);"><i class="bi bi-download"></i></div>
                            <p class="text-muted">Вы ещё ничего не скачивали</p>
                            <a href="dictionaries" class="btn btn-primary">
                                <i class="bi bi-search me-1"></i> Найти контент
                            </a>
                        </div>
                    </div>
                }
            </div>
            @if (DownloadTotalPages > 1)
            {
                <nav class="mt-4">
                    <ul class="pagination justify-content-center">
                        <li class="page-item @(DownloadPage == 1 ? "disabled" : "")">
                            <button class="page-link" @onclick="() => DownloadPage--">
                                <i class="bi bi-chevron-left"></i>
                            </button>
                        </li>
                        @foreach (var pageNum in GetPageWindow(DownloadPage, DownloadTotalPages))
                        {
                            @if (pageNum == -1)
                            {
                                <li class="page-item disabled"><span class="page-link">&hellip;</span></li>
                            }
                            else
                            {
                                var p = pageNum;
                                <li class="page-item @(p == DownloadPage ? "active" : "")">
                                    <button class="page-link" @onclick="() => DownloadPage = p">@p</button>
                                </li>
                            }
                        }
                        <li class="page-item @(DownloadPage == DownloadTotalPages ? "disabled" : "")">
                            <button class="page-link" @onclick="() => DownloadPage++">
                                <i class="bi bi-chevron-right"></i>
                            </button>
                        </li>
                    </ul>
                </nav>
            }
        }
    }
</div>

@if (ShowImportModal)
{
    <div class="import-modal-overlay" @onmousedown="CloseImportDialog">
        <div class="import-modal" @onmousedown:stopPropagation="true">
            <!-- Gradient accent bar -->
            <div class="import-modal-accent"></div>

            <!-- Header -->
            <div class="import-modal-header">
                <div class="import-modal-icon">
                    <i class="bi bi-cloud-arrow-up"></i>
                </div>
                <div>
                    <h4 class="import-modal-title">Импорт словаря</h4>
                    <p class="import-modal-subtitle">Загрузите JSON, CSV или Anki (.apkg) файл — структура распознается автоматически</p>
                </div>
                <button type="button" class="import-modal-close" @onclick="CloseImportDialog">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>

            <!-- Body -->
            <div class="import-modal-body">
                <!-- Drop zone -->
                <div class="import-dropzone-wrap">
                    <label class="import-field-label">Файл словаря</label>
                    <div class="import-dropzone @(ImportFile != null ? "import-dropzone--filled" : "")">
                        <div class="import-dropzone-content">
                            @if (ImportFile == null)
                            {
                                <div class="import-dropzone-icon">
                                    <i class="bi bi-file-earmark-arrow-up"></i>
                                </div>
                                <span class="import-dropzone-title">Выберите файл</span>
                                <span class="import-dropzone-hint">или перетащите сюда · JSON, CSV, Anki (.apkg)</span>
                            }
                            else
                            {
                                <div class="import-dropzone-icon import-dropzone-icon--success">
                                    <i class="bi bi-file-earmark-check-fill"></i>
                                </div>
                                <span class="import-dropzone-title">@ImportFile.Name</span>
                                <span class="import-dropzone-hint">@((ImportFile.Size / 1024.0).ToString("F1")) KB</span>
                            }
                        </div>
                        <InputFile OnChange="OnImportFileSelected" accept=".json,.csv,.apkg,.colpkg"
                                   class="import-dropzone-input" />
                    </div>
                </div>

                <!-- Name field -->
                <div class="import-field">
                    <label class="import-field-label">Название</label>
                    <input type="text" class="form-control" @bind="ImportDictionaryName"
                           placeholder="Название словаря (необязательно)" />
                </div>

                <!-- Language selectors -->
                <div class="import-lang-row">
                    <div class="import-field">
                        <label class="import-field-label">
                            <i class="bi bi-translate me-1"></i> Оригинал
                        </label>
                        <select class="form-select" @bind="ImportLanguageFrom">
                            <option value="">Автоопределение</option>
                            <option value="English">English</option>
                            <option value="Russian">Русский</option>
                            <option value="German">Deutsch</option>
                            <option value="French">Français</option>
                            <option value="Spanish">Español</option>
                            <option value="Italian">Italiano</option>
                            <option value="Portuguese">Português</option>
                            <option value="Chinese">中文</option>
                            <option value="Japanese">日本語</option>
                            <option value="Korean">한국어</option>
                            <option value="Arabic">العربية</option>
                            <option value="Turkish">Türkçe</option>
                            <option value="Polish">Polski</option>
                            <option value="Dutch">Nederlands</option>
                            <option value="Swedish">Svenska</option>
                            <option value="Norwegian">Norsk</option>
                            <option value="Danish">Dansk</option>
                            <option value="Finnish">Suomi</option>
                            <option value="Czech">Čeština</option>
                            <option value="Greek">Ελληνικά</option>
                            <option value="Hindi">हिन्दी</option>
                            <option value="Thai">ไทย</option>
                            <option value="Vietnamese">Tiếng Việt</option>
                            <option value="Indonesian">Bahasa Indonesia</option>
                            <option value="Ukrainian">Українська</option>
                            <option value="Hungarian">Magyar</option>
                            <option value="Romanian">Română</option>
                            <option value="Hebrew">עברית</option>
                            <option value="Croatian">Hrvatski</option>
                            <option value="Bulgarian">Български</option>
                        </select>
                    </div>
                    <div class="import-lang-arrow">
                        <i class="bi bi-arrow-right"></i>
                    </div>
                    <div class="import-field">
                        <label class="import-field-label">
                            <i class="bi bi-translate me-1"></i> Перевод
                        </label>
                        <select class="form-select" @bind="ImportLanguageTo">
                            <option value="">Автоопределение</option>
                            <option value="English">English</option>
                            <option value="Russian">Русский</option>
                            <option value="German">Deutsch</option>
                            <option value="French">Français</option>
                            <option value="Spanish">Español</option>
