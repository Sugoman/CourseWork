    private async Task DownloadFile(byte[] data, string fileName, string contentType)
    {
        var base64 = Convert.ToBase64String(data);
        await JS.InvokeVoidAsync("downloadFile", fileName, contentType, base64);
    }

    private void OpenShareDictionary(int contentId, string contentName)
    {
        ShareContentId = contentId;
        ShareContentName = contentName;
        ShareContentType = "dictionary";
        ShareDialogVisible = true;
    }

    private void OpenShareRule(int contentId, string contentName)
    {
        ShareContentId = contentId;
        ShareContentName = contentName;
        ShareContentType = "rule";
        ShareDialogVisible = true;
    }

    private void CloseShareDialog()
    {
        ShareDialogVisible = false;
    }
