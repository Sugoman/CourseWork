@page "/grammar"
@using LearningTrainerWeb.Services
@inject IGrammarApiService GrammarApi
@inject IAuthService AuthService
@inject NavigationManager Navigation
@inject ILogger<Grammar> Logger

<PageTitle>Грамматика - Ingat</PageTitle>

<div class="grammar-page">
    <!-- Header -->
    <div class="gp-header">
        <div class="gp-header-left">
            <div class="gp-header-icon"><i class="bi bi-book"></i></div>
            <h1 class="gp-header-title">Грамматика</h1>
        </div>
        @if (ProgressSummary != null)
        {
            <div class="gp-header-badges">
                <div class="gp-badge gp-badge-mastery">
                    <i class="bi bi-trophy-fill"></i>
                    <span>@ProgressSummary.MasteredRules / @ProgressSummary.TotalRules</span>
                </div>
                @if (ProgressSummary.OverallAccuracy > 0)
                {
                    <div class="gp-badge gp-badge-accuracy">
                        <i class="bi bi-bullseye"></i>
                        <span>@ProgressSummary.OverallAccuracy.ToString("F0")%</span>
                    </div>
                }
            </div>
        }
    </div>

    @if (IsLoading)
    {
        <div class="gp-loading">
            <div class="spinner-border" style="width: 3rem; height: 3rem;" role="status">
                <span class="visually-hidden">Загрузка...</span>
            </div>
            <p>Загрузка грамматики...</p>
        </div>
    }
    else
    {
        <!-- Due Reviews Banner -->
        @if (DueReviews != null && DueReviews.Count > 0)
        {
            <div class="gp-due-banner" @onclick="StartDueReview">
                <div class="gp-due-icon"><i class="bi bi-clock-history"></i></div>
                <div class="gp-due-info">
                    <span class="gp-due-title">Повторение</span>
                    <span class="gp-due-desc">
                        @DueReviews.Count @GetRulesWord(DueReviews.Count)
                        @if (DueReviews.Rules.Any())
                        {
                            <span> · @DueReviews.Rules.First().RuleTitle</span>
                        }
                    </span>
                </div>
                <button class="gp-due-btn">
                    <i class="bi bi-play-fill me-1"></i> Повторить
                </button>
            </div>
        }

        <!-- Progress Overview -->
        @if (ProgressSummary != null)
        {
            <div class="gp-progress-card">
                <div class="gp-progress-bar-wrap">
                    <div class="gp-progress-track">
                        <div class="gp-progress-mastered" style="width: @GpMasteredPct.ToString("F0")%"></div>
                        <div class="gp-progress-inprogress" style="width: @GpInProgressPct.ToString("F0")%"></div>
                    </div>
                </div>
                <div class="gp-progress-stats">
                    <div class="gp-stat">
                        <span class="gp-stat-dot gp-dot-mastered"></span>
                        <span class="gp-stat-label">Освоено</span>
                        <span class="gp-stat-value">@ProgressSummary.MasteredRules</span>
                    </div>
                    <div class="gp-stat">
                        <span class="gp-stat-dot gp-dot-progress"></span>
                        <span class="gp-stat-label">В процессе</span>
                        <span class="gp-stat-value">@ProgressSummary.InProgressRules</span>
                    </div>
                    <div class="gp-stat">
                        <span class="gp-stat-dot gp-dot-new"></span>
                        <span class="gp-stat-label">Не начато</span>
                        <span class="gp-stat-value">@(ProgressSummary.TotalRules - ProgressSummary.MasteredRules - ProgressSummary.InProgressRules)</span>
                    </div>
                    <div class="gp-stat">
                        <i class="bi bi-journal-check gp-stat-icon"></i>
                        <span class="gp-stat-label">Сессий</span>
                        <span class="gp-stat-value">@ProgressSummary.TotalSessions</span>
                    </div>
                </div>
            </div>
        }

        <!-- Skill Tree -->
        @if (SkillNodes != null && SkillNodes.Any())
        {
            @foreach (var levelGroup in SkillNodes.GroupBy(n => n.SkillTreeLevel).OrderBy(g => g.Key))
            {
                <div class="gp-level-group">
                    <div class="gp-level-header">
                        <span class="gp-level-emoji">@GetSkillTreeLevelEmoji(levelGroup.Key)</span>
                        <span class="gp-level-title">@GetSkillTreeLevelTitle(levelGroup.Key)</span>
                        <span class="gp-level-count">@levelGroup.Count()</span>
                    </div>
                    <div class="gp-skills-grid">
                        @foreach (var node in levelGroup)
                        {
                            <div class="gp-skill @GetSkillStateClass(node)"
                                 @onclick="() => OpenSkill(node)">
                                @if (node.NextReview.HasValue && node.NextReview.Value <= DateTime.UtcNow && node.IsUnlocked)
                                {
                                    <div class="gp-skill-due-dot" title="Пора повторить"></div>
                                }
                                <div class="gp-skill-icon">
                                    @if (!node.IsUnlocked)
                                    {
                                        <i class="bi bi-lock-fill"></i>
                                    }
                                    else if (!string.IsNullOrEmpty(node.IconEmoji))
                                    {
                                        <span>@node.IconEmoji</span>
                                    }
                                    else
                                    {
                                        <i class="bi bi-book"></i>
                                    }
                                </div>
                                <span class="gp-skill-title">@node.Title</span>
                                <div class="gp-skill-stars">
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        var starClass = i <= node.KnowledgeLevel ? "gp-star-filled" : "gp-star-empty";
                                        <span class="gp-star @starClass">★</span>
                                    }
                                </div>
                                @if (node.ExerciseCount > 0 || node.TotalSessions > 0)
                                {
                                    <div class="gp-skill-meta">
                                        @if (node.ExerciseCount > 0)
                                        {
                                            <span>@node.ExerciseCount упр.</span>
                                        }
                                        @if (node.TotalSessions > 0)
                                        {
                                            <span>@node.AccuracyPercent.ToString("F0")%</span>
                                        }
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>
            }

            <div class="gp-marketplace-link">
                <a href="rules">
                    <i class="bi bi-compass me-2"></i> Маркетплейс правил
                </a>
            </div>
        }
        else
        {
            <div class="empty-state-card">
                <div class="empty-state-icon">
                    <i class="bi bi-book"></i>
                </div>
                <h3>У вас нет грамматических правил</h3>
                <p class="text-muted mb-4">
                    Создайте свои правила в разделе «Мой контент» или скачайте из маркетплейса.
                </p>
                <div class="empty-state-actions">
                    <a href="rules" class="btn btn-primary">
                        <i class="bi bi-search me-2"></i> Маркетплейс правил
                    </a>
                    <a href="my-content" class="btn btn-outline-primary">
                        <i class="bi bi-plus-circle me-2"></i> Мой контент
                    </a>
                </div>
            </div>
        }
    }
</div>

@code {
    private List<SkillTreeNodeDto>? SkillNodes;
    private DueReviewsDto? DueReviews;
    private GrammarProgressSummaryDto? ProgressSummary;
    private bool IsLoading = true;

    private double GpMasteredPct => ProgressSummary == null ? 0 : (double)ProgressSummary.MasteredRules / Math.Max(1, ProgressSummary.TotalRules) * 100;
    private double GpInProgressPct => ProgressSummary == null ? 0 : (double)ProgressSummary.InProgressRules / Math.Max(1, ProgressSummary.TotalRules) * 100;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            await AuthService.InitializeAsync();

            var skillTreeTask = GrammarApi.GetSkillTreeAsync();
            var dueReviewsTask = GrammarApi.GetDueReviewsAsync();
            var progressTask = GrammarApi.GetProgressSummaryAsync();

            await Task.WhenAll(skillTreeTask, dueReviewsTask, progressTask);

            SkillNodes = skillTreeTask.Result;
            DueReviews = dueReviewsTask.Result;
            ProgressSummary = progressTask.Result;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading grammar page");
        }
        finally
        {
            IsLoading = false;
        }
    }

    private void OpenSkill(SkillTreeNodeDto node)
    {
        if (!node.IsUnlocked) return;
        Navigation.NavigateTo($"/grammar/{node.Id}");
    }

    private void StartDueReview()
    {
        if (DueReviews?.Rules.Any() == true)
        {
            Navigation.NavigateTo($"/grammar/{DueReviews.Rules.First().RuleId}?mode=review");
        }
    }

    private string GetSkillStateClass(SkillTreeNodeDto node)
    {
        if (!node.IsUnlocked) return "gp-skill-locked";
        return node.KnowledgeLevel switch
        {
            >= 5 => "gp-skill-gold",
            >= 4 => "gp-skill-mastered",
            >= 1 => "gp-skill-started",
            _ => "gp-skill-new"
        };
    }

    private string GetSkillTreeLevelEmoji(int level) => level switch
    {
        1 => "🌱",
        2 => "🌿",
        3 => "🌳",
        _ => "🎯"
    };

    private string GetSkillTreeLevelTitle(int level) => level switch
    {
        1 => "Базовый уровень",
        2 => "Средний уровень",
        3 => "Продвинутый уровень",
        _ => $"Уровень {level}"
    };

    private string GetRulesWord(int count)
    {
        if (count % 100 >= 11 && count % 100 <= 19) return "правил";
        return (count % 10) switch
        {
            1 => "правило",
            2 or 3 or 4 => "правила",
            _ => "правил"
        };
    }
}
