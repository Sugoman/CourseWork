@page "/rule/{Id:int}"
@using LearningTrainerWeb.Services
@inject IContentApiService ContentApi
@inject IAuthService AuthService
@inject IHtmlSanitizerService HtmlSanitizer
@inject ILogger<LearningTrainerWeb.Components.Pages.RuleDetails> Logger

<PageTitle>@(Rule?.Title ?? "Правило") - Ingat</PageTitle>

<div class="container rule-details-page">
    @if (IsLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border" style="width: 3rem; height: 3rem;" role="status">
                <span class="visually-hidden">Загрузка...</span>
            </div>
            <p class="text-muted mt-3">Загрузка правила...</p>
        </div>
    }
    else if (Rule == null)
    {
        <div class="text-center py-5">
            <div style="font-size: 4rem; margin-bottom: 1rem; color: var(--gray-400);"><i class="bi bi-emoji-frown"></i></div>
            <h2>Правило не найдено</h2>
            <p class="text-muted mb-4">Возможно, оно было удалено или вы перешли по неверной ссылке</p>
            <a href="rules" class="btn btn-primary">
                <i class="bi bi-arrow-left me-2"></i> К списку правил
            </a>
        </div>
    }
    else
    {
        <!-- Breadcrumb -->
        <nav aria-label="breadcrumb" class="mb-4">
            <ol class="breadcrumb" style="background: transparent; padding: 0;">
                <li class="breadcrumb-item">
                    <a href="rules" style="color: var(--primary-600);">
                        <i class="bi bi-journal-text me-1"></i> Правила
                    </a>
                </li>
                <li class="breadcrumb-item active" style="color: var(--gray-500);">@Rule.Title</li>
            </ol>
        </nav>

        <div class="row g-4">
            <div class="col-lg-8">
                <!-- Main Info Card -->
                <div class="card mb-4" style="border-radius: var(--radius-xl); overflow: hidden;">
                    <div class="rule-hero-header">
                        <div class="rule-hero-content">
                            <div class="rule-badges">
                                <span class="badge" style="background: rgba(255,255,255,0.2);">@Rule.Category</span>
                                <span class="badge @GetDifficultyBadgeClass(Rule.DifficultyLevel)" style="opacity: 0.9;">
                                    @GetDifficultyText(Rule.DifficultyLevel)
                                </span>
                            </div>
                            <h1 class="rule-title">@Rule.Title</h1>
                            <p class="rule-description">@Rule.Description</p>
                            <button class="btn btn-light rule-download-btn" @onclick="DownloadRule">
                                <i class="bi bi-download me-2"></i> Скачать
                            </button>
                        </div>
                    </div>
                    <div class="card-body">
                        <div class="rule-stats">
                            <div class="rule-stat-item rule-stat-rating">
                                <i class="bi bi-star-fill"></i>
                                <span class="rule-stat-value">@Rule.Rating.ToString("F1")</span>
                                <span class="rule-stat-label">(@Rule.RatingCount оценок)</span>
                            </div>
                            <div class="rule-stat-item rule-stat-downloads">
                                <i class="bi bi-download"></i>
                                <span class="rule-stat-value">@Rule.Downloads</span>
                                <span class="rule-stat-label">скачиваний</span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Rule Content -->
                <div class="card mb-4" style="border-radius: var(--radius-lg);">
                    <div class="card-body p-4">
                        <h5 class="d-flex align-items-center gap-2 mb-4">
                            <i class="bi bi-file-text" style="color: var(--primary-500);"></i>
                            Содержание
                        </h5>
                        <div class="markdown-content">
                            @((MarkupString)HtmlSanitizer.Sanitize(Rule.HtmlContent))
                        </div>
                    </div>
                </div>

                <!-- Test Yourself -->
                @if (Rule.Exercises != null && Rule.Exercises.Any())
                {
                    <div class="card mb-4" style="border-radius: var(--radius-lg);">
                        <div class="card-body p-4">
                            <div class="d-flex justify-content-between align-items-center mb-4" @onclick="ToggleQuiz" style="cursor: pointer;">
                                <h5 class="d-flex align-items-center gap-2 mb-0">
                                    <i class="bi bi-pencil-square" style="color: var(--primary-500);"></i>
                                    Проверь себя
                                    <span class="badge bg-secondary bg-opacity-25 text-secondary">@Rule.Exercises.Count</span>
                                </h5>
                                <i class="bi @(QuizExpanded ? "bi-chevron-up" : "bi-chevron-down") fs-5 text-muted"></i>
                            </div>

                            @if (QuizExpanded)
                            {
                                @for (int i = 0; i < Rule.Exercises.Count; i++)
                                {
                                    var exercise = Rule.Exercises[i];
                                    var index = i;
                                    <div class="card mb-3" style="border-radius: var(--radius); border: 1px solid var(--gray-200);">
                                        <div class="card-body p-3">
                                            <p class="fw-semibold mb-3">
                                                <span class="text-muted me-2">@(index + 1).</span>
                                                @exercise.Question
                                            </p>

                                            <div class="row g-2 mb-2">
                                                @for (int j = 0; j < exercise.Options.Length; j++)
                                                {
                                                    var optionIndex = j;
                                                    var option = exercise.Options[j];
                                                    var answered = Answers.ContainsKey(index);
                                                    var selected = answered && Answers[index] == optionIndex;
                                                    var isCorrect = optionIndex == exercise.CorrectIndex;

                                                    var btnClass = "btn btn-outline-secondary w-100 text-start";
                                                    if (answered)
                                                    {
                                                        if (isCorrect)
                                                            btnClass = "btn btn-success w-100 text-start";
                                                        else if (selected)
                                                            btnClass = "btn btn-danger w-100 text-start";
                                                    }

                                                    <div class="col-6">
                                                        <button class="@btnClass" 
                                                                disabled="@answered"
                                                                @onclick="() => SelectAnswer(index, optionIndex)"
                                                                style="border-radius: var(--radius);">
                                                            @option
                                                        </button>
                                                    </div>
                                                }
                                            </div>

                                            @if (Answers.ContainsKey(index))
                                            {
                                                var userCorrect = Answers[index] == exercise.CorrectIndex;
                                                <div class="mt-2 p-2 rounded" style="background: @(userCorrect ? "rgba(16,185,129,0.1)" : "rgba(239,68,68,0.1)");">
                                                    <small>
                                                        @if (userCorrect)
                                                        {
                                                            <span class="text-success fw-semibold"><i class="bi bi-check-circle me-1"></i> Верно!</span>
                                                        }
                                                        else
                                                        {
                                                            <span class="text-danger fw-semibold"><i class="bi bi-x-circle me-1"></i> Неверно</span>
                                                        }
                                                        @if (!string.IsNullOrWhiteSpace(exercise.Explanation))
                                                        {
                                                            <span class="text-muted ms-2">— @exercise.Explanation</span>
                                                        }
                                                    </small>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                }

                                @if (Answers.Count == Rule.Exercises.Count)
                                {
                                    var correctCount = Rule.Exercises.Where((e, i) => Answers.ContainsKey(i) && Answers[i] == e.CorrectIndex).Count();
                                    <div class="card mt-3" style="border-radius: var(--radius); background: var(--gray-50);">
                                        <div class="card-body text-center p-3">
                                            <h5 class="mb-2">Результат: @correctCount / @Rule.Exercises.Count</h5>
                                            <button class="btn btn-primary btn-sm" @onclick="ResetQuiz">
                                                <i class="bi bi-arrow-clockwise me-1"></i> Попробовать снова
                                            </button>
                                        </div>
                                    </div>
                                }
                            }
                        </div>
                    </div>
                }

                <!-- Comments -->
                <LearningTrainerWeb.Components.Shared.CommentsSection 
                    EntityType="rule" 
                    EntityId="Id" 
                    IsAuthenticated="IsAuthenticated" />
            </div>

            <!-- Sidebar -->
            <div class="col-lg-4">
                <!-- Author Card -->
                <a href="/profile/@Rule.AuthorId" class="text-decoration-none">
                    <div class="card mb-4 author-card" style="border-radius: var(--radius-lg); transition: all 0.2s ease;">
                        <div class="card-body text-center py-4">
                            <div style="width: 100px; height: 100px; background: linear-gradient(135deg, var(--primary-400), var(--primary-700)); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 1rem; color: white; font-size: 2.5rem; font-weight: 700; box-shadow: var(--shadow-colored);">
                                @(Rule.AuthorName?.FirstOrDefault() ?? '?')
                            </div>
                            <h4 style="margin-bottom: 0.25rem; color: var(--gray-800);">@Rule.AuthorName</h4>
                            <p class="text-muted small mb-3">Автор правила</p>
                            <div class="d-inline-flex align-items-center gap-2 px-3 py-2" style="background: var(--gray-100); border-radius: var(--radius-full);">
                                <i class="bi bi-folder" style="color: var(--primary-500);"></i>
                                <span style="font-weight: 500; color: var(--gray-700);">@Rule.AuthorContentCount материалов</span>
                            </div>
                            <div class="mt-3">
                                <span class="text-muted small"><i class="bi bi-box-arrow-up-right me-1"></i>Открыть профиль</span>
                            </div>
                        </div>
                    </div>
                </a>

                <!-- Related Rules -->
                <div class="card" style="border-radius: var(--radius-lg);">
                    <div class="card-body">
                        <h5 class="d-flex align-items-center gap-2 mb-3">
                            <i class="bi bi-link-45deg" style="color: var(--primary-500);"></i>
                            Похожие правила
                        </h5>
                        @if (RelatedRules != null && RelatedRules.Any())
                        {
                            <div style="display: flex; flex-direction: column; gap: 0.5rem;">
                                @foreach (var related in RelatedRules)
                                {
                                    <a href="rule/@related.Id" style="display: flex; align-items: center; gap: 0.85rem; padding: 0.75rem 0.85rem; background: var(--gray-50); border-radius: var(--radius); text-decoration: none; border: 1px solid transparent; transition: all var(--transition);"
                                       onmouseover="this.style.borderColor='var(--primary-200)'; this.style.boxShadow='var(--shadow-sm)'; this.style.background='var(--surface-card)'"
                                       onmouseout="this.style.borderColor='transparent'; this.style.boxShadow='none'; this.style.background='var(--gray-50)'">
                                        <div style="width: 38px; height: 38px; min-width: 38px; border-radius: var(--radius-sm); background: var(--primary-50); display: flex; align-items: center; justify-content: center;">
                                            <i class="bi bi-book" style="color: var(--primary-500); font-size: 1rem;"></i>
                                        </div>
                                        <div style="flex: 1; min-width: 0;">
                                            <div style="font-weight: 600; color: var(--text-primary); font-size: 0.9rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                                                @related.Title
                                            </div>
                                            @if (!string.IsNullOrEmpty(related.Category))
                                            {
                                                <div style="font-size: 0.78rem; color: var(--text-muted); margin-top: 1px;">
                                                    @related.Category
                                                </div>
                                            }
                                        </div>
                                        <div style="display: flex; align-items: center; gap: 0.3rem; padding: 0.2rem 0.6rem; background: var(--accent-yellow-light); border-radius: var(--radius-full); flex-shrink: 0;">
                                            <i class="bi bi-star-fill" style="color: var(--accent-yellow); font-size: 0.75rem;"></i>
                                            <span style="font-size: 0.8rem; font-weight: 700; color: var(--accent-yellow);">@related.Rating.ToString("F1")</span>
                                        </div>
                                    </a>
                                }
                            </div>
                        }
                        else
                        {
                            <div style="text-align: center; padding: 1.5rem 0.5rem;">
                                <div style="width: 48px; height: 48px; margin: 0 auto 0.75rem; background: var(--gray-100); border-radius: 50%; display: flex; align-items: center; justify-content: center;">
                                    <i class="bi bi-link-45deg" style="font-size: 1.25rem; color: var(--gray-400);"></i>
                                </div>
                                <p style="margin: 0; font-size: 0.875rem; color: var(--text-muted);">Нет похожих правил</p>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<LearningTrainerWeb.Components.Shared.AppToast
    Message="@DownloadMessage"
    IsSuccess="@DownloadSuccess"
    OnDismiss="() => DownloadMessage = null" />

@code {
    [Parameter]
    public int Id { get; set; }

    private RuleDetailDto? Rule;
    private List<RuleListItem>? RelatedRules;
    private bool IsLoading = true;
    private bool IsAuthenticated;
    private string? DownloadMessage;
    private bool DownloadSuccess;
    private bool QuizExpanded = true;
    private Dictionary<int, int> Answers = new();
    private int _previousId;

    protected override async Task OnInitializedAsync()
    {
        await AuthService.InitializeAsync();
        var session = await AuthService.GetCurrentSessionAsync();
        IsAuthenticated = session != null;
        _previousId = Id;
        await LoadRule();
    }

    protected override async Task OnParametersSetAsync()
    {
        if (Id != _previousId)
        {
            _previousId = Id;
            Answers.Clear();
            QuizExpanded = true;
            await LoadRule();
        }
    }

    private async Task LoadRule()
    {
        IsLoading = true;
        try
        {
            Rule = await ContentApi.GetRuleDetailsAsync(Id);
            if (Rule != null && !string.IsNullOrEmpty(Rule.Category))
            {
                RelatedRules = await ContentApi.GetRelatedRulesAsync(Id, Rule.Category);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading rule {Id}", Id);
        }
        finally
        {
            IsLoading = false;
        }
    }

    private async Task DownloadRule()
    {
        var session = await AuthService.GetCurrentSessionAsync();
        if (session == null)
        {
            DownloadMessage = "Войдите в аккаунт для скачивания";
            DownloadSuccess = false;
            return;
        }

        try
        {
            await ContentApi.DownloadRuleAsync(Id);
            DownloadMessage = "Правило успешно скачано!";
            DownloadSuccess = true;
        }
        catch (Exception ex)
        {
            DownloadMessage = $"Ошибка: {ex.Message}";
            DownloadSuccess = false;
        }
    }

    private string GetDifficultyBadgeClass(int level) => level switch
    {
        1 => "bg-success",
        2 => "bg-warning text-dark",
        3 => "bg-danger",
        _ => "bg-secondary"
    };

    private string GetDifficultyText(int level) => level switch
    {
        1 => "Начальный",
        2 => "Средний",
        3 => "Продвинутый",
        _ => "Неизвестно"
    };

    private void ToggleQuiz()
    {
        QuizExpanded = !QuizExpanded;
    }

    private void SelectAnswer(int exerciseIndex, int optionIndex)
    {
        if (!Answers.ContainsKey(exerciseIndex))
        {
            Answers[exerciseIndex] = optionIndex;
        }
    }

    private void ResetQuiz()
    {
        Answers.Clear();
    }
}
