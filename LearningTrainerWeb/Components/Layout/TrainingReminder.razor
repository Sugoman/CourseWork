@using LearningTrainerWeb.Services
@inject ITrainingReminderService ReminderService
@inject ITrainingApiService TrainingService
@inject IAuthService AuthService
@inject IJSRuntime JS
@inject NavigationManager Navigation
@implements IDisposable

@* In-app reminder toast (#7 LEARNING_IMPROVEMENTS) *@
@if (ShowReminder && CurrentReminder != null)
{
    <div class="reminder-overlay" @onclick="DismissReminder">
        <div class="reminder-card" @onclick:stopPropagation="true">
            <div class="reminder-accent"></div>
            <div class="reminder-content">
                <div class="reminder-header">
                    <div class="reminder-icon">@CurrentReminder.Icon</div>
                    <div class="reminder-title">@CurrentReminder.Title</div>
                    <button class="reminder-close" @onclick="DismissReminder" aria-label="Закрыть">
                        <i class="bi bi-x-lg"></i>
                    </button>
                </div>
                <div class="reminder-body">
                    <p class="reminder-text">@CurrentReminder.Text</p>
                    <button class="reminder-action" @onclick="GoToTraining">
                        <i class="bi bi-play-fill"></i>
                        <span>Тренировка</span>
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<style>
    .reminder-overlay {
        position: fixed;
        bottom: 1.5rem;
        right: 1.5rem;
        z-index: 1060;
        animation: reminderSlideIn 350ms cubic-bezier(0.34, 1.56, 0.64, 1);
    }

    .reminder-card {
        display: flex;
        width: 360px;
        max-width: calc(100vw - 2rem);
        background: white;
        border-radius: var(--radius-lg);
        box-shadow: var(--shadow-xl), 0 0 0 1px rgb(0 0 0 / 0.04);
        overflow: hidden;
    }

    .reminder-accent {
        width: 4px;
        flex-shrink: 0;
        background: linear-gradient(180deg, var(--primary-500), var(--accent-purple));
    }

    .reminder-content {
        flex: 1;
        padding: 1rem 1.25rem;
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
    }

    .reminder-header {
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .reminder-icon {
        font-size: 1.25rem;
        line-height: 1;
    }

    .reminder-title {
        flex: 1;
        font-weight: 600;
        font-size: 0.85rem;
        color: var(--gray-800);
    }

    .reminder-close {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 28px;
        height: 28px;
        border: none;
        background: var(--gray-100);
        border-radius: var(--radius-sm);
        color: var(--gray-500);
        cursor: pointer;
        transition: all var(--transition-fast);
        flex-shrink: 0;
        font-size: 0.75rem;
    }

    .reminder-close:hover {
        background: var(--gray-200);
        color: var(--gray-700);
    }

    .reminder-body {
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }

    .reminder-text {
        flex: 1;
        margin: 0;
        font-size: 0.875rem;
        color: var(--gray-600);
        line-height: 1.4;
    }

    .reminder-action {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        padding: 0.5rem 1rem;
        border: none;
        border-radius: var(--radius);
        background: linear-gradient(135deg, var(--primary-500), var(--accent-purple));
        color: white;
        font-size: 0.8rem;
        font-weight: 600;
        cursor: pointer;
        transition: all var(--transition-fast);
        white-space: nowrap;
        flex-shrink: 0;
        box-shadow: var(--shadow-colored);
    }

    .reminder-action:hover {
        transform: translateY(-1px);
        box-shadow: 0 6px 20px rgb(99 102 241 / 0.35);
    }

    .reminder-action:active {
        transform: translateY(0);
    }

    @@keyframes reminderSlideIn {
        from {
            opacity: 0;
            transform: translateY(16px) scale(0.96);
        }
        to {
            opacity: 1;
            transform: translateY(0) scale(1);
        }
    }

    @@media (max-width: 480px) {
        .reminder-overlay {
            bottom: 1rem;
            right: 1rem;
            left: 1rem;
        }

        .reminder-card {
            width: 100%;
        }

        .reminder-body {
            flex-direction: column;
            align-items: stretch;
        }

        .reminder-action {
            justify-content: center;
        }
    }
</style>

@code {
    private bool ShowReminder;
    private ReminderMessage? CurrentReminder;
    private System.Threading.Timer? _timer;
    private bool _notificationPermissionRequested;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var session = await AuthService.GetCurrentSessionAsync();
            if (session != null)
            {
                // Request notification permission on first load
                try
                {
                    await JS.InvokeVoidAsync("requestNotificationPermission");
                }
                catch { /* Browser may not support notifications */ }

                // Check reminder every 5 minutes
                _timer = new System.Threading.Timer(
                    async _ => await CheckReminder(),
                    null,
                    TimeSpan.FromMinutes(2), // first check after 2 min
                    TimeSpan.FromMinutes(5));
            }
        }
    }

    private async Task CheckReminder()
    {
        try
        {
            var plan = await TrainingService.GetDailyPlanAsync();
            if (plan == null) return;

            var reminder = await ReminderService.GetReminderAsync(
                plan.Stats.TotalReviewCount,
                plan.Stats.CurrentStreak,
                10, // dailyGoal default
                plan.Stats.CompletedToday);

            if (reminder != null)
            {
                CurrentReminder = reminder;
                ShowReminder = true;

                // Also try browser notification
                try
                {
                    await JS.InvokeVoidAsync("showBrowserNotification",
                        reminder.Title, reminder.Text, null);
                }
                catch { /* JS interop may fail if circuit disposed */ }

                await InvokeAsync(StateHasChanged);
            }
        }
        catch
        {
            // Silently fail — don't break the app for a reminder
        }
    }

    private void DismissReminder()
    {
        ShowReminder = false;
    }

    private void GoToTraining()
    {
        ShowReminder = false;
        Navigation.NavigateTo("/training");
    }

    public void Dispose()
    {
        _timer?.Dispose();
    }
}
