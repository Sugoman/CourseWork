@inherits LayoutComponentBase

<div class="page-wrapper">
    <!-- Top Navigation -->
    <header class="top-navbar">
        <div class="navbar-container">
            <a class="navbar-brand" href="">
                <span class="brand-icon"><i class="bi bi-rocket-takeoff-fill"></i></span>
                Ingat
            </a>
            
            <nav class="navbar-nav">
                <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                    <i class="bi bi-house-door"></i> <span>Главная</span>
                </NavLink>
                <NavLink class="nav-link" href="training">
                    <i class="bi bi-mortarboard"></i> <span>Тренировка</span>
                </NavLink>
                <NavLink class="nav-link" href="dictionaries">
                    <i class="bi bi-book"></i> <span>Словари</span>
                </NavLink>
                <NavLink class="nav-link" href="grammar">
                    <i class="bi bi-book-half"></i> <span>Грамматика</span>
                </NavLink>
                <NavLink class="nav-link" href="rules">
                    <i class="bi bi-journal-text"></i> <span>Правила</span>
                </NavLink>

                <div class="nav-more-wrapper">
                    <button class="nav-link nav-more-btn" @onclick="ToggleMoreMenu" @onclick:stopPropagation="true">
                        <i class="bi bi-grid"></i> <span>Ещё</span>
                        <i class="bi bi-chevron-down nav-more-chevron @(showMoreMenu ? "rotated" : "")"></i>
                    </button>
                    @if (showMoreMenu)
                    {
                        <div class="nav-more-backdrop" @onclick="CloseMoreMenu"></div>
                        <div class="nav-more-dropdown">
                            <NavLink class="nav-more-item" href="statistics" @onclick="CloseMoreMenu">
                                <i class="bi bi-graph-up"></i> Статистика
                            </NavLink>
                            <NavLink class="nav-more-item" href="my-content" @onclick="CloseMoreMenu">
                                <i class="bi bi-folder2-open"></i> Мой контент
                            </NavLink>
                            <NavLink class="nav-more-item" href="classroom" @onclick="CloseMoreMenu">
                                <i class="bi bi-people"></i> Класс
                            </NavLink>
                        </div>
                    }
                </div>
            </nav>

            <div class="navbar-auth">
                <a href="settings" class="settings-nav-btn" title="Настройки" aria-label="Настройки">
                    <i class="bi bi-gear"></i>
                </a>
                <ThemeToggle />
                <AuthStatus />
            </div>

            <button class="mobile-menu-toggle" @onclick="ToggleMobileMenu" aria-label="Открыть меню">
                <i class="bi @(showMobileMenu ? "bi-x-lg" : "bi-list")"></i>
            </button>
        </div>
    </header>

    <!-- Mobile Menu -->
    @if (showMobileMenu)
    {
        <div class="mobile-menu-overlay" @onclick="CloseMobileMenu"></div>
        <div class="mobile-menu">
            <nav class="mobile-nav">
                <NavLink class="mobile-nav-link" href="" Match="NavLinkMatch.All" @onclick="CloseMobileMenu">
                    <i class="bi bi-house-door"></i> Главная
                </NavLink>
                <NavLink class="mobile-nav-link" href="training" @onclick="CloseMobileMenu">
                    <i class="bi bi-mortarboard"></i> Тренировка
                </NavLink>
                <NavLink class="mobile-nav-link" href="dictionaries" @onclick="CloseMobileMenu">
                    <i class="bi bi-book"></i> Словари
                </NavLink>
                <NavLink class="mobile-nav-link" href="grammar" @onclick="CloseMobileMenu">
                    <i class="bi bi-book-half"></i> Грамматика
                </NavLink>
                <NavLink class="mobile-nav-link" href="rules" @onclick="CloseMobileMenu">
                    <i class="bi bi-journal-text"></i> Правила
                </NavLink>
                <div class="mobile-nav-divider"></div>
                <NavLink class="mobile-nav-link" href="statistics" @onclick="CloseMobileMenu">
                    <i class="bi bi-graph-up"></i> Статистика
                </NavLink>
                <NavLink class="mobile-nav-link" href="my-content" @onclick="CloseMobileMenu">
                    <i class="bi bi-folder2-open"></i> Мой контент
                </NavLink>
                <NavLink class="mobile-nav-link" href="classroom" @onclick="CloseMobileMenu">
                    <i class="bi bi-people"></i> Класс
                </NavLink>
                <div class="mobile-nav-divider"></div>
                <NavLink class="mobile-nav-link" href="settings" @onclick="CloseMobileMenu">
                    <i class="bi bi-gear"></i> Настройки
                </NavLink>
            </nav>
            <div class="mobile-auth">
                <div class="d-flex align-items-center gap-2 mb-2">
                    <ThemeToggle />
                </div>
                <AuthStatus />
            </div>
        </div>
    }

    <!-- Main Content -->
    <main class="main-content">
        @Body
    </main>

    <!-- Training Reminders (#7 LEARNING_IMPROVEMENTS) -->
    <TrainingReminder />

    <!-- Footer -->
    <footer class="site-footer">
        <div class="footer-container">
            <div class="footer-brand">
                <span class="brand-icon"><i class="bi bi-rocket-takeoff-fill"></i></span>
                <span>Ingat</span>
            </div>
            <div class="footer-text">
                © @DateTime.Now.Year Ingat. Платформа для обучения.
            </div>
            <div class="footer-links">
                <a href="dictionaries">Словари</a>
                <a href="rules">Правила</a>
            </div>
        </div>
    </footer>
</div>

@inject IJSRuntime JS

@code {
    private bool showMobileMenu = false;
    private bool showMoreMenu = false;

    private async Task ToggleMobileMenu()
    {
        showMobileMenu = !showMobileMenu;
        showMoreMenu = false;
        await SetBodyScrollLock(showMobileMenu);
    }

    private async Task CloseMobileMenu()
    {
        showMobileMenu = false;
        showMoreMenu = false;
        await SetBodyScrollLock(false);
    }

    private void ToggleMoreMenu()
    {
        showMoreMenu = !showMoreMenu;
    }

    private void CloseMoreMenu()
    {
        showMoreMenu = false;
    }

    private async Task SetBodyScrollLock(bool locked)
    {
        try
        {
            if (locked)
                await JS.InvokeVoidAsync("document.body.classList.add", "mobile-menu-open");
            else
                await JS.InvokeVoidAsync("document.body.classList.remove", "mobile-menu-open");
        }
        catch { }
    }
}
