@inject IAuthService AuthService
@inject IContentApiService ContentApi

<div class="comments-section">
    <!-- Header with count and average -->
    <div class="comments-header">
        <div class="comments-title">
            <i class="bi bi-chat-dots"></i>
            <span>Отзывы</span>
            <span class="comments-count">@(CommentsResult?.TotalCount ?? 0)</span>
        </div>
        @if (CommentsResult != null && CommentsResult.Items.Any())
        {
            <div class="comments-avg">
                <i class="bi bi-star-fill"></i>
                <span>@GetAverageRating()</span>
            </div>
        }
    </div>

    <!-- Reviews list -->
    @if (CommentsResult != null && CommentsResult.Items.Any())
    {
        <div class="comments-list">
            @foreach (var comment in CommentsResult.Items)
            {
                <div class="review-card">
                    <div class="review-top">
                        <a href="/profile/@comment.AuthorId" class="review-author">
                            <div class="review-avatar">
                                @(comment.AuthorName?.FirstOrDefault() ?? '?')
                            </div>
                            <div class="review-author-info">
                                <span class="review-author-name">@comment.AuthorName</span>
                                <span class="review-date">@comment.CreatedAt.ToString("dd.MM.yyyy")</span>
                            </div>
                        </a>
                        <div class="review-rating">
                            @for (int i = 0; i < 5; i++)
                            {
                                <i class="bi @(i < comment.Rating ? "bi-star-fill star-filled" : "bi-star star-empty")"></i>
                            }
                        </div>
                    </div>
                    @if (!string.IsNullOrWhiteSpace(comment.Text))
                    {
                        <p class="review-text">@comment.Text</p>
                    }
                </div>
            }
        </div>

        @if (CommentsResult.TotalPages > 1)
        {
            <nav class="comments-pagination">
                <button class="page-btn" @onclick="PreviousPage" disabled="@(CurrentPage <= 1)">
                    <i class="bi bi-chevron-left"></i>
                </button>
                @foreach (var pageNum in GetPageWindow())
                {
                    @if (pageNum == -1)
                    {
                        <span class="page-ellipsis">&hellip;</span>
                    }
                    else
                    {
                        var p = pageNum;
                        <button class="page-btn @(p == CurrentPage ? "active" : "")" @onclick="() => GoToPage(p)">@p</button>
                    }
                }
                <button class="page-btn" @onclick="NextPage" disabled="@(CurrentPage >= CommentsResult.TotalPages)">
                    <i class="bi bi-chevron-right"></i>
                </button>
            </nav>
        }
    }
    else
    {
        <div class="comments-empty">
            <div class="comments-empty-icon">
                <i class="bi bi-chat-heart"></i>
            </div>
            <p>Пока нет отзывов</p>
            <span>Будьте первым, кто поделится мнением!</span>
        </div>
    }

    <!-- Write a review form -->
    <div class="comments-divider"></div>

    @if (IsAuthenticated)
    {
        <div class="review-form">
            <h6 class="review-form-title">
                <i class="bi bi-pencil-square"></i>
                <span>Оставить отзыв</span>
            </h6>

            @if (!string.IsNullOrEmpty(CommentError))
            {
                <div class="review-alert review-alert-error">
                    <i class="bi bi-exclamation-triangle-fill"></i>
                    <span>@CommentError</span>
                </div>
            }
            @if (!string.IsNullOrEmpty(CommentSuccess))
            {
                <div class="review-alert review-alert-success">
                    <i class="bi bi-check-circle-fill"></i>
                    <span>@CommentSuccess</span>
                </div>
            }

            <div class="review-form-group">
                <label class="review-form-label">Оценка</label>
                <div class="star-picker">
                    @for (int i = 1; i <= 5; i++)
                    {
                        var star = i;
                        <button type="button"
                                class="star-pick-btn @(star <= (HoverRating > 0 ? HoverRating : NewRating) ? "star-active" : "")"
                                @onclick="() => NewRating = star"
                                @onmouseenter="() => HoverRating = star"
                                @onmouseleave="() => HoverRating = 0">
                            <i class="bi @(star <= (HoverRating > 0 ? HoverRating : NewRating) ? "bi-star-fill" : "bi-star")"></i>
                        </button>
                    }
                    <span class="star-pick-label">@GetRatingLabel(HoverRating > 0 ? HoverRating : NewRating)</span>
                </div>
            </div>

            <div class="review-form-group">
                <label class="review-form-label">Комментарий</label>
                <textarea class="review-textarea" rows="3" placeholder="Поделитесь своим мнением..." @bind="NewComment"></textarea>
            </div>

            <button class="review-submit-btn" @onclick="SubmitComment" disabled="@IsSubmitting">
                @if (IsSubmitting)
                {
                    <span class="spinner-border spinner-border-sm"></span>
                }
                else
                {
                    <i class="bi bi-send-fill"></i>
                }
                <span>Отправить</span>
            </button>
        </div>
    }
    else
    {
        <div class="comments-login">
            <i class="bi bi-lock"></i>
            <p>Войдите, чтобы оставить отзыв</p>
            <a href="login" class="comments-login-btn">
                <i class="bi bi-box-arrow-in-right"></i>
                <span>Войти</span>
            </a>
        </div>
    }
</div>

@code {
    [Parameter, EditorRequired]
    public string EntityType { get; set; } = "";

    [Parameter, EditorRequired]
    public int EntityId { get; set; }

    [Parameter]
    public bool IsAuthenticated { get; set; }

    private PagedResult<CommentItem>? CommentsResult;
    private int CurrentPage = 1;
    private const int PageSize = 5;
    private bool IsSubmitting;
    private int NewRating = 5;
    private int HoverRating;
    private string NewComment = "";
    private string? CommentError;
    private string? CommentSuccess;

    private int _previousEntityId;
    private string _previousEntityType = "";

    private string GetAverageRating()
    {
        if (CommentsResult == null || !CommentsResult.Items.Any()) return "0";
        var avg = CommentsResult.Items.Average(c => c.Rating);
        return avg.ToString("0.0");
    }

    private static string GetRatingLabel(int rating) => rating switch
    {
        1 => "Ужасно",
        2 => "Плохо",
        3 => "Нормально",
        4 => "Хорошо",
        5 => "Отлично",
        _ => ""
    };

    protected override async Task OnParametersSetAsync()
    {
        if (EntityId != _previousEntityId || EntityType != _previousEntityType)
        {
            _previousEntityId = EntityId;
            _previousEntityType = EntityType;
            CurrentPage = 1;
            await LoadComments();
        }
    }

    private IEnumerable<int> GetPageWindow()
    {
        var total = CommentsResult?.TotalPages ?? 1;
        var current = CurrentPage;
        const int wing = 2;

        var pages = new List<int>();

        pages.Add(1);

        var rangeStart = Math.Max(2, current - wing);
        var rangeEnd = Math.Min(total - 1, current + wing);

        if (rangeStart > 2)
            pages.Add(-1);

        for (int p = rangeStart; p <= rangeEnd; p++)
            pages.Add(p);

        if (rangeEnd < total - 1)
            pages.Add(-1);

        if (total > 1)
            pages.Add(total);

        return pages;
    }

    private async Task LoadComments()
    {
        try
        {
            CommentsResult = EntityType == "dictionary"
                ? await ContentApi.GetDictionaryCommentsAsync(EntityId, CurrentPage, PageSize)
                : await ContentApi.GetRuleCommentsAsync(EntityId, CurrentPage, PageSize);
        }
        catch
        {
            CommentsResult = new PagedResult<CommentItem>();
        }
    }

    private async Task GoToPage(int page)
    {
        CurrentPage = page;
        await LoadComments();
    }

    private async Task PreviousPage()
    {
        if (CurrentPage > 1)
        {
            CurrentPage--;
            await LoadComments();
        }
    }

    private async Task NextPage()
    {
        if (CommentsResult != null && CurrentPage < CommentsResult.TotalPages)
        {
            CurrentPage++;
            await LoadComments();
        }
    }

    private async Task SubmitComment()
    {
        CommentError = null;
        CommentSuccess = null;

        if (string.IsNullOrWhiteSpace(NewComment))
        {
            CommentError = "Введите текст комментария";
            return;
        }

        IsSubmitting = true;

        try
        {
            if (EntityType == "dictionary")
                await ContentApi.AddDictionaryCommentAsync(EntityId, NewRating, NewComment);
            else
                await ContentApi.AddRuleCommentAsync(EntityId, NewRating, NewComment);

            CommentSuccess = "Отзыв успешно добавлен!";
            NewComment = "";
            NewRating = 5;
            CurrentPage = 1;
            await LoadComments();
        }
        catch (Exception ex)
        {
            CommentError = $"Ошибка: {ex.Message}";
        }
        finally
        {
            IsSubmitting = false;
        }
    }
}
