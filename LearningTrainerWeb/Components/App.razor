<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Poppins:wght@500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="css/bootstrap/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="css/app.css" />
    <link rel="stylesheet" href="LearningTrainerWeb.styles.css" />
    <link rel="icon" type="image/png" href="favicon.png" />
    <HeadOutlet @rendermode="new InteractiveServerRenderMode(prerender: false)" />
    <script>
        // Apply saved theme BEFORE first paint to avoid flash (§12.1 LEARNING_IMPROVEMENTS)
        (function() {
            var saved = localStorage.getItem('ingat-theme');
            if (saved === 'dark' || (!saved && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
                document.documentElement.setAttribute('data-theme', 'dark');
                document.documentElement.setAttribute('data-bs-theme', 'dark');
            }
        })();
    </script>
</head>

<body>
    <Routes @rendermode="new InteractiveServerRenderMode(prerender: false)" />
    <script src="_framework/blazor.web.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function downloadFile(fileName, contentType, base64Data) {
            const link = document.createElement('a');
            link.href = 'data:' + contentType + ';base64,' + base64Data;
            link.download = fileName;
            document.body.appendChild(link);
            link.click();
            document.body.removeChild(link);
        }

        // Language name → BCP-47 code mapping for TTS
        var langMap = {
            'english': 'en-US', 'en': 'en-US',
            'russian': 'ru-RU', 'русский': 'ru-RU', 'ru': 'ru-RU',
            'german': 'de-DE', 'deutsch': 'de-DE', 'de': 'de-DE',
            'french': 'fr-FR', 'français': 'fr-FR', 'fr': 'fr-FR',
            'spanish': 'es-ES', 'español': 'es-ES', 'es': 'es-ES',
            'italian': 'it-IT', 'italiano': 'it-IT', 'it': 'it-IT',
            'portuguese': 'pt-BR', 'português': 'pt-BR', 'pt': 'pt-BR',
            'chinese': 'zh-CN', '中文': 'zh-CN', 'zh': 'zh-CN',
            'japanese': 'ja-JP', '日本語': 'ja-JP', 'ja': 'ja-JP',
            'korean': 'ko-KR', '한국어': 'ko-KR', 'ko': 'ko-KR',
            'arabic': 'ar-SA', 'ar': 'ar-SA',
            'turkish': 'tr-TR', 'türkçe': 'tr-TR', 'tr': 'tr-TR',
            'polish': 'pl-PL', 'polski': 'pl-PL', 'pl': 'pl-PL',
            'dutch': 'nl-NL', 'nederlands': 'nl-NL', 'nl': 'nl-NL',
            'swedish': 'sv-SE', 'svenska': 'sv-SE', 'sv': 'sv-SE',
            'norwegian': 'nb-NO', 'norsk': 'nb-NO', 'no': 'nb-NO',
            'danish': 'da-DK', 'dansk': 'da-DK', 'da': 'da-DK',
            'finnish': 'fi-FI', 'suomi': 'fi-FI', 'fi': 'fi-FI',
            'czech': 'cs-CZ', 'čeština': 'cs-CZ', 'cs': 'cs-CZ',
            'greek': 'el-GR', 'ελληνικά': 'el-GR', 'el': 'el-GR',
            'hindi': 'hi-IN', 'हिन्दी': 'hi-IN', 'hi': 'hi-IN',
            'thai': 'th-TH', 'ไทย': 'th-TH', 'th': 'th-TH',
            'vietnamese': 'vi-VN', 'tiếng việt': 'vi-VN', 'vi': 'vi-VN',
            'indonesian': 'id-ID', 'bahasa indonesia': 'id-ID', 'id': 'id-ID',
            'ukrainian': 'uk-UA', 'українська': 'uk-UA', 'uk': 'uk-UA',
            'hungarian': 'hu-HU', 'magyar': 'hu-HU', 'hu': 'hu-HU',
            'romanian': 'ro-RO', 'română': 'ro-RO', 'ro': 'ro-RO',
            'hebrew': 'he-IL', 'עברית': 'he-IL', 'he': 'he-IL',
            'catalan': 'ca-ES', 'català': 'ca-ES', 'ca': 'ca-ES',
            'croatian': 'hr-HR', 'hrvatski': 'hr-HR', 'hr': 'hr-HR',
            'slovak': 'sk-SK', 'slovenčina': 'sk-SK', 'sk': 'sk-SK',
            'bulgarian': 'bg-BG', 'български': 'bg-BG', 'bg': 'bg-BG',
            'malay': 'ms-MY', 'melayu': 'ms-MY', 'ms': 'ms-MY',
            'persian': 'fa-IR', 'فارسی': 'fa-IR', 'fa': 'fa-IR',
            'bengali': 'bn-IN', 'বাংলা': 'bn-IN', 'bn': 'bn-IN',
            'tamil': 'ta-IN', 'தமிழ்': 'ta-IN', 'ta': 'ta-IN'
        };

        function resolveLang(lang) {
            if (!lang) return 'en-US';
            var key = lang.trim().toLowerCase();
            return langMap[key] || lang;
        }

        function findBestVoice(bcp47) {
            var voices = window.speechSynthesis.getVoices();
            if (!voices.length) return null;
            var langPrefix = bcp47.split('-')[0].toLowerCase();
            // Exact match first
            var exact = voices.find(function(v) { return v.lang.toLowerCase() === bcp47.toLowerCase(); });
            if (exact) return exact;
            // Prefix match (e.g. "da" matches "da-DK")
            var prefix = voices.find(function(v) { return v.lang.toLowerCase().startsWith(langPrefix); });
            return prefix || null;
        }

        function speakText(text, lang, volume) {
            if ('speechSynthesis' in window) {
                window.speechSynthesis.cancel();
                var bcp47 = resolveLang(lang);
                var utterance = new SpeechSynthesisUtterance(text);
                utterance.lang = bcp47;
                var savedSpeed = parseFloat(localStorage.getItem('ingat-tts-speed'));
                utterance.rate = (!isNaN(savedSpeed) && savedSpeed >= 0.5 && savedSpeed <= 1.5) ? savedSpeed : 0.9;
                utterance.volume = (typeof volume === 'number') ? Math.max(0, Math.min(1, volume)) : 1;
                var voice = findBestVoice(bcp47);
                if (voice) utterance.voice = voice;
                window.speechSynthesis.speak(utterance);
            }
        }

        // Pre-load voices (some browsers load them async)
        if ('speechSynthesis' in window) {
            window.speechSynthesis.onvoiceschanged = function() { window.speechSynthesis.getVoices(); };
            window.speechSynthesis.getVoices();
        }

        function isEdgeBrowser() {
            return /Edg\//.test(navigator.userAgent);
        }

        // Training reminders (#7 LEARNING_IMPROVEMENTS)
        function requestNotificationPermission() {
            if ('Notification' in window) {
                return Notification.requestPermission();
            }
            return Promise.resolve('denied');
        }

        function showBrowserNotification(title, body, icon) {
            if ('Notification' in window && Notification.permission === 'granted') {
                var n = new Notification(title, { body: body, icon: icon || '/favicon.png' });
                n.onclick = function () { window.focus(); n.close(); };
                setTimeout(function () { n.close(); }, 10000);
                return true;
            }
            return false;
        }

        function getNotificationPermission() {
            if ('Notification' in window) return Notification.permission;
            return 'denied';
        }

        // Theme toggle (§12.1 LEARNING_IMPROVEMENTS — Dark Mode)
        function getTheme() {
            return document.documentElement.getAttribute('data-theme') || 'light';
        }

        function setTheme(theme) {
            if (theme === 'dark') {
                document.documentElement.setAttribute('data-theme', 'dark');
                document.documentElement.setAttribute('data-bs-theme', 'dark');
            } else {
                document.documentElement.removeAttribute('data-theme');
                document.documentElement.removeAttribute('data-bs-theme');
            }
            localStorage.setItem('ingat-theme', theme);
        }

        function toggleTheme() {
            var current = getTheme();
            var next = current === 'dark' ? 'light' : 'dark';
            setTheme(next);
            return next;
        }

        // Markdown anchor navigation: prevent Blazor from intercepting in-page #hash links
        document.addEventListener('click', function (e) {
            var anchor = e.target.closest('.markdown-content a[href^="#"]');
            if (!anchor) return;
            e.preventDefault();
            var id = anchor.getAttribute('href').substring(1);
            var target = document.getElementById(id);
            if (target) {
                target.scrollIntoView({ behavior: 'smooth', block: 'start' });
                history.replaceState(null, '', '#' + id);
            }
        });
    </script>
</body>

</html>
